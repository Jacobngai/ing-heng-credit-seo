---
/**
 * Equipment Index Page - Bahasa Malaysia
 * Catalog page showcasing all equipment types available for financing
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProductCard from '../../../components/ProductCard.astro';
import Calculator from '../../../components/Calculator.astro';
import FAQItem from '../../../components/FAQItem.astro';
import { encodeJSONLD } from '../../../utils/schema';
import { SITE_CONFIG, COMPANY_INFO } from '../../../utils/constants';

const lang = 'ms';

// SEO Data
const pageTitle = 'Katalog Pembiayaan Peralatan | Jengkaut, Lori & Mesin Industri | Ing Heng';
const pageDescription = 'Kami biayai jentera berat yang bank tolak. Dari jengkaut 20 tahun hingga mesin CNC baru. Kelulusan 48 jam. Bayaran pendahuluan rendah.';

// Featured Equipment Listings
const featuredEquipment = [
  {
    name: 'Jengkaut (Excavator)',
    description: 'Dari 1 tan hingga 30 tan. Kami terima jengkaut terpakai walaupun sudah 20 tahun bekerja.',
    image: '/images/equipment/excavator.jpg',
    link: '/ms/equipment/excavator',
    badge: 'Paling Popular'
  },
  {
    name: 'Lori Komersial',
    description: 'Lori 1-tan hingga 40-tan. Sesuai untuk startup logistik yang memerlukan lori terpakai.',
    image: '/images/equipment/lorry.jpg',
    link: '/ms/equipment/lorry',
    badge: 'Startup Mesra'
  },
  {
    name: 'Forklift',
    description: 'Unit diesel dan elektrik. Kami biayai untuk operasi gudang dan kilang di seluruh Malaysia.',
    image: '/images/equipment/forklift.jpg',
    link: '/ms/equipment/forklift',
    badge: 'Kelulusan 24 Jam'
  },
  {
    name: 'Prime Mover',
    description: 'Unit traktor tugas berat untuk kontena. Kami pakar dalam pembiayaan armada logistik.',
    image: '/images/equipment/prime-mover.jpg',
    link: '/ms/equipment/prime-mover',
    badge: 'Kapasiti Tinggi'
  },
  {
    name: 'Backhoe & Loader',
    description: 'Mesin serba guna 2-dalam-1. Kami faham nilai mesin ini walaupun ia sudah lama.',
    image: '/images/equipment/case-backhoe.jpg',
    link: '/ms/equipment/backhoe',
    badge: 'Mesin 2-in-1'
  },
  {
    name: 'Mesin CNC & Industri',
    description: 'Peralatan pembuatan ketepatan. Kami bantu anda naik taraf kilang tanpa beban tunai.',
    image: '/images/equipment/cnc-machine.jpg',
    link: '/ms/equipment/cnc-machinery',
    badge: 'Teknologi Tinggi'
  }
];

// FAQs
const faqs = [
  { question: 'Mesin lama boleh biayai ke?', answer: 'YA. Kami adalah pakar mesin terpakai. Jengkaut atau lori yang berumur 15-20 tahun pun kami boleh pertimbangkan, asalkan ia masih boleh buat kerja dan buat untung.' },
  { question: 'Berapa lama kelulusan?', answer: 'Keputusan awal biasanya dalam masa 24 jam. Jika dokumen lengkap, dana boleh keluar dalam masa 3-5 hari bekerja.' },
  { question: 'Berapa deposit minimum?', answer: 'Kami boleh tawarkan pembiayaan sehingga 90% atau 100% untuk kes tertentu. Biasanya deposit adalah antara 10% ke 20% sahaja.' },
  { question: 'Saya startup, boleh mohon?', answer: 'Boleh. Kami suka bantu bisnes baru yang ada kontrak kerja yang jelas. Kami tak tengok sejarah lama, kami tengok potensi masa depan anda.' }
];

// JSON-LD Schema
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Katalog Pembiayaan Peralatan Ing Heng',
  description: 'Pilihan pembiayaan peralatan pembinaan dan industri di Malaysia',
  itemListElement: featuredEquipment.map((equipment, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    item: {
      '@type': 'Product',
      name: equipment.name,
      description: equipment.description,
      image: `${SITE_CONFIG.url}${equipment.image}`
    }
  }))
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
>
  <!-- Structured Data -->
  <Fragment slot="head">
    <script type="application/ld+json" set:html={encodeJSONLD(itemListSchema)} />
  </Fragment>

  <!-- HERO: THE MECHANICAL AUTHORITY -->
  <section class="relative min-h-[60vh] flex items-center bg-[#0A0A0A] overflow-hidden pt-20">
    <div class="absolute inset-0 opacity-30">
      <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#0A0A0A]"></div>
    </div>

    <div class="container-custom relative z-10 py-20">
      <div class="max-w-4xl">
        <span class="text-[#D4A574] font-display uppercase tracking-[0.4em] text-[10px] font-bold mb-6 block">Katalog Peralatan</span>
        <h1 class="text-7xl md:text-8xl lg:text-9xl font-display leading-[0.85] text-white uppercase mb-8 tracking-tighter">
          Aset <span class="text-[#D4A574]">ANDA</span>,<br/>
          Modal <span class="text-white">KAMI</span>
        </h1>
        <p class="text-xl text-[#F5F5F5]/60 max-w-2xl font-light leading-relaxed mb-12">
          Dari jengkaut 20 tahun hingga mesin CNC paling moden—jika ia boleh buat untung, kami sedia biayakannya. Kelulusan pantas tanpa syarat bank yang kaku.
        </p>
      </div>
    </div>
  </section>

  <!-- CATEGORIES: THE 3 PILLARS -->
  <section class="py-24 bg-white border-b border-black/5">
    <div class="container-custom">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="p-10 bg-[#F5F5F5] group hover:bg-[#0A0A0A] transition-all duration-500">
          <span class="text-4xl mb-6 block">🏗️</span>
          <h3 class="text-3xl font-display uppercase mb-4 text-[#0A0A0A] group-hover:text-white transition-colors">Pembinaan</h3>
          <p class="text-[#0A0A0A]/60 group-hover:text-white/60 text-sm leading-relaxed font-light">Jengkaut, jentolak, kren, dan alat penggalian. Kami hargai jentera berat yang sudah lama berbakti.</p>
        </div>
        <div class="p-10 bg-[#F5F5F5] group hover:bg-[#8B6F47] transition-all duration-500">
          <span class="text-4xl mb-6 block">🚛</span>
          <h3 class="text-3xl font-display uppercase mb-4 text-[#0A0A0A] group-hover:text-white transition-colors">Logistik</h3>
          <p class="text-[#0A0A0A]/60 group-hover:text-white/60 text-sm leading-relaxed font-light">Lori, prime mover, dan treler kontena. Modal pantas untuk kembangkan armada pengangkutan anda.</p>
        </div>
        <div class="p-10 bg-[#F5F5F5] group hover:bg-[#D4A574] transition-all duration-500">
          <span class="text-4xl mb-6 block">🏭</span>
          <h3 class="text-3xl font-display uppercase mb-4 text-[#0A0A0A] group-hover:text-black transition-colors">Industri</h3>
          <p class="text-[#0A0A0A]/60 group-hover:text-black/60 text-sm leading-relaxed font-light">Forklift, mesin CNC, dan alat kilang. Naik taraf kapasiti pengeluaran tanpa ganggu aliran tunai.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUCT GRID: THE CATALOG -->
  <section class="py-32 bg-white">
    <div class="container-custom">
      <div class="flex flex-col md:flex-row justify-between items-end mb-20 gap-8">
        <div>
          <h2 class="text-6xl font-display uppercase leading-none text-[#0A0A0A] tracking-tight">Peralatan <br/><span class="text-[#8B6F47]">Pilihan</span></h2>
          <p class="text-[#1A140D]/40 uppercase tracking-widest text-[10px] font-bold mt-4">Kepakaran Mesin Sejak 1985</p>
        </div>
        <div class="hidden md:block">
          <a href={COMPANY_INFO.whatsapp.link} class="text-[10px] uppercase tracking-widest font-bold text-[#0A0A0A] border-b-2 border-[#D4A574] pb-2 hover:text-[#8B6F47] transition-colors">Semua Kategori WhatsApp →</a>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {featuredEquipment.map((equipment) => (
          <ProductCard
            name={equipment.name}
            description={equipment.description}
            link={equipment.link}
            lang={lang}
            image={equipment.image}
            badge={equipment.badge}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- CALCULATOR: PRECISE ACTION -->
  <section class="py-32 bg-[#F5F5F5]">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
        <div>
          <h2 class="text-6xl font-display uppercase mb-8 text-[#0A0A0A]">Kira Kos <br/><span class="text-[#8B6F47]">Bisnes</span> Anda</h2>
          <p class="text-[#1A140D]/60 mb-12 leading-relaxed font-light text-lg">
            Gunakan kalkulator kami untuk lihat anggaran bayaran bulanan. Kami telus. Tiada kos tersembunyi. Apa yang anda nampak, itu yang anda dapat.
          </p>
          <div class="space-y-6">
            <div class="flex items-center gap-6">
              <div class="w-12 h-12 bg-[#0A0A0A] flex items-center justify-center text-white font-display">01</div>
              <p class="text-sm font-medium">Masukkan harga mesin anda.</p>
            </div>
            <div class="flex items-center gap-6">
              <div class="w-12 h-12 bg-[#0A0A0A] flex items-center justify-center text-white font-display">02</div>
              <p class="text-sm font-medium">Pilih tempoh bayaran (1-5 tahun).</p>
            </div>
            <div class="flex items-center gap-6">
              <div class="w-12 h-12 bg-[#D4A574] flex items-center justify-center text-[#0A0A0A] font-display">✓</div>
              <p class="text-sm font-medium text-[#8B6F47] font-bold uppercase tracking-tight">Keputusan Segera Di Skrin.</p>
            </div>
          </div>
        </div>
        <div>
          <Calculator lang={lang} />
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ: THE NO-BULLS PROMISE -->
  <section class="py-32 bg-white">
    <div class="container-custom max-w-4xl">
      <div class="text-center mb-20">
        <h2 class="text-6xl font-display uppercase mb-6 text-[#0A0A0A]">Soalan <span class="text-[#8B6F47]">Lazim</span></h2>
        <p class="text-[#1A140D]/40 uppercase tracking-[0.3em] text-[10px] font-bold">Jawapan Terus, Tanpa Berbelit</p>
      </div>

      <div class="space-y-6">
        {faqs.map((faq) => (
          <FAQItem question={faq.question} answer={faq.answer} />
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA: THE PARTNER -->
  <section class="py-40 bg-[#0A0A0A] relative overflow-hidden">
    <div class="container-custom relative z-10 text-center">
      <h2 class="text-7xl md:text-8xl lg:text-9xl font-display leading-[0.85] text-white uppercase mb-12 tracking-tighter">
        Mesin Anda <br/><span class="text-[#D4A574]">Tunggu Anda</span>
      </h2>
      <p class="text-xl text-[#F5F5F5]/60 mb-16 max-w-2xl mx-auto font-light leading-relaxed">
        Jangan biarkan impian kembangkan armada anda terkubur di meja bank. Kami hargai usaha anda.
      </p>
      <div class="flex flex-col sm:flex-row gap-6 justify-center">
        <a href={COMPANY_INFO.whatsapp.link} class="bg-[#D4A574] text-[#0A0A0A] font-display uppercase tracking-widest text-sm px-16 py-8 hover:bg-white transition-all duration-500">
          WhatsApp Saya Sekarang
        </a>
        <a href="/ms/contact" class="border border-white/20 text-white font-display uppercase tracking-widest text-sm px-16 py-8 hover:bg-white hover:text-[#0A0A0A] transition-all duration-500">
          Hubungi Pejabat
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  h1, h2, h3, h4 {
    font-family: 'Bebas Neue', var(--font-display);
  }
</style>iv>
  </section>
</BaseLayout>
