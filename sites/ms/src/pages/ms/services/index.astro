---
/**
 * Services Overview Page - Malay
 * Penyelesaian pembiayaan lengkap untuk semua keperluan peralatan anda
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import ContactForm from '../../../components/ContactForm.astro';
import { COMPANY_INFO } from '../../../utils/constants';

const lang = 'ms';

// SEO Configuration
const title = 'Perkhidmatan Kami | Modal Bisnes Tanpa Karenah | Ing Heng Credit';
const description = 'Sewa Beli, Pinjaman PKS, dan Insurans. Kami beri modal untuk jentera berat yang bank tolak. Kelulusan 48 jam. Syarikat berlesen KPKT.';
---

<BaseLayout
  title={title}
  description={description}
  lang={lang}
>
  
  <!-- HERO: THE POWER OF DIRECT CAPITAL -->
  <section class="relative min-h-[70vh] flex items-center bg-[#0A0A0A] overflow-hidden pt-20">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0 bg-gradient-to-r from-[#0A0A0A] via-transparent to-[#0A0A0A]"></div>
    </div>

    <div class="container-custom relative z-10 py-20">
      <div class="max-w-4xl">
        <span class="text-[#D4A574] font-display uppercase tracking-[0.4em] text-[10px] font-bold mb-6 block">Kekuatan Modal Terus</span>
        <h1 class="text-7xl md:text-8xl lg:text-9xl font-display leading-[0.85] text-white uppercase mb-8 tracking-tighter">
          Penyelesaian Modal <br/>
          Tanpa <span class="text-[#D4A574]">Karenah Bank</span>
        </h1>
        <p class="text-xl text-[#F5F5F5]/60 max-w-2xl font-light leading-relaxed mb-12">
          Kami bukan ejen. Kami adalah pemberi modal terus. Ini bermakna bisnes anda dapat keputusan pantas, tanpa proses birokrasi yang memeningkan.
        </p>
        <div class="flex flex-col sm:flex-row gap-6">
          <a href={COMPANY_INFO.whatsapp.link} class="bg-[#D4A574] text-[#0A0A0A] font-display uppercase tracking-widest text-sm px-12 py-6 hover:bg-white transition-all duration-500 text-center">
            Mula Berbincang Sekarang
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- PILLARS: THE THREE CORES -->
  <section class="py-32 bg-white">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">
        <!-- Asset Finance -->
        <div class="group">
          <div class="aspect-[4/5] bg-[#0A0A0A] p-12 flex flex-col justify-between mb-8 overflow-hidden relative">
            <div class="absolute inset-0 bg-[#8B6F47] translate-y-full group-hover:translate-y-0 transition-transform duration-700"></div>
            <div class="relative z-10">
              <span class="text-4xl mb-8 block">🚜</span>
              <h3 class="text-4xl font-display text-white uppercase mb-4 leading-none">Modal <br/>Untuk Mesin</h3>
              <p class="text-white/60 group-hover:text-black/60 transition-colors text-sm font-light">Sewa beli untuk jengkaut, lori, dan jentera berat. Baru atau terpakai (mesin 20 tahun pun boleh).</p>
            </div>
            <a href="/ms/services/hire-purchase" class="relative z-10 text-[10px] uppercase tracking-widest font-bold text-[#D4A574] group-hover:text-black transition-colors border-b border-[#D4A574] group-hover:border-black pb-2 self-start">Lihat Mekanisme →</a>
          </div>
        </div>

        <!-- Working Capital -->
        <div class="group">
          <div class="aspect-[4/5] bg-[#F5F5F5] p-12 flex flex-col justify-between mb-8 overflow-hidden relative border border-black/5">
            <div class="absolute inset-0 bg-[#0A0A0A] translate-y-full group-hover:translate-y-0 transition-transform duration-700"></div>
            <div class="relative z-10">
              <span class="text-4xl mb-8 block">💰</span>
              <h3 class="text-4xl font-display text-[#0A0A0A] group-hover:text-white uppercase mb-4 leading-none transition-colors">Aliran <br/>Tunai Bisnes</h3>
              <p class="text-[#0A0A0A]/60 group-hover:text-white/60 transition-colors text-sm font-light">Pinjaman PKS untuk modal pusingan, baik pulih mesin, atau beli stok. Kelulusan dalam 48 jam.</p>
            </div>
            <a href="/ms/services/loan-financing" class="relative z-10 text-[10px] uppercase tracking-widest font-bold text-[#8B6F47] group-hover:text-[#D4A574] transition-colors border-b border-[#8B6F47] group-hover:border-[#D4A574] pb-2 self-start">Ketahui Lanjut →</a>
          </div>
        </div>

        <!-- Protection -->
        <div class="group">
          <div class="aspect-[4/5] bg-white p-12 flex flex-col justify-between mb-8 overflow-hidden relative border border-black/5">
            <div class="absolute inset-0 bg-[#D4A574] translate-y-full group-hover:translate-y-0 transition-transform duration-700"></div>
            <div class="relative z-10">
              <span class="text-4xl mb-8 block">🛡️</span>
              <h3 class="text-4xl font-display text-[#0A0A0A] uppercase mb-4 leading-none">Perlindungan <br/>Aset</h3>
              <p class="text-[#0A0A0A]/60 group-hover:text-black/60 transition-colors text-sm font-light">Insurans komprehensif untuk peralatan dan kenderaan motor. Lindungi pelaburan fizikal anda.</p>
            </div>
            <a href="/ms/services/insurance" class="relative z-10 text-[10px] uppercase tracking-widest font-bold text-[#8B6F47] group-hover:text-black transition-colors border-b border-[#8B6F47] group-hover:border-black pb-2 self-start">Ketahui Lanjut →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESS: THE 48-HOUR PROMISE -->
  <section class="py-32 bg-[#0A0A0A] text-white">
    <div class="container-custom">
      <div class="text-center mb-24">
        <h2 class="text-6xl md:text-7xl font-display uppercase mb-6 tracking-tight">Proses <span class="text-[#D4A574]">Pantas</span> Kami</h2>
        <p class="text-white/40 uppercase tracking-[0.3em] text-[10px] font-bold">Empat Langkah Mudah Menuju Modal</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-12 relative">
        <div class="absolute top-12 left-0 w-full h-[1px] bg-white/10 hidden md:block"></div>
        
        <div class="relative">
          <div class="w-24 h-24 bg-[#0A0A0A] border border-white/20 flex items-center justify-center text-3xl font-display text-[#D4A574] mb-8 relative z-10 group-hover:border-[#D4A574] transition-colors">01</div>
          <h4 class="text-xl font-display uppercase mb-4">Cakap Terus</h4>
          <p class="text-white/40 text-sm font-light">WhatsApp atau telefon kami. Beritahu apa mesin anda perlukan.</p>
        </div>

        <div class="relative">
          <div class="w-24 h-24 bg-[#0A0A0A] border border-white/20 flex items-center justify-center text-3xl font-display text-white mb-8 relative z-10">02</div>
          <h4 class="text-xl font-display uppercase mb-4">Hantar Dokumen</h4>
          <p class="text-white/40 text-sm font-light">Dokumen minimum. Tanpa borang panjang yang memeningkan kepala.</p>
        </div>

        <div class="relative">
          <div class="w-24 h-24 bg-[#0A0A0A] border border-white/20 flex items-center justify-center text-3xl font-display text-white mb-8 relative z-10">03</div>
          <h4 class="text-xl font-display uppercase mb-4">Keputusan "YA"</h4>
          <p class="text-white/40 text-sm font-light">Kami buat keputusan sendiri. Kelulusan selalunya dalam masa 48 jam.</p>
        </div>

        <div class="relative">
          <div class="w-24 h-24 bg-[#D4A574] flex items-center justify-center text-3xl font-display text-[#0A0A0A] mb-8 relative z-10">04</div>
          <h4 class="text-xl font-display uppercase mb-4">Modal Di Tangan</h4>
          <p class="text-white/40 text-sm font-light">Dana disalurkan dan mesin anda sedia untuk bekerja guna buat untung.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA: ACTION TAKER -->
  <section class="py-40 bg-white">
    <div class="container-custom text-center">
      <h2 class="text-7xl md:text-8xl lg:text-9xl font-display uppercase leading-[0.85] text-[#0A0A0A] mb-12 tracking-tighter">
        Modal <span class="text-[#8B6F47]">Sedia</span>,<br/> Bisnes <span class="text-[#0A0A0A]/20">Mula</span>
      </h2>
      <div class="flex flex-col sm:flex-row gap-6 justify-center">
        <a href={COMPANY_INFO.whatsapp.link} class="bg-[#0A0A0A] text-white font-display uppercase tracking-widest text-sm px-16 py-8 hover:bg-[#8B6F47] transition-all duration-500">
          WhatsApp Sekarang
        </a>
        <a href="/ms/contact" class="border border-black/10 text-[#0A0A0A] font-display uppercase tracking-widest text-sm px-16 py-8 hover:bg-black hover:text-white transition-all duration-500">
          Isi Borang Permohonan
        </a>
      </div>
    </div>
  </section>

  <!-- FORM: DIRECT LINE -->
  <section class="py-32 bg-[#F5F5F5]">
    <div class="container-custom max-w-6xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
        <div>
          <h2 class="text-6xl font-display uppercase mb-8 text-[#0A0A0A]">Sedia <br/>Dapatkan <span class="text-[#8B6F47]">Sebut Harga</span>?</h2>
          <p class="text-[#1A140D]/60 mb-12 leading-relaxed font-light">
            Jangan biarkan peluang bisnes berlalu. Cakap dengan pakar kami hari ini untuk tahu berapa banyak modal anda boleh dapat.
          </p>
          <div class="flex items-center gap-6 p-8 bg-white border border-black/5">
            <div class="text-4xl">⚡</div>
            <div>
              <span class="block text-[10px] uppercase tracking-widest font-bold text-[#8B6F47]">Respon Pantas</span>
              <p class="text-sm font-medium">Kami membalas semua pertanyaan dalam masa 2 jam waktu bekerja.</p>
            </div>
          </div>
        </div>
        <div class="bg-white p-10 md:p-16 shadow-2xl relative">
          <div class="absolute -top-4 -right-4 w-12 h-12 bg-[#8B6F47]"></div>
          <ContactForm lang={lang} />
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  h1, h2, h3, h4 {
    font-family: 'Bebas Neue', var(--font-display);
  }
</style>    </div>
    </div>
  </section>
</BaseLayout>
