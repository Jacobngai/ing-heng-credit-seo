---
/**
 * Malay Homepage
 * Pembiayaan Peralatan Malaysia - Ing Heng Credit & Leasing
 * Target Audience: Kontraktor Bumiputera, usahawan Melayu, pemilik perniagaan kecil
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import ContactForm from '../../components/ContactForm.astro';
import StructuredData from '../../components/StructuredData.astro';
import { generateOrganizationSchema } from '../../utils/schema';
import { COMPANY_INFO } from '../../utils/constants';

const lang = 'ms';
const organizationSchema = generateOrganizationSchema();

// Equipment showcase for catalog
const equipment = [
  {
    name: 'Excavator (Jengkaut)',
    description: 'Kami biaya semua model: CAT, Komatsu, Kobelco. Mesin 20 tahun pun kami terima.',
    image: 'https://images.unsplash.com/photo-1546452204-7407a1600170?auto=format&fit=crop&q=80&w=800',
    link: '/ms/equipment/excavator'
  },
  {
    name: 'Lorry (Lori)',
    description: 'Beli lori untuk logistik atau pembinaan. Isuzu, Hino, Mitsubishi. Kelulusan 48 jam.',
    image: 'https://images.unsplash.com/photo-1591768793355-74d04bb6608f?auto=format&fit=crop&q=80&w=800',
    link: '/ms/equipment/lorry'
  },
  {
    name: 'Forklift',
    description: 'Untuk gudang atau kilang. Baru atau terpakai. Bayaran pendahuluan rendah.',
    image: 'https://images.unsplash.com/photo-1586528116311-ad86df68ca10?auto=format&fit=crop&q=80&w=800',
    link: '/ms/equipment/forklift'
  }
];
---

<BaseLayout
  title="Pembiayaan Peralatan Malaysia | Kami Kata YA Bila Bank Kata TIDAK"
  description="Dapatkan modal untuk jengkaut, lori, dan jentera berat. Kami syarikat berlesen KPKT sejak 1985. Proses senang, kelulusan cepat. WhatsApp sekarang."
  lang={lang}
>
  <StructuredData schema={organizationSchema} />

  <!-- HERO: THE ACTION TAKER -->
  <section class="relative min-h-[90vh] flex items-center bg-[#0A0A0A] overflow-hidden pt-20">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-[#0A0A0A]/80 to-[#0A0A0A]"></div>
    </div>

    <div class="container-custom relative z-10 py-20">
      <div class="max-w-4xl">
        <div class="inline-flex items-center gap-3 bg-white/5 border border-white/10 px-4 py-2 mb-8 group hover:bg-white/10 transition-all cursor-default">
          <div class="w-2 h-2 bg-[#D4A574] rounded-full animate-pulse"></div>
          <span class="text-[10px] uppercase tracking-[0.3em] text-[#F5F5F5]/60 font-bold">Berlesen KPKT Sejak 1985</span>
        </div>

        <h1 class="text-7xl md:text-8xl lg:text-9xl font-display leading-[0.85] text-white uppercase mb-8 tracking-tighter">
          Kami Kata <span class="text-[#D4A574]">YA</span><br/>
          Bila Bank Kata <span class="text-white/20">TIDAK</span>
        </h1>

        <p class="text-xl md:text-2xl text-[#F5F5F5]/60 mb-12 max-w-2xl font-light leading-relaxed">
          Jangan biarkan bank halang bisnes anda. Kami beri modal untuk <span class="text-white font-medium">Mana-mana Mesin, Berapa Saja Usia</span>—dari jengkaut 1980-an hingga lori baru.
        </p>

        <div class="flex flex-col sm:flex-row gap-6">
          <a href={COMPANY_INFO.whatsapp.link} class="group relative bg-[#D4A574] text-[#0A0A0A] font-display uppercase tracking-widest text-sm px-12 py-6 overflow-hidden transition-all duration-500">
            <span class="relative z-10">WhatsApp Kami Sekarang</span>
            <div class="absolute inset-0 bg-white translate-y-full group-hover:translate-y-0 transition-transform duration-500"></div>
          </a>
          <a href="/ms/equipment" class="group border border-white/20 text-white font-display uppercase tracking-widest text-sm px-12 py-6 hover:bg-white hover:text-[#0A0A0A] transition-all duration-500">
            Lihat Katalog Mesin
          </a>
        </div>

        <!-- Trust Badges -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mt-24 border-t border-white/10 pt-12">
          <div>
            <span class="block text-3xl font-display text-white mb-1">40 TAHUN</span>
            <span class="text-[10px] uppercase tracking-widest text-[#F5F5F5]/40 font-bold">Pengalaman Pasaran</span>
          </div>
          <div>
            <span class="block text-3xl font-display text-[#D4A574] mb-1">KPKT</span>
            <span class="text-[10px] uppercase tracking-widest text-[#F5F5F5]/40 font-bold">Pemberi Pinjam Wang Berlesen</span>
          </div>
          <div>
            <span class="block text-3xl font-display text-white mb-1">RM 30K+</span>
            <span class="text-[10px] uppercase tracking-widest text-[#F5F5F5]/40 font-bold">Pinjaman Minimum</span>
          </div>
          <div>
            <span class="block text-3xl font-display text-white mb-1">48 JAM</span>
            <span class="text-[10px] uppercase tracking-widest text-[#F5F5F5]/40 font-bold">Kelulusan Pantas</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- AUTHORITY: THE DIRECT METHOD -->
  <section class="py-32 bg-white relative">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
        <div>
          <span class="text-[#8B6F47] font-display uppercase tracking-[0.3em] text-xs font-bold mb-6 block">Kenapa Pilih Kami?</span>
          <h2 class="text-6xl md:text-7xl font-display leading-[0.9] text-[#0A0A0A] uppercase mb-10 tracking-tight">
            Kami Melabur Dalam <span class="text-[#8B6F47]">Masa Depan</span> Anda
          </h2>
          <div class="space-y-8">
            <div class="flex gap-6">
              <div class="w-12 h-12 bg-[#F5F5F5] flex items-center justify-center font-display text-xl shrink-0">01</div>
              <div>
                <h4 class="text-xl font-display uppercase mb-2 tracking-tight">Kami Pembuat Keputusan</h4>
                <p class="text-[#1A140D]/60 text-sm leading-relaxed">Kami bukan ejen. Kami labur duit kami sendiri. Ini bermakna kelulusan lebih cepat dan kurang karenah birokrasi.</p>
              </div>
            </div>
            <div class="flex gap-6">
              <div class="w-12 h-12 bg-[#F5F5F5] flex items-center justify-center font-display text-xl shrink-0">02</div>
              <div>
                <h4 class="text-xl font-display uppercase mb-2 tracking-tight">Mesin Lama? Tiada Masalah</h4>
                <p class="text-[#1A140D]/60 text-sm leading-relaxed">Bank benci mesin lama. Kami pula hargai nilai kerjanya. Mesin 50 tahun pun kami boleh bincang jika ia buat duit untuk anda.</p>
              </div>
            </div>
            <div class="flex gap-6">
              <div class="w-12 h-12 bg-[#F5F5F5] flex items-center justify-center font-display text-xl shrink-0">03</div>
              <div>
                <h4 class="text-xl font-display uppercase mb-2 tracking-tight">Syarikat Berlesen (IPW)</h4>
                <p class="text-[#1A140D]/60 text-sm leading-relaxed">Kami beroperasi di bawah lesen Akta Pemberi Pinjam Wang 1951. Bisnes anda selamat dengan kami.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="relative group">
          <div class="absolute -inset-4 border border-black/5 opacity-0 group-hover:opacity-100 transition-all duration-700"></div>
          <img 
            src="https://images.unsplash.com/photo-1581094288338-2314dddb7ecc?auto=format&fit=crop&q=80&w=1200" 
            alt="Ing Heng Credit Workshop" 
            class="grayscale hover:grayscale-0 transition-all duration-1000 shadow-2xl"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- CATALOG: THE TOOLS OF PROFIT -->
  <section class="py-32 bg-[#F5F5F5]">
    <div class="container-custom">
      <div class="flex flex-col md:flex-row justify-between items-end mb-20 gap-8">
        <div class="max-w-2xl">
          <h2 class="text-6xl md:text-7xl font-display leading-[0.9] text-[#0A0A0A] uppercase mb-6 tracking-tight">
            Peralatan <span class="text-[#8B6F47]">Pilihan</span>
          </h2>
          <p class="text-[#1A140D]/60 uppercase tracking-[0.2em] text-[10px] font-bold">Pilih Alatan Yang Buat Duit Untuk Bisnes Anda</p>
        </div>
        <a href="/ms/equipment" class="font-display uppercase tracking-widest text-[#0A0A0A] hover:text-[#8B6F47] transition-colors border-b-2 border-[#0A0A0A] pb-1">
          Lihat Semua Katalog
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        {equipment.map(item => (
          <ProductCard 
            name={item.name}
            description={item.description}
            image={item.image}
            link={item.link}
            lang={lang}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA: THE ACTION -->
  <section class="py-40 bg-[#0A0A0A] relative overflow-hidden">
    <div class="absolute inset-0 bg-[#8B6F47]/5"></div>
    <div class="container-custom relative z-10 text-center">
      <h2 class="text-7xl md:text-8xl lg:text-9xl font-display leading-none text-white uppercase mb-12 tracking-tighter">
        Bisnes Tak Boleh <span class="text-[#D4A574]">Tunggu</span>
      </h2>
      <p class="text-xl text-[#F5F5F5]/60 mb-16 max-w-2xl mx-auto font-light">
        Dapatkan modal kerja atau mesin yang anda perlu hari ini. Cakap terus dengan pakar pembiayaan kami.
      </p>
      <div class="flex flex-col sm:flex-row gap-6 justify-center">
        <a href={COMPANY_INFO.whatsapp.link} class="bg-[#D4A574] text-[#0A0A0A] font-display uppercase tracking-widest text-sm px-16 py-8 hover:bg-white transition-all duration-500">
          WhatsApp Sekarang
        </a>
        <a href="/ms/contact" class="border border-white/20 text-white font-display uppercase tracking-widest text-sm px-16 py-8 hover:bg-white hover:text-[#0A0A0A] transition-all duration-500">
          Hubungi Kami
        </a>
      </div>
    </div>
  </section>

  <!-- FORM: THE DIRECT LINE -->
  <section class="py-32 bg-white">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-20">
          <div>
            <h2 class="text-6xl font-display leading-[0.9] text-[#0A0A0A] uppercase mb-8 tracking-tight">Dapatkan <span class="text-[#8B6F47]">Sebut Harga</span></h2>
            <p class="text-[#1A140D]/60 mb-12 leading-relaxed">
              Kami akan proses permohonan anda dengan pantas. Isikan butiran dan kami hubungi anda dalam masa terdekat.
            </p>
            <div class="space-y-6 text-[#1A140D]">
              <div class="p-6 bg-[#F5F5F5]">
                <span class="block text-[10px] uppercase tracking-widest font-bold text-[#8B6F47] mb-2">Ibu Pejabat</span>
                <p class="font-display text-xl uppercase">{COMPANY_INFO.address.city}, {COMPANY_INFO.address.state}</p>
              </div>
              <div class="p-6 bg-[#F5F5F5]">
                <span class="block text-[10px] uppercase tracking-widest font-bold text-[#8B6F47] mb-2">Waktu Operasi</span>
                <p class="font-display text-xl uppercase">Isnin - Jumaat: 9AM - 5PM</p>
              </div>
            </div>
          </div>
          <div class="bg-[#F5F5F5] p-10 md:p-16 relative">
            <div class="absolute -top-4 -left-4 w-12 h-12 bg-[#8B6F47]"></div>
            <ContactForm lang={lang} />
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  h1, h2, h3, h4 {
    font-family: 'Bebas Neue', var(--font-display);
  }
</style>or.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
