---
/**
 * Bahasa Malaysia Contact Page
 * Revamped with Midnight Luxe design and Action Taker voice
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/ContactForm.astro';
import { COMPANY_INFO, SITE_CONFIG } from '../../utils/constants';

const lang = 'ms';

// SEO Configuration
const pageTitle = 'Berhenti Menunggu. Mula Bertindak. | Hubungi Ing Heng Credit';
const pageDescription = 'Bercakap terus dengan pembuat keputusan. Jangan biarkan bank melambatkan bisnes anda. WhatsApp +60175700889 untuk kelulusan modal pantas.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
>
  
  <!-- HERO: THE ULTIMATUM (Midnight) -->
  <section class="relative min-h-[60vh] flex items-center bg-[#0A0A0A] overflow-hidden pt-20">
    <div class="absolute inset-0 opacity-30">
        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#0A0A0A]"></div>
    </div>

    <div class="container-custom relative z-10 py-20 text-center">
      <div class="max-w-4xl mx-auto">
        <span class="text-[#D4A574] font-display uppercase tracking-[0.4em] text-[10px] font-bold mb-6 block">Masa Adalah Wang</span>
        <h1 class="text-7xl md:text-8xl lg:text-9xl font-display leading-[0.85] text-white uppercase mb-8 tracking-tighter">
          Berhenti <span class="text-white/20 italic">Menunggu.</span><br/>
          Mula <span class="text-[#D4A574]">Bertindak.</span>
        </h1>
        <p class="text-xl text-[#F5F5F5]/60 max-w-2xl mx-auto font-light leading-relaxed mb-12">
            Bank kata tidak? Kami kata YA. Modal bisnes anda hanya satu mesej sahaja lagi. Jangan biarkan peluang ini terlepas.
        </p>
      </div>
    </div>
  </section>

  <!-- CONTACT OPTIONS: THE TRI-TONE ARCHITECTURE -->
  <section class="py-24 bg-white border-b border-black/5">
    <div class="container-custom">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 -mt-20 relative z-20">
        
        <!-- WhatsApp (Fast Track - Midnight) -->
        <a href={COMPANY_INFO.whatsapp.link} class="p-12 bg-[#0A0A0A] group hover:bg-[#8B6F47] transition-all duration-500 text-white shadow-2xl">
          <span class="text-4xl mb-8 block">📱</span>
          <h3 class="text-3xl font-display uppercase mb-4 group-hover:text-white transition-colors">WhatsApp</h3>
          <p class="text-white/60 mb-8 text-sm font-light leading-relaxed">Keputusan segera. Hantar butiran aset anda sekarang untuk penilaian on-the-spot.</p>
          <span class="text-[10px] font-black uppercase tracking-widest border-b border-[#D4A574] pb-1 italic">Hantar Mesej Sekarang →</span>
        </a>

        <!-- Call (Direct - Bronze) -->
        <a href={`tel:${COMPANY_INFO.phone.international}`} class="p-12 bg-[#8B6F47] group hover:bg-[#0A0A0A] transition-all duration-500 text-white shadow-2xl">
          <span class="text-4xl mb-8 block">📞</span>
          <h3 class="text-3xl font-display uppercase mb-4 group-hover:text-[#D4A574] transition-colors">Panggilan Terus</h3>
          <p class="text-white/80 mb-8 text-sm font-light leading-relaxed">Bercakap terus dengan pakar modal kami. Tiada robot, tiada ejen tengah.</p>
          <span class="text-[10px] font-black uppercase tracking-widest border-b border-white pb-1 italic">Panggil: {COMPANY_INFO.phone.display} →</span>
        </a>

        <!-- Office (Heritage - Editorial Gray) -->
        <div class="p-12 bg-[#F5F5F5] group hover:bg-white transition-all duration-500 border border-black/5 shadow-2xl">
          <span class="text-4xl mb-8 block">🏢</span>
          <h3 class="text-3xl font-display uppercase mb-4 text-[#0A0A0A]">Pejabat Klang</h3>
          <p class="text-[#0A0A0A]/60 mb-8 text-sm font-light leading-relaxed">{COMPANY_INFO.address.full}</p>
          <a href={COMPANY_INFO.address.googleMapsUrl} target="_blank" class="text-[10px] font-black uppercase tracking-widest border-b border-[#0A0A0A] pb-1 italic text-[#0A0A0A]">Cari Kami Di Map →</a>
        </div>

      </div>
    </div>
  </section>

  <!-- FORM: THE PARTNERSHIP (White) -->
  <section class="py-32 bg-white">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
        <div>
          <h2 class="text-6xl font-display uppercase mb-8 text-[#0A0A0A]">Modal <span class="text-[#8B6F47]">Bermula</span> <br/>Di Sini</h2>
          <p class="text-[#1A140D]/60 mb-12 leading-relaxed font-light text-lg">
            Isi borang di sebelah. Kami tidak perlukan borang bank yang tebal. Kami hanya perlukan keberanian anda untuk kembangkan bisnes.
          </p>
          <div class="space-y-8">
            <div class="flex items-start gap-6">
                <div class="text-[#D4A574] text-2xl">✓</div>
                <div>
                    <h4 class="font-display text-xl uppercase text-[#0A0A0A]">Penilaian Percuma</h4>
                    <p class="text-sm text-[#1A140D]/40 font-light">Kami nilai aset anda tanpa sebarang bayaran pendahuluan.</p>
                </div>
            </div>
            <div class="flex items-start gap-6">
                <div class="text-[#D4A574] text-2xl">✓</div>
                <div>
                    <h4 class="font-display text-xl uppercase text-[#0A0A0A]">Keputusan 24 Jam</h4>
                    <p class="text-sm text-[#1A140D]/40 font-light">Masa anda berharga. Kami berikan keputusan awal dengan pantas.</p>
                </div>
            </div>
          </div>
        </div>
        <div class="p-12 bg-[#F5F5F5] border border-black/5 shadow-inner">
          <ContactForm lang={lang} />
        </div>
      </div>
    </div>
  </section>

  <!-- MAP: THE PRESENCE -->
  <section class="h-[60vh] relative grayscale hover:grayscale-0 transition-all duration-1000">
    <iframe
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3984.3448!2d101.4424!3d3.0449!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31cc530000000001%3A0xe764724a7378f79!2sIng%20Heng%20Credit%20%26%20Leasing%20Sdn%20Bhd!5e0!3m2!1sen!2smy!4v1713800000000!5m2!1sen!2smy"
      width="100%"
      height="100%"
      style="border:0;"
      allowfullscreen=""
      loading="lazy"
      class="opacity-80"
    ></iframe>
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 bg-[#0A0A0A] text-white px-12 py-6 font-display uppercase tracking-widest text-sm shadow-2xl">
        Kunjungi Kami Di Klang
    </div>
  </section>

</BaseLayout>

<style>
  h1, h2, h3, h4 {
    font-family: 'Bebas Neue', var(--font-display);
  }
</style>
