---
/**
 * Malay Blog Index Page
 * Updated with Midnight Luxe design and Action Taker voice
 */

import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { COMPANY_INFO } from '../../../utils/constants';

const lang = 'ms';

// Get blog posts from Content Collections
const allMdPosts = await getCollection('blogs');
const allPosts = allMdPosts
  .filter(post => post.data.locale === lang)
  .map(post => ({
    title: post.data.title,
    excerpt: post.data.description,
    slug: post.slug.includes('/') ? post.slug.split('/').pop() : post.slug,
    date: typeof post.data.publishDate === 'string' ? post.data.publishDate : post.data.publishDate.toISOString(),
    category: post.data.category,
    readTime: post.data.readingTime || 5,
    featured: post.data.featured,
    image: post.data.ogImage || `/images/blog/${post.slug}.jpg`,
  }));

const sortedPosts = allPosts.sort((a, b) =>
  new Date(b.date).valueOf() - new Date(a.date).valueOf()
);

const featuredPost = sortedPosts.find(p => p.featured) || sortedPosts[0];
const recentPosts = sortedPosts.filter(p => p.slug !== featuredPost?.slug).slice(0, 6);

// SEO Configuration
const pageTitle = 'Pakar Modal & Wawasan Industri | Blog Ing Heng Credit';
const pageDescription = 'Wawasan pakar tentang pembiayaan mesin, pengurusan tunai PKS, dan strategi bisnes pembinaan. Pelajari dari 40 tahun pengalaman kami.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
>
  
  <!-- HERO: THE AUTHORITY -->
  <section class="relative min-h-[60vh] flex items-center bg-[#0A0A0A] overflow-hidden pt-20">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#0A0A0A]"></div>
    </div>

    <div class="container-custom relative z-10 py-20">
      <div class="max-w-4xl">
        <span class="text-[#D4A574] font-display uppercase tracking-[0.4em] text-[10px] font-bold mb-6 block">Wawasan Pakar</span>
        <h1 class="text-7xl md:text-8xl lg:text-9xl font-display leading-[0.85] text-white uppercase mb-8 tracking-tighter">
          Pakar <span class="text-[#D4A574]">MODAL.</span><br/>
          Wawasan <span class="text-white">PASARAN.</span>
        </h1>
        <p class="text-xl text-[#F5F5F5]/60 max-w-2xl font-light leading-relaxed mb-12">
          Kami kongsikan strategi pembiayaan yang bank tidak mahu anda tahu. Pelajari bagaimana usahawan paling berjaya di Malaysia menguruskan aset mereka.
        </p>
      </div>
    </div>
  </section>

  <!-- FEATURED: THE HEADLINER -->
  {featuredPost && (
    <section class="py-24 bg-white">
      <div class="container-custom">
        <div class="group relative bg-[#0A0A0A] overflow-hidden">
          <div class="grid grid-cols-1 lg:grid-cols-2">
            <div class="aspect-video lg:aspect-auto overflow-hidden relative">
              <img 
                src={featuredPost.image} 
                alt={featuredPost.title}
                class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700"
              />
              <div class="absolute top-8 left-8">
                 <span class="bg-[#D4A574] text-[#0A0A0A] font-display uppercase tracking-widest text-[10px] px-4 py-2 font-bold shadow-xl italic">Terlaras</span>
              </div>
            </div>
            <div class="p-12 md:p-20 flex flex-col justify-center text-white">
              <span class="text-[#D4A574] font-display uppercase tracking-widest text-xs mb-6 block">{featuredPost.category}</span>
              <h2 class="text-5xl md:text-6xl font-display uppercase mb-8 leading-none tracking-tight">{featuredPost.title}</h2>
              <p class="text-white/60 mb-10 text-lg font-light leading-relaxed line-clamp-3">{featuredPost.excerpt}</p>
              <div class="flex items-center justify-between">
                <a href={`/ms/blog/${featuredPost.slug}`} class="text-[10px] uppercase tracking-widest font-bold border-b border-[#D4A574] pb-2 hover:text-[#D4A574] transition-colors">Baca Analisis Penuh →</a>
                <span class="text-white/20 text-[10px] uppercase tracking-widest">{featuredPost.readTime} MIN BACA</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- RECENT: THE FEED -->
  <section class="py-32 bg-[#F5F5F5]">
    <div class="container-custom">
      <div class="text-center mb-24">
        <h2 class="text-6xl font-display uppercase text-[#0A0A0A] mb-4">Laporan <span class="text-[#8B6F47]">Terkini</span></h2>
        <p class="text-[#1A140D]/40 uppercase tracking-[0.3em] text-[10px] font-bold">Wawasan Berasaskan Data & Pengalaman</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
        {recentPosts.map((post) => (
          <div class="group bg-white border border-black/5 flex flex-col">
            <div class="aspect-video overflow-hidden">
              <img 
                src={post.image} 
                alt={post.title}
                class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500"
              />
            </div>
            <div class="p-10 flex-grow">
              <span class="text-[#8B6F47] font-display uppercase tracking-widest text-[10px] mb-4 block">{post.category}</span>
              <h3 class="text-3xl font-display uppercase mb-6 leading-none group-hover:text-[#8B6F47] transition-colors">{post.title}</h3>
              <p class="text-[#1A140D]/60 text-sm font-light leading-relaxed mb-8 line-clamp-3">{post.excerpt}</p>
              <div class="mt-auto pt-6 border-t border-black/5 flex justify-between items-center">
                <a href={`/ms/blog/${post.slug}`} class="text-[10px] uppercase tracking-widest font-black italic hover:text-[#8B6F47] transition-colors">Baca Lagi →</a>
                <span class="text-gray-300 text-[10px] uppercase">{post.readTime} MIN</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA: THE SYNDICATE -->
  <section class="py-40 bg-[#0A0A0A] relative overflow-hidden">
    <div class="container-custom relative z-10 text-center">
      <h2 class="text-7xl md:text-8xl lg:text-9xl font-display leading-[0.85] text-white uppercase mb-12 tracking-tighter">
        Dapatkan <span class="text-[#D4A574]">Wawasan</span><br/>
        Terus Ke <span class="text-white/20">Bisnes</span> Anda
      </h2>
      <p class="text-xl text-[#F5F5F5]/60 mb-16 max-w-2xl mx-auto font-light">
        Sertai 4,000+ usahawan yang mendapat wawasan pasaran secara terus dari pakar kami.
      </p>
      <div class="flex flex-col sm:flex-row gap-6 justify-center">
        <a href={COMPANY_INFO.whatsapp.link} class="bg-[#D4A574] text-[#0A0A0A] font-display uppercase tracking-widest text-sm px-16 py-8 hover:bg-white transition-all duration-500">
          WhatsApp Kami Untuk Nasihat
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  h1, h2, h3, h4 {
    font-family: 'Bebas Neue', var(--font-display);
  }
</style>
