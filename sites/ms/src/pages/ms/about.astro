---
/**
 * About Page - Malay
 * Pembiayaan Peralatan Sejak 1985
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/ContactForm.astro';
import { COMPANY_INFO } from '../../utils/constants';

const lang = 'ms';
const pageTitle = 'Tentang Kami | 40 Tahun Membina Bisnes Malaysia | Ing Heng Credit';
const pageDescription = 'Sejarah Ing Heng Credit & Leasing. Dari 1985, kami sokong kontraktor dan usahawan Malaysia dengan modal pantas untuk jentera berat.';
---

<BaseLayout title={pageTitle} description={pageDescription} lang={lang}>
  
  <!-- HERO: THE HERITAGE -->
  <section class="relative min-h-[60vh] flex items-center bg-[#0A0A0A] overflow-hidden pt-20">
    <div class="absolute inset-0 opacity-30">
      <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#0A0A0A]"></div>
    </div>

    <div class="container-custom relative z-10 py-20 text-center">
      <div class="max-w-4xl mx-auto">
        <span class="text-[#D4A574] font-display uppercase tracking-[0.4em] text-[10px] font-bold mb-6 block">Sejak 1985</span>
        <h1 class="text-7xl md:text-8xl lg:text-9xl font-display leading-none text-white uppercase mb-8 tracking-tighter">
          Warisan <span class="text-[#D4A574]">40 TAHUN</span><br/>
          Keputusan <span class="text-white">HARI INI</span>
        </h1>
        <p class="text-xl text-[#F5F5F5]/60 max-w-2xl mx-auto font-light leading-relaxed">
          Kami bukan sekadar syarikat kewangan. Kami adalah rakan kongsi yang memahami setiap peluh dan titik mesin anda dalam membina Malaysia.
        </p>
      </div>
    </div>
  </section>

  <!-- STORY: THE HUMAN ELEMENT -->
  <section class="py-32 bg-white">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
        <div class="relative">
          <div class="absolute -top-10 -left-10 w-40 h-40 bg-[#8B6F47]/5 -z-10"></div>
          <img 
            src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?auto=format&fit=crop&q=80&w=1200" 
            alt="Ing Heng Legacy" 
            class="grayscale shadow-2xl"
          />
          <div class="absolute -bottom-8 -right-8 bg-[#0A0A0A] p-10 text-white hidden md:block">
            <span class="block text-5xl font-display leading-none mb-2">1985</span>
            <span class="text-[10px] uppercase tracking-widest font-bold text-[#D4A574]">Ditempa Di Klang</span>
          </div>
        </div>

        <div>
          <h2 class="text-6xl font-display leading-[0.9] text-[#0A0A0A] uppercase mb-10 tracking-tight">
            Kami Labur Dalam <span class="text-[#8B6F47]">Manusia</span>,<br/> Bukan Algoritma
          </h2>
          <div class="space-y-6 text-[#1A140D]/70 leading-relaxed font-light text-lg">
            <p>
              Di <strong>Ing Heng Credit</strong>, kami tahu nilai sebenar mesin bukan pada kertas, tapi pada orang yang mengendalikannya. Sejak 1985, kami telah melihat ribuan usahawan Malaysia bergelut dengan kerenah bank yang terlalu kaku.
            </p>
            <p>
              Sebab itu kami wujud. Kami hargai aset lama yang bank tolak. Kami faham lori 20 tahun masih mampu buat untung jika di tangan yang betul. Kami tidak pandang skor kredit semata-mata—kami pandang potensi bisnes anda.
            </p>
            <p class="text-[#0A0A0A] font-medium italic">
              "Kami kata YA bila bank kata TIDAK—ini bukan sekadar slogan, ini adalah janji kami kepada setiap kontraktor dan pemilik logistik di Malaysia."
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS: THE AUTHORITY -->
  <section class="py-32 bg-[#0A0A0A] text-white">
    <div class="container-custom">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-20">
        <div class="border-l border-white/10 pl-10">
          <span class="text-7xl font-display text-[#D4A574] block mb-4">4,000+</span>
          <h4 class="text-xl font-display uppercase tracking-tight mb-4">Perniagaan Dibiayai</h4>
          <p class="text-white/40 text-sm leading-relaxed">Dari kontraktor kecil sehinggalah armada logistik besar, kepercayaan mereka adalah kekuatan kami.</p>
        </div>
        <div class="border-l border-white/10 pl-10">
          <span class="text-7xl font-display text-white block mb-4">RM 500J+</span>
          <h4 class="text-xl font-display uppercase tracking-tight mb-4">Modal Disalurkan</h4>
          <p class="text-white/40 text-sm leading-relaxed">Kami telah menyuntik lebih setengah bilion ringgit ke dalam ekonomi industri Malaysia.</p>
        </div>
        <div class="border-l border-white/10 pl-10">
          <span class="text-7xl font-display text-white block mb-4">100%</span>
          <h4 class="text-xl font-display uppercase tracking-tight mb-4">Fokus Peralatan</h4>
          <p class="text-white/40 text-sm leading-relaxed">Kami adalah pakar. Kami tahu selok belok setiap jengkaut, lori, dan forklift yang kami biayai.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- LICENSE: THE LEGAL STAND -->
  <section class="py-32 bg-white">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto text-center">
        <div class="w-24 h-24 bg-[#D4A574] rounded-full flex items-center justify-center mx-auto mb-10 shadow-xl">
          <svg class="w-12 h-12 text-[#0A0A0A]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
          </svg>
        </div>
        <h2 class="text-5xl font-display uppercase mb-8 text-[#0A0A0A]">Keselamatan & Kepatuhan</h2>
        <p class="text-xl text-[#1A140D]/60 mb-12 leading-relaxed">
          Ing Heng Credit & Leasing Sdn Bhd adalah syarikat pembiayaan berlesen di bawah Akta Pemberi Pinjam Wang 1951. Kami mematuhi semua peraturan <strong>KPKT (Kementerian Perumahan dan Kerajaan Tempatan)</strong>.
        </p>
        <div class="inline-block border border-black/10 px-10 py-6 bg-[#F5F5F5]">
          <span class="block text-[10px] uppercase tracking-widest font-bold text-[#8B6F47] mb-2">No. Lesen IPW</span>
          <span class="text-2xl font-display uppercase text-[#0A0A0A]">WL5920 / 10 / 01 - 9 / 231124</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA: THE NEXT CHAPTER -->
  <section class="py-40 bg-[#0A0A0A] relative overflow-hidden border-t border-white/5">
    <div class="container-custom relative z-10 text-center">
      <h2 class="text-7xl md:text-8xl lg:text-9xl font-display leading-none text-white uppercase mb-12 tracking-tighter">
        Mari Bina <span class="text-[#D4A574]">Masa Depan</span>
      </h2>
      <p class="text-xl text-[#F5F5F5]/60 mb-16 max-w-2xl mx-auto font-light">
        Sertai ribuan perniagaan yang telah berkembang bersama kami selama 40 tahun ini.
      </p>
      <div class="flex flex-col sm:flex-row gap-6 justify-center">
        <a href={COMPANY_INFO.whatsapp.link} class="bg-[#D4A574] text-[#0A0A0A] font-display uppercase tracking-widest text-sm px-16 py-8 hover:bg-white transition-all duration-500">
          WhatsApp Sekarang
        </a>
        <a href="/ms/contact" class="border border-white/20 text-white font-display uppercase tracking-widest text-sm px-16 py-8 hover:bg-white hover:text-[#0A0A0A] transition-all duration-500">
          Hubungi Pejabat
        </a>
      </div>
    </div>
  </section>

  <!-- FORM: THE DIRECT LINE -->
  <section class="py-32 bg-white">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto">
        <div class="bg-[#F5F5F5] p-10 md:p-16 relative">
          <div class="absolute -top-4 -left-4 w-12 h-12 bg-[#8B6F47]"></div>
          <div class="text-center mb-16">
            <h2 class="text-5xl font-display leading-[0.9] text-[#0A0A0A] uppercase mb-4 tracking-tight">Hantar Permohonan</h2>
            <p class="text-[#1A140D]/60 uppercase tracking-widest text-[10px] font-bold tracking-[0.2em]">Respons Dalam Masa 24 Jam Bekerja</p>
          </div>
          <ContactForm lang={lang} />
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  h1, h2, h3, h4 {
    font-family: 'Bebas Neue', var(--font-display);
  }
</style>