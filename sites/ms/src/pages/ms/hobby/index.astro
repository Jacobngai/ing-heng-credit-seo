---
/**
 * Hobby Financing Hub Page - Malay
 * Main hub page showcasing all hobby financing categories
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import HobbyCard from '../../../components/HobbyCard.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import FAQItem from '../../../components/FAQItem.astro';

import { COMPANY_INFO } from '../../../utils/constants';
import { encodeJSONLD } from '../../../utils/schema';

const lang = 'ms';

// SEO Data
const pageTitle = 'Impian Anda. Modal Kami. | Pembiayaan Hobi | Ing Heng Credit';
const pageDescription = 'Bank kata TIDAK kepada kereta lama. Kami kata YA. Biayai kereta klasik, legenda JDM, superbike, dan kapal layar tanpa had umur mesin.';

// Category Cards
const categoryCards = [
  {
    title: 'Kereta Klasik',
    description: 'Biayai kereta koleksi impian anda. Kami terima legenda JDM, klasik Eropah, dan Muscle American tanpa had umur.',
    image: '/images/hobby/classic-cars-card.jpg',
    href: '/ms/hobby/classic-cars',
    items: ['Legenda JDM', 'Klasik Eropah', 'Muscle American'],
    badge: 'Popular'
  },
  {
    title: 'Motosikal Berkuasa Tinggi',
    description: 'Pembiayaan motosikal klasik dan vintaj. Dari Harley-Davidson hingga superbike Eropah dan vintaj Jepun.',
    image: '/images/hobby/motorcycles-card.jpg',
    href: '/ms/hobby/motorcycles',
    items: ['Harley-Davidson', 'Vintaj Jepun', 'Superbike Eropah']
  },
  {
    title: 'Bot & Kapal Layar',
    description: 'Miliki kapal layar impian anda. Speedboat, bot memancing, dan jet ski - segala jenis aset maritim.',
    image: '/images/hobby/marine-card.jpg',
    href: '/ms/hobby/marine',
    items: ['Kapal Layar (Yacht)', 'Speedboat', 'Jet Ski']
  },
  {
    title: 'Kenderaan Rekreasi (RV)',
    description: 'Pengembaraan menanti. Motorhome, ATV, UTV, dan buggy golf untuk gaya hidup luar anda.',
    image: '/images/hobby/recreational-card.jpg',
    href: '/ms/hobby/recreational',
    items: ['Motorhomes', 'ATV/UTV', 'Buggy Golf']
  },
  {
    title: 'Pesawat Ringan',
    description: 'Pembiayaan helikopter dan pesawat kecil untuk peminat penerbangan. Terbang hari ini.',
    image: '/images/hobby/aircraft-card.jpg',
    href: '/ms/hobby/aircraft',
    items: ['Helikopter', 'Pesawat Kecil', 'Gyrocopters']
  },
  {
    title: "Permintaan Khas",
    description: "Jumpa sesuatu yang unik? Kami biayai koleksi khas dan aset nadir yang bank tidak faham.",
    image: '/images/hobby/custom-card.jpg',
    href: 'https://wa.me/60175700889?text=Hi!%20Saya%20ingin%20bertanya%20tentang%20pembiayaan%20hobi%20khas.',
    badge: 'Pakar'
  }
];

// Specialist Benefits
const benefits = [
  {
    icon: 'search',
    title: 'Penilaian Pakar',
    description: 'Bank guna "nilai buku". Kami guna "nilai pasaran". Kami tahu GTR 90-an yang dijaga rapi bernilai tinggi.'
  },
  {
    icon: 'infinity',
    title: 'Tanpa Had Umur',
    description: 'Kami biayai kenderaan vintaj dan koleksi tanpa mengira umur. Ikon 50 tahun sangat dialu-alukan.'
  },
  {
    icon: 'clock',
    title: 'Modal Terus',
    description: 'Tanpa orang tengah. Anda bercakap terus dengan pembuat keputusan yang membiayai minat anda.'
  }
];

// FAQs - Simplified
const faqs = [
  {
    question: 'Bolehkah saya biayai kereta berumur 30 tahun?',
    answer: 'YA. Bank selalunya menolak kereta lebih 10-15 tahun. Kami tiada had umur. Jika kereta itu bernilai, kami beri pinjaman.'
  },
  {
    question: 'Bagaimana anda tentukan nilai aset?',
    answer: 'Bank tengok carta. Kami tengok pasaran sebenar. Pakar kami faham kenapa kereta klasik tertentu mahal, dan kami biayai berasaskan nilai itu.'
  },
  {
    question: 'Berapakah pinjaman maksimum?',
    answer: 'Kami boleh biayai sehingga RM 1,000,000 untuk koleksi bernilai tinggi seperti kapal layar atau kereta klasik nadir.'
  }
];

// Schema
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Kategori Pembiayaan Hobi',
  description: 'Pembiayaan hobi khusus untuk kereta klasik, motor, dan bot di Malaysia',
  itemListElement: categoryCards.map((card, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    item: {
      '@type': 'Product',
      name: card.title,
      description: card.description,
    }
  }))
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={encodeJSONLD(itemListSchema)} />
  </Fragment>

  <!-- HERO: YOUR PASSION (Midnight Theme) -->
  <section class="relative min-h-[70vh] flex items-center bg-[#0A0A0A] pt-20 overflow-hidden">
    <div class="absolute top-[-10%] right-[-10%] w-[40%] h-[40%] bg-[#8B6F47]/15 blur-[120px] rounded-full"></div>
    
    <div class="container-custom relative z-10">
      <div class="max-w-4xl">
        <span class="inline-block text-[#D4A574] font-display tracking-[0.4em] uppercase text-sm mb-6 font-bold">Pakar Aset Koleksi</span>
        <h1 class="text-white leading-[0.9] mb-8 uppercase font-display text-7xl md:text-9xl">
          IMPIAN ANDA. <br />
          <span class="text-[#D4A574]">MODAL KAMI.</span>
        </h1>
        <p class="text-white/70 text-xl font-light max-w-2xl mb-12 leading-relaxed">
          Bank kata TIDAK kepada kereta lama. Kami kata YA. Kami sediakan pembiayaan terus untuk kereta klasik, superbike, dan kapal layar tanpa had umur. Anda jumpa asetnya—kami sediakan modalnya.
        </p>

        <div class="flex flex-wrap gap-4">
            <a href={COMPANY_INFO.whatsapp.link} class="bg-[#8B6F47] text-white font-display text-xl tracking-widest px-10 py-5 hover:bg-white hover:text-[#0A0A0A] transition-all uppercase">Dapatkan Sebut Harga →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CATEGORIES: CHOOSE PASSION (Daylight Theme) -->
  <section class="bg-white py-24 md:py-32 rounded-t-[40px] -mt-10 relative z-20">
    <div class="container-custom">
      <div class="text-center mb-16">
        <span class="text-[#8B6F47] font-display tracking-[0.3em] uppercase text-sm mb-4 block font-bold">Koleksi Kami</span>
        <h2 class="text-[#0A0A0A] mb-4 text-5xl md:text-6xl font-display uppercase">Pilih <span class="text-[#D4A574]">Minat</span> Anda</h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {categoryCards.map((card) => (
          <HobbyCard
            lang={lang}
            title={card.title}
            description={card.description}
            image={card.image}
            href={card.href}
            items={card.items}
            badge={card.badge}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- SPECIALIST: WHY US (Alloy Theme) -->
  <section class="bg-[#F5F5F5] py-24 md:py-32">
    <div class="container-custom">
      <div class="grid lg:grid-cols-3 gap-12">
        {benefits.map((benefit) => (
          <div class="flex flex-col items-center text-center group mt-8">
            <div class="w-16 h-16 bg-[#0A0A0A] text-[#D4A574] flex items-center justify-center text-3xl mb-8 group-hover:bg-[#8B6F47] group-hover:text-white transition-all duration-500">
               {benefit.icon === 'search' && '🔍'}
               {benefit.icon === 'infinity' && '♾️'}
               {benefit.icon === 'clock' && '💳'}
            </div>
            <h3 class="font-display text-3xl uppercase text-[#0A0A0A] mb-4">{benefit.title}</h3>
            <p class="text-[#1A140D]/60 font-light leading-relaxed">{benefit.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS: THE ROADMAP (Midnight Theme) -->
  <section class="bg-[#0A0A0A] py-24 md:py-32 text-white">
    <div class="container-custom">
      <div class="text-center mb-20">
        <h2 class="text-white text-5xl md:text-6xl uppercase tracking-tighter mb-4 font-display">Miliki Dalam <span class="text-[#D4A574]">4 Langkah.</span></h2>
        <p class="text-white/40 max-w-xl mx-auto">Satu jalan terus ke arah impian anda.</p>
      </div>

      <div class="grid md:grid-cols-4 gap-12 relative">
        <div class="hidden md:block absolute top-12 left-0 w-full h-[1px] bg-white/10 z-0"></div>
        
        <div class="relative z-10 text-center">
            <div class="w-24 h-24 bg-[#1A1A1A] border border-white/10 rounded-full flex items-center justify-center mx-auto mb-8 text-[#D4A574] font-display text-4xl hover:border-[#8B6F47] transition-all">01</div>
            <h4 class="font-display text-xl uppercase mb-3">Pilih Impian</h4>
            <p class="text-white/40 text-sm font-light">Cari aset yang anda minat di pasaran pilihan anda.</p>
        </div>
        <div class="relative z-10 text-center">
            <div class="w-24 h-24 bg-[#1A1A1A] border border-white/10 rounded-full flex items-center justify-center mx-auto mb-8 text-[#D4A574] font-display text-4xl hover:border-[#8B6F47] transition-all">02</div>
            <h4 class="font-display text-xl uppercase mb-3">Dapatkan Sebut Harga</h4>
            <p class="text-white/40 text-sm font-light">WhatsApp butiran aset. Kami nilai harga sebenar on-the-spot.</p>
        </div>
        <div class="relative z-10 text-center">
            <div class="w-24 h-24 bg-[#1A1A1A] border border-white/10 rounded-full flex items-center justify-center mx-auto mb-8 text-[#D4A574] font-display text-4xl hover:border-[#8B6F47] transition-all">03</div>
            <h4 class="font-display text-xl uppercase mb-3">Kelulusan Pantas</h4>
            <p class="text-white/40 text-sm font-light">Bercakap terus dengan pembuat keputusan. Bank kata tidak, kami kata ya.</p>
        </div>
        <div class="relative z-10 text-center">
            <div class="w-24 h-24 bg-[#D4A574] rounded-full flex items-center justify-center mx-auto mb-8 text-[#0A0A0A] font-display text-4xl transform hover:scale-110 transition-all">04</div>
            <h4 class="font-display text-xl uppercase mb-3">Milik Anda</h4>
            <p class="text-white/40 text-sm font-light">Kami salurkan modal. Anda ambil aset hobi anda. Mula nikmati hidup.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ SECTION (Daylight Theme) -->
  <section class="bg-white py-24 md:py-32">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-16">
            <h2 class="text-[#0A0A0A] uppercase tracking-widest text-4xl mb-4 font-display">Soalan Lazim</h2>
            <div class="w-20 h-1 bg-[#8B6F47] mx-auto"></div>
        </div>
        <div class="space-y-6">
          {faqs.map((faq) => (
            <FAQItem question={faq.question} answer={faq.answer} />
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA: TALK SPECIALIST (Alloy Theme) -->
  <section class="bg-[#F5F5F5] py-24 md:py-32">
    <div class="container-custom text-center">
        <h2 class="text-[#0A0A0A] mb-8 uppercase font-display tracking-widest text-4xl md:text-5xl">Berhenti Menunggu. <br /><span class="text-[#D4A574]">Miliki Impian Anda.</span></h2>
        <p class="text-[#1A140D]/60 mb-12 text-xl max-w-2xl mx-auto font-light">Sertai pengumpul aset yang memilih Ing Heng Credit untuk membiayai kejayaan mereka.</p>
        <a href={COMPANY_INFO.whatsapp.link} class="bg-[#0A0A0A] text-white font-display text-2xl tracking-[0.1em] px-12 py-6 hover:bg-[#8B6F47] hover:translate-y-[-5px] transition-all duration-500 inline-block uppercase">
            Bercakap Dengan Pakar Aset
        </a>
    </div>
  </section>
</BaseLayout>

<style>
  h1, h2, h3, h4 {
    font-family: 'Bebas Neue', var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
