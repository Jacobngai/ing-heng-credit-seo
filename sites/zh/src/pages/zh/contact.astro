---
/**
 * Chinese Contact Page
 * Revamped with Midnight Luxe design and "Action Taker" voice
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/ContactForm.astro';
import { COMPANY_INFO } from '../../utils/constants';

const lang = 'zh';

// SEO Configuration
const pageTitle = '联系我们 | 开启您的商业信贷之门 | 永恒信贷 (Ing Heng Credit)';
const pageDescription = '直接联系大马40年信贷专家。不论是重型机械、商用车融资还是中小企业贷款，我们提供快速审批与诚信服务。';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
>
  
  <!-- HERO: THE ULTIMATUM (Midnight) -->
  <section class="relative min-h-[50vh] flex items-center bg-[#0A0A0A] overflow-hidden pt-20">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#0A0A0A]"></div>
    </div>

    <div class="container-custom relative z-10 py-20">
      <div class="max-w-4xl">
        <span class="text-[#D4A574] font-display uppercase tracking-[0.4em] text-[10px] font-bold mb-6 block">即刻成交</span>
        <h1 class="text-7xl md:text-8xl lg:text-9xl font-display leading-[0.85] text-white uppercase mb-8 tracking-tighter">
          直接<span class="text-white/20 italic">沟通</span><br/>
          快速<span class="text-[#D4A574]">拍板</span>
        </h1>
        <p class="text-xl text-[#F5F5F5]/60 max-w-2xl font-light leading-relaxed">
            与其在银行的繁文缛节中等待，不如直接联系决策者。40年直接注资经验，我们更懂您的急迫与雄心。
        </p>
      </div>
    </div>
  </section>

  <!-- CONTACT CHANNELS: THE TRI-TONE NODES (Editorial) -->
  <section class="py-32 bg-white">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        
        <!-- CHANNEL: WHATSAPP (Bronze Highlight) -->
        <div class="p-12 bg-[#8B6F47] text-white shadow-2xl scale-105 z-10">
          <span class="text-4xl mb-8 block">💬</span>
          <h3 class="text-3xl font-display uppercase mb-4">WhatsApp 咨询</h3>
          <p class="text-white/80 text-sm font-light mb-8">这是联系我们最快的方式。我们的顾问将为您提供 1 对 1 的极速解答。</p>
          <a href={COMPANY_INFO.whatsapp.link} class="inline-block bg-white text-[#8B6F47] font-display uppercase tracking-widest text-xs px-8 py-4 hover:bg-[#0A0A0A] hover:text-white transition-all font-bold italic">
            立即开始对话 →
          </a>
        </div>

        <!-- CHANNEL: OFFICE (Midnight Black) -->
        <div class="p-12 bg-[#0A0A0A] text-white border border-black/5">
          <span class="text-4xl mb-8 block">📍</span>
          <h3 class="text-3xl font-display uppercase mb-4">总部办公室</h3>
          <p class="text-white/60 text-sm font-light mb-8">欢迎莅临我们位于巴生的总部，面对面探讨您的商业蓝图。请提前预约。</p>
          <div class="text-sm font-display text-[#D4A574] tracking-widest leading-relaxed uppercase">
            NO. 16, JALAN SERULING 57,<br/>
            TAMAN KLANG JAYA, 41200 KLANG,<br/>
            SELANGOR, MALAYSIA.
          </div>
        </div>

        <!-- CHANNEL: PHONE (Pure White / Editorial) -->
        <div class="p-12 bg-[#F5F5F5] border border-black/5">
          <span class="text-4xl mb-8 block">📞</span>
          <h3 class="text-3xl font-display uppercase mb-4 text-[#0A0A0A]">联系电话</h3>
          <p class="text-[#1A140D]/60 text-sm font-light mb-8">更倾向于直接通话？拨打我们的服务热线，即刻接入专家指导。</p>
          <div class="space-y-2">
            <a href="tel:0333231122" class="block text-2xl font-display text-[#0A0A0A] hover:text-[#8B6F47] transition-colors">{COMPANY_INFO.phone}</a>
            <p class="text-[10px] text-gray-400 uppercase tracking-widest">办公时间: 周一至周五 (09:00 - 18:00)</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- FORM: THE STRATEGIC INQUIRY (Alloy) -->
  <section class="py-32 bg-[#0A0A0A]">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-24">
        <div>
           <span class="text-[#D4A574] font-display uppercase tracking-[0.4em] text-[10px] font-bold mb-6 block">诚信为本</span>
           <h2 class="text-6xl font-display uppercase text-white mb-8">40年直接外贷<br/><span class="text-white/20 italic">谢绝中介</span></h2>
           <p class="text-white/60 text-lg font-light leading-relaxed mb-12">
            我们不是帮人投资的中介。我们使用自有资金，为您提供最稳健、透明的融资服务。
            <br/><br/>
            在永恒信贷，每一个询问都能得到决策者的直面回应。我们保护您的隐私，尊重您的商业愿景。
           </p>
           <div class="grid grid-cols-2 gap-8 border-t border-white/10 pt-12">
              <div>
                <h4 class="text-white font-display text-xl mb-2">诚信</h4>
                <p class="text-white/40 text-xs">公开、公平、透明的利息与条款。</p>
              </div>
              <div>
                <h4 class="text-white font-display text-xl mb-2">专业</h4>
                <p class="text-white/40 text-xs">深港机械行业40年，懂行、懂价。</p>
              </div>
           </div>
        </div>
        <div class="bg-white p-12">
           <ContactForm lang={lang} />
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  h1, h2, h3, h4 {
    font-family: 'Bebas Neue', var(--font-display);
  }
</style>
