---
/**
 * Chinese Excavator Financing Page
 * Revamped with Midnight Luxe design and "Mechanical Master" voice
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Calculator from '../../../components/Calculator.astro';
import { COMPANY_INFO } from '../../../utils/constants';

const lang = 'zh';

// SEO Configuration
const pageTitle = '挖掘机融资贷款 | 接受50年旧机械 | 永恒信贷 (Ing Heng Credit)';
const pageDescription = '专业融资各类挖掘机，不论大小、不论品牌、不论新旧。银行说不，我们说好。40年机械价值评估经验，助您快速扩充工程车队。';

const features = [
  { title: '无车龄限制', desc: '我们甚至融资 1980 年代的经典机种。' },
  { title: '极速价值评估', desc: '基于真实市场价值，而非僵化的折旧表。' },
  { title: '低首付方案', desc: '减轻运营压力，将资金留在最需要的地方。' },
  { title: '直接融资渠道', desc: '内部资金拍板，省去中介抽成与漫长等待。' },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
>
  
  <!-- HERO: THE IRON AUTHORITY (Midnight) -->
  <section class="relative min-h-[60vh] flex items-center bg-[#0A0A0A] overflow-hidden pt-20">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0 bg-gradient-to-tr from-[#D4A574]/20 to-transparent"></div>
    </div>

    <div class="container-custom relative z-10 py-20">
      <div class="max-w-4xl">
        <span class="text-[#D4A574] font-display uppercase tracking-[0.4em] text-[10px] font-bold mb-6 block">机械融资旗舰</span>
        <h1 class="text-7xl md:text-8xl lg:text-9xl font-display leading-[0.85] text-white uppercase mb-8 tracking-tighter">
          挖掘机<br/>
          <span class="text-[#D4A574]">融资专家</span>
        </h1>
        <p class="text-xl text-[#F5F5F5]/60 max-w-2xl font-light leading-relaxed mb-12">
            我们不仅仅融资挖掘机，我们更懂它们的每一颗齿轮。从 1 吨微挖到 30 吨巨兽，只要它能开工，我们就敢注资。
        </p>
      </div>
    </div>
  </section>

  <!-- THE MANIFESTO: WHY WE SAY YES (Daylight) -->
  <section class="py-32 bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
        <div>
          <h2 class="text-6xl font-display uppercase mb-12 leading-none">银行对旧机器<br/><span class="text-[#8B6F47]">说不？我们说好。</span></h2>
          <p class="text-[#1A140D]/60 text-lg font-light leading-relaxed mb-8">
            在银行眼中，一台 20 年的挖掘机是“零价值”的废铁。在永恒信贷眼中，它是一台能够为您创造收益的财富引擎。
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
            {features.map(f => (
              <div class="border-l-2 border-[#D4A574] pl-6 py-2">
                <h4 class="text-xl font-display uppercase mb-2">{f.title}</h4>
                <p class="text-[#1A140D]/40 text-sm font-light">{f.desc}</p>
              </div>
            ))}
          </div>
          <a href={COMPANY_INFO.whatsapp.link} class="inline-block bg-[#0A0A0A] text-white font-display uppercase tracking-widest text-sm px-12 py-6 hover:bg-[#8B6F47] transition-all duration-500 font-bold">
            立即索取估价报告
          </a>
        </div>
        <div class="relative">
          <div class="aspect-[4/5] bg-[#F5F5F5] grayscale overflow-hidden shadow-2xl">
            <img src="/images/equipment/excavator-main.jpg" alt="Heavy Excavator" class="w-full h-full object-cover" />
          </div>
          <div class="absolute -bottom-12 -right-12 bg-[#D4A574] p-12 text-[#0A0A0A] hidden lg:block">
            <span class="text-5xl font-display block leading-none mb-2 italic">1985</span>
            <span class="text-[10px] uppercase tracking-widest font-black">源自实战经验</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CALCULATOR: PRECISE ROI (Alloy) -->
  <section class="py-32 bg-[#0A0A0A]">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
        <div>
          <h2 class="text-6xl font-display uppercase text-white mb-8">供款<span class="text-[#D4A574]">预估</span></h2>
          <p class="text-white/50 text-lg font-light leading-relaxed mb-12 max-w-md">
            掌控您的资金流。使用下方计算器，快速了解您的每月供款。我们提供极具灵活性的还款方案。
          </p>
          <div class="space-y-4">
             <div class="flex justify-between items-center py-4 border-b border-white/10">
                <span class="text-white/40 text-sm uppercase tracking-widest">最高贷款额度</span>
                <span class="text-white font-display text-2xl">不设限</span>
             </div>
             <div class="flex justify-between items-center py-4 border-b border-white/10">
                <span class="text-white/40 text-sm uppercase tracking-widest">最快审批时间</span>
                <span class="text-[#D4A574] font-display text-2xl">24小时</span>
             </div>
          </div>
        </div>
        <div class="bg-white/5 p-12 border border-white/10">
          <Calculator lang="zh" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA: THE SYNDICATE (Editorial Mixed) -->
  <section class="py-40 bg-white text-center">
    <div class="container-custom relative z-10">
      <h2 class="text-7xl md:text-8xl lg:text-9xl font-display leading-[0.85] text-[#0A0A0A] uppercase mb-12 tracking-tighter">
        扩充车队<br/><span class="text-[#8B6F47]">成就大事</span>
      </h2>
      <p class="text-xl text-[#1A140D]/60 mb-16 max-w-2xl mx-auto font-light">
        别让机会在手中流失。联系我们，让您的挖掘机今天就开始赚钱。
      </p>
      <div class="flex flex-col sm:flex-row gap-6 justify-center">
        <a href={COMPANY_INFO.whatsapp.link} class="bg-[#0A0A0A] text-white font-display uppercase tracking-widest text-sm px-16 py-8 hover:bg-[#8B6F47] transition-all duration-500 font-bold">
          立即通过 WhatsApp 咨询
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  h1, h2, h3, h4 {
    font-family: 'Bebas Neue', var(--font-display);
  }
</style>
