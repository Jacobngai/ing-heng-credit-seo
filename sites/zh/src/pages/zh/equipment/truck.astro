---
/**
 * Chinese Lorry/Truck Financing Page
 * Revamped with Midnight Luxe design and "Mechanical Master" voice
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Calculator from '../../../components/Calculator.astro';
import { COMPANY_INFO } from '../../../utils/constants';

const lang = 'zh';

// SEO Configuration
const pageTitle = '商用罗里与货车融资 | 接受二手机器与旧车 | 永恒信贷 (Ing Heng Credit)';
const pageDescription = '助您建立运输车队。不论是 1 吨还是 40 吨罗里，新旧均可融资。40年信贷经验，让您的生意跑遍全马，决胜物流。';

const features = [
  { title: '无障碍二手融资', desc: '接受高达 20 年车龄的各类商用车辆。' },
  { title: '全马车队支持', desc: '从单辆经营到大型物流车队，我们均能处理。' },
  { title: '极速现金发放', desc: '资料齐全，资金可在 3-5 个工作日内到账。' },
  { title: '灵活还款方案', desc: '针对不同季节性的商业流水，量身定制还款节奏。' },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
>
  
  <!-- HERO: THE TRANSPORT AUTHORITY (Midnight) -->
  <section class="relative min-h-[60vh] flex items-center bg-[#0A0A0A] overflow-hidden pt-20">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0 bg-gradient-to-tr from-[#8B6F47]/20 to-transparent"></div>
    </div>

    <div class="container-custom relative z-10 py-20">
      <div class="max-w-4xl">
        <span class="text-[#D4A574] font-display uppercase tracking-[0.4em] text-[10px] font-bold mb-6 block">物流资产专家</span>
        <h1 class="text-7xl md:text-8xl lg:text-9xl font-display leading-[0.85] text-white uppercase mb-8 tracking-tighter">
          商用罗里<br/>
          <span class="text-[#D4A574]">融资方案</span>
        </h1>
        <p class="text-xl text-[#F5F5F5]/60 max-w-2xl font-light leading-relaxed mb-12">
            我们不仅仅融资罗里，我们更懂大马物流的脉动。从 1 吨货车到 40 吨拖挂，只要您的生意在路上，我们就是您的油料。
        </p>
      </div>
    </div>
  </section>

  <!-- THE MANIFESTO: POWERING LOGISTICS (Daylight) -->
  <section class="py-32 bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
        <div class="order-2 lg:order-1 relative">
          <div class="aspect-[4/5] bg-[#F5F5F5] grayscale overflow-hidden shadow-2xl">
            <img src="/images/equipment/truck-main.jpg" alt="Commercial Lorry" class="w-full h-full object-cover" />
          </div>
          <div class="absolute -top-12 -left-12 bg-[#0A0A0A] p-12 text-white hidden lg:block shadow-2xl">
            <span class="text-5xl font-display block leading-none mb-2 text-[#D4A574]">40年</span>
            <span class="text-[10px] uppercase tracking-widest font-black text-white/50">深耕物流金融</span>
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <h2 class="text-6xl font-display uppercase mb-12 leading-none">别让资金<br/><span class="text-[#8B6F47]">限制您的运输版图</span></h2>
          <p class="text-[#1A140D]/60 text-lg font-light leading-relaxed mb-8">
            在银行看来，一辆二手的罗里可能是高风险资产。但在我们眼中，它是连接全马商机的纽带。这就是为什么我们敢于融资银行拒绝的旧车。
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
            {features.map(f => (
              <div class="border-l-2 border-[#D4A574] pl-6 py-2">
                <h4 class="text-xl font-display uppercase mb-2">{f.title}</h4>
                <p class="text-[#1A140D]/40 text-sm font-light">{f.desc}</p>
              </div>
            ))}
          </div>
          <a href={COMPANY_INFO.whatsapp.link} class="inline-block bg-[#0A0A0A] text-white font-display uppercase tracking-widest text-sm px-12 py-6 hover:bg-[#8B6F47] transition-all duration-500 font-bold">
            立即申请快速审批
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CALCULATOR: PRECISE LOGISTICS (Alloy) -->
  <section class="py-32 bg-[#0A0A0A]">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
        <div>
          <h2 class="text-6xl font-display uppercase text-white mb-8">精准<span class="text-[#D4A574]">预算</span></h2>
          <p class="text-white/50 text-lg font-light leading-relaxed mb-12 max-w-md">
            高效的生意离不开精准的账目。使用下方计算器，快速预估每月的贷款成本，让您的现金流永远处于最佳状态。
          </p>
          <div class="space-y-4">
             <div class="flex justify-between items-center py-4 border-b border-white/10">
                <span class="text-white/40 text-sm uppercase tracking-widest">支持吨位</span>
                <span class="text-white font-display text-2xl uppercase">1-TON TO 40-TON</span>
             </div>
             <div class="flex justify-between items-center py-4 border-b border-white/10">
                <span class="text-white/40 text-sm uppercase tracking-widest">分期年限</span>
                <span class="text-[#D4A574] font-display text-2xl">最长 7 年</span>
             </div>
          </div>
        </div>
        <div class="bg-white/5 p-12 border border-white/10">
          <Calculator lang="zh" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA: THE SYNDICATE (Editorial Mixed) -->
  <section class="py-40 bg-[#F5F5F5] text-center border-t border-black/5">
    <div class="container-custom relative z-10">
      <h2 class="text-7xl md:text-8xl lg:text-9xl font-display leading-[0.85] text-[#0A0A0A] uppercase mb-12 tracking-tighter">
        全马生意<br/><span class="text-[#8B6F47]">由您送达</span>
      </h2>
      <p class="text-xl text-[#1A140D]/60 mb-16 max-w-2xl mx-auto font-light">
        今天就联系我们的专业顾问，让我们为您的运输帝国注入动力。
      </p>
      <div class="flex flex-col sm:flex-row gap-6 justify-center">
        <a href={COMPANY_INFO.whatsapp.link} class="bg-[#0A0A0A] text-white font-display uppercase tracking-widest text-sm px-16 py-8 hover:bg-[#8B6F47] transition-all duration-500 font-bold">
          立即通过 WhatsApp 咨询
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  h1, h2, h3, h4 {
    font-family: 'Bebas Neue', var(--font-display);
  }
</style>
