---
/**
 * Chinese Forklift Financing Page
 * Revamped with Midnight Luxe design and "Mechanical Master" voice
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Calculator from '../../../components/Calculator.astro';
import { COMPANY_INFO } from '../../../utils/constants';

const lang = 'zh';

// SEO Configuration
const pageTitle = '叉车与仓储设备融资 | 柴油与电力叉车贷款 | 永恒信贷 (Ing Heng Credit)';
const pageDescription = '专业融资各类叉车及仓储设备。不论是全新的电力叉车还是翻新的柴油叉车，我们均提供高额贷款与灵活还款方案。40年经验，挺大马工厂。';

const features = [
  { title: '多元动力支持', desc: '全面覆盖柴油、汽油及电力驱动叉车融资。' },
  { title: '二手翻新设备', desc: '专门针对二手及翻新叉车提供优厚的信贷条件。' },
  { title: '灵活周转资金', desc: '助您在不影响现金流的情况下，快速升级仓库产能。' },
  { title: '24小时初步答复', desc: '高效审批流程，让您的生产计划不被资金耽误。' },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
>
  
  <!-- HERO: THE OPERATIONAL AUTHORITY (Midnight) -->
  <section class="relative min-h-[60vh] flex items-center bg-[#0A0A0A] overflow-hidden pt-20">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0 bg-gradient-to-tr from-[#D4A574]/20 to-transparent"></div>
    </div>

    <div class="container-custom relative z-10 py-20">
      <div class="max-w-4xl">
        <span class="text-[#D4A574] font-display uppercase tracking-[0.4em] text-[10px] font-bold mb-6 block">工业资产专家</span>
        <h1 class="text-7xl md:text-8xl lg:text-9xl font-display leading-[0.85] text-white uppercase mb-8 tracking-tighter">
          叉车<br/>
          <span class="text-[#D4A574]">融资方案</span>
        </h1>
        <p class="text-xl text-[#F5F5F5]/60 max-w-2xl font-light leading-relaxed mb-12">
            我们不只是在融资机器，我们是在提升您的生产力。无论是一个托盘还是一整座仓库的周转，我们的资金随时待命。
        </p>
      </div>
    </div>
  </section>

  <!-- THE MANIFESTO: POWERING INDUSTRY (Daylight) -->
  <section class="py-32 bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
        <div>
          <h2 class="text-6xl font-display uppercase mb-12 leading-none">别让搬运效率<br/><span class="text-[#8B6F47]">限制您的工厂增长</span></h2>
          <p class="text-[#1A140D]/60 text-lg font-light leading-relaxed mb-8">
            在传统的融资视角下，叉车可能只是微不足道的环节。但在永恒信贷眼中，它是您供应链条上最坚实的支点。我们为各种规模的工厂提供最懂行的财务支持。
          </p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
            {features.map(f => (
              <div class="border-l-2 border-[#D4A574] pl-6 py-2">
                <h4 class="text-xl font-display uppercase mb-2">{f.title}</h4>
                <p class="text-[#1A140D]/40 text-sm font-light">{f.desc}</p>
              </div>
            ))}
          </div>
          <a href={COMPANY_INFO.whatsapp.link} class="inline-block bg-[#0A0A0A] text-white font-display uppercase tracking-widest text-sm px-12 py-6 hover:bg-[#8B6F47] transition-all duration-500 font-bold">
            立即咨询工业专家
          </a>
        </div>
        <div class="relative">
          <div class="aspect-[4/5] bg-[#F5F5F5] grayscale overflow-hidden shadow-2xl">
            <img src="/images/equipment/forklift-main.jpg" alt="Industrial Forklift" class="w-full h-full object-cover" />
          </div>
          <div class="absolute -bottom-12 -right-12 bg-[#0A0A0A] p-12 text-white hidden lg:block shadow-2xl">
            <span class="text-5xl font-display block leading-none mb-2 text-[#D4A574]">4,000+</span>
            <span class="text-[10px] uppercase tracking-widest font-black text-white/50">服务全马客户</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CALCULATOR: PRECISE INDUSTRY (Alloy) -->
  <section class="py-32 bg-[#0A0A0A]">
    <div class="container-custom text-center mb-20">
        <h2 class="text-6xl font-display uppercase text-white mb-4">精准<span class="text-[#D4A574]">财务</span>预案</h2>
        <p class="text-white/40 uppercase tracking-[0.3em] text-[10px] font-bold">掌控每一分投入的效率</p>
    </div>
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
        <div class="bg-white/5 p-12 border border-white/10 order-2 lg:order-1">
          <Calculator lang="zh" />
        </div>
        <div class="order-1 lg:order-2">
          <p class="text-white/50 text-lg font-light leading-relaxed mb-12">
            利用我们的计算器，快速获取您的每月负担预估。我们致力于让您的工厂升级变得简单、透明、无忧。
          </p>
          <div class="space-y-6">
            <div class="p-8 border border-white/10 hover:border-[#D4A574] transition-all">
                <h4 class="text-[#D4A574] font-display text-2xl mb-2">二手设备支持</h4>
                <p class="text-white/40 text-sm">即使是 10 年以上的翻新叉车，我们依然提供优厚的贷款利率。</p>
            </div>
            <div class="p-8 border border-white/10 hover:border-[#D4A574] transition-all">
                <h4 class="text-[#D4A574] font-display text-2xl mb-2">快速文件处理</h4>
                <p class="text-white/40 text-sm">化繁为简，我们只需最基础的文件即可开始评估流程。</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA: THE SYNDICATE (Editorial Mixed) -->
  <section class="py-40 bg-white text-center border-t border-black/5">
    <div class="container-custom relative z-10">
      <h2 class="text-7xl md:text-8xl lg:text-9xl font-display leading-[0.85] text-[#0A0A0A] uppercase mb-12 tracking-tighter">
        提升<br/><span class="text-[#8B6F47]">生产动力</span>
      </h2>
      <p class="text-xl text-[#1A140D]/60 mb-16 max-w-2xl mx-auto font-light">
        今天就联系永恒信贷，让您的仓库动起来。
      </p>
      <div class="flex flex-col sm:flex-row gap-6 justify-center">
        <a href={COMPANY_INFO.whatsapp.link} class="bg-[#0A0A0A] text-white font-display uppercase tracking-widest text-sm px-16 py-8 hover:bg-[#8B6F47] transition-all duration-500 font-bold">
          立即通过 WhatsApp 咨询
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  h1, h2, h3, h4 {
    font-family: 'Bebas Neue', var(--font-display);
  }
</style>
