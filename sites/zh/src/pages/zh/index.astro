---
/**
 * Chinese Homepage Hub
 * Revamped with Midnight Luxe design and "Action Taker" voice
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Calculator from '../../components/Calculator.astro';
import ProductCard from '../../components/ProductCard.astro';
import { COMPANY_INFO } from '../../utils/constants';

const lang = 'zh';

// SEO Configuration
const pageTitle = '银行拒绝，我们答应。| 40年大马机器融资专家 | 永恒信贷 (Ing Heng Credit)';
const pageDescription = '我们懂您的机器，更懂您的生意。专业融资重型机械、商用车及二手设备。40年信誉，KPKT执照，助您快速获取营运资金。';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
>
  
  <!-- HERO: THE ULTIMATUM (Midnight) -->
  <section class="relative min-h-screen flex items-center bg-[#0A0A0A] overflow-hidden">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#0A0A0A]"></div>
    </div>

    <div class="container-custom relative z-10 pt-20">
      <div class="max-w-5xl">
        <span class="text-[#D4A574] font-display uppercase tracking-[0.4em] text-[10px] font-bold mb-6 block">大马中小企业首选</span>
        <h1 class="text-7xl md:text-8xl lg:text-9xl font-display leading-[0.85] text-white uppercase mb-8 tracking-tighter">
          银行<span class="text-white/20 italic">拒绝</span><br/>
          我们<span class="text-[#D4A574]">答应</span>
        </h1>
        <p class="text-xl md:text-2xl text-[#F5F5F5]/60 max-w-2xl font-light leading-relaxed mb-12">
          别让银行的繁杂程序拖慢您的生意。我们看重您的商业潜能，而不只是信用分数。40年经验，我们懂您的机器，更懂您的生意。
        </p>
        <div class="flex flex-col sm:flex-row gap-6">
          <a href={COMPANY_INFO.whatsapp.link} class="bg-[#D4A574] text-[#0A0A0A] font-display uppercase tracking-widest text-sm px-12 py-6 hover:bg-white transition-all duration-500 text-center font-bold">
            立即通过 WhatsApp 咨询
          </a>
          <div class="flex items-center gap-4 px-6 text-[#F5F5F5]/40 text-[10px] uppercase tracking-[0.2em]">
            <span>✓ 40年信誉</span>
            <span class="w-1 h-1 bg-[#D4A574] rounded-full"></span>
            <span>✓ KPKT 合法执照</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 animate-bounce opacity-20">
        <div class="w-[1px] h-20 bg-white"></div>
    </div>
  </section>

  <!-- THE POWER OF YES: THE NARRATIVE (Daylight) -->
  <section class="py-32 bg-white relative overflow-hidden">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-24 items-center">
        <div>
          <h2 class="text-6xl font-display uppercase leading-none text-[#0A0A0A] mb-12">为什么我们敢于<br/><span class="text-[#8B6F47]">说“好”？</span></h2>
          <div class="space-y-12">
            <div class="group">
              <h3 class="text-2xl font-display uppercase mb-4 text-[#0A0A0A] group-hover:text-[#8B6F47] transition-colors">我们懂机器的价值</h3>
              <p class="text-[#1A140D]/60 leading-relaxed font-light">银行只看报表，我们看机器。无论是20年还是50年的机器，只要能为您赚钱，就是好资产。我们亲自评估机器，给您最合理的贷款额度。</p>
            </div>
            <div class="group">
              <h3 class="text-2xl font-display uppercase mb-4 text-[#0A0A0A] group-hover:text-[#8B6F47] transition-colors">拒绝中介，直接交易</h3>
              <p class="text-[#1A140D]/60 leading-relaxed font-light">我们不是帮人投资的中介，我们是用自己的钱为您投资。这代表我们可以直接拍板，省去漫长的等待，把现金直接送到您手中。</p>
            </div>
          </div>
        </div>
        <div class="relative group">
          <div class="aspect-[4/5] bg-[#F5F5F5] overflow-hidden grayscale group-hover:grayscale-0 transition-all duration-1000 border border-black/5">
             <img src="/images/hero-heavy-machinery.jpg" alt="Heavy Machinery" class="w-full h-full object-cover scale-110 group-hover:scale-100 transition-transform duration-1000" />
          </div>
          <div class="absolute -bottom-12 -right-12 bg-[#0A0A0A] p-12 text-white hidden lg:block shadow-2xl">
            <span class="text-6xl font-display block mb-2 text-[#D4A574]">1985</span>
            <span class="text-[10px] uppercase tracking-[0.4em] font-bold">深耕大马 40 载</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CALCULATOR: THE PRECISION (Alloy) -->
  <section class="py-32 bg-[#0A0A0A]">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-24">
        <div class="flex flex-col justify-center">
          <span class="text-[#D4A574] font-display uppercase tracking-[0.4em] text-[10px] font-bold mb-6 block">财务透明</span>
          <h2 class="text-6xl font-display uppercase text-white mb-8">精准<span class="text-white/20 italic">计算</span><br/>掌控未来</h2>
          <p class="text-white/50 text-lg font-light leading-relaxed mb-12 max-w-md">
            我们的算盘不打诳语。利用下方的计算器，您可以快速预估每月的供款。没有隐藏收费，只有最实在的财务方案。
          </p>
        </div>
        <div>
          <Calculator lang="zh" />
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES: THE ECOSYSTEM (Editorial) -->
  <section class="py-32 bg-[#F5F5F5]">
    <div class="container-custom">
      <div class="text-center mb-24">
        <h2 class="text-6xl font-display uppercase text-[#0A0A0A] mb-4">全方位<span class="text-[#8B6F47]">融资</span>方案</h2>
        <p class="text-[#1A140D]/40 uppercase tracking-[0.3em] text-[10px] font-bold">针对不同商业需求定制</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <ProductCard 
          title="重型机械融资" 
          description="挖泥机、推土机、起重机。无论新旧，我们都提供极具竞争力的贷款利率。"
          icon="🏗️"
          link="/zh/equipment"
          lang="zh"
        />
        <ProductCard 
          title="商用车贷款" 
          description="罗里、拖车、客货车。助您建立强大的运输车队，生意跑遍全马。"
          icon="🚛"
          link="/zh/equipment#trucks"
          lang="zh"
        />
        <ProductCard 
          title="中小企业贷款" 
          description="快速周转资金，无需复杂的担保。我们挺您的生意，助您渡过难关。"
          icon="💼"
          link="/zh/services"
          lang="zh"
        />
      </div>
    </div>
  </section>

  <!-- SYNDICATE: THE CALL TO ACTION (Midnight) -->
  <section class="py-40 bg-[#0A0A0A] relative overflow-hidden text-center">
    <div class="container-custom relative z-10">
      <h2 class="text-7xl md:text-8xl lg:text-9xl font-display leading-[0.85] text-white uppercase mb-12 tracking-tighter">
        您的生意<br/><span class="text-[#D4A574]">不仅如此</span>
      </h2>
      <p class="text-xl text-[#F5F5F5]/60 mb-16 max-w-2xl mx-auto font-light">
        今天就联系我们的专业顾问。与其听银行说“不”，不如听我们为您规划未来。
      </p>
      <div class="flex flex-col sm:flex-row gap-6 justify-center">
        <a href={COMPANY_INFO.whatsapp.link} class="bg-[#D4A574] text-[#0A0A0A] font-display uppercase tracking-widest text-sm px-16 py-8 hover:bg-white transition-all duration-500 font-bold">
          立即咨询
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  h1, h2, h3, h4 {
    font-family: 'Bebas Neue', var(--font-display);
  }
</style>
