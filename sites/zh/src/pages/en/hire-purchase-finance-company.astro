---
/**
 * Hire Purchase Page - Hobby Financing
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQItem from '../../components/FAQItem.astro';
import { generateFAQSchema, encodeJSONLD } from '../../utils/schema';

const lang = 'en';

const pageTitle = 'Hire Purchase Financing | Motorcycles, Boats, Sports Cars | Malaysia';
const pageDescription = 'Hire purchase financing for motorcycles, superbikes, boats, and sports cars in Malaysia. 0% deposit available. Build ownership with monthly payments. Since 1985.';

const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Hire Purchase', url: '/en/hire-purchase-finance-company' },
];

const benefits = [
  { icon: '💰', title: '0% Deposit Available', description: 'Finance up to 100% for qualified applicants. No large upfront payment needed.' },
  { icon: '📈', title: 'Build Ownership', description: 'Every payment builds your equity. At the end, you own the vehicle outright.' },
  { icon: '📋', title: 'Fixed Payments', description: 'Know exactly what you pay each month. No surprises, easy budgeting.' },
  { icon: '🔄', title: 'Flexible Terms', description: 'Choose terms from 1-10 years depending on vehicle type. Longer terms = lower payments.' },
  { icon: '✅', title: 'New & Used', description: 'Finance new or pre-owned motorcycles, boats, and cars up to 10-15 years old.' },
  { icon: '🏆', title: 'Since 1985', description: '40 years of trusted hire purchase financing in Malaysia.' },
];

const faqs = [
  {
    question: 'What is hire purchase financing?',
    answer: 'Hire purchase (HP) is a financing method where you pay monthly installments to own a vehicle. You use the motorcycle, boat, or car while paying. Once all payments are complete, full ownership transfers to you.'
  },
  {
    question: 'How is hire purchase different from a loan?',
    answer: 'In hire purchase, the finance company technically owns the vehicle until final payment. With a loan, you own it from day one but it\'s used as collateral. Practically, both allow you to use the vehicle while paying.'
  },
  {
    question: 'What vehicles can I finance with hire purchase?',
    answer: 'We offer hire purchase for motorcycles (all brands), superbikes, boats and marine equipment (fishing boats, speedboats, yachts, jet skis), and sports cars (Porsche, Ferrari, Lamborghini, BMW M, etc.).'
  },
  {
    question: 'What happens if I miss a payment?',
    answer: 'Contact us immediately if you anticipate payment difficulty. We can discuss restructuring options. Consistent default may result in vehicle repossession as per agreement terms.'
  },
  {
    question: 'Can I settle early?',
    answer: 'Yes! Early settlement is allowed with no penalty. Pay off your hire purchase anytime and save on future interest charges.'
  },
];

const faqSchema = generateFAQSchema(faqs);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
>
  <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />
  
  <Breadcrumbs items={breadcrumbs} lang={lang} />

  <!-- Hero -->
  <section class="py-20 bg-gradient-to-br from-primary to-secondary text-white">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">Hire Purchase Financing</h1>
      <p class="text-xl opacity-90 max-w-3xl mx-auto">
        Own your dream motorcycle, boat, or sports car through affordable monthly payments. 0% deposit available. Build equity with every payment.
      </p>
      <div class="mt-8">
        <a href="https://wa.me/60175700889?text=Hi%20I%27m%20interested%20in%20hire%20purchase%20financing" 
           class="bg-yellow-400 text-navy-900 px-8 py-4 rounded-lg font-bold hover:bg-yellow-300 transition inline-block">
          Get Started
        </a>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">How Hire Purchase Works</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-5 gap-6 max-w-5xl mx-auto">
        <div class="text-center">
          <div class="w-16 h-16 bg-blue-800 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">1</div>
          <h3 class="font-bold mb-2">Choose Vehicle</h3>
          <p class="text-gray-600 text-sm">Select your motorcycle, boat, or car</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-blue-800 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">2</div>
          <h3 class="font-bold mb-2">Apply</h3>
          <p class="text-gray-600 text-sm">Submit documents for approval</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-blue-800 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">3</div>
          <h3 class="font-bold mb-2">Get Approved</h3>
          <p class="text-gray-600 text-sm">Receive financing approval</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-blue-800 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">4</div>
          <h3 class="font-bold mb-2">Pay Monthly</h3>
          <p class="text-gray-600 text-sm">Make fixed monthly payments</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-blue-800 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">5</div>
          <h3 class="font-bold mb-2">Own It</h3>
          <p class="text-gray-600 text-sm">After final payment, it's yours!</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Benefits of Hire Purchase</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {benefits.map(benefit => (
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <div class="text-4xl mb-4">{benefit.icon}</div>
            <h3 class="text-xl font-bold mb-2">{benefit.title}</h3>
            <p class="text-gray-600">{benefit.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What We Finance -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Vehicles We Finance</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <a href="/en/equipment/motorcycle" class="group">
          <div class="bg-gradient-to-br from-primary to-secondary text-white rounded-xl p-8 text-center hover:shadow-xl transition-shadow">
            <div class="text-5xl mb-4">🏍️</div>
            <h3 class="text-xl font-bold mb-2">Motorcycles & Superbikes</h3>
            <p class="opacity-90 text-sm">All brands, new & used</p>
          </div>
        </a>
        <a href="/en/equipment/boat" class="group">
          <div class="bg-gradient-to-br from-primary to-secondary text-white rounded-xl p-8 text-center hover:shadow-xl transition-shadow">
            <div class="text-5xl mb-4">⛵</div>
            <h3 class="text-xl font-bold mb-2">Boats & Marine</h3>
            <p class="opacity-90 text-sm">Fishing boats, yachts, jet skis</p>
          </div>
        </a>
        <a href="/en/equipment/sports-car" class="group">
          <div class="bg-gradient-to-br from-primary to-secondary text-white rounded-xl p-8 text-center hover:shadow-xl transition-shadow">
            <div class="text-5xl mb-4">🚗</div>
            <h3 class="text-xl font-bold mb-2">Sports Cars</h3>
            <p class="opacity-90 text-sm">Premium & exotic brands</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Hire Purchase FAQ</h2>
      
      <div class="max-w-3xl mx-auto space-y-4">
        {faqs.map(faq => (
          <div class="border border-gray-200 rounded-lg overflow-hidden bg-white">
            <details class="group">
              <summary class="flex justify-between items-center p-6 cursor-pointer hover:bg-gray-50 transition-colors">
                <h3 class="font-bold pr-4">{faq.question}</h3>
                <span class="text-xl text-primary group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <div class="px-6 pb-6">
                <p class="text-gray-700">{faq.answer}</p>
              </div>
            </details>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-blue-800 text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to Start?</h2>
      <p class="text-xl mb-8 opacity-90">Get a free hire purchase consultation today.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://wa.me/60175700889" 
           class="bg-yellow-400 text-navy-900 px-8 py-4 rounded-lg font-bold hover:bg-yellow-300 transition">
          WhatsApp Us
        </a>
        <a href="/en/contact" 
           class="border-2 border-white px-8 py-4 rounded-lg font-bold hover:bg-white/10 transition">
          Contact Form
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
