---
/**
 * Contact Page - Hobby Financing
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ContactForm from '../../components/ContactForm.astro';

const lang = 'en';

const pageTitle = 'Contact Us | Hobby Financing Malaysia';
const pageDescription = 'Get in touch for motorcycle, superbike, boat, or sports car financing. WhatsApp, call, or visit our office in Klang. Free consultation, no obligation.';

const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Contact Us', url: '/en/contact' },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
>
  <Breadcrumbs items={breadcrumbs} lang={lang} />

  <!-- Hero -->
  <section class="py-16 bg-gradient-to-br from-primary to-secondary text-white">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Contact Us</h1>
      <p class="text-xl opacity-90">Ready to finance your dream? We're here to help.</p>
    </div>
  </section>

  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
        
        <!-- Contact Info -->
        <div>
          <h2 class="text-2xl font-bold mb-8">Get In Touch</h2>
          
          <div class="space-y-6">
            <!-- WhatsApp -->
            <div class="flex items-start gap-4">
              <div class="text-3xl">💬</div>
              <div>
                <h3 class="font-bold text-lg">WhatsApp (Fastest)</h3>
                <a href="https://wa.me/60175700889" class="text-primary hover:underline text-lg">
                  +60 17-570 0889
                </a>
                <p class="text-gray-600 text-sm mt-1">Click to chat instantly</p>
              </div>
            </div>
            
            <!-- Phone -->
            <div class="flex items-start gap-4">
              <div class="text-3xl">📞</div>
              <div>
                <h3 class="font-bold text-lg">Phone</h3>
                <a href="tel:+60175700889" class="text-primary hover:underline text-lg">
                  017-570 0889
                </a>
                <p class="text-gray-600 text-sm mt-1">Mon-Fri 9AM-6PM, Sat 9AM-1PM</p>
              </div>
            </div>
            
            <!-- Office -->
            <div class="flex items-start gap-4">
              <div class="text-3xl">📍</div>
              <div>
                <h3 class="font-bold text-lg">Office</h3>
                <p class="text-gray-700">
                  Klang, Selangor<br/>
                  Malaysia
                </p>
                <p class="text-gray-600 text-sm mt-1">By appointment</p>
              </div>
            </div>
          </div>

          <!-- What We Finance -->
          <div class="mt-12 p-6 bg-gray-50 rounded-lg">
            <h3 class="font-bold text-lg mb-4">We Finance:</h3>
            <ul class="space-y-2">
              <li class="flex items-center gap-2">
                <span>🏍️</span>
                <span>Motorcycles & Superbikes</span>
              </li>
              <li class="flex items-center gap-2">
                <span>⛵</span>
                <span>Boats & Marine Equipment</span>
              </li>
              <li class="flex items-center gap-2">
                <span>🚗</span>
                <span>Sports Cars & Exotics</span>
              </li>
            </ul>
          </div>
        </div>

        <!-- Contact Form -->
        <div>
          <h2 class="text-2xl font-bold mb-8">Send Us a Message</h2>
          <div class="bg-white border border-gray-200 rounded-lg p-6 shadow-sm">
            <ContactForm lang={lang} />
          </div>
        </div>
        
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 bg-primary text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold mb-4">Prefer Instant Response?</h2>
      <p class="mb-6 opacity-90">WhatsApp is the fastest way to reach us.</p>
      <a href="https://wa.me/60175700889?text=Hi%20I%27m%20interested%20in%20hobby%20financing" 
         class="bg-yellow-400 text-navy-900 px-8 py-4 rounded-lg font-bold hover:bg-yellow-300 transition inline-block">
        WhatsApp Us Now
      </a>
    </div>
  </section>

</BaseLayout>
