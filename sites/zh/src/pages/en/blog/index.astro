---
/**
 * Blog Index Page - Hobby Financing
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';

const lang = 'en';

const pageTitle = 'Hobby Financing Blog | Tips & Guides';
const pageDescription = 'Expert guides on motorcycle financing, boat loans, and sports car financing in Malaysia. Tips, comparisons, and industry insights.';

const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Blog', url: '/en/blog' },
];

// Placeholder - will be populated with actual blog posts
const featuredPosts = [
  {
    title: 'How to Finance Your First Superbike in Malaysia',
    excerpt: 'A complete guide to financing high-performance motorcycles, from documentation to approval.',
    url: '/en/equipment/superbike',
    category: 'Motorcycles'
  },
  {
    title: 'Boat Financing: What You Need to Know',
    excerpt: 'Understanding marine loans, insurance requirements, and financing terms for boats in Malaysia.',
    url: '/en/equipment/boat',
    category: 'Marine'
  },
  {
    title: 'Sports Car Financing Options Compared',
    excerpt: 'Bank loans vs alternative financing for exotic and premium sports cars.',
    url: '/en/equipment/sports-car',
    category: 'Sports Cars'
  },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
>
  <Breadcrumbs items={breadcrumbs} lang={lang} />

  <section class="py-16">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl font-bold text-center mb-4">Hobby Financing Blog</h1>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
        Expert guides and tips on financing motorcycles, boats, and sports cars in Malaysia.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        {featuredPosts.map(post => (
          <a href={post.url} class="group">
            <div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden hover:shadow-xl transition-shadow">
              <div class="h-40 bg-gradient-to-br from-primary to-secondary flex items-center justify-center">
                <span class="text-white text-sm font-semibold bg-white/20 px-3 py-1 rounded-full">{post.category}</span>
              </div>
              <div class="p-6">
                <h2 class="text-xl font-bold mb-3 group-hover:text-primary transition-colors">{post.title}</h2>
                <p class="text-gray-600 text-sm">{post.excerpt}</p>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center">
        <p class="text-gray-500">More articles coming soon...</p>
        <a href="/en/contact" class="text-primary font-semibold hover:underline mt-4 inline-block">
          Have a question? Contact us →
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 " style="background: linear-gradient(135deg, #2D1810, #4C3729); color: white;">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to Finance Your Passion?</h2>
      <p class="text-xl mb-8" style="color: white; opacity: 0.9;">
        Get a free consultation today.
      </p>
      <a href="https://wa.me/60175700889" 
         class="bg-yellow-400 text-navy-900 px-8 py-4 rounded-lg font-bold hover:bg-yellow-300 transition inline-block">
        WhatsApp Us Now
      </a>
    </div>
  </section>

</BaseLayout>
