---
/**
 * Calculator Page - Hobby Financing
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Calculator from '../../components/Calculator.astro';

const lang = 'en';

const pageTitle = 'Loan Calculator | Motorcycle, Boat, Sports Car Financing';
const pageDescription = 'Calculate your monthly payment for motorcycle, boat, or sports car financing. Estimate your loan repayment with our easy calculator.';

const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Calculator', url: '/en/calculator' },
];

const examples = [
  { name: 'Honda CB650R Motorcycle', price: 45000, term: 60 },
  { name: 'Ducati Panigale V4 Superbike', price: 180000, term: 72 },
  { name: 'Yamaha WaveRunner Jet Ski', price: 65000, term: 60 },
  { name: 'Fishing Boat with Engine', price: 120000, term: 84 },
  { name: 'Porsche Cayman 718', price: 450000, term: 84 },
  { name: 'BMW M4 Competition', price: 650000, term: 84 },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
>
  <Breadcrumbs items={breadcrumbs} lang={lang} />

  <!-- Hero -->
  <section class="py-16 bg-gradient-to-br from-primary to-secondary text-white">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Loan Calculator</h1>
      <p class="text-xl  " style="color: white; opacity: 0.9;">See how affordable your dream can be</p>
    </div>
  </section>

  <!-- Calculator Section -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="max-w-2xl mx-auto">
        <Calculator 
          lang={lang}
          defaultAmount={50000}
          minAmount={5000}
          maxAmount={5000000}
          defaultTerm={60}
          defaultRate={10}
        />
      </div>
    </div>
  </section>

  <!-- Example Calculations -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-2xl font-bold text-center mb-8">Example Financing</h2>
      <p class="text-center text-gray-600 mb-8">Here's what financing could look like for popular vehicles:</p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {examples.map(example => (
          <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-6">
            <h3 class="font-bold text-lg mb-2">{example.name}</h3>
            <p class="text-2xl font-bold text-primary mb-1">
              RM {example.price.toLocaleString()}
            </p>
            <p class="text-gray-600 text-sm mb-4">{example.term} months term</p>
            <p class="text-sm text-gray-500">
              Estimated monthly: ~RM {Math.round((example.price * 1.5) / example.term).toLocaleString()}*
            </p>
          </div>
        ))}
      </div>
      
      <p class="text-center text-gray-500 text-sm mt-8">
        *Estimates only. Actual payments depend on interest rate, down payment, and terms approved.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 " style="background: linear-gradient(135deg, #2D1810, #4C3729); color: white;">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold mb-4">Ready for an Accurate Quote?</h2>
      <p class="mb-8  " style="color: white; opacity: 0.9;">Contact us for a personalized financing proposal.</p>
      <a href="https://wa.me/60175700889?text=Hi%20I%27d%20like%20a%20financing%20quote" 
         class="bg-yellow-400 text-navy-900 px-8 py-4 rounded-lg font-bold hover:bg-yellow-300 transition inline-block">
        Get Your Quote
      </a>
    </div>
  </section>

</BaseLayout>
