---
/**
 * About Page - Hobby Financing
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const lang = 'en';

const pageTitle = 'About Us | Hobby Financing Malaysia | Since 1985';
const pageDescription = 'Learn about Malaysia\'s trusted hobby financing company. Financing motorcycles, superbikes, boats, and sports cars since 1985. 4,000+ happy customers.';

const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'About Us', url: '/en/about' },
];

const milestones = [
  { year: '1985', title: 'Founded', description: 'Started as a small financing company in Klang, Selangor.' },
  { year: '1995', title: '1,000 Customers', description: 'Reached our first thousand happy customers milestone.' },
  { year: '2005', title: 'Expanded Services', description: 'Expanded into motorcycle and recreational vehicle financing.' },
  { year: '2015', title: '3,000+ Customers', description: 'Continued growth with marine and sports car financing.' },
  { year: '2025', title: '4,000+ Customers', description: '40 years of trusted financing, now specializing in hobby and lifestyle assets.' },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
>
  <Breadcrumbs items={breadcrumbs} lang={lang} />

  <!-- Hero Section -->
  <section class="py-20 bg-gradient-to-br from-primary to-secondary text-white">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">About Us</h1>
      <p class="text-xl opacity-90 max-w-3xl mx-auto">
        Malaysia's trusted hobby financing company since 1985. We help enthusiasts own their dream motorcycles, superbikes, boats, and sports cars.
      </p>
    </div>
  </section>

  <!-- Our Story -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-8">Our Story</h2>
        
        <div class="prose prose-lg max-w-none">
          <p>
            For 40 years, we've been helping Malaysians finance their passions. What started as a small financing company in Klang has grown into a trusted name for hobby and lifestyle asset financing.
          </p>
          
          <p>
            We understand that motorcycles, boats, and sports cars aren't just vehicles — they're dreams, passions, and a way of life. That's why we've dedicated ourselves to making these dreams accessible with flexible financing solutions.
          </p>
          
          <p>
            Today, we specialize in financing:
          </p>
          
          <ul>
            <li><strong>Motorcycles & Superbikes</strong> — From daily riders to high-performance machines</li>
            <li><strong>Boats & Marine Equipment</strong> — Fishing boats, speedboats, yachts, jet skis</li>
            <li><strong>Sports Cars</strong> — Porsche, Ferrari, Lamborghini, and premium brands</li>
          </ul>
          
          <p>
            With over 4,000 happy customers and counting, we're proud to be Malaysia's choice for hobby financing.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Milestones -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">40 Years of Trust</h2>
      
      <div class="max-w-4xl mx-auto">
        <div class="space-y-8">
          {milestones.map(milestone => (
            <div class="flex items-start gap-6">
              <div class="bg-primary text-white font-bold px-4 py-2 rounded-lg min-w-[80px] text-center">
                {milestone.year}
              </div>
              <div>
                <h3 class="font-bold text-lg">{milestone.title}</h3>
                <p class="text-gray-600">{milestone.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Why Choose Us?</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        <div class="text-center p-6">
          <div class="text-5xl mb-4">🏆</div>
          <h3 class="text-xl font-bold mb-2">40 Years Experience</h3>
          <p class="text-gray-600">Trusted since 1985. KPKT licensed and regulated.</p>
        </div>
        <div class="text-center p-6">
          <div class="text-5xl mb-4">❤️</div>
          <h3 class="text-xl font-bold mb-2">Passion Specialists</h3>
          <p class="text-gray-600">We understand motorcycles, boats, and cars — not just numbers.</p>
        </div>
        <div class="text-center p-6">
          <div class="text-5xl mb-4">🤝</div>
          <h3 class="text-xl font-bold mb-2">4,000+ Customers</h3>
          <p class="text-gray-600">Thousands of happy enthusiasts have trusted us with their dreams.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA - Dark Khaki with White Text -->
  <section class="py-16 cta-dark">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to Finance Your Passion?</h2>
      <p class="text-xl mb-8 opacity-90">Get a free consultation today.</p>
      <a href="https://wa.me/60175700889" 
         class="bg-yellow-400 text-navy-900 px-8 py-4 rounded-lg font-bold hover:bg-yellow-300 transition inline-block">
        WhatsApp Us Now
      </a>
    </div>
  </section>

</BaseLayout>
