      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://wa.me/60175700889?text=Hi%20I%27m%20interested%20in%20motorcycle%20financing" 
           class="bg-yellow-400 text-navy-900 px-8 py-4 rounded-lg font-bold text-lg hover:bg-yellow-300 transition">
          WhatsApp Us Now
        </a>
        <a href="/en/contact" 
           class="border-2 border-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-white/10 transition" style="color: white;">
          Contact Form
        </a>
      </div>
      <p class="mt-6 text-white/75">
        Or call us: <a href="tel:+60175700889" class="underline">017-570 0889</a>
      </p>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="text-center mb-8">
        <h2 class="text-3xl font-bold mb-4">Apply for Motorcycle Financing</h2>
        <p class="text-gray-600">Fill out the form and we'll contact you within 24 hours</p>
