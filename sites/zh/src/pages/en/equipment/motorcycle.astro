    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">How to Finance Your Motorcycle</h2>
        <p class="text-gray-600">Simple 5-step process to ride your dream bike</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-5 gap-6 max-w-6xl mx-auto">
        {steps.map(step => (
          <div class="text-center">
            <div class="w-16 h-16 " style="background: linear-gradient(135deg, #2D1810, #4C3729); color: white; rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">
              {step.stepNumber}
            </div>
            <h3 class="font-bold mb-2">{step.title}</h3>
            <p class="text-gray-600 text-sm">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Calculator Section -->
  <section class="py-16" id="calculator">
    <div class="container mx-auto px-4">
      <div class="text-center mb-8">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Calculate Your Monthly Payment</h2>
        <p class="text-gray-600">See how affordable your dream motorcycle can be</p>
      </div>
      <div class="max-w-2xl mx-auto">
        <Calculator 
          lang={lang}
          defaultAmount={30000}
          minAmount={5000}
          maxAmount={500000}
          defaultTerm={60}
          defaultRate={10}
        />
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">What Riders Say</h2>
        <p class="text-gray-600">Join thousands of satisfied riders</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {testimonials.map(testimonial => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <div class="flex mb-4">
              {[...Array(testimonial.rating)].map(() => (
                <span class="text-yellow-400">★</span>
              ))}
            </div>
            <p class="text-gray-600 mb-4 italic">"{testimonial.testimonial}"</p>
            <div>
              <p class="font-bold">{testimonial.name}</p>
              <p class="text-sm text-gray-500">{testimonial.company}</p>
              <p class="text-sm text-gray-500">{testimonial.location}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
