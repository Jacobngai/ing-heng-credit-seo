---
/**
 * Motorcycle Financing Landing Page - English
 * Target: Motorcycle enthusiasts, collectors, daily riders
 * Keywords: motorcycle financing Malaysia, motorcycle loan, bike financing
 * Cultural Focus: Passion-driven, lifestyle-focused messaging
 * Word Count: 2,500+ words
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import StepCard from '../../../components/StepCard.astro';
import FAQItem from '../../../components/FAQItem.astro';
import ContactForm from '../../../components/ContactForm.astro';
import Calculator from '../../../components/Calculator.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import RelatedEquipment from '../../../components/RelatedEquipment.astro';
import { generateProductSchema, generateFAQSchema, encodeJSONLD } from '../../../utils/schema';

import { SITE_CONFIG } from '../../../utils/constants';
const lang = 'en';

// SEO Data
const pageTitle = 'Motorcycle Financing Malaysia | Bike Loan 0% Deposit | Since 1985';
const pageDescription = 'Finance your dream motorcycle with 0% deposit. New & used bikes accepted. Yamaha, Honda, Kawasaki, BMW, Ducati. Streamlined processing, flexible terms up to 7 years. 4,000+ riders funded.';
const keywords = ['motorcycle financing Malaysia', 'motorcycle loan Malaysia', 'bike financing', 'superbike loan', 'used motorcycle financing', 'Yamaha financing', 'Honda bike loan'];

// Breadcrumbs
const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Equipment', url: '/en/equipment' },
  { label: 'Motorcycle Financing', url: '/en/equipment/motorcycle' },
];

// Benefits
const benefits = [
  { icon: 'clock', title: 'Streamlined Processing', description: 'Get approved quickly. Our experienced team understands motorcycle financing and processes applications efficiently.' },
  { icon: 'percentage', title: '0% Deposit Available', description: 'Finance up to 100% of your motorcycle value. Preserve your cash for gear, modifications, and riding adventures.' },
  { icon: 'shield', title: 'New & Used Accepted', description: 'Finance new or used motorcycles. We accept bikes up to 10 years old in good condition.' },
  { icon: 'users', title: 'All Brands Welcome', description: 'Yamaha, Honda, Kawasaki, Suzuki, BMW, Ducati, KTM, Triumph, Harley-Davidson - we finance them all.' },
  { icon: 'document', title: 'Simple Documentation', description: 'IC, proof of income, and bank statements. No complex paperwork. Salaried or self-employed welcome.' },
  { icon: 'shield', title: 'Flexible Terms', description: 'Choose repayment terms from 1-7 years. Monthly payments that fit your budget. No early settlement penalty.' },
];

// Process Steps
const steps = [
  { stepNumber: 1, icon: 'contact', title: 'Contact Us via WhatsApp', description: 'Share your dream bike details. Our motorcycle financing specialists will provide a quick assessment.' },
  { stepNumber: 2, icon: 'document', title: 'Submit Documents', description: 'IC, 3-6 months bank statements, proof of income. Simple and straightforward process.' },
  { stepNumber: 3, icon: 'check', title: 'Get Approved', description: 'Receive your approval decision. We evaluate your application fairly and efficiently.' },
  { stepNumber: 4, icon: 'clipboard', title: 'Sign Agreement', description: 'Review terms, sign the agreement. Transparent pricing with no hidden fees.' },
  { stepNumber: 5, icon: 'truck', title: 'Ride Your Dream Bike', description: 'Collect your motorcycle and hit the road. Your riding journey begins!' },
];

// Motorcycle Types
const equipmentTypes = [
  {
    name: 'Sport Bikes (150cc-400cc)',
    description: 'Entry-level sport bikes perfect for daily commuting and weekend rides. Yamaha R15, Honda CBR150R, Kawasaki Ninja 250.',
    applications: 'Daily commute, weekend rides, learning sport riding'
  },
  {
    name: 'Superbikes (600cc+)',
    description: 'High-performance machines for serious riders. Yamaha R6, Honda CBR600RR, Kawasaki ZX-6R, BMW S1000RR, Ducati Panigale.',
    applications: 'Track days, spirited riding, collector pieces'
  },
  {
    name: 'Cruisers',
    description: 'Comfortable touring machines for long-distance riding. Harley-Davidson, Indian, Honda Rebel, Kawasaki Vulcan.',
    applications: 'Highway touring, relaxed cruising, club rides'
  },
  {
    name: 'Adventure Bikes',
    description: 'Versatile dual-sport machines for on and off-road adventures. BMW GS, KTM Adventure, Honda Africa Twin.',
    applications: 'Long-distance touring, off-road exploration, all-terrain riding'
  },
  {
    name: 'Naked Bikes',
    description: 'Streetfighter style with upright ergonomics. Yamaha MT series, Kawasaki Z series, KTM Duke, Ducati Monster.',
    applications: 'Urban commuting, spirited street riding, versatile daily use'
  },
  {
    name: 'Scooters & Mopeds',
    description: 'Practical urban transportation. Yamaha NMax, Honda PCX, Vespa, Piaggio. Automatic transmission for easy riding.',
    applications: 'City commuting, errands, fuel-efficient transport'
  },
];

// Accepted Brands
const acceptedBrands = ['Yamaha', 'Honda', 'Kawasaki', 'Suzuki', 'BMW Motorrad', 'Ducati', 'KTM', 'Triumph', 'Harley-Davidson', 'Indian', 'Aprilia', 'Vespa', 'Benelli', 'CFMoto', 'Royal Enfield'];

// FAQs
const faqs = [
  {
    question: 'What is the minimum down payment for motorcycle financing?',
    answer: 'We offer 0% deposit financing for qualified applicants. This means you can ride your dream bike without any upfront payment. Terms and conditions apply based on your credit profile and the motorcycle value.'
  },
  {
    question: 'Can I finance a used motorcycle?',
    answer: 'Yes! We finance both new and used motorcycles. Used bikes up to 10 years old in good running condition are accepted. The bike will be inspected to ensure it meets our financing criteria.'
  },
  {
    question: 'What documents do I need to apply?',
    answer: 'Basic documents include: IC (front and back), proof of income (payslips or business documents), 3-6 months bank statements, and the motorcycle quotation or details. Self-employed applicants welcome.'
  },
  {
    question: 'How long are the repayment terms?',
    answer: 'We offer flexible terms from 12 months to 84 months (7 years). Longer terms mean lower monthly payments. You can choose what fits your budget best.'
  },
  {
    question: 'Do you finance imported or grey market bikes?',
    answer: 'Yes, we can finance AP (Approved Permit) motorcycles and parallel imports. The bike must have valid registration and road tax. Additional documentation may be required.'
  },
  {
    question: 'Can I settle my loan early?',
    answer: 'Yes! There is no early settlement penalty. You can pay off your loan anytime and save on interest. We encourage financial flexibility.'
  },
  {
    question: 'What if I have a poor credit history?',
    answer: 'We evaluate applications holistically. While credit history matters, we also consider your current income, employment stability, and overall financial situation. Many riders with past credit issues have been approved.'
  },
  {
    question: 'Do you finance motorcycle modifications?',
    answer: 'The primary loan covers the motorcycle purchase. Major modifications that significantly increase the bike value may be considered on a case-by-case basis. Discuss your plans with our team.'
  },
];

// Schema
const productSchema = generateProductSchema({
  name: 'Motorcycle Financing Malaysia',
  description: pageDescription,
  brand: 'Ing Heng Credit',
  category: 'Financial Services > Vehicle Financing > Motorcycle Loans'
});

const faqSchema = generateFAQSchema(faqs);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  keywords={keywords}
  lang={lang}
>
  <script type="application/ld+json" set:html={encodeJSONLD(productSchema)} />
  <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />

  <!-- Breadcrumbs -->
  <Breadcrumbs items={breadcrumbs} lang={lang} />

  <!-- Hero Section -->
  <Hero
    title="Motorcycle Financing Malaysia"
    subtitle="Finance your dream bike with 0% deposit. New & used motorcycles accepted. Yamaha, Honda, Kawasaki, BMW, Ducati - all brands welcome. Flexible terms up to 7 years."
    ctaText="Apply Now via WhatsApp"
    ctaLink="https://wa.me/60175700889?text=Hi%20I%27m%20interested%20in%20motorcycle%20financing"
    ctaSecondaryText="Calculate Payments"
    ctaSecondaryLink="#calculator"
    lang={lang}
    trustSignals={['Since 1985', '4,000+ Funded', '0% Deposit Available']}
  />

  <!-- Benefits Section -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Why Finance Your Motorcycle With Us?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {benefits.map(benefit => (
          <BenefitCard {...benefit} />
        ))}
      </div>
    </div>
  </section>

  <!-- Motorcycle Types Section -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-4">Motorcycles We Finance</h2>
      <p class="text-center text-gray-600 mb-12 max-w-3xl mx-auto">
        From daily commuters to high-performance superbikes, we finance all types of motorcycles. 
        New or used, local or imported - if it has two wheels and an engine, we can help you own it.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {equipmentTypes.map(type => (
          <div class="bg-white p-6 rounded-lg shadow-md border border-gray-100">
            <h3 class="text-xl font-bold text-primary mb-3">{type.name}</h3>
            <p class="text-gray-600 mb-3">{type.description}</p>
            <p class="text-sm text-gray-500"><strong>Popular for:</strong> {type.applications}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Accepted Brands -->
  <section class="py-12 bg-primary text-white">
    <div class="container mx-auto px-4">
      <h2 class="text-2xl font-bold text-center mb-8">All Major Brands Accepted</h2>
      <div class="flex flex-wrap justify-center gap-4">
        {acceptedBrands.map(brand => (
          <span class="bg-white/20 px-4 py-2 rounded-full text-sm">{brand}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Process Steps -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">How to Get Your Motorcycle Financed</h2>
      <div class="grid grid-cols-1 md:grid-cols-5 gap-6">
        {steps.map(step => (
          <StepCard {...step} />
        ))}
      </div>
    </div>
  </section>

  <!-- Calculator Section -->
  <section class="py-16" id="calculator">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-4">Calculate Your Monthly Payment</h2>
      <p class="text-center text-gray-600 mb-8">
        See how affordable your dream motorcycle can be. Adjust the values to match your situation.
      </p>
      <Calculator 
        lang={lang}
        defaultAmount={30000}
        minAmount={5000}
        maxAmount={500000}
        defaultTerm={60}
        defaultRate={8}
      />
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Frequently Asked Questions</h2>
      <div class="max-w-3xl mx-auto space-y-4">
        {faqs.map(faq => (
          <FAQItem question={faq.question} answer={faq.answer} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-primary text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to Ride Your Dream Bike?</h2>
      <p class="text-xl mb-8 opacity-90">
        Get started with a free consultation. No obligation. Our motorcycle financing specialists are ready to help.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://wa.me/60175700889?text=Hi%20I%27m%20interested%20in%20motorcycle%20financing" 
           class="bg-white text-primary px-8 py-4 rounded-lg font-bold hover:bg-gray-100 transition">
          WhatsApp Us Now
        </a>
        <a href="/en/contact" 
           class="border-2 border-white px-8 py-4 rounded-lg font-bold hover:bg-white/10 transition">
          Contact Form
        </a>
      </div>
      <p class="mt-6 text-sm opacity-75">
        Or call us: <a href="tel:+60175700889" class="underline">017-570 0889</a>
      </p>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-4">Apply for Motorcycle Financing</h2>
      <p class="text-center text-gray-600 mb-8">
        Fill out the form below and our team will contact you within 24 hours.
      </p>
      <div class="max-w-2xl mx-auto">
        <ContactForm lang={lang} equipmentType="Motorcycle" />
      </div>
    </div>
  </section>

</BaseLayout>
