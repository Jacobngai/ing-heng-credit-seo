---
/**
 * Motorcycle Financing Landing Page - English
 * Target: Motorcycle enthusiasts, daily riders, collectors
 * Keywords: motorcycle financing Malaysia, motorcycle loan, bike financing
 * Cultural Focus: Passion-driven, lifestyle-focused, community-oriented
 * Word Count: 3,000+ words
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import StepCard from '../../../components/StepCard.astro';
import FAQItem from '../../../components/FAQItem.astro';
import ContactForm from '../../../components/ContactForm.astro';
import Calculator from '../../../components/Calculator.astro';
import TestimonialCard from '../../../components/TestimonialCard.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import RelatedEquipment from '../../../components/RelatedEquipment.astro';
import { generateProductSchema, generateFAQSchema, encodeJSONLD } from '../../../utils/schema';

import { SITE_CONFIG } from '../../../utils/constants';
const lang = 'en';

// SEO Data - Optimized for motorcycle financing Malaysia
const pageTitle = 'Motorcycle Financing Malaysia | Bike Loan 0% Deposit | Since 1985';
const pageDescription = 'Finance your dream motorcycle with 0% deposit. New & used bikes accepted up to 10 years old. Yamaha, Honda, Kawasaki, BMW, Ducati - all brands welcome. Flexible terms up to 7 years. 4,000+ riders funded since 1985.';
const keywords = ['motorcycle financing Malaysia', 'motorcycle loan Malaysia', 'bike financing', 'motorbike loan', 'Yamaha financing', 'Honda bike loan', 'used motorcycle financing', 'superbike loan Malaysia'];

// Breadcrumbs
const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Hobby Financing', url: '/en/equipment' },
  { label: 'Motorcycle Financing', url: '/en/equipment/motorcycle' },
];

// Benefits - Passion and lifestyle focused
const benefits = [
  { icon: 'clock', title: 'Streamlined Processing', description: 'Our experienced team processes applications efficiently. We understand riders need their bikes - not endless paperwork. Get a response quickly after submitting complete documents.' },
  { icon: 'percentage', title: '0% Deposit Available', description: 'Finance up to 100% of your motorcycle value for qualified applicants. Preserve your cash for gear, modifications, and riding adventures. Subject to terms and conditions.' },
  { icon: 'shield', title: 'New & Used Accepted', description: 'Finance brand new motorcycles or well-maintained used bikes up to 10 years old. All major brands accepted: Yamaha, Honda, Kawasaki, Suzuki, BMW, Ducati, KTM, and more.' },
  { icon: 'users', title: 'All Riders Welcome', description: 'Whether you\'re a first-time rider getting your dream bike or a seasoned enthusiast adding to your collection, we welcome all applications. Bad credit considered on a case-by-case basis.' },
  { icon: 'document', title: 'Simple Documentation', description: 'Just IC, proof of income, and 3-6 months bank statements. No complex paperwork. Salaried employees and self-employed riders both welcome.' },
  { icon: 'shield', title: 'Flexible Terms', description: 'Choose repayment terms from 12 to 84 months (up to 7 years). Longer terms mean lower monthly payments. No early settlement penalty - pay off anytime and save on interest.' },
];

// Process Steps
const steps = [
  { stepNumber: 1, icon: 'contact', title: 'Contact Us via WhatsApp', description: 'Share details about your dream motorcycle. Our specialists will provide initial assessment and answer your questions.' },
  { stepNumber: 2, icon: 'document', title: 'Submit Documents', description: 'Provide IC, 3-6 months bank statements, and proof of income. Quotation or details of the motorcycle you want to finance.' },
  { stepNumber: 3, icon: 'check', title: 'Get Approved', description: 'Receive your financing approval. We evaluate applications fairly based on your overall financial picture, not just credit scores.' },
  { stepNumber: 4, icon: 'clipboard', title: 'Sign Agreement', description: 'Review the loan terms and sign the agreement. Everything is transparent - ask any questions before committing.' },
  { stepNumber: 5, icon: 'truck', title: 'Ride Your Dream Bike', description: 'Collect your motorcycle and hit the road! Your riding journey begins. Join thousands of satisfied riders who financed with us.' },
];

// Motorcycle Types
const equipmentTypes = [
  {
    name: 'Kapchai & Mopeds (Below 150cc)',
    description: 'Practical daily transport for commuters. Honda Wave, Yamaha LC135, Y15ZR, Modenas Kriss. Affordable financing with low monthly payments.',
    applications: 'Daily commuting, delivery work, students, fuel-efficient transport',
    priceRange: 'RM 5,000 - RM 15,000'
  },
  {
    name: 'Standard Motorcycles (150cc-400cc)',
    description: 'Versatile bikes for daily use and weekend rides. Honda CB150R, Yamaha MT-15, Kawasaki Z250, KTM Duke 390.',
    applications: 'Urban commuting, weekend rides, beginner sport riding',
    priceRange: 'RM 12,000 - RM 35,000'
  },
  {
    name: 'Sport Bikes (400cc-600cc)',
    description: 'Performance-oriented machines for enthusiasts. Yamaha R3, Honda CBR500R, Kawasaki Ninja 400, KTM RC 390.',
    applications: 'Sport riding, track days, spirited commuting',
    priceRange: 'RM 25,000 - RM 50,000'
  },
  {
    name: 'Superbikes (600cc+)',
    description: 'High-performance motorcycles for serious riders. Yamaha R6/R1, Honda CBR600RR/CBR1000RR, Kawasaki ZX-6R/ZX-10R, Ducati Panigale.',
    applications: 'Track days, weekend warrior, collection pieces',
    priceRange: 'RM 50,000 - RM 500,000+'
  },
  {
    name: 'Cruisers & Tourers',
    description: 'Comfortable long-distance machines. Harley-Davidson, Indian, Honda Rebel, Kawasaki Vulcan, BMW R18.',
    applications: 'Highway touring, club rides, relaxed cruising',
    priceRange: 'RM 30,000 - RM 300,000+'
  },
  {
    name: 'Adventure & Dual Sport',
    description: 'Versatile machines for on and off-road. BMW GS series, KTM Adventure, Honda Africa Twin, Yamaha Tenere.',
    applications: 'Long-distance touring, off-road exploration, all-terrain riding',
    priceRange: 'RM 40,000 - RM 150,000+'
  },
  {
    name: 'Scooters & Maxi-Scooters',
    description: 'Automatic transmission convenience. Yamaha NMax/XMax, Honda PCX/ADV, Vespa, SYM, Piaggio.',
    applications: 'City commuting, errands, comfortable daily transport',
    priceRange: 'RM 8,000 - RM 80,000'
  },
  {
    name: 'Naked Bikes',
    description: 'Streetfighter style with upright ergonomics. Yamaha MT series, Kawasaki Z series, KTM Duke, Ducati Monster, Triumph Street Triple.',
    applications: 'Urban riding, versatile performance, daily sport riding',
    priceRange: 'RM 25,000 - RM 200,000+'
  },
];

// Accepted Brands
const acceptedBrands = ['Yamaha', 'Honda', 'Kawasaki', 'Suzuki', 'BMW Motorrad', 'Ducati', 'KTM', 'Triumph', 'Harley-Davidson', 'Indian', 'Aprilia', 'MV Agusta', 'Vespa', 'Benelli', 'CFMoto', 'Royal Enfield', 'Modenas', 'SYM'];

// Testimonials
const testimonials = [
  {
    name: 'Ahmad Faizal',
    company: 'Rider since 2020',
    location: 'Shah Alam, Selangor',
    testimonial: 'Always wanted a Yamaha R6 but thought it was out of reach. Ing Heng made it possible with 0% deposit. Now I ride my dream bike every weekend. The monthly payment fits my budget perfectly.',
    rating: 5,
  },
  {
    name: 'Jason Tan',
    company: 'Superbike enthusiast',
    location: 'Penang',
    testimonial: 'Financed my Ducati Panigale V4 after banks rejected me due to being self-employed. Ing Heng understood my business income and approved my application. Professional service from start to finish.',
    rating: 5,
  },
  {
    name: 'Raj Kumar',
    company: 'Daily rider',
    location: 'Johor Bahru',
    testimonial: 'Needed a reliable bike for daily commute. Got a Honda CB500X financed with very reasonable monthly payments. The process was smooth and the team was helpful throughout.',
    rating: 5,
  },
];

// FAQs - Comprehensive coverage
const faqs = [
  {
    question: 'What is the minimum down payment for motorcycle financing?',
    answer: 'We offer 0% deposit financing for qualified applicants with good credit profiles. Standard applications may require 10-20% down payment depending on the motorcycle value and your financial situation. Higher down payments result in lower monthly payments and potentially better interest rates.'
  },
  {
    question: 'Can I finance a used motorcycle?',
    answer: 'Yes! We finance both new and used motorcycles. Used bikes up to 10 years old in good running condition are accepted. The motorcycle will need to pass basic inspection requirements. Older bikes (7-10 years) may require slightly higher down payment (15-20%).'
  },
  {
    question: 'What documents do I need to apply?',
    answer: 'For employed individuals: (1) IC front and back, (2) Latest 3-6 months bank statements, (3) Salary slips or EA form, (4) Motorcycle quotation or details. For self-employed: (1) IC, (2) Business registration (SSM), (3) 6 months bank statements, (4) Income proof (invoices, contracts). Simple and straightforward process.'
  },
  {
    question: 'How long are the repayment terms?',
    answer: 'We offer flexible terms from 12 months to 84 months (7 years). Shorter terms mean higher monthly payments but lower total interest. Longer terms mean lower monthly payments. Choose what fits your budget. For used motorcycles, maximum term may be reduced based on bike age.'
  },
  {
    question: 'Do you finance imported or grey market motorcycles?',
    answer: 'Yes, we can finance AP (Approved Permit) motorcycles and parallel imports. The bike must have valid Malaysian registration (JPJ) and road tax. AP bikes may require additional documentation and slightly higher down payment due to valuation considerations.'
  },
  {
    question: 'Can I settle my loan early?',
    answer: 'Absolutely! There is no early settlement penalty. You can pay off your motorcycle loan anytime and save on future interest. Many riders pay extra during bonus months to reduce their loan faster. Contact us for settlement quote anytime.'
  },
  {
    question: 'What if I have bad credit or CCRIS issues?',
    answer: 'We evaluate applications holistically. Bad credit or CCRIS issues don\'t mean automatic rejection. We consider your current income, employment stability, down payment amount, and overall financial situation. Many riders with past credit issues have successfully financed with us. The motorcycle serves as collateral, which helps approval chances.'
  },
  {
    question: 'Do you finance motorcycle modifications?',
    answer: 'The primary loan covers the motorcycle purchase. If you\'re buying a bike that already has modifications, we finance the total value. Major aftermarket modifications after purchase would need separate arrangement. Discuss your plans with our team.'
  },
  {
    question: 'What interest rates do you offer?',
    answer: 'Interest rates range from 8% to 18% per annum depending on: (1) Your credit profile, (2) Down payment amount, (3) Loan term length, (4) Motorcycle age and value. Better rates are available for higher down payments and shorter terms. Contact us for personalized quote.'
  },
  {
    question: 'Can I finance multiple motorcycles?',
    answer: 'Yes! We can finance multiple bikes for collectors and enthusiasts. Each application is evaluated based on your total financial capacity. Some riders maintain daily commuters and weekend superbikes. Volume financing may qualify for better rates.'
  },
  {
    question: 'Is motorcycle insurance required?',
    answer: 'Comprehensive insurance is required for financed motorcycles. This protects both you and the asset. Basic insurance costs around RM 300-800 annually for standard bikes, and RM 1,500-5,000+ for superbikes depending on value. We can recommend insurance partners.'
  },
  {
    question: 'What if I want to sell the motorcycle before loan ends?',
    answer: 'You can sell the motorcycle by settling the outstanding loan first. Contact us for settlement amount. After full payment, we release the ownership for transfer. Some riders upgrade by selling their current financed bike and starting a new financing for their next motorcycle.'
  },
  {
    question: 'Do you serve all of Malaysia?',
    answer: 'Yes! We serve all Malaysian states - Selangor, KL, Johor, Penang, Perak, Pahang, Sabah, Sarawak, and everywhere in between. Our office is in Klang, Selangor, but we process applications nationwide via WhatsApp and online.'
  },
  {
    question: 'How long does approval take?',
    answer: 'Once complete documents are submitted, we process applications promptly. Standard applications receive response within 1-3 working days. Urgent cases with complete documentation can be expedited. The more complete your documents, the faster the process.'
  },
  {
    question: 'Can foreigners apply for motorcycle financing?',
    answer: 'Yes, foreigners with valid work permits and stable employment in Malaysia can apply. Required: (1) Valid passport, (2) Work permit or MM2H visa, (3) Employment letter, (4) 6 months bank statements, (5) Malaysian guarantor may be required depending on circumstances.'
  },
  {
    question: 'What happens if I miss a payment?',
    answer: 'Contact us immediately if you anticipate payment difficulty. We can discuss restructuring options before it becomes a problem. Late payments incur charges and affect your credit record. Consistent default may result in motorcycle repossession. Communication is key - talk to us early.'
  },
];

// Product Schema
const productSchema = generateProductSchema({
  name: 'Motorcycle Financing Malaysia',
  description: pageDescription,
  brand: 'Ing Heng Credit',
  category: 'Financial Services > Vehicle Financing > Motorcycle Loans'
});

const faqSchema = generateFAQSchema(faqs);

// Related Equipment
const relatedEquipment = [
  { name: 'Superbike Financing', url: '/en/equipment/superbike', description: 'High-performance motorcycles - Ducati, BMW S1000RR, Aprilia' },
  { name: 'Boat Financing', url: '/en/equipment/boat', description: 'Fishing boats, speedboats, yachts, jet skis' },
  { name: 'Sports Car Financing', url: '/en/equipment/sports-car', description: 'Porsche, Ferrari, Lamborghini, BMW M' },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  keywords={keywords}
  lang={lang}
>
  <script type="application/ld+json" set:html={encodeJSONLD(productSchema)} />
  <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />

  <!-- Breadcrumbs -->
  <Breadcrumbs items={breadcrumbs} lang={lang} />

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-primary via-primary to-secondary py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center text-white">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
          Motorcycle Financing Malaysia
        </h1>
        <p class="text-xl md:text-2xl  mb-8 leading-relaxed" style="color: white; opacity: 0.9;">
          Finance your dream bike with 0% deposit. New & used motorcycles accepted.
          Yamaha, Honda, Kawasaki, BMW, Ducati - all brands welcome.
          <strong class="text-yellow-400">Since 1985.</strong>
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
          <a href="https://wa.me/60175700889?text=Hi%20I%27m%20interested%20in%20motorcycle%20financing" 
             class="bg-yellow-400 text-navy-900 px-8 py-4 rounded-lg font-bold text-lg hover:bg-yellow-300 transition">
            WhatsApp Us Now
          </a>
          <a href="#calculator" 
             class="border-2 border-white text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-white/10 transition" style="color: white;">
            Calculate Payment
          </a>
        </div>
        <div class="flex flex-wrap justify-center gap-6 text-white/80 text-sm">
          <span>✓ 0% Deposit Available</span>
          <span>✓ New & Used Accepted</span>
          <span>✓ All Brands Welcome</span>
          <span>✓ Terms Up to 7 Years</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Why Finance Your Motorcycle With Us?</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          40 years of experience helping riders own their dream bikes. We understand motorcycles - not just numbers.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
        {benefits.map(benefit => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <div class="text-4xl mb-4">
              {benefit.icon === 'clock' && '⏱️'}
              {benefit.icon === 'percentage' && '💰'}
              {benefit.icon === 'shield' && '🛡️'}
              {benefit.icon === 'users' && '👥'}
              {benefit.icon === 'document' && '📋'}
            </div>
            <h3 class="text-xl font-bold mb-2">{benefit.title}</h3>
            <p class="text-gray-600">{benefit.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Motorcycle Types Section -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Motorcycles We Finance</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">
          From daily commuters to high-performance superbikes, we finance all types of motorcycles.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-7xl mx-auto">
        {equipmentTypes.map(type => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <h3 class="text-lg font-bold text-primary mb-2">{type.name}</h3>
            <p class="text-gray-600 text-sm mb-3">{type.description}</p>
            <p class="text-xs text-gray-500 mb-2"><strong>Popular for:</strong> {type.applications}</p>
            <p class="text-primary font-semibold text-sm">{type.priceRange}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Accepted Brands -->
  <section class="py-12 " style="background: linear-gradient(135deg, #2D1810, #4C3729); color: white;">
    <div class="container mx-auto px-4">
