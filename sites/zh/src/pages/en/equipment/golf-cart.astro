---
/**
 * Golf Cart Financing Landing Page - English
 * Target: Golf enthusiasts, resort owners, gated community residents
 * Keywords: golf cart financing Malaysia, golf buggy loan, electric cart financing
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import FAQItem from '../../../components/FAQItem.astro';
import ContactForm from '../../../components/ContactForm.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { generateProductSchema, generateFAQSchema, encodeJSONLD } from '../../../utils/schema';

import { SITE_CONFIG } from '../../../utils/constants';
const lang = 'en';

const pageTitle = 'Golf Cart Financing Malaysia | Golf Buggy Loan | 0% Deposit | Since 1985';
const pageDescription = 'Finance your golf cart with 0% deposit. Club Car, E-Z-GO, Yamaha golf buggies. Personal, commercial, and resort carts. New & used accepted. Flexible terms since 1985.';
const keywords = ['golf cart financing Malaysia', 'golf buggy loan', 'electric cart financing', 'Club Car financing', 'E-Z-GO loan Malaysia'];

const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Hobby Financing', url: '/en/equipment' },
  { label: 'Golf Cart Financing', url: '/en/equipment/golf-cart' },
];

const benefits = [
  { icon: 'percentage', title: '0% Deposit Available', description: 'Finance up to 100% of your golf cart. No large upfront payment required for qualified applicants.' },
  { icon: 'shield', title: 'New & Used Accepted', description: 'Finance brand new carts or quality pre-owned. Well-maintained used carts up to 10 years accepted.' },
  { icon: 'star', title: 'All Major Brands', description: 'Club Car, E-Z-GO, Yamaha, Cushman, ICON, Advanced EV - we finance all reputable golf cart brands.' },
  { icon: 'calendar', title: 'Flexible Terms', description: 'Terms from 1-7 years. Choose monthly payments that fit your budget.' },
  { icon: 'document', title: 'Simple Process', description: 'IC, income proof, cart details. Quick approval for qualified applicants.' },
  { icon: 'money', title: 'Competitive Rates', description: 'Rates from 8% per annum. Fleet discounts available for multiple carts.' },
];

const equipmentTypes = [
  {
    name: 'Personal Golf Carts',
    description: '2-4 seater carts for personal use at golf courses and gated communities. Electric and gas options.',
    applications: 'Golf, gated community transport, resort living',
    priceRange: 'RM 25,000 - RM 80,000'
  },
  {
    name: 'Lifted Golf Carts',
    description: 'Custom lifted carts with enhanced suspension, larger wheels. For off-road and rough terrain use.',
    applications: 'Plantations, farms, rough terrain, recreation',
    priceRange: 'RM 40,000 - RM 120,000'
  },
  {
    name: 'Luxury Golf Carts',
    description: 'Premium features: leather seats, sound systems, custom paint. Club Car Onward, E-Z-GO Liberty.',
    applications: 'Personal transport, VIP use, resort showcase',
    priceRange: 'RM 60,000 - RM 200,000'
  },
  {
    name: 'Commercial Fleet Carts',
    description: 'Utility carts for resorts, hotels, golf courses. Multiple units financing available.',
    applications: 'Golf courses, resorts, hotels, security patrol',
    priceRange: 'RM 20,000 - RM 60,000 per unit'
  },
  {
    name: 'Electric Utility Vehicles',
    description: 'Larger utility vehicles like Cushman Hauler, Club Car Carryall. For cargo and maintenance.',
    applications: 'Maintenance, cargo transport, industrial sites',
    priceRange: 'RM 50,000 - RM 150,000'
  },
];

const acceptedBrands = ['Club Car', 'E-Z-GO', 'Yamaha Golf Cart', 'Cushman', 'ICON', 'Advanced EV', 'Star EV', 'Tomberlin', 'Garia', 'Evolution Electric'];

const faqs = [
  {
    question: 'What is the minimum down payment for golf cart financing?',
    answer: 'We offer 0% deposit (full loan) financing for qualified applicants. You can finance 100% of your golf cart value with no upfront payment. This is our specialty since 1985.'
  },
  {
    question: 'Can I finance a used golf cart?',
    answer: 'Yes! We finance both new and used golf carts. Pre-owned carts up to 10 years old in good working condition are accepted. Electric carts should have healthy battery systems.'
  },
  {
    question: 'Do you finance electric and gas golf carts?',
    answer: 'We finance both electric and gas-powered golf carts. Electric carts are increasingly popular due to lower running costs. Both qualify for the same financing terms.'
  },
  {
    question: 'Can I finance multiple golf carts for my business?',
    answer: 'Absolutely! We provide fleet financing for golf courses, resorts, and hotels. Volume purchases may qualify for better rates. Contact us for commercial fleet quotes.'
  },
  {
    question: 'What documents do I need?',
    answer: 'For personal: IC, income proof, bank statements. For business: SSM registration, company financials, authorized signatory documents. Simple and straightforward process.'
  },
  {
    question: 'How long are repayment terms?',
    answer: 'Flexible terms from 12 to 84 months (7 years). Choose what fits your budget. Shorter terms have lower total interest, longer terms have lower monthly payments.'
  },
  {
    question: 'Is the golf cart registered like a car?',
    answer: 'Golf carts are typically not road-registered vehicles in Malaysia. They\'re used on private property, golf courses, and designated areas. No JPJ registration required for standard use.'
  },
];

const productSchema = generateProductSchema({
  name: 'Golf Cart Financing Malaysia',
  description: pageDescription,
  brand: 'Ing Heng Credit',
  price: '25000',
  priceCurrency: 'MYR',
});

const faqSchema = generateFAQSchema(faqs);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
  keywords={keywords}
>
  <script type="application/ld+json" set:html={encodeJSONLD(productSchema)} />
  <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />
  
  <Breadcrumbs items={breadcrumbs} lang={lang} />

  <Hero
    title="Golf Cart Financing"
    subtitle="Finance your golf cart with 0% deposit. Club Car, E-Z-GO, Yamaha. Personal and commercial carts. New & used accepted."
    ctaText="WhatsApp Us"
    ctaLink="https://wa.me/60175700889?text=Hi%20I'm%20interested%20in%20golf%20cart%20financing"
    lang={lang}
    trustSignals={['Since 1985', '0% Deposit', 'All Brands']}
  />

  <!-- Benefits Section -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Why Finance Your Golf Cart With Us?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {benefits.map(benefit => (
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <div class="text-4xl mb-4">⛳</div>
            <h3 class="text-xl font-bold mb-2">{benefit.title}</h3>
            <p class="text-gray-600">{benefit.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Equipment Types -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-4">Types of Golf Carts We Finance</h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
        From personal golf buggies to commercial fleet vehicles
      </p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {equipmentTypes.map(type => (
          <div class="bg-white rounded-xl shadow-lg border border-gray-100 p-6">
            <h3 class="text-xl font-bold text-primary mb-3">{type.name}</h3>
            <p class="text-gray-600 mb-4">{type.description}</p>
            <div class="space-y-2 text-sm">
              <p><strong>Use:</strong> {type.applications}</p>
              <p><strong>Price Range:</strong> {type.priceRange}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Accepted Brands -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-8">Brands We Finance</h2>
      <div class="flex flex-wrap justify-center gap-4">
        {acceptedBrands.map(brand => (
          <span class="bg-white px-4 py-2 rounded-full text-sm font-medium border">{brand}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Frequently Asked Questions</h2>
      <div class="max-w-3xl mx-auto space-y-4">
        {faqs.map(faq => (
          <FAQItem question={faq.question} answer={faq.answer} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16" style="background: linear-gradient(135deg, #2D1810, #4C3729); color: white;">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4" style="color: white;">Ready to Finance Your Golf Cart?</h2>
      <p class="text-xl mb-8" style="color: white; opacity: 0.9;">
        Get started with a free consultation. No obligation.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://wa.me/60175700889?text=Hi%20I'm%20interested%20in%20golf%20cart%20financing" 
           class="bg-white text-primary px-8 py-4 rounded-lg font-bold hover:bg-gray-100 transition">
          WhatsApp Us
        </a>
        <a href="/en/contact" 
           class="border-2 border-white px-8 py-4 rounded-lg font-bold hover:bg-white/10 transition" style="color: white;">
          Contact Form
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-4">Get a Free Quote</h2>
        <p class="text-center text-gray-600 mb-8">Fill out the form and we'll contact you within 24 hours.</p>
        <ContactForm lang={lang} />
      </div>
    </div>
  </section>

</BaseLayout>
