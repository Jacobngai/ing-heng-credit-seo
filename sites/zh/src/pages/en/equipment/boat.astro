    <div class="container mx-auto px-4">
      <div class="text-center mb-12"><h2 class="text-3xl md:text-4xl font-bold mb-4">What Boat Owners Say</h2></div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
