        <a href="/en/contact" class="border-2 border-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-white/10 transition">Contact Form</a>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="text-center mb-8"><h2 class="text-3xl font-bold mb-4">Apply for Boat Financing</h2></div>
