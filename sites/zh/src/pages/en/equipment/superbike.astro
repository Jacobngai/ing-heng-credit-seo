---
/**
 * Superbike Financing Landing Page - English
 * Target: High-performance motorcycle enthusiasts, collectors, track riders
 * Keywords: superbike financing Malaysia, sportbike loan, Ducati financing
 * Cultural Focus: Premium service, passion-driven, enthusiast community
 * Word Count: 3,000+ words
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import StepCard from '../../../components/StepCard.astro';
import FAQItem from '../../../components/FAQItem.astro';
import ContactForm from '../../../components/ContactForm.astro';
import Calculator from '../../../components/Calculator.astro';
import TestimonialCard from '../../../components/TestimonialCard.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { generateProductSchema, generateFAQSchema, encodeJSONLD } from '../../../utils/schema';

import { SITE_CONFIG } from '../../../utils/constants';
const lang = 'en';

// SEO Data
const pageTitle = 'Superbike Financing Malaysia | Ducati, BMW S1000RR, Kawasaki ZX-10R | Since 1985';
const pageDescription = 'Finance your dream superbike with flexible terms. Ducati Panigale, BMW S1000RR, Kawasaki ZX-10R, Yamaha R1, Honda CBR1000RR. New & used high-performance motorcycles. 0% deposit available. Premium service since 1985.';
const keywords = ['superbike financing Malaysia', 'sportbike loan', 'Ducati financing Malaysia', 'BMW S1000RR loan', 'Kawasaki ZX-10R financing', 'litre class bike loan', 'high-performance motorcycle financing'];

const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Hobby Financing', url: '/en/equipment' },
  { label: 'Superbike Financing', url: '/en/equipment/superbike' },
];

const benefits = [
  { icon: 'star', title: 'Premium Service', description: 'Dedicated specialists who understand high-value motorcycle financing. Confidential, professional consultation for discerning enthusiasts. We speak your language.' },
  { icon: 'percentage', title: '0% Deposit Options', description: 'Finance up to 100% of your superbike value for qualified applicants. Keep your capital for track days, gear, and modifications. Subject to terms.' },
  { icon: 'shield', title: 'New & Pre-Owned', description: 'Finance brand new superbikes or well-maintained pre-owned machines. Used bikes up to 10 years old accepted. All premium brands welcome.' },
  { icon: 'brands', title: 'All Premium Brands', description: 'Ducati, BMW Motorrad, Aprilia, MV Agusta, Kawasaki, Yamaha, Honda, Suzuki, KTM - every high-performance brand accepted.' },
  { icon: 'document', title: 'Efficient Process', description: 'Streamlined documentation for busy professionals. We respect your time and make superbike financing hassle-free.' },
  { icon: 'money', title: 'High-Value Expertise', description: 'Finance superbikes from RM50K to RM800K+. We understand exotic motorcycle valuation and the premium market.' },
];

const steps = [
  { stepNumber: 1, icon: 'contact', title: 'Confidential Inquiry', description: 'Contact us via WhatsApp. Share your superbike details. We provide discrete, professional assessment.' },
  { stepNumber: 2, icon: 'document', title: 'Submit Documents', description: 'IC, income proof, bank statements. For high-value superbikes, additional verification may apply.' },
  { stepNumber: 3, icon: 'check', title: 'Get Approved', description: 'Receive financing approval. We evaluate your overall financial capacity fairly and efficiently.' },
  { stepNumber: 4, icon: 'clipboard', title: 'Sign Agreement', description: 'Review transparent terms. No hidden fees. Ask any questions before committing.' },
  { stepNumber: 5, icon: 'truck', title: 'Collect Your Superbike', description: 'Take delivery of your dream machine. Join the elite community of superbike owners.' },
];

const equipmentTypes = [
  {
    name: 'Supersport (600cc-750cc)',
    description: 'Track-focused machines with balanced performance. Yamaha R6, Honda CBR600RR, Kawasaki ZX-6R, Triumph Daytona 675.',
    applications: 'Track days, canyon carving, weekend warrior',
    priceRange: 'RM 50,000 - RM 100,000'
  },
  {
    name: 'Litre-Class Superbikes (1000cc)',
    description: 'The pinnacle of motorcycle performance. Ducati Panigale V4, BMW S1000RR, Kawasaki ZX-10R, Yamaha R1, Honda CBR1000RR-R Fireblade.',
    applications: 'Track days, sport touring, collection pieces',
    priceRange: 'RM 80,000 - RM 250,000+'
  },
  {
    name: 'Hypernaked',
    description: 'Stripped superbike performance in streetfighter form. Ducati Streetfighter V4, BMW S1000R, Kawasaki Z H2, Aprilia Tuono.',
    applications: 'Street performance, aggressive commuting, versatile sport riding',
    priceRange: 'RM 70,000 - RM 200,000+'
  },
  {
    name: 'Limited Editions & Homologation Specials',
    description: 'Rare and race-spec machines. Ducati Superleggera, Panigale V4 R, BMW M1000RR, Aprilia RSV4 Factory.',
    applications: 'Collection, serious track work, investment',
    priceRange: 'RM 200,000 - RM 800,000+'
  },
  {
    name: 'Premium Adventure Sport',
    description: 'High-performance adventure touring. Ducati Multistrada V4 S, BMW S1000XR, KTM 1290 Super Adventure.',
    applications: 'Sport touring, long-distance performance',
    priceRange: 'RM 100,000 - RM 180,000+'
  },
  {
    name: 'Exotic Italian',
    description: 'MV Agusta, Bimota - rare Italian exotics for true connoisseurs.',
    applications: 'Collection, exclusive ownership, special occasions',
    priceRange: 'RM 150,000 - RM 500,000+'
  },
];

const acceptedBrands = ['Ducati', 'BMW Motorrad', 'Aprilia', 'MV Agusta', 'Kawasaki', 'Yamaha', 'Honda', 'Suzuki', 'KTM', 'Triumph', 'Bimota', 'Norton'];

const testimonials = [
  {
    name: 'Dr. Ahmad Rizal',
    company: 'Surgeon & Track Enthusiast',
    location: 'Kuala Lumpur',
    testimonial: 'Financed my Ducati Panigale V4 S through Ing Heng. The process was professional and discrete - exactly what I needed. They understood that superbikes are more than just transport; they\'re a passion. Excellent service.',
    rating: 5,
  },
  {
    name: 'James Wong',
    company: 'Business Owner',
    location: 'Penang',
    testimonial: 'Banks wouldn\'t touch my BMW S1000RR application due to my business income structure. Ing Heng understood my financials and approved me within days. Now I ride my dream bike on track days and weekends.',
    rating: 5,
  },
  {
    name: 'Vikram Singh',
    company: 'Superbike Collector',
    location: 'Johor Bahru',
    testimonial: 'This is my third superbike financed with Ing Heng - Yamaha R1, then Kawasaki ZX-10R, now Ducati Streetfighter V4. They offer the best terms for high-value motorcycles and understand collectors like me.',
    rating: 5,
  },
];

const faqs = [
  {
    question: 'What is the financing range for superbikes?',
    answer: 'We finance superbikes from RM50,000 to RM800,000+. Whether it\'s a used Yamaha R6 or a new Ducati Panigale V4 S, we have financing solutions for all superbike price ranges. Limited editions and rare models are welcome.'
  },
  {
    question: 'Do you finance imported/AP superbikes?',
    answer: 'Yes, we finance AP (Approved Permit) and parallel import superbikes. The motorcycle must have valid Malaysian registration (JPJ). We understand the premium motorcycle market and the value of AP bikes.'
  },
  {
    question: 'Can I finance a superbike as a second or third vehicle?',
    answer: 'Absolutely. Many of our clients finance superbikes as weekend or track-day machines in addition to their daily vehicles. We evaluate your overall financial capacity, not just single-vehicle ownership.'
  },
  {
    question: 'What about insurance for high-value superbikes?',
    answer: 'Comprehensive insurance is required for financed superbikes. Premium superbike insurance costs approximately RM 3,000-10,000+ annually depending on value and coverage. We can recommend specialist insurers who understand superbike coverage.'
  },
  {
    question: 'Do you finance track-only motorcycles?',
    answer: 'We primarily finance road-registered motorcycles. Pure track bikes without road registration are evaluated case-by-case. Many track riders finance road-legal superbikes and convert them for track use. Discuss your specific situation with us.'
  },
  {
    question: 'What documentation is needed for high-value superbikes?',
    answer: 'Standard documents: IC, income proof, 6 months bank statements. For superbikes over RM200,000, we may request additional income verification such as tax returns or business financials. The process remains straightforward for qualified applicants.'
  },
  {
    question: 'Can I finance modifications or track preparation?',
    answer: 'The primary financing covers the superbike purchase. If buying a bike with existing performance modifications, we finance the total value. Post-purchase track preparation (exhaust, ECU, suspension) would need separate arrangement.'
  },
  {
    question: 'What interest rates apply to superbike financing?',
    answer: 'Interest rates range from 8% to 16% per annum depending on your profile, down payment, and loan term. Premium superbikes may qualify for competitive rates due to strong resale values. Contact us for personalized quote.'
  },
  {
    question: 'How long are repayment terms for superbikes?',
    answer: 'We offer terms from 12 to 84 months (7 years) for superbikes. Longer terms mean lower monthly payments. For used superbikes, maximum term may be reduced based on bike age. Choose what fits your financial situation.'
  },
  {
    question: 'What happens if I want to upgrade to a newer superbike?',
    answer: 'We offer refinancing and upgrade programs. After 12-18 months of timely payments, you can trade in your current superbike and upgrade to a newer model. Many enthusiasts upgrade every 2-3 years to the latest technology.'
  },
  {
    question: 'Do you finance rare limited editions?',
    answer: 'Yes! We finance limited editions like Ducati Superleggera, BMW HP4 Race, and special anniversary models. These bikes often hold value well. Valuation may require specialist assessment for very rare models.'
  },
  {
    question: 'Is the financing process confidential?',
    answer: 'Absolutely. We maintain strict confidentiality for all clients. Your financial details and superbike purchase are handled with complete discretion. Many high-profile clients trust us for this reason.'
  },
];

const productSchema = generateProductSchema({
  name: 'Superbike Financing Malaysia',
  description: pageDescription,
  brand: 'Ing Heng Credit',
  category: 'Financial Services > Vehicle Financing > Superbike Loans'
});

const faqSchema = generateFAQSchema(faqs);

const relatedEquipment = [
  { name: 'Motorcycle Financing', url: '/en/equipment/motorcycle', description: 'All motorcycles from daily riders to premium bikes' },
  { name: 'Sports Car Financing', url: '/en/equipment/sports-car', description: 'Porsche, Ferrari, Lamborghini, BMW M' },
  { name: 'Boat Financing', url: '/en/equipment/boat', description: 'Speedboats, yachts, jet skis' },
];
---

<BaseLayout title={pageTitle} description={pageDescription} keywords={keywords} lang={lang}>
  <script type="application/ld+json" set:html={encodeJSONLD(productSchema)} />
  <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />

  <Breadcrumbs items={breadcrumbs} lang={lang} />

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-gray-900 via-primary to-secondary py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center text-white">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
          Superbike Financing Malaysia
        </h1>
        <p class="text-xl md:text-2xl  mb-8 leading-relaxed" style="color: white; opacity: 0.9;">
          Finance your high-performance dream machine. Ducati, BMW, Aprilia, MV Agusta - all premium brands welcome.
          <strong class="text-yellow-400">Premium service since 1985.</strong>
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
          <a href="https://wa.me/60175700889?text=Hi%20I%27m%20interested%20in%20superbike%20financing" 
             class="bg-yellow-400 text-navy-900 px-8 py-4 rounded-lg font-bold text-lg hover:bg-yellow-300 transition">
            WhatsApp Us Now
          </a>
          <a href="#calculator" class="border-2 border-white text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-white/10 transition" style="color: white;">
            Calculate Payment
          </a>
        </div>
        <div class="flex flex-wrap justify-center gap-6 text-white/80 text-sm">
          <span>✓ 0% Deposit Available</span>
          <span>✓ Premium Brands</span>
          <span>✓ Confidential Service</span>
          <span>✓ RM50K - RM800K+</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Premium Superbike Financing</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">Specialized financing for serious riders and collectors.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
        {benefits.map(benefit => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <div class="text-4xl mb-4">⭐</div>
            <h3 class="text-xl font-bold mb-2">{benefit.title}</h3>
            <p class="text-gray-600">{benefit.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Superbike Types -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Superbikes We Finance</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">From track weapons to exotic collectibles.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
        {equipmentTypes.map(type => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <h3 class="text-lg font-bold text-primary mb-2">{type.name}</h3>
            <p class="text-gray-600 text-sm mb-3">{type.description}</p>
            <p class="text-xs text-gray-500 mb-2"><strong>Perfect for:</strong> {type.applications}</p>
            <p class="text-primary font-semibold text-sm">{type.priceRange}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Brands -->
  <section class="py-12 bg-gray-900 text-white">
    <div class="container mx-auto px-4">
      <h2 class="text-2xl font-bold text-center mb-8">Premium Brands We Finance</h2>
      <div class="flex flex-wrap justify-center gap-3 max-w-5xl mx-auto">
        {acceptedBrands.map(brand => (
          <span class="bg-white/20 px-4 py-2 rounded-full text-sm">{brand}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Premium Financing Process</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-5 gap-6 max-w-6xl mx-auto">
        {steps.map(step => (
          <div class="text-center">
            <div class="w-16 h-16 " style="background: linear-gradient(135deg, #2D1810, #4C3729); color: white; rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">{step.stepNumber}</div>
            <h3 class="font-bold mb-2">{step.title}</h3>
            <p class="text-gray-600 text-sm">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Calculator -->
  <section class="py-16" id="calculator">
    <div class="container mx-auto px-4">
      <div class="text-center mb-8">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Superbike Payment Calculator</h2>
        <p class="text-gray-600">Calculate your monthly payment for that dream superbike</p>
      </div>
      <div class="max-w-2xl mx-auto">
        <Calculator lang={lang} defaultAmount={120000} minAmount={30000} maxAmount={1000000} defaultTerm={60} defaultRate={10} />
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">What Superbike Owners Say</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {testimonials.map(testimonial => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <div class="flex mb-4">{[...Array(testimonial.rating)].map(() => <span class="text-yellow-400">★</span>)}</div>
            <p class="text-gray-600 mb-4 italic">"{testimonial.testimonial}"</p>
            <div>
              <p class="font-bold">{testimonial.name}</p>
              <p class="text-sm text-gray-500">{testimonial.company}</p>
              <p class="text-sm text-gray-500">{testimonial.location}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Superbike Financing FAQ</h2>
      </div>
      <div class="max-w-3xl mx-auto space-y-4">
        {faqs.map(faq => (
          <div class="border border-gray-200 rounded-lg overflow-hidden">
            <details class="group">
              <summary class="flex justify-between items-center p-6 cursor-pointer hover:bg-gray-50 transition-colors">
                <h3 class="font-bold pr-4">{faq.question}</h3>
                <span class="text-xl text-primary group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <div class="px-6 pb-6"><p class="text-gray-700 leading-relaxed">{faq.answer}</p></div>
            </details>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Related -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-2xl font-bold text-center mb-8">Other Hobby Financing</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        {relatedEquipment.map(item => (
          <a href={item.url} class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <h3 class="font-bold text-primary mb-2">{item.name}</h3>
            <p class="text-gray-600 text-sm">{item.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 " style="background: linear-gradient(135deg, #2D1810, #4C3729); color: white;">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Ready for Ultimate Performance?</h2>
      <p class="text-xl mb-8  max-w-2xl mx-auto" style="color: white; opacity: 0.9;">Your dream superbike is closer than you think. Premium service for discerning riders.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://wa.me/60175700889?text=Hi%20I%27m%20interested%20in%20superbike%20financing" class="bg-yellow-400 text-navy-900 px-8 py-4 rounded-lg font-bold text-lg hover:bg-yellow-300 transition">WhatsApp Us Now</a>
        <a href="/en/contact" class="border-2 border-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-white/10 transition" style="color: white;">Contact Form</a>
