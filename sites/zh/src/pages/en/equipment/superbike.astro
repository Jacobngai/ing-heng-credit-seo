    </div>
  </section>

  <!-- Contact Form -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="text-center mb-8">
        <h2 class="text-3xl font-bold mb-4">Apply for Superbike Financing</h2>
      </div>
      <div class="max-w-2xl mx-auto">
        <ContactForm lang={lang} equipmentType="Superbike" />
      </div>
    </div>
  </section>
</BaseLayout>
