---
/**
 * Superbike Financing Landing Page - English
 * Target: High-performance motorcycle enthusiasts, collectors
 * Keywords: superbike financing Malaysia, sportbike loan, high-performance motorcycle financing
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import StepCard from '../../../components/StepCard.astro';
import FAQItem from '../../../components/FAQItem.astro';
import ContactForm from '../../../components/ContactForm.astro';
import Calculator from '../../../components/Calculator.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { generateProductSchema, generateFAQSchema, encodeJSONLD } from '../../../utils/schema';

import { SITE_CONFIG } from '../../../utils/constants';
const lang = 'en';

// SEO Data
const pageTitle = 'Superbike Financing Malaysia | Premium Sportbike Loans | Since 1985';
const pageDescription = 'Finance your dream superbike with 0% deposit. Ducati, BMW S1000RR, Kawasaki ZX-10R, Yamaha R1, Honda CBR1000RR. New & used high-performance motorcycles. 4,000+ riders funded since 1985.';
const keywords = ['superbike financing Malaysia', 'sportbike loan', 'Ducati financing Malaysia', 'BMW S1000RR loan', 'high-performance motorcycle financing', 'litre class bike loan'];

// Breadcrumbs
const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Equipment', url: '/en/equipment' },
  { label: 'Superbike Financing', url: '/en/equipment/superbike' },
];

// Benefits
const benefits = [
  { icon: 'clock', title: 'Premium Service', description: 'Dedicated specialists who understand high-value motorcycle financing. Confidential, professional consultation.' },
  { icon: 'percentage', title: '0% Deposit Options', description: 'Finance up to 100% of your superbike value. Keep your capital for gear, track days, and modifications.' },
  { icon: 'shield', title: 'New & Used Accepted', description: 'Finance brand new or pre-owned superbikes. Well-maintained bikes up to 10 years old accepted.' },
  { icon: 'users', title: 'All Premium Brands', description: 'Ducati, BMW, Aprilia, MV Agusta, Kawasaki, Yamaha, Honda, Suzuki - every high-performance brand welcome.' },
  { icon: 'document', title: 'Streamlined Process', description: 'Efficient documentation for busy professionals. We respect your time and make financing hassle-free.' },
  { icon: 'shield', title: 'Flexible High-Value Terms', description: 'Finance superbikes from RM50K to RM500K+. Terms up to 7 years with competitive rates.' },
];

// Superbike Categories
const equipmentTypes = [
  {
    name: 'Litre-Class Superbikes (1000cc)',
    description: 'The pinnacle of motorcycle performance. Ducati Panigale V4, BMW S1000RR, Kawasaki ZX-10R, Yamaha R1, Honda CBR1000RR-R Fireblade.',
    applications: 'Track days, sport touring, collection pieces'
  },
  {
    name: 'Supersport (600-750cc)',
    description: 'Balanced performance machines. Yamaha R6, Honda CBR600RR, Kawasaki ZX-6R, Triumph Daytona 675.',
    applications: 'Track days, canyon carving, daily sportbike riding'
  },
  {
    name: 'Hypernaked',
    description: 'Stripped superbike performance. Ducati Streetfighter V4, BMW S1000R, Kawasaki Z H2, Aprilia Tuono.',
    applications: 'Street performance, aggressive commuting, versatile sport riding'
  },
  {
    name: 'Premium Adventure Sport',
    description: 'High-performance adventure machines. Ducati Multistrada V4, BMW S1000XR, KTM 1290 Super Adventure.',
    applications: 'Sport touring, long-distance performance riding'
  },
  {
    name: 'Limited Editions & Collectibles',
    description: 'Rare and limited production superbikes. Ducati Superleggera, BMW HP4 Race, special editions.',
    applications: 'Collection, investment, exclusive ownership'
  },
  {
    name: 'Track-Ready Homologation Specials',
    description: 'Race-spec road bikes. Aprilia RSV4 Factory, Ducati Panigale V4 R, BMW M1000RR.',
    applications: 'Serious track work, racing, ultimate performance'
  },
];

// Premium Brands
const acceptedBrands = ['Ducati', 'BMW Motorrad', 'Aprilia', 'MV Agusta', 'Kawasaki', 'Yamaha', 'Honda', 'Suzuki', 'KTM', 'Triumph', 'Bimota', 'Norton'];

// FAQs
const faqs = [
  {
    question: 'What is the financing range for superbikes?',
    answer: 'We finance superbikes from RM50,000 to RM500,000+. Whether it\'s a used Yamaha R6 or a new Ducati Panigale V4 S, we have financing solutions for all price ranges.'
  },
  {
    question: 'Do you finance imported/AP superbikes?',
    answer: 'Yes, we finance AP (Approved Permit) and parallel import superbikes. The motorcycle must have valid Malaysian registration. We understand the premium motorcycle market.'
  },
  {
    question: 'Can I finance a superbike as a second vehicle?',
    answer: 'Absolutely. Many of our clients finance superbikes as weekend or track-day machines. We evaluate your overall financial capacity, not just single-vehicle ownership.'
  },
  {
    question: 'What about insurance requirements?',
    answer: 'Comprehensive insurance is required for financed superbikes. We can recommend insurance partners who specialize in high-value motorcycle coverage.'
  },
  {
    question: 'Do you finance track-only motorcycles?',
    answer: 'We primarily finance road-registered motorcycles. Pure track bikes without road registration are evaluated case-by-case. Contact us to discuss your specific situation.'
  },
  {
    question: 'What documentation is needed for high-value superbikes?',
    answer: 'Standard documents: IC, income proof, bank statements. For superbikes over RM200K, we may request additional income verification. The process remains straightforward.'
  },
];

const productSchema = generateProductSchema({
  name: 'Superbike Financing Malaysia',
  description: pageDescription,
  brand: 'Ing Heng Credit',
  category: 'Financial Services > Vehicle Financing > Superbike Loans'
});

const faqSchema = generateFAQSchema(faqs);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  keywords={keywords}
  lang={lang}
>
  <script type="application/ld+json" set:html={encodeJSONLD(productSchema)} />
  <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />

  <Breadcrumbs items={breadcrumbs} lang={lang} />

  <Hero
    title="Superbike Financing Malaysia"
    subtitle="Finance your high-performance dream machine. Ducati, BMW, Aprilia, MV Agusta - all premium brands welcome. 0% deposit available. Terms up to 7 years."
    ctaText="Apply Now via WhatsApp"
    ctaLink="https://wa.me/60175700889?text=Hi%20I%27m%20interested%20in%20superbike%20financing"
    ctaSecondaryText="Calculate Payments"
    ctaSecondaryLink="#calculator"
    lang={lang}
    trustSignals={['Since 1985', 'Premium Service', '0% Deposit Available']}
  />

  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Premium Superbike Financing Benefits</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {benefits.map(benefit => (
          <BenefitCard {...benefit} />
        ))}
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-4">Superbikes We Finance</h2>
      <p class="text-center text-gray-600 mb-12 max-w-3xl mx-auto">
        From entry-level supersports to exotic limited editions, we finance the machines that make your heart race.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {equipmentTypes.map(type => (
          <div class="bg-white p-6 rounded-lg shadow-md border border-gray-100">
            <h3 class="text-xl font-bold text-primary mb-3">{type.name}</h3>
            <p class="text-gray-600 mb-3">{type.description}</p>
            <p class="text-sm text-gray-500"><strong>Perfect for:</strong> {type.applications}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-12 bg-primary text-white">
    <div class="container mx-auto px-4">
      <h2 class="text-2xl font-bold text-center mb-8">Premium Brands We Finance</h2>
      <div class="flex flex-wrap justify-center gap-4">
        {acceptedBrands.map(brand => (
          <span class="bg-white/20 px-4 py-2 rounded-full text-sm">{brand}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16" id="calculator">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-4">Superbike Payment Calculator</h2>
      <p class="text-center text-gray-600 mb-8">
        Calculate your monthly payment for that dream superbike.
      </p>
      <Calculator 
        lang={lang}
        defaultAmount={80000}
        minAmount={30000}
        maxAmount={800000}
        defaultTerm={60}
        defaultRate={8}
      />
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Superbike Financing FAQ</h2>
      <div class="max-w-3xl mx-auto space-y-4">
        {faqs.map(faq => (
          <FAQItem question={faq.question} answer={faq.answer} />
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-primary text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready for Ultimate Performance?</h2>
      <p class="text-xl mb-8 opacity-90">
        Your dream superbike is closer than you think. Get a free consultation today.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://wa.me/60175700889?text=Hi%20I%27m%20interested%20in%20superbike%20financing" 
           class="bg-white text-primary px-8 py-4 rounded-lg font-bold hover:bg-gray-100 transition">
          WhatsApp Us Now
        </a>
        <a href="/en/contact" 
           class="border-2 border-white px-8 py-4 rounded-lg font-bold hover:bg-white/10 transition">
          Contact Form
        </a>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-8">Apply for Superbike Financing</h2>
      <div class="max-w-2xl mx-auto">
        <ContactForm lang={lang} equipmentType="Superbike" />
      </div>
    </div>
  </section>

</BaseLayout>
