---
/**
 * Sports Car Financing Landing Page - English
 * Target: Sports car enthusiasts, collectors, high-net-worth individuals
 * Keywords: sports car financing Malaysia, supercar loan, exotic car financing
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import StepCard from '../../../components/StepCard.astro';
import FAQItem from '../../../components/FAQItem.astro';
import ContactForm from '../../../components/ContactForm.astro';
import Calculator from '../../../components/Calculator.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { generateProductSchema, generateFAQSchema, encodeJSONLD } from '../../../utils/schema';

import { SITE_CONFIG } from '../../../utils/constants';
const lang = 'en';

// SEO Data
const pageTitle = 'Sports Car Financing Malaysia | Supercar Loans | Porsche, Ferrari, Lamborghini';
const pageDescription = 'Finance your dream sports car with flexible terms. Porsche, Ferrari, Lamborghini, McLaren, BMW M, Mercedes AMG. New & used exotic cars. Confidential premium service since 1985.';
const keywords = ['sports car financing Malaysia', 'supercar loan', 'Porsche financing Malaysia', 'Ferrari loan', 'exotic car financing', 'luxury car loan Malaysia'];

// Breadcrumbs
const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Equipment', url: '/en/equipment' },
  { label: 'Sports Car Financing', url: '/en/equipment/sports-car' },
];

// Benefits
const benefits = [
  { icon: 'clock', title: 'Confidential Service', description: 'Discrete, professional consultation for high-net-worth clients. Your privacy and time are respected throughout the process.' },
  { icon: 'percentage', title: 'Flexible Down Payment', description: 'Competitive financing structures for high-value vehicles. Terms designed for exotic car ownership.' },
  { icon: 'shield', title: 'New & Pre-Owned', description: 'Finance new or certified pre-owned sports cars. Well-maintained exotics with documented history accepted.' },
  { icon: 'users', title: 'All Exotic Brands', description: 'Porsche, Ferrari, Lamborghini, McLaren, Aston Martin, Bentley, BMW M, Mercedes AMG, Audi RS - all welcome.' },
  { icon: 'document', title: 'Premium Process', description: 'Streamlined documentation for busy professionals. Efficient processing without compromising thoroughness.' },
  { icon: 'shield', title: 'High-Value Expertise', description: 'Finance sports cars from RM300K to RM5M+. We understand exotic car valuation and market dynamics.' },
];

// Sports Car Categories
const equipmentTypes = [
  {
    name: 'Entry-Level Sports Cars',
    description: 'Accessible performance. Porsche Cayman/Boxster, BMW M2, Audi TT RS, Toyota GR Supra, Nissan Z.',
    applications: 'Daily sports car, weekend driving, track day starter'
  },
  {
    name: 'Premium Sports Cars',
    description: 'Serious performance machines. Porsche 911, BMW M3/M4, Mercedes AMG GT, Audi R8, Corvette.',
    applications: 'Enthusiast ownership, spirited driving, car meets'
  },
  {
    name: 'Supercars',
    description: 'Exotic performance. Ferrari, Lamborghini, McLaren, Aston Martin. The pinnacle of automotive engineering.',
    applications: 'Collection, statement ownership, exclusive experiences'
  },
  {
    name: 'Hypercars & Limited Editions',
    description: 'Ultra-rare machines. Ferrari SF90, McLaren 765LT, Lamborghini SVJ, Porsche GT3 RS, limited editions.',
    applications: 'Investment, exclusive collection, special occasions'
  },
  {
    name: 'Performance Sedans',
    description: 'Four-door performance. BMW M5, Mercedes E63 AMG, Audi RS6/RS7, Porsche Panamera Turbo.',
    applications: 'Daily driver with performance, family sports car'
  },
  {
    name: 'Classic & Collectible Sports Cars',
    description: 'Vintage performance icons. Classic Porsches, vintage Ferraris, collectible Japanese sports cars.',
    applications: 'Collection, investment, classic car events'
  },
];

// Premium Brands
const acceptedBrands = ['Porsche', 'Ferrari', 'Lamborghini', 'McLaren', 'Aston Martin', 'Bentley', 'BMW M', 'Mercedes-AMG', 'Audi RS/S', 'Maserati', 'Lotus', 'Alfa Romeo', 'Nissan GT-R', 'Corvette'];

// FAQs
const faqs = [
  {
    question: 'What is the financing range for sports cars?',
    answer: 'We finance sports cars from RM300,000 to RM5,000,000+. From entry-level Porsche Caymans to exotic Ferraris and Lamborghinis, we have financing solutions for serious enthusiasts.'
  },
  {
    question: 'Do you finance imported/recond sports cars?',
    answer: 'Yes, we finance AP (Approved Permit) and reconditioned sports cars. The vehicle must have valid Malaysian registration and proper import documentation.'
  },
  {
    question: 'What about sports cars for collection (not daily use)?',
    answer: 'We finance both daily drivers and collection vehicles. Usage pattern doesn\'t affect eligibility. We understand that exotic cars may have limited mileage.'
  },
  {
    question: 'Is vehicle inspection required?',
    answer: 'For pre-owned sports cars, an inspection or recent service history may be required. This ensures the vehicle\'s condition matches its value and protects your investment.'
  },
  {
    question: 'Do you finance modified sports cars?',
    answer: 'Factory-spec and lightly modified cars are generally accepted. Heavily modified vehicles are evaluated case-by-case based on modifications and value impact.'
  },
  {
    question: 'What documentation is needed for exotic car financing?',
    answer: 'IC, proof of substantial income, bank statements, and vehicle documents. For high-value exotics, additional income verification ensures responsible financing.'
  },
  {
    question: 'Can I finance a sports car as a second/third vehicle?',
    answer: 'Absolutely. Many clients finance sports cars as addition to their existing fleet. We evaluate overall financial capacity, not vehicle count.'
  },
];

const productSchema = generateProductSchema({
  name: 'Sports Car Financing Malaysia',
  description: pageDescription,
  brand: 'Ing Heng Credit',
  category: 'Financial Services > Vehicle Financing > Sports Car Loans'
});

const faqSchema = generateFAQSchema(faqs);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  keywords={keywords}
  lang={lang}
>
  <script type="application/ld+json" set:html={encodeJSONLD(productSchema)} />
  <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />

  <Breadcrumbs items={breadcrumbs} lang={lang} />

  <Hero
    title="Sports Car Financing Malaysia"
    subtitle="Finance your dream sports car. Porsche, Ferrari, Lamborghini, McLaren - all exotic brands welcome. Confidential premium service. Flexible terms for high-value vehicles."
    ctaText="Apply Now via WhatsApp"
    ctaLink="https://wa.me/60175700889?text=Hi%20I%27m%20interested%20in%20sports%20car%20financing"
    ctaSecondaryText="Calculate Payments"
    ctaSecondaryLink="#calculator"
    lang={lang}
    trustSignals={['Since 1985', 'Confidential Service', 'Exotic Car Specialists']}
  />

  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Premium Sports Car Financing</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {benefits.map(benefit => (
          <BenefitCard {...benefit} />
        ))}
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-4">Sports Cars We Finance</h2>
      <p class="text-center text-gray-600 mb-12 max-w-3xl mx-auto">
        From attainable sports cars to exotic supercars, we help enthusiasts own their dream machines.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {equipmentTypes.map(type => (
          <div class="bg-white p-6 rounded-lg shadow-md border border-gray-100">
            <h3 class="text-xl font-bold text-primary mb-3">{type.name}</h3>
            <p class="text-gray-600 mb-3">{type.description}</p>
            <p class="text-sm text-gray-500"><strong>Perfect for:</strong> {type.applications}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-12 bg-primary text-white">
    <div class="container mx-auto px-4">
      <h2 class="text-2xl font-bold text-center mb-8">Exotic Brands We Finance</h2>
      <div class="flex flex-wrap justify-center gap-4">
        {acceptedBrands.map(brand => (
          <span class="bg-white/20 px-4 py-2 rounded-full text-sm">{brand}</span>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16" id="calculator">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-4">Sports Car Payment Calculator</h2>
      <p class="text-center text-gray-600 mb-8">
        Calculate your monthly payment for that dream exotic.
      </p>
      <Calculator 
        lang={lang}
        defaultAmount={500000}
        minAmount={100000}
        maxAmount={5000000}
        defaultTerm={60}
        defaultRate={8}
      />
    </div>
  </section>

  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Sports Car Financing FAQ</h2>
      <div class="max-w-3xl mx-auto space-y-4">
        {faqs.map(faq => (
          <FAQItem question={faq.question} answer={faq.answer} />
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-primary text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to Own Your Dream Exotic?</h2>
      <p class="text-xl mb-8 opacity-90">
        Your dream sports car is within reach. Confidential consultation with our exotic car financing specialists.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://wa.me/60175700889?text=Hi%20I%27m%20interested%20in%20sports%20car%20financing" 
           class="bg-white text-primary px-8 py-4 rounded-lg font-bold hover:bg-gray-100 transition">
          WhatsApp Us Now
        </a>
        <a href="/en/contact" 
           class="border-2 border-white px-8 py-4 rounded-lg font-bold hover:bg-white/10 transition">
          Contact Form
        </a>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-8">Apply for Sports Car Financing</h2>
      <div class="max-w-2xl mx-auto">
        <ContactForm lang={lang} equipmentType="Sports Car" />
      </div>
    </div>
  </section>

</BaseLayout>
