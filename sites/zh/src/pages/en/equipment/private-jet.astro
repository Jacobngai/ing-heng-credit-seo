---
/**
 * Private Jet Financing Landing Page - English
 * Target: Ultra high net worth individuals, business owners, aviation enthusiasts
 * Keywords: private jet financing Malaysia, aircraft loan, business jet financing
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import FAQItem from '../../../components/FAQItem.astro';
import ContactForm from '../../../components/ContactForm.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { generateProductSchema, generateFAQSchema, encodeJSONLD } from '../../../utils/schema';

import { SITE_CONFIG } from '../../../utils/constants';
const lang = 'en';

const pageTitle = 'Private Jet Financing Malaysia | Aircraft Loan | Business Jet | Since 1985';
const pageDescription = 'Finance your private jet with flexible terms. Cessna, Gulfstream, Bombardier, Embraer. 0% deposit available. Business jets, turboprops, light jets. Confidential aviation financing since 1985.';
const keywords = ['private jet financing Malaysia', 'aircraft loan Malaysia', 'business jet financing', 'Gulfstream financing', 'Cessna Citation loan'];

const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Hobby Financing', url: '/en/equipment' },
  { label: 'Private Jet Financing', url: '/en/equipment/private-jet' },
];

const benefits = [
  { icon: 'percentage', title: '0% Deposit Available', description: 'Full loan financing for qualified applicants. Finance up to 100% of aircraft value. Preserve capital for operations and hangar.' },
  { icon: 'star', title: 'Confidential Service', description: 'Discrete, professional consultation. Your financial details and aircraft purchase handled with complete privacy.' },
  { icon: 'shield', title: 'New & Pre-Owned', description: 'Finance factory-new jets or certified pre-owned aircraft. We evaluate airframe hours, maintenance records, and condition.' },
  { icon: 'calendar', title: 'Extended Terms', description: 'Terms up to 15 years for newer aircraft. Structured payments aligned with aircraft useful life and your cash flow.' },
  { icon: 'document', title: 'Aviation Expertise', description: 'We understand aircraft valuation, pre-purchase inspections, and aviation industry requirements. Not just financing - partnership.' },
  { icon: 'money', title: 'High-Value Capability', description: 'Finance jets from RM 5 million to RM 200 million+. We have experience with significant aviation transactions.' },
];

const equipmentTypes = [
  {
    name: 'Very Light Jets (VLJ)',
    description: 'Entry-level private jets. Cessna Citation M2, Embraer Phenom 100, HondaJet. 4-6 passengers, short-medium range.',
    applications: 'Regional travel, business trips, personal use',
    priceRange: 'RM 15,000,000 - RM 30,000,000'
  },
  {
    name: 'Light Jets',
    description: 'Cessna Citation CJ series, Embraer Phenom 300, Pilatus PC-24. 6-8 passengers, medium range.',
    applications: 'Cross-country business travel, charter operations',
    priceRange: 'RM 30,000,000 - RM 60,000,000'
  },
  {
    name: 'Midsize Jets',
    description: 'Cessna Citation Latitude, Embraer Praetor 500, Hawker 800. 8-10 passengers, transcontinental range.',
    applications: 'International business travel, corporate fleet',
    priceRange: 'RM 50,000,000 - RM 100,000,000'
  },
  {
    name: 'Super Midsize Jets',
    description: 'Gulfstream G280, Bombardier Challenger 350, Cessna Citation Longitude. Premium cabin, long range.',
    applications: 'International executive travel, corporate transport',
    priceRange: 'RM 80,000,000 - RM 130,000,000'
  },
  {
    name: 'Large Cabin Jets',
    description: 'Gulfstream G650, Bombardier Global 7500, Dassault Falcon 8X. Ultimate in private aviation.',
    applications: 'Ultra-long-haul, heads of state, UHNW individuals',
    priceRange: 'RM 150,000,000 - RM 300,000,000+'
  },
  {
    name: 'Turboprops',
    description: 'Pilatus PC-12, Beechcraft King Air, Daher TBM. Efficient, versatile single and twin turboprops.',
    applications: 'Short runway operations, regional connectivity, utility',
    priceRange: 'RM 10,000,000 - RM 40,000,000'
  },
];

const acceptedBrands = ['Gulfstream', 'Bombardier', 'Cessna', 'Embraer', 'Dassault', 'Pilatus', 'Beechcraft', 'HondaJet', 'Cirrus', 'Textron Aviation'];

const faqs = [
  {
    question: 'What is the typical down payment for private jet financing?',
    answer: '0% deposit (full loan) financing is available for qualified applicants. We can finance up to 100% of aircraft value, preserving your capital for operations, crew, hangar, and maintenance. This is our specialty since 1985.'
  },
  {
    question: 'What types of private jets do you finance?',
    answer: 'We finance all categories: very light jets, light jets, midsize, super midsize, large cabin jets, and turboprops. Both new and pre-owned aircraft from reputable manufacturers like Gulfstream, Bombardier, Cessna, Embraer, and Dassault.'
  },
  {
    question: 'Can I finance a pre-owned private jet?',
    answer: 'Absolutely. We have extensive experience with pre-owned aircraft financing. The aircraft should have documented maintenance history, current inspections, and be enrolled in maintenance programs. Pre-purchase inspection recommended.'
  },
  {
    question: 'How long are aircraft financing terms?',
    answer: 'Terms range from 5-15 years depending on aircraft age, type, and configuration. Newer jets qualify for longer terms. We structure payments to match aircraft useful life and your cash flow requirements.'
  },
  {
    question: 'What documentation is needed?',
    answer: 'Aircraft documents, proof of substantial income/net worth, bank statements. For corporate purchases: company financials, board resolution. The process is thorough but efficient for qualified applicants.'
  },
  {
    question: 'Is the financing process confidential?',
    answer: 'Completely. We maintain strict confidentiality for all high-value transactions. Your financial details and aircraft purchase are handled with absolute discretion. Many prominent individuals trust us for this reason.'
  },
  {
    question: 'Do you help with aircraft registration?',
    answer: 'We can guide you through Malaysian CAAM registration requirements or advise on offshore registration options (Cayman, Isle of Man, etc.) based on your operational needs and tax considerations.'
  },
  {
    question: 'Can I finance an aircraft for charter operations?',
    answer: 'Yes, we finance aircraft intended for charter/commercial operations. Additional documentation about your AOC (Air Operator Certificate) and business plan may be required. Revenue-generating aircraft are acceptable.'
  },
];

const productSchema = generateProductSchema({
  name: 'Private Jet Financing Malaysia',
  description: pageDescription,
  brand: 'Ing Heng Credit',
  price: '15000000',
  priceCurrency: 'MYR',
});

const faqSchema = generateFAQSchema(faqs);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
  keywords={keywords}
>
  <script type="application/ld+json" set:html={encodeJSONLD(productSchema)} />
  <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />
  
  <Breadcrumbs items={breadcrumbs} lang={lang} />

  <Hero
    title="Private Jet Financing"
    subtitle="Finance your private jet with 0% deposit. Gulfstream, Bombardier, Cessna, Embraer. Business jets and turboprops. Confidential service since 1985."
    ctaText="Confidential Inquiry"
    ctaLink="https://wa.me/60175700889?text=Hi%20I'm%20interested%20in%20private%20jet%20financing"
    lang={lang}
    trustSignals={['Since 1985', 'Confidential', 'Full Loan Available']}
  />

  <!-- Benefits Section -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Why Finance Your Aircraft With Us?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {benefits.map(benefit => (
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <div class="text-4xl mb-4">✈️</div>
            <h3 class="text-xl font-bold mb-2">{benefit.title}</h3>
            <p class="text-gray-600">{benefit.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Aircraft Types -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-4">Aircraft Categories We Finance</h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
        From turboprops to large cabin jets - comprehensive aviation financing
      </p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {equipmentTypes.map(type => (
          <div class="bg-white rounded-xl shadow-lg border border-gray-100 p-6">
            <h3 class="text-xl font-bold text-primary mb-3">{type.name}</h3>
            <p class="text-gray-600 mb-4">{type.description}</p>
            <div class="space-y-2 text-sm">
              <p><strong>Use:</strong> {type.applications}</p>
              <p><strong>Price Range:</strong> {type.priceRange}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Accepted Brands -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-8">Manufacturers We Finance</h2>
      <div class="flex flex-wrap justify-center gap-4">
        {acceptedBrands.map(brand => (
          <span class="bg-white px-4 py-2 rounded-full text-sm font-medium border">{brand}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Frequently Asked Questions</h2>
      <div class="max-w-3xl mx-auto space-y-4">
        {faqs.map(faq => (
          <FAQItem question={faq.question} answer={faq.answer} />
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16" style="background: linear-gradient(135deg, #2D1810, #4C3729); color: white;">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4" style="color: white;">Ready to Discuss Aircraft Financing?</h2>
      <p class="text-xl mb-8" style="color: white; opacity: 0.9;">
        Confidential consultation. No obligation. Discrete and professional.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://wa.me/60175700889?text=Hi%20I'm%20interested%20in%20private%20jet%20financing" 
           class="bg-white text-primary px-8 py-4 rounded-lg font-bold hover:bg-gray-100 transition">
          Confidential Inquiry
        </a>
        <a href="/en/contact" 
           class="border-2 border-white px-8 py-4 rounded-lg font-bold hover:bg-white/10 transition" style="color: white;">
          Contact Form
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="max-w-2xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-4">Request Confidential Quote</h2>
        <p class="text-center text-gray-600 mb-8">Submit your inquiry and we'll contact you within 24 hours.</p>
        <ContactForm lang={lang} />
      </div>
    </div>
  </section>

</BaseLayout>
