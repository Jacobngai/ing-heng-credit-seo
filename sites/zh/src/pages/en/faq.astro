---
/**
 * FAQ Page - Hobby Financing
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQItem from '../../components/FAQItem.astro';
import { generateFAQSchema, encodeJSONLD } from '../../utils/schema';

const lang = 'en';

const pageTitle = 'FAQ | Hobby Financing Malaysia | Motorcycles, Boats, Sports Cars';
const pageDescription = 'Frequently asked questions about motorcycle financing, boat loans, and sports car financing in Malaysia. Learn about deposits, terms, and requirements.';

const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'FAQ', url: '/en/faq' },
];

const faqs = [
  {
    question: 'What types of vehicles do you finance?',
    answer: 'We specialize in hobby and lifestyle vehicle financing including: motorcycles and superbikes (all brands), boats and marine equipment (fishing boats, speedboats, yachts, jet skis), and sports cars (Porsche, Ferrari, Lamborghini, BMW M, Mercedes AMG, etc.).'
  },
  {
    question: 'Is a down payment required?',
    answer: 'We offer 0% deposit financing for qualified applicants. This means you can own your dream vehicle without any upfront payment. Terms and conditions apply based on your credit profile and vehicle value.'
  },
  {
    question: 'Can I finance a used motorcycle, boat, or car?',
    answer: 'Yes! We finance both new and pre-owned vehicles. Used motorcycles and cars up to 10 years old, and boats up to 15 years old may qualify, subject to condition assessment.'
  },
  {
    question: 'What documents are required to apply?',
    answer: 'Basic documents include: IC (front and back), proof of income (payslips for employed, business documents for self-employed), 3-6 months bank statements, and the vehicle quotation or details.'
  },
  {
    question: 'How long are the repayment terms?',
    answer: 'We offer flexible terms: motorcycles up to 7 years, boats up to 10 years, and sports cars up to 7 years. Longer terms mean lower monthly payments. Choose what fits your budget.'
  },
  {
    question: 'What are your interest rates?',
    answer: 'Interest rates range from 8-18% per annum depending on vehicle type, loan amount, tenure, and your credit profile. We provide transparent quotes with no hidden fees.'
  },
  {
    question: 'Can I apply if I have bad credit?',
    answer: 'We evaluate applications holistically. While credit history is considered, we also look at your current income, employment stability, and overall financial situation. Many applicants with past credit issues have been approved.'
  },
  {
    question: 'Do you finance imported or grey market vehicles?',
    answer: 'Yes, we can finance AP (Approved Permit) vehicles and parallel imports. The vehicle must have valid Malaysian registration. Additional documentation may be required.'
  },
  {
    question: 'How long does approval take?',
    answer: 'Our team evaluates applications efficiently. Once all documents are submitted, you\'ll receive a response promptly. Urgent cases are handled with priority.'
  },
  {
    question: 'Can I settle my loan early?',
    answer: 'Yes! Early settlement is allowed with no penalty. You can pay off your loan anytime and save on future interest. Contact us for your settlement quote.'
  },
  {
    question: 'Is insurance required?',
    answer: 'Comprehensive insurance is required for financed vehicles. This protects both you and the asset. We can recommend insurance partners who specialize in motorcycles, boats, and sports cars.'
  },
  {
    question: 'Can I finance a vehicle as a second/third purchase?',
    answer: 'Absolutely. Many of our clients finance hobby vehicles in addition to their existing assets. We evaluate your overall financial capacity, not just single-vehicle ownership.'
  },
];

const faqSchema = generateFAQSchema(faqs);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
>
  <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />
  
  <Breadcrumbs items={breadcrumbs} lang={lang} />

  <!-- Hero -->
  <section class="py-16 bg-gradient-to-br from-primary to-secondary text-white">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Frequently Asked Questions</h1>
      <p class="text-xl opacity-90">Everything you need to know about hobby financing</p>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto space-y-4">
        {faqs.map(faq => (
          <div class="border border-gray-200 rounded-lg overflow-hidden">
            <details class="group">
              <summary class="flex justify-between items-center p-6 cursor-pointer hover:bg-gray-50 transition-colors">
                <h3 class="font-bold text-lg pr-4">{faq.question}</h3>
                <span class="text-2xl text-primary group-open:rotate-180 transition-transform">▼</span>
              </summary>
              <div class="px-6 pb-6">
                <p class="text-gray-700 leading-relaxed">{faq.answer}</p>
              </div>
            </details>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Still Have Questions -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold mb-4">Still Have Questions?</h2>
      <p class="text-gray-600 mb-8">Our hobby financing specialists are ready to help.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://wa.me/60175700889" 
           class="bg-primary text-white px-8 py-4 rounded-lg font-bold hover:bg-primary/90 transition">
          WhatsApp Us
        </a>
        <a href="/en/contact" 
           class="border-2 border-primary text-primary px-8 py-4 rounded-lg font-bold hover:bg-primary/10 transition">
          Contact Form
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
