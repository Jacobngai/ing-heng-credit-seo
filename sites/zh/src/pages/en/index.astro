---
/**
 * Hobby Financing Homepage - English
 * Target: Motorcycle enthusiasts, boat owners, sports car collectors
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import BenefitCard from '../../components/BenefitCard.astro';
import ContactForm from '../../components/ContactForm.astro';
import StructuredData from '../../components/StructuredData.astro';
import { generateOrganizationSchema } from '../../utils/schema';
import { COMPANY_INFO } from '../../utils/constants';

const lang = 'en';
const organizationSchema = generateOrganizationSchema();

const categories = [
  {
    title: 'Motorcycle Financing',
    description: 'Yamaha, Honda, Kawasaki, BMW, and all major brands',
    url: '/en/equipment/motorcycle',
    icon: '🏍️',
    range: 'RM5K - RM500K'
  },
  {
    title: 'Superbike Financing',
    description: 'Ducati, BMW S1000RR, Aprilia, MV Agusta',
    url: '/en/equipment/superbike',
    icon: '🏎️',
    range: 'RM50K - RM800K'
  },
  {
    title: 'Boat & Marine',
    description: 'Fishing boats, speedboats, yachts, jet skis',
    url: '/en/equipment/boat',
    icon: '⛵',
    range: 'RM30K - RM2M+'
  },
  {
    title: 'Sports Car Financing',
    description: 'Porsche, Ferrari, Lamborghini, McLaren',
    url: '/en/equipment/sports-car',
    icon: '🚗',
    range: 'RM300K - RM5M+'
  },
];

const benefits = [
  { icon: '💰', title: '0% Deposit Available', description: 'Finance up to 100% for qualified applicants. Keep your cash for other needs.' },
  { icon: '📋', title: 'Simple Documentation', description: 'IC, income proof, bank statements. No complicated paperwork required.' },
  { icon: '✅', title: 'New & Used Accepted', description: 'Finance new or pre-owned. Well-maintained vehicles up to 10+ years accepted.' },
  { icon: '🏆', title: 'Since 1985', description: '40 years of trusted financing in Malaysia. 4,000+ happy customers.' },
  { icon: '🔄', title: 'Flexible Terms', description: 'Choose terms from 1-10 years. Monthly payments that fit your budget.' },
  { icon: '🤝', title: 'Bad Credit Considered', description: 'We evaluate your full picture. Past credit issues don\'t automatically disqualify.' },
];
---

<BaseLayout
  title="Hobby Financing Malaysia | Motorcycles, Boats, Sports Cars | Since 1985"
  description="Finance your passion. Motorcycles, superbikes, boats, and sports cars. 0% deposit available. New & used accepted. Trusted since 1985. WhatsApp for instant quote."
  lang={lang}
  keywords={[
    'motorcycle financing Malaysia',
    'boat financing Malaysia',
    'sports car financing',
    'superbike loan Malaysia',
    'hobby financing',
    'marine financing Malaysia',
    'exotic car loan',
    'Ducati financing',
    'Porsche financing Malaysia'
  ]}
>
  <StructuredData schema={organizationSchema} />

  <!-- Hero Section -->
  <section class="hero relative overflow-hidden bg-gradient-to-br from-primary to-secondary py-20">
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold text-white mb-6">
          Finance Your <span class="text-yellow-400">Passion</span>
        </h1>
        <p class="text-xl md:text-2xl text-white/90 mb-8 leading-relaxed">
          Motorcycles. Superbikes. Boats. Sports Cars.<br/>
          0% deposit available. Flexible terms up to 10 years. Since 1985.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://wa.me/60175700889?text=Hi%20I%27m%20interested%20in%20hobby%20financing" 
             class="bg-yellow-400 text-navy-900 px-8 py-4 rounded-lg font-bold text-lg hover:bg-yellow-300 transition">
            WhatsApp Us Now
          </a>
          <a href="#categories" 
             class="border-2 border-white text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-white/10 transition">
            View Options
          </a>
        </div>
        <div class="mt-8 flex flex-wrap justify-center gap-6 text-white/80">
          <span>✓ Since 1985</span>
          <span>✓ KPKT Licensed</span>
          <span>✓ 4,000+ Funded</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories Section -->
  <section class="py-16" id="categories">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-4">What Would You Like to Finance?</h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">
        Choose your passion. We offer flexible financing for motorcycles, boats, and exotic cars.
      </p>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {categories.map(cat => (
          <a href={cat.url} class="group">
            <div class="bg-white rounded-xl shadow-lg border border-gray-100 p-6 hover:shadow-xl transition-shadow text-center">
              <div class="text-5xl mb-4">{cat.icon}</div>
              <h3 class="text-xl font-bold text-primary mb-2">{cat.title}</h3>
              <p class="text-gray-600 text-sm mb-3">{cat.description}</p>
              <p class="text-primary font-semibold text-sm">{cat.range}</p>
              <span class="text-primary text-sm group-hover:underline mt-4 block">Learn More →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Why Finance With Us?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {benefits.map(benefit => (
          <div class="bg-white rounded-lg p-6 shadow-sm">
            <div class="text-4xl mb-4">{benefit.icon}</div>
            <h3 class="text-xl font-bold mb-2">{benefit.title}</h3>
            <p class="text-gray-600">{benefit.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">How It Works</h2>
      <div class="grid grid-cols-1 md:grid-cols-5 gap-8 max-w-5xl mx-auto">
        <div class="text-center">
          <div class="w-16 h-16 bg-blue-800 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">1</div>
          <h3 class="font-bold mb-2">Contact Us</h3>
          <p class="text-gray-600 text-sm">WhatsApp or call us with your vehicle details</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-blue-800 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">2</div>
          <h3 class="font-bold mb-2">Submit Docs</h3>
          <p class="text-gray-600 text-sm">IC, income proof, bank statements</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-blue-800 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">3</div>
          <h3 class="font-bold mb-2">Get Approved</h3>
          <p class="text-gray-600 text-sm">Receive your approval decision</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-blue-800 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">4</div>
          <h3 class="font-bold mb-2">Sign Agreement</h3>
          <p class="text-gray-600 text-sm">Review and sign loan documents</p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-blue-800 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-4">5</div>
          <h3 class="font-bold mb-2">Get Your Vehicle</h3>
          <p class="text-gray-600 text-sm">Collect and enjoy your purchase!</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-blue-800 text-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to Finance Your Dream?</h2>
      <p class="text-xl mb-8 opacity-90">
        Get started with a free consultation. No obligation. Our specialists are ready to help.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://wa.me/60175700889?text=Hi%20I%27m%20interested%20in%20hobby%20financing" 
           class="bg-yellow-400 text-navy-900 px-8 py-4 rounded-lg font-bold hover:bg-yellow-300 transition">
          WhatsApp Us Now
        </a>
        <a href="/en/contact" 
           class="border-2 border-white px-8 py-4 rounded-lg font-bold hover:bg-white/10 transition">
          Contact Form
        </a>
      </div>
      <p class="mt-6 text-sm opacity-75">
        Or call us: <a href="tel:+60175700889" class="underline">017-570 0889</a>
      </p>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-4">Get a Free Quote</h2>
      <p class="text-center text-gray-600 mb-8">
        Fill out the form below and we'll contact you within 24 hours.
      </p>
      <div class="max-w-2xl mx-auto">
        <ContactForm lang={lang} />
      </div>
    </div>
  </section>

</BaseLayout>
