---
/**
 * ProductCard Component
 * Card for displaying equipment/product information with pricing
 */

import type { Locale } from '../utils/i18n';
import { t, formatCurrency } from '../utils/i18n';

interface Props {
  name: string;
  description: string;
  features?: string[];
  link?: string;
  lang: Locale;
  image?: string;
  badge?: string;
}

const {
  name,
  description,
  features = [],
  link,
  lang,
  image,
  badge,
} = Astro.props;
---

<div class="relative group cursor-pointer overflow-hidden border border-black/5 bg-white shadow-xl hover:shadow-2xl transition-all duration-700 h-full flex flex-col">
  {/* Product Image */}
  {image && (
    <div class="aspect-[16/10] overflow-hidden relative">
      <img
        src={image}
        alt={name}
        class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-[#0A0A0A]/60 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
      
      {badge && (
        <span class="absolute top-6 right-6 bg-[#D4A574] text-white font-display tracking-widest text-[10px] uppercase px-4 py-2">
          {badge}
        </span>
      )}
    </div>
  )}

  <div class="p-8 md:p-10 flex flex-col flex-grow bg-white items-start">
    {/* Product Name */}
    <h3 class="text-3xl text-[#0A0A0A] mb-4 group-hover:text-[#8B6F47] transition-all uppercase leading-none font-display tracking-tight">
      {name}
    </h3>

    {/* Description */}
    <p class="text-[#1A140D]/60 text-sm font-light mb-8 leading-relaxed line-clamp-3">
      {description}
    </p>

    {/* Features List */}
    {features.length > 0 && (
      <ul class="space-y-3 mb-10 flex-grow w-full border-t border-black/5 pt-8 mt-auto">
        {features.map((feature) => (
          <li class="flex items-center gap-3">
            <div class="w-1.5 h-1.5 bg-[#8B6F47] rounded-full"></div>
            <span class="text-[11px] uppercase tracking-widest text-[#0A0A0A]/80 font-medium">{feature}</span>
          </li>
        ))}
      </ul>
    )}

    {/* CTA Button */}
    {link && (
      <a
        href={link}
        class="w-full border border-black text-[#0A0A0A] font-display uppercase tracking-widest text-sm py-4 text-center hover:bg-[#0A0A0A] hover:text-white transition-all duration-500"
      >
        {t('common.getStarted', lang)}
      </a>
    )}
  </div>
</div>

<style>
    h3 {
        font-family: 'Bebas Neue', var(--font-display);
    }
</style>
