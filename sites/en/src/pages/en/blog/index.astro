---
/**
 * English Blog Index Page - Overhauled with Midnight Luxe Design
 * Expert Insights & Direct Partnership Advice
 */

import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const lang = 'en';

// Get blog posts from Content Collections
const allMdPosts = await getCollection('blogs');
const mdPosts = allMdPosts
  .filter(post => post.data.locale === lang)
  .map(post => ({
    title: post.data.title,
    excerpt: post.data.description,
    slug: post.slug.includes('/') ? post.slug.split('/').pop() : post.slug,
    date: typeof post.data.publishDate === 'string' ? post.data.publishDate : post.data.publishDate.toISOString(),
    author: post.data.author,
    category: post.data.category,
    readTime: post.data.readingTime || 5,
    featured: post.data.featured,
    image: post.data.ogImage || `/images/blog/${post.slug}.jpg`,
  }));

// Sort by date
const sortedPosts = mdPosts.sort((a, b) =>
  new Date(b.date).valueOf() - new Date(a.date).valueOf()
);

const featuredPosts = sortedPosts.filter(p => p.featured).slice(0, 3);
const displayFeaturedPosts = featuredPosts.length > 0 ? featuredPosts : sortedPosts.slice(0, 1);

// Categories
const categories = [
  { name: 'Equipment Financing', slug: 'equipment-financing-tips', icon: '🏗️' },
  { name: 'Industry Insights', slug: 'industry-news-trends', icon: '📰' },
  { name: 'Growth Strategies', slug: 'business-growth', icon: '📈' },
  { name: 'How-To Guides', slug: 'contractor-guides', icon: '👷' },
];
---

<BaseLayout
  title="Expert Insights. Better Finance. | Ing Heng Blog"
  description="Learn from 40+ years of equipment financing expertise. Practical tips, ROI strategies, and industrial insights banks don't tell you."
  lang={lang}
>
  <!-- HERO: EXPERT INSIGHTS (Midnight Theme) -->
  <section class="relative min-h-[60vh] flex items-center bg-[#0A0A0A] pt-20 overflow-hidden">
    <div class="absolute top-[-10%] right-[-10%] w-[40%] h-[40%] bg-[#8B6F47]/10 blur-[120px] rounded-full"></div>
    
    <div class="container-custom relative z-10">
      <div class="max-w-4xl">
        <span class="inline-block text-[#D4A574] font-display tracking-[0.4em] uppercase text-sm mb-6 font-bold">The Direct Advantage Hub</span>
        <h1 class="text-white leading-[0.9] mb-8">
          EXPERT <span class="text-[#D4A574]">INSIGHTS.</span><br />
          BETTER FINANCE.
        </h1>
        <p class="text-white/60 text-xl font-light max-w-2xl mb-12 leading-relaxed">
          We don't just lend money; we share the knowledge you need to grow your fleet and avoid the common traps that banks and agents set. No metaphors. Just ROI.
        </p>
      </div>
    </div>
  </section>

  <!-- CATEGORY NAV: (Daylight Theme) -->
  <section class="bg-white py-12 border-b border-black/5 relative z-20">
    <div class="container-custom">
      <div class="flex flex-wrap justify-center gap-6 md:gap-12">
        {categories.map((cat) => (
          <a href={`/${lang}/blog/category/${cat.slug}`} class="group flex items-center gap-3">
            <span class="text-xl group-hover:scale-125 transition-transform">{cat.icon}</span>
            <span class="font-display uppercase tracking-widest text-sm text-[#0A0A0A]/40 group-hover:text-[#8B6F47] transition-colors">{cat.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURED: THE LEADERSHIP (Alloy Theme) -->
  <section class="bg-[#F5F5F5] py-24">
    <div class="container-custom">
      <div class="grid lg:grid-cols-2 gap-12 items-center mb-24">
        {displayFeaturedPosts.map((post) => (
            <div class="relative group cursor-pointer overflow-hidden border border-black/5 bg-white shadow-xl">
                <div class="aspect-[16/9] overflow-hidden">
                    <img src={post.image} alt={post.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000" />
                </div>
                <div class="p-12">
                    <span class="text-[#8B6F47] font-display tracking-widest text-xs uppercase mb-4 block">Featured Insight</span>
                    <h2 class="text-4xl text-[#0A0A0A] mb-6 group-hover:text-[#8B6F47] transition-all uppercase leading-tight font-display tracking-tighter">{post.title}</h2>
                    <p class="text-[#1A140D]/60 font-light mb-8 line-clamp-3">{post.excerpt}</p>
                    <a href={`/${lang}/blog/${post.slug}`} class="border-b border-[#0A0A0A] text-[#0A0A0A] font-display uppercase tracking-widest text-sm py-2 hover:border-[#8B6F47] hover:text-[#8B6F47] transition-all inline-block">Read Full Insight →</a>
                </div>
            </div>
        ))}

        <div class="space-y-8">
            <div class="bg-[#0A0A0A] p-12 text-white border-l-4 border-[#8B6F47]">
                <h3 class="font-display text-2xl uppercase mb-4 tracking-widest">Why we share this?</h3>
                <p class="text-white/60 font-light leading-relaxed">
                    A smarter borrower is a better partner. When you know how to calculate your ROI properly, you succeed. When you succeed, we succeed. This is direct partnership.
                </p>
            </div>
            <div class="bg-white p-12 border border-black/5">
                <span class="text-[#8B6F47] font-display tracking-widest text-xs uppercase mb-4 block">Direct Contact</span>
                <h3 class="text-2xl text-[#0A0A0A] font-display uppercase mb-6 tracking-widest">Need a Finance Answer Now?</h3>
                <a href="https://wa.me/60175700889" class="bg-[#8B6F47] text-white font-display text-xl tracking-widest px-8 py-4 hover:bg-[#0A0A0A] transition-all inline-block uppercase w-full text-center">Ask a Specialist</a>
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- RECENT INSIGHTS: (Daylight Theme) -->
  <section class="bg-white py-24">
    <div class="container-custom">
        <div class="mb-16">
            <h2 class="text-[#0A0A0A] text-5xl uppercase font-display tracking-tighter">Recent <span class="text-[#D4A574]">Insights.</span></h2>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-12">
            {sortedPosts.slice(1, 7).map((post) => (
                <div class="group cursor-pointer">
                    <div class="aspect-[4/3] overflow-hidden bg-[#F5F5F5] border border-black/5 mb-8">
                        <img src={post.image} alt={post.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                    </div>
                    <span class="text-[#0A0A0A]/40 font-display tracking-widest text-[10px] uppercase mb-3 block">{post.category} • {post.readTime}m Read</span>
                    <h3 class="text-2xl text-[#0A0A0A] font-display uppercase tracking-tighter leading-tight mb-4 group-hover:text-[#8B6F47] transition-all">{post.title}</h3>
                    <p class="text-[#1A140D]/60 text-sm font-light mb-6 line-clamp-2">{post.excerpt}</p>
                    <a href={`/${lang}/blog/${post.slug}`} class="text-[#0A0A0A] font-display uppercase tracking-widest text-xs border-b border-[#0A0A0A] pb-1 group-hover:text-[#8B6F47] group-hover:border-[#8B6F47] transition-all">Read More →</a>
                </div>
            ))}
        </div>
    </div>
  </section>

  <!-- CTA: (Midnight Theme) -->
  <section class="bg-[#0A0A0A] py-24 text-center">
    <div class="container-custom">
        <h2 class="text-white text-4xl font-display uppercase tracking-widest mb-8">Ready to grow your business?</h2>
        <a href="https://wa.me/60175700889" class="bg-[#8B6F47] text-white font-display text-2xl tracking-widest px-12 py-6 hover:bg-white hover:text-[#0A0A0A] transition-all uppercase inline-block">Start Your Application</a>
    </div>
  </section>
</BaseLayout>

<style>
    h1, h2, h3 {
        font-family: 'Bebas Neue', var(--font-display);
        letter-spacing: 0.05em;
    }
</style>
