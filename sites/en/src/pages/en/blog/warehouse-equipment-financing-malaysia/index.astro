                <td class="px-4 py-3 border-b border-[#D4A574]">Extremely strict (3 years audited accounts)</td>
                <td class="px-4 py-3 border-b border-[#D4A574] text-green-700 font-bold">Practical (Bank statements & SSM)</td>
              </tr>
              <tr class="bg-[#F5F1EC]">
                <td class="px-4 py-3 border-b border-[#D4A574] font-bold">New Businesses</td>
                <td class="px-4 py-3 border-b border-[#D4A574]">Usually rejected</td>
                <td class="px-4 py-3 border-b border-[#D4A574] text-green-700 font-bold">Welcome (min 6 months operation)</td>
