---
/**
 * Hobby Financing Hub Page - English
 * Main hub page showcasing all hobby financing categories
 * SEO: Hobby financing Malaysia, classic car financing, motorcycle financing
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import HobbyCard from '../../../components/HobbyCard.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import FAQItem from '../../../components/FAQItem.astro';

import { COMPANY_INFO } from '../../../utils/constants';
import { encodeJSONLD } from '../../../utils/schema';

const lang = 'en';

// SEO Data
const pageTitle = 'Your Passion. Our Capital. | Hobby Financing | Ing Heng Credit';
const pageDescription = 'Banks say no to old cars. We say yes. Finance classic cars, JDM legends, superbikes, and yachts with no age limit. Expert assessment for collectors.';
const keywords = [
  'hobby financing Malaysia',
  'classic car financing',
  'vintage car loan',
  'motorcycle financing',
  'boat financing',
  'yacht financing',
  'RV financing',
  'collector car financing',
  'JDM car financing',
  'old car loan Malaysia'
];

// Breadcrumbs
const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Hobby Financing', url: '/en/hobby' },
];

// Category Cards
const categoryCards = [
  {
    title: 'Classic Cars',
    description: 'Finance your dream collector car. We finance vintage JDM legends, European classics, and American muscle with no age limit.',
    image: '/images/hobby/classic-cars-card.jpg',
    href: '/en/hobby/classic-cars',
    items: ['JDM Legends', 'European Classics', 'American Muscle'],
    badge: 'Popular'
  },
  {
    title: 'Motorcycles',
    description: 'Classic and vintage motorcycle financing. Harley-Davidson, Japanese vintage, and European superbikes.',
    image: '/images/hobby/motorcycles-card.jpg',
    href: '/en/hobby/motorcycles',
    items: ['Harley-Davidson', 'Japanese Vintage', 'European Bikes']
  },
  {
    title: 'Boats & Yachts',
    description: 'Own your dream boat. Yachts, speedboats, fishing boats, and jet skis - all types of marine financing.',
    image: '/images/hobby/marine-card.jpg',
    href: '/en/hobby/marine',
    items: ['Yachts', 'Speedboats', 'Jet Ski']
  },
  {
    title: 'Recreational Vehicles',
    description: 'Adventure awaits. Motorhomes, ATVs, UTVs, and golf carts for your outdoor lifestyle.',
    image: '/images/hobby/recreational-card.jpg',
    href: '/en/hobby/recreational',
    items: ['Motorhomes', 'ATV/UTV', 'Golf Carts']
  },
  {
    title: 'Aircraft',
    description: 'Helicopter and small aircraft financing for aviation enthusiasts. Take flight today.',
    image: '/images/hobby/aircraft-card.jpg',
    href: '/en/hobby/aircraft',
    items: ['Helicopters', 'Small Planes', 'Gyrocopters']
  },
  {
    title: "Special Requests",
    description: "Found something unique? We finance specialized collectibles and rare assets that banks don't understand.",
    image: '/images/hobby/custom-card.jpg',
    href: 'https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20inquire%20about%20custom%20hobby%20financing.',
    badge: 'Specialist'
  }
];

// Specialist Benefits
const benefits = [
  {
    icon: 'search',
    title: 'Expert Valuation',
    description: 'Banks use "book value." We use "market value." We know a pristine 90s GTR is worth more than zero.'
  },
  {
    icon: 'infinity',
    title: 'No Age Limit',
    description: 'We finance vintage and collectible vehicles regardless of age. 50-year-old icons are welcome.'
  },
  {
    icon: 'clock',
    title: 'Direct Capital',
    description: 'No middleman. No data blasting. You talk directly to the decision makers who fund your passion.'
  }
];

// FAQs - Simplified
const faqs = [
  {
    question: 'Can I finance a 30-year-old car?',
    answer: 'Yes. Banks usually refuse cars older than 10-15 years. We have no age limit. If the car is worth the money, we give you the loan.'
  },
  {
    question: 'How do you decide the car value?',
    answer: 'Banks look at a chart. We look at the actual market. Our experts understand why certain classic cars and bikes cost more, and we fund them based on that real value.'
  },
  {
    question: 'What is the maximum loan?',
    answer: 'We can finance up to RM 1,000,000 for high-value collectibles like yachts or rare classic cars.'
  }
];

// Schema
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Hobby Financing Categories',
  description: 'Specialized hobby financing for classic cars, bikes, and boats in Malaysia',
  itemListElement: categoryCards.map((card, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    item: {
      '@type': 'Product',
      name: card.title,
      description: card.description,
    }
  }))
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
  keywords={keywords}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={encodeJSONLD(itemListSchema)} />
  </Fragment>

  <!-- HERO: YOUR PASSION (Midnight Theme) -->
  <section class="relative min-h-[70vh] flex items-center bg-[#0A0A0A] pt-20 overflow-hidden">
    <div class="absolute top-[-10%] right-[-10%] w-[40%] h-[40%] bg-[#8B6F47]/15 blur-[120px] rounded-full"></div>
    
    <div class="container-custom relative z-10">
      <div class="max-w-4xl">
        <span class="inline-block text-[#D4A574] font-display tracking-[0.4em] uppercase text-sm mb-6 font-bold">Collector Asset Specialists</span>
        <h1 class="text-white leading-[0.9] mb-8">
          YOUR PASSION. <br />
          <span class="text-[#D4A574]">OUR CAPITAL.</span>
        </h1>
        <p class="text-white/70 text-xl font-light max-w-2xl mb-12 leading-relaxed">
          Banks say no to old cars. We say yes. We provide direct financing for classic cars, superbikes, and yachts with no age limit. You found the asset—we have the money.
        </p>

        <div class="flex flex-wrap gap-4">
            <a href="https://wa.me/60175700889" class="bg-[#8B6F47] text-white font-display text-xl tracking-widest px-10 py-5 hover:bg-white hover:text-[#0A0A0A] transition-all uppercase">Get a Quote →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CATEGORIES: CHOOSE PASSION (Daylight Theme) -->
  <section class="bg-white py-24 md:py-32 rounded-t-[40px] -mt-10 relative z-20">
    <div class="container-custom">
      <div class="text-center mb-16">
        <span class="text-[#8B6F47] font-display tracking-[0.3em] uppercase text-sm mb-4 block font-bold">Our Collections</span>
        <h2 class="text-[#0A0A0A] mb-4 text-5xl md:text-6xl">Choose Your <span class="text-[#D4A574]">Passion.</span></h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {categoryCards.map((card) => (
          <HobbyCard
            lang={lang}
            title={card.title}
            description={card.description}
            image={card.image}
            href={card.href}
            items={card.items}
            badge={card.badge}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- SPECIALIST: WHY US (Alloy Theme) -->
  <section class="bg-[#F5F5F5] py-24 md:py-32">
    <div class="container-custom">
      <div class="grid lg:grid-cols-3 gap-12">
        {benefits.map((benefit) => (
          <div class="flex flex-col items-center text-center group mt-8">
            <div class="w-16 h-16 bg-[#0A0A0A] text-[#D4A574] flex items-center justify-center text-3xl mb-8 group-hover:bg-[#8B6F47] group-hover:text-white transition-all duration-500">
               {benefit.icon === 'search' && '🔍'}
               {benefit.icon === 'infinity' && '♾️'}
               {benefit.icon === 'clock' && '💳'}
            </div>
            <h3 class="font-display text-3xl uppercase text-[#0A0A0A] mb-4">{benefit.title}</h3>
            <p class="text-[#1A140D]/60 font-light leading-relaxed">{benefit.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS: THE ROADMAP (Midnight Theme) -->
  <section class="bg-[#0A0A0A] py-24 md:py-32 text-white">
    <div class="container-custom">
      <div class="text-center mb-20">
        <h2 class="text-white text-5xl md:text-6xl uppercase tracking-tighter mb-4">Own It In <span class="text-[#D4A574]">4 Steps.</span></h2>
        <p class="text-white/40 max-w-xl mx-auto">No complex metaphors. Just a direct path to your passion.</p>
      </div>

      <div class="grid md:grid-cols-4 gap-12 relative">
        <div class="hidden md:block absolute top-12 left-0 w-full h-[1px] bg-white/10 z-0"></div>
        
        <div class="relative z-10 text-center">
            <div class="w-24 h-24 bg-[#1A1A1A] border border-white/10 rounded-full flex items-center justify-center mx-auto mb-8 text-[#D4A574] font-display text-4xl hover:border-[#8B6F47] transition-all">01</div>
            <h4 class="font-display text-xl uppercase mb-3">Find Your Dream</h4>
            <p class="text-white/40 text-sm font-light">Browse the market for the car, bike, or boat you love.</p>
        </div>
        <div class="relative z-10 text-center">
            <div class="w-24 h-24 bg-[#1A1A1A] border border-white/10 rounded-full flex items-center justify-center mx-auto mb-8 text-[#D4A574] font-display text-4xl hover:border-[#8B6F47] transition-all">02</div>
            <h4 class="font-display text-xl uppercase mb-3">Get a Quote</h4>
            <p class="text-white/40 text-sm font-light">WhatsApp us the details. We'll assess the real cost instantly.</p>
        </div>
        <div class="relative z-10 text-center">
            <div class="w-24 h-24 bg-[#1A1A1A] border border-white/10 rounded-full flex items-center justify-center mx-auto mb-8 text-[#D4A574] font-display text-4xl hover:border-[#8B6F47] transition-all">03</div>
            <h4 class="font-display text-xl uppercase mb-3">Fast Approval</h4>
            <p class="text-white/40 text-sm font-light">We talk directly. No agents. We say yes when banks say no.</p>
        </div>
        <div class="relative z-10 text-center">
            <div class="w-24 h-24 bg-[#1A1A1A] border border-white/10 rounded-full flex items-center justify-center mx-auto mb-8 text-[#D4A574] font-display text-4xl hover:border-[#8B6F47] transition-all">04</div>
            <h4 class="font-display text-xl uppercase mb-3">Collect & Drive</h4>
            <p class="text-white/40 text-sm font-light">We release the funds. You collect your new asset. Start your journey.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ SECTION (Daylight Theme) -->
  <section class="bg-white py-24 md:py-32">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-16">
            <h2 class="text-[#0A0A0A] uppercase tracking-widest text-4xl mb-4">Common Questions</h2>
            <div class="w-20 h-1 bg-[#8B6F47] mx-auto"></div>
        </div>
        <div class="space-y-6">
          {faqs.map((faq) => (
            <FAQItem question={faq.question} answer={faq.answer} />
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA: TALK SPECIALIST (Alloy Theme) -->
  <section class="bg-[#F5F5F5] py-24 md:py-32">
    <div class="container-custom text-center">
        <h2 class="text-[#0A0A0A] mb-8 uppercase font-display tracking-widest text-4xl md:text-5xl">Stop Waiting. <br /><span class="text-[#D4A574]">Own Your Passion.</span></h2>
        <p class="text-[#1A140D]/60 mb-12 text-xl max-w-2xl mx-auto font-light">Join the collectors who chose Ing Heng Credit to fund their milestones.</p>
        <a href="https://wa.me/60175700889" class="bg-[#0A0A0A] text-white font-display text-2xl tracking-[0.1em] px-12 py-6 hover:bg-[#8B6F47] hover:translate-y-[-5px] transition-all duration-500 inline-block uppercase">
            Talk to an Asset Specialist
        </a>
    </div>
  </section>
</BaseLayout>

<style>
  h1, h2, h3, h4 {
    font-family: 'Bebas Neue', var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
