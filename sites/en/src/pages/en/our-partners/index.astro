---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PartnerCard from '../../../components/partners/PartnerCard.astro';
import { listPartners } from '../../../utils/partners';

const partners = await listPartners();

const pageTitle = 'Our Partners | Ing Heng Credit';
const pageDescription = 'Browse the Ing Heng partner directory with profile pages, contact information, and supporting image galleries.';
---

<BaseLayout title={pageTitle} description={pageDescription} lang="en" keywords={['Ing Heng partners', 'partner directory', 'supplier directory']}>
  <section class="border-b-3 border-[#2D1810] bg-[#1A140D] py-24 text-white relative overflow-hidden">
    <!-- Ambient Glow -->
    <div class="absolute top-[-20%] left-[-10%] w-[50%] h-[50%] bg-[#8B6F47]/10 blur-[120px] rounded-full"></div>
    
    <div class="container-custom relative z-10">
      <div class="max-w-4xl space-y-6">
        <p class="text-sm font-black uppercase tracking-[0.3em] text-[#D4A574]">The Network</p>
        <h1 class="text-white font-display text-6xl uppercase tracking-tighter">Business <span class="text-[#D4A574]">Eco-System</span></h1>
        <p class="max-w-2xl text-xl leading-relaxed text-[#E8DFD4] font-light">
          We believe in direct partnership. Below is our directory of verified experts, suppliers, and partners who help drive business value across the region.
        </p>
      </div>
    </div>
  </section>

  <section class="py-24 bg-[#FBF9F6]">
    <div class="container-custom">
      <div class="mb-16 grid lg:grid-cols-2 gap-8 items-end">
        <div>
          <div class="flex items-center gap-3 mb-4">
             <div class="w-12 h-0.5 bg-[#D4A574]"></div>
             <p class="text-sm font-black uppercase tracking-widest text-[#8B6F47] m-0">{partners.length} Profiles Verified</p>
          </div>
          <h2 class="text-5xl font-display uppercase text-[#1A140D] m-0">Partner Directory</h2>
        </div>
        <p class="text-lg text-[#4F3E29] leading-relaxed m-0 border-l-4 border-[#D4A574]/20 pl-6">
          This system is directly linked to our partner database. Real-time updates ensure you have access to the latest contact info and portfolios.
        </p>
      </div>

      {partners.length > 0 ? (
        <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-3">
          {partners.map((partner) => <PartnerCard partner={partner} />)}
        </div>
      ) : (
        <div class="border-4 border-dashed border-black/10 bg-white p-16 text-center shadow-brutal">
          <h2 class="text-3xl font-display uppercase mb-4 text-[#1A140D]">Directory Offline</h2>
          <p class="text-[#4F3E29]">No partner profiles are currently live. Please check back soon or contact support.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
