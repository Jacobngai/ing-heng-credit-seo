---
/**
 * Jaw Crusher Financing Landing Page - English
 * Target: Demolition contractors and concrete recycling operations
 * Keywords: jaw crusher financing Malaysia, concrete recycling loan, demolition equipment financing
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import FAQItem from '../../../components/FAQItem.astro';
import Calculator from '../../../components/Calculator.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import RelatedEquipment from '../../../components/RelatedEquipment.astro';

import { generateProductSchema, generateFAQSchema, encodeJSONLD } from '../../../utils/schema';
import { SITE_CONFIG } from '../../../utils/constants';

const lang = 'en';

// SEO Data
const pageTitle = 'Jaw Crusher Equipment Financing Malaysia | Demolition Support | Ing Heng';
const pageDescription = 'Finance your hydraulic jaw crushers today. 0% deposit available for demolition recycling. We fund Sandvik and Metso units of any age. Own your crushing plant.';
const keywords = ['jaw crusher financing Malaysia', 'concrete recycling equipment loan', 'demolition machine financing', 'hydraulic crusher loan'];

// Breadcrumbs
const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Equipment', url: '/en/equipment' },
  { label: 'Jaw Crusher', url: '/en/equipment/jaw-crusher' },
];

const benefits = [
  { icon: 'clock', title: 'Asset Debris Revenue', description: 'Transform waste into wealth. We provide the capital for jaw crushers that turn concrete debris into high-value recycled aggregate.' },
  { icon: 'percentage', title: '0% Deposit for Recyclers', description: 'Finance up to 100% of your crushing plant. Preserve your capital for site mobilization and demolition labor costs.' },
  { icon: 'shield', title: 'Heavy-Duty Agnostic', description: 'Excavator attachments or standalone plants—any brand, any age. If the jaws and hydraulics are functional, we fund it.' },
  { icon: 'lightning', title: 'Contract-Speed Execution', description: 'Fast credit decisions within 24-48 hours. Secure the machinery needed to fulfill demolition tenders immediately.' },
];

const faqs = [
  { 
    question: 'Do you finance excavator-mounted jaw crusher attachments?', 
    answer: 'Yes. We provide strategic financing for both standalone mobile crushing plants and hydraulic jaw attachments for your existing excavator fleet.' 
  },
  { 
    question: 'Can I include hydraulic hammer attachments in the same loan?', 
    answer: 'Absolutely. We can package your entire demolition toolset—including crushers, hammers, and shears—into a single, efficient financing facility.' 
  }
];

const productSchema = generateProductSchema({
  name: 'Jaw Crusher Equipment Financing Malaysia',
  description: 'Specialized financing for concrete recycling and demolition jaw crushers. Mobilize high-value industrial assets with strategic capital.',
  imageUrl: `${SITE_CONFIG.url}/images/equipment/jaw-crusher.jpg`,
  category: 'Construction Financing',
  offers: {
    price: '225000',
    currency: 'MYR',
    availability: 'https://schema.org/InStock',
  },
});

const faqSchema = generateFAQSchema(faqs);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
  keywords={keywords}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={encodeJSONLD(productSchema)} />
    <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />
  </Fragment>

  <!-- Hero Section -->
  <Hero
    title="Jaw Crusher Financing"
    subtitle="Enter the high-margin concrete recycling market with 0% deposit. We fund hydraulic jaw crushers and mobile plants—any age, any brand."
    ctaText="Secure Demolition Capital"
    ctaLink="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20get%20a%20quote%20for%20jaw%20crusher%20financing."
    ctaSecondaryText="Call Decision Maker"
    ctaSecondaryLink="tel:+60175700889"
    lang={lang}
    variant="luxe"
    equipmentImage="/images/equipment/Jaw Crasher.JPG"
    trustSignals={['40 Years Expertise', 'Demolition Specialist', '0% Deposit Option', 'Bad Credit Approved']}
  />

  <!-- Breadcrumbs -->
  <div class="container-custom py-4 font-display text-white">
    <Breadcrumbs items={breadcrumbs} lang={lang} />
  </div>

  <!-- Economics Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto">
        <div class="mb-16 md:mb-20 text-center">
            <h2 class="text-4xl md:text-7xl font-display uppercase  mb-8 tracking-tight leading-[1.1]">
                Demolition <br/><span class="text-[#D4A574]">Calculating</span>
            </h2>
            <p class="text-lg md:text-xl text-[#0A0A0A]/60 font-light max-w-2xl mx-auto leading-relaxed">
                Sustainability in demolition is a profit multiplier. We provide the capital equipment you need to eliminate landfill fees and sell recycled materials directly from the site.
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 md:gap-16 mb-16 md:mb-20 items-center">
            <div class="bg-[#F9F9F9] p-8 md:p-12 rounded-[30px] md:rounded-[40px] border border-[#eee]">
                <p class="text-xl md:text-2xl font-display uppercase tracking-widest text-[#0A0A0A] mb-8">Asset Returns</p>
                <div class="space-y-6">
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Disposal Cost Saving (Per Project)</span>
                        <span class="font-display tracking-widest text-sm md:text-base">RM 40,000+</span>
                    </div>
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Recycled Aggregate Revenue</span>
                        <span class="font-display tracking-widest text-sm md:text-base">RM 80-120 /TON</span>
                    </div>
                    <div class="pt-4 border-t-2 border-green-500/20">
                        <div class="flex justify-between items-center">
                            <span class="font-bold text-[#0A0A0A] text-sm uppercase">Estimated Payback Period</span>
                            <span class="font-display text-2xl text-[#D4A574]">12-15 MONTHS</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-[#0A0A0A] p-8 md:p-16 rounded-[40px] md:rounded-[60px] text-white shadow-2xl">
                <h3 class="text-2xl md:text-4xl font-display uppercase text-[#D4A574] mb-8">Asset <br/>Planner</h3>
                <div class="space-y-6 mb-12">
                   <div class="flex justify-between border-b border-white/10 pb-4">
                       <span class="font-light text-white/40 text-sm">Financed Installment</span>
                       <span class="font-display tracking-widest text-white/50 italic">Monthly Commitment</span>
                   </div>
                   <div class="flex justify-between pb-4">
                       <span class="font-light text-green-500/80 text-sm italic">Operational Cash Flow</span>
                       <span class="font-display tracking-widest text-green-500 ">POSITIVE</span>
                   </div>
                </div>
                <Calculator lang={lang} equipmentType="Crusher" defaultPrice={220000} variant="luxe" />
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section bg-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16">
        <h2 class="text-4xl md:text-5xl font-display uppercase  text-white mb-4 tracking-tight leading-[1.1]">
          Dominant <span class="text-[#D4A574]">Recycling.</span>
        </h2>
        <p class="text-lg text-white/50 font-light max-w-xl">
          Scale your demolition fleet with heavy-duty jaw crushers that transform environmental compliance into a tangible revenue stream.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        {benefits.map((benefit) => (
          <BenefitCard
            icon={benefit.icon}
            title={benefit.title}
            description={benefit.description}
            variant="luxe"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16 md:mb-20 text-center">
        <h2 class="text-4xl md:text-6xl font-display uppercase  mb-4  text-[#0A0A0A] tracking-tight leading-[1.1]">
          Industrial <br/> <span class="text-[#D4A574]">Intelligence</span>
        </h2>
        <p class="text-lg md:text-xl text-[#0A0A0A]/40 font-light mx-auto max-w-xl">
          Everything you need to know about scaling your demolition and material processing assets.
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="space-y-4">
          {faqs.map((faq) => (
            <FAQItem question={faq.question} answer={faq.answer} variant="luxe" />
          ))}
        </div>
      </div>
    </div>
  </section>

  <RelatedEquipment lang={lang} currentEquipment="excavator" variant="luxe" />

  <section class="section bg-[#D4A574] relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('/images/texture.png')] mix-blend-overlay pointer-events-none"></div>
    <div class="container-custom text-center relative z-10">
      <h2 class="text-5xl md:text-8xl font-display uppercase  text-[#0A0A0A] mb-8 tracking-tight leading-[1.1]">
        COMMAND YOUR <br/><span class="opacity-40">FINISHING FIELD</span>
      </h2>
      <p class="text-[#0A0A0A]/70 text-xl font-light mb-12 max-w-2xl mx-auto leading-relaxed">
        Stop losing margin to disposal fees. Build your own concrete recycling empire. Secure your jaw crusher financing today.
      </p>
 
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center mb-20">
        <a
          href="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20apply%20for%20jaw%20crusher%20financing."
          class="bg-[#0A0A0A] text-white px-12 py-6 font-display uppercase tracking-widest hover:bg-white hover:text-[#0A0A0A] transition-all shadow-2xl"
        >
          Secure Your Unit
        </a>
      </div>
    </div>
  </section>
</BaseLayout>