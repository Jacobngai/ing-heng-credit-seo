---
/**
 * Remote Control Grab Financing Landing Page - English
 * Target: Scrap metal yard owners, port operators and recycling centers
 * Keywords: remote control grab financing Malaysia, scrap handling loan, clamshell bucket financing
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import FAQItem from '../../../components/FAQItem.astro';
import Calculator from '../../../components/Calculator.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import RelatedEquipment from '../../../components/RelatedEquipment.astro';

import { generateProductSchema, generateFAQSchema, encodeJSONLD } from '../../../utils/schema';
import { SITE_CONFIG } from '../../../utils/constants';

const lang = 'en';

// SEO Data
const pageTitle = 'Remote Control Grab Financing Malaysia | Scrap & Recycling Support | Ing Heng';
const pageDescription = 'Finance your 25-ton remote control grabs today. 0% deposit available for scrap yards and recycling centers. Own your high-efficiency material handling units.';
const keywords = ['remote control grab financing Malaysia', 'scrap handling loan', 'recycling center equipment loan', 'clamshell bucket financing'];

// Breadcrumbs
const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Equipment', url: '/en/equipment' },
  { label: 'Remote Control Grab', url: '/en/equipment/grab' },
];

const benefits = [
  { icon: 'clock', title: 'High-Velocity Handling', description: 'Scrap margins are built on volume. We provide the specialized grabs you need to processing 300+ tons daily with wireless precision.' },
  { icon: 'percentage', title: '0% Deposit for Recyclers', description: 'Finance up to 100% of your remote control grab. Preserve your capital for material procurement and stock hedging.' },
  { icon: 'shield', title: 'Efficiency Over Brand', description: 'New or used wireless grabs accepted. If the hydraulic seals and radio control systems are verified, we fund it.' },
  { icon: 'lightning', title: 'Operational Speed', description: 'Fast credit decisions within 24-48 hours. Don\'t let port or scrap contracts pass you by due to equipment delays.' },
];

const faqs = [
  { 
    question: 'Do you finance both the grab and the crane pairing?', 
    answer: 'Yes. We can package the 25-ton remote control grab and the hydraulic crane or excavator pairing into a single, comprehensive financing facility.' 
  },
  { 
    question: 'Can I include radio control system upgrades in the loan?', 
    answer: 'Absolutely. We support the modernization of scrap yards. Initial wireless system overhauls and electronic synchronization can be included in your capital plan.' 
  }
];

const productSchema = generateProductSchema({
  name: 'Remote Control Grab Financing Malaysia',
  description: 'Specialized financing for 25-ton wireless material handling grabs. Control your scrap and recycling revenue with strategic capital.',
  imageUrl: `${SITE_CONFIG.url}/images/equipment/grab.jpg`,
  category: 'Recycling Financing',
  offers: {
    price: '285000',
    currency: 'MYR',
    availability: 'https://schema.org/InStock',
  },
});

const faqSchema = generateFAQSchema(faqs);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
  keywords={keywords}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={encodeJSONLD(productSchema)} />
    <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />
  </Fragment>

  <!-- Hero Section -->
  <Hero
    title="Remote Control Grab Financing"
    subtitle="Enter the high-profit recycling market with 0% deposit. We fund 25-ton remote control grabs and hydraulic material handling systems—new or used."
    ctaText="Maximize Scrap Margin"
    ctaLink="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20get%20a%20quote%20for%20remote%20control%20grab%20financing."
    ctaSecondaryText="Call Decision Maker"
    ctaSecondaryLink="tel:+60175700889"
    lang={lang}
    variant="luxe"
    equipmentImage="/images/equipment/25 Tons Remote Control Grab.jpg"
    trustSignals={['40 Years Expertise', 'Recycling Specialist', '0% Deposit Option', 'Bad Credit Approved']}
  />

  <!-- Breadcrumbs -->
  <div class="container-custom py-4 font-display text-white">
    <Breadcrumbs items={breadcrumbs} lang={lang} />
  </div>

  <!-- Economics Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto">
        <div class="mb-16 md:mb-20 text-center">
            <h2 class="text-4xl md:text-7xl font-display uppercase  mb-8 tracking-tight leading-[1.1]">
                Recycling <br/><span class="text-[#D4A574]">Calculus</span>
            </h2>
            <p class="text-lg md:text-xl text-[#0A0A0A]/60 font-light max-w-2xl mx-auto leading-relaxed">
                Material handling efficiency is the difference between surviving and scaling. We provide the capital equipment you need to process thousands of tons annually.
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 md:gap-16 mb-16 md:mb-20 items-center">
            <div class="bg-[#F9F9F9] p-8 md:p-12 rounded-[30px] md:rounded-[40px] border border-[#eee]">
                <p class="text-xl md:text-2xl font-display uppercase tracking-widest text-[#0A0A0A] mb-8">Asset Returns</p>
                <div class="space-y-6">
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Processing Volume Gain (Daily)</span>
                        <span class="font-display tracking-widest text-sm md:text-base">150-300 TONS</span>
                    </div>
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Safety Labor Reduction</span>
                        <span class="font-display tracking-widest text-sm md:text-base">UP TO 40%</span>
                    </div>
                    <div class="pt-4 border-t-2 border-green-500/20">
                        <div class="flex justify-between items-center">
                            <span class="font-bold text-[#0A0A0A] text-sm uppercase">Estimated Payback Period</span>
                            <span class="font-display text-2xl text-[#D4A574]">12-18 MONTHS</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-[#0A0A0A] p-8 md:p-16 rounded-[40px] md:rounded-[60px] text-white shadow-2xl">
                <h3 class="text-2xl md:text-4xl font-display uppercase text-[#D4A574] mb-8">Yield <br/>Planner</h3>
                <div class="space-y-6 mb-12">
                   <div class="flex justify-between border-b border-white/10 pb-4">
                       <span class="font-light text-white/40 text-sm">Financed Installment</span>
                       <span class="font-display tracking-widest text-white/50 italic">Monthly Asset Cost</span>
                   </div>
                   <div class="flex justify-between pb-4">
                       <span class="font-light text-green-500/80 text-sm italic">Projected Cash Flow</span>
                       <span class="font-display tracking-widest text-green-500 ">POSITIVE</span>
                   </div>
                </div>
                <Calculator lang={lang} equipmentType="Grab" defaultPrice={280000} variant="luxe" />
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section bg-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16">
        <h2 class="text-4xl md:text-5xl font-display uppercase  text-white mb-4 tracking-tight leading-[1.1]">
          Dominant <span class="text-[#D4A574]">Control.</span>
        </h2>
        <p class="text-lg text-white/50 font-light max-w-xl">
          Modernize your scrap yard or port operation with wireless control technology that pays for itself through increased safety and processing speed.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        {benefits.map((benefit) => (
          <BenefitCard
            icon={benefit.icon}
            title={benefit.title}
            description={benefit.description}
            variant="luxe"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16 md:mb-20 text-center">
        <h2 class="text-4xl md:text-6xl font-display uppercase  mb-4  text-[#0A0A0A] tracking-tight leading-[1.1]">
          Material <br/> <span class="text-[#D4A574]">Intelligence</span>
        </h2>
        <p class="text-lg md:text-xl text-[#0A0A0A]/40 font-light mx-auto max-w-xl">
          Everything you need to know about scaling your scrap and material handling assets.
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="space-y-4">
          {faqs.map((faq) => (
            <FAQItem question={faq.question} answer={faq.answer} variant="luxe" />
          ))}
        </div>
      </div>
    </div>
  </section>

  <RelatedEquipment lang={lang} currentEquipment="crane" variant="luxe" />

  <section class="section bg-[#D4A574] relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('/images/texture.png')] mix-blend-overlay pointer-events-none"></div>
    <div class="container-custom text-center relative z-10">
      <h2 class="text-5xl md:text-8xl font-display uppercase  text-[#0A0A0A] mb-8 tracking-tight leading-[1.1]">
        COMMAND YOUR <br/><span class="opacity-40">PROCESSING FIELD</span>
      </h2>
      <p class="text-[#0A0A0A]/70 text-xl font-light mb-12 max-w-2xl mx-auto leading-relaxed">
        Stop losing margin to operational inefficiency. Build your own recycling empire. Secure your remote control grab financing today.
      </p>
 
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center mb-20">
        <a
          href="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20apply%20for%20remote%20control%20grab%20financing."
          class="bg-[#0A0A0A] text-white px-12 py-6 font-display uppercase tracking-widest hover:bg-white hover:text-[#0A0A0A] transition-all shadow-2xl"
        >
          Secure Your Asset
        </a>
      </div>
    </div>
  </section>
</BaseLayout>