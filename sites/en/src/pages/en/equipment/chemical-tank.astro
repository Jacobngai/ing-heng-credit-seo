---
/**
 * Chemical Tank Financing Landing Page - English
 * Target: Pharmaceutical manufacturers, chemical processors, food-grade production
 * Keywords: chemical tank financing Malaysia, pharmaceutical processing loan, stainless steel vessel financing
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import StepCard from '../../../components/StepCard.astro';
import FAQItem from '../../../components/FAQItem.astro';
import ContactForm from '../../../components/ContactForm.astro';
import Calculator from '../../../components/Calculator.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import RelatedEquipment from '../../../components/RelatedEquipment.astro';

import { generateProductSchema, generateFAQSchema, encodeJSONLD } from '../../../utils/schema';
import { SITE_CONFIG } from '../../../utils/constants';

const lang = 'en';

// SEO Data
const pageTitle = 'Industrial Chemical Tank Financing Malaysia | SS316 Processing | Ing Heng';
const pageDescription = 'Finance pharmaceutical-grade stainless steel tanks and mixing vessels with 0% deposit. Strategic capital for chemical manufacturers. GMP compliance ready.';
const keywords = ['chemical tank financing Malaysia', 'pharmaceutical processing loan', 'stainless steel tank financing', 'mixing vessel loan'];

// Breadcrumbs
const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Equipment', url: '/en/equipment' },
  { label: 'Chemical Tank', url: '/en/equipment/chemical-tank' },
];

const benefits = [
  { icon: 'shield', title: 'GMP Compliance Ready', description: 'Finance pharmaceutical-grade SS316L tanks that meet strict regulatory standards. We understand the high capital requirements of healthcare manufacturing.' },
  { icon: 'percentage', title: '0% Deposit for Producers', description: 'Preserve your R&D capital. Finance up to 100% of your processing vessels and mixing plants with zero upfront cash outlay.' },
  { icon: 'clock', title: 'Industrial-Speed Funding', description: 'Fast credit decisions within 24-48 hours. Secure the machinery needed to fulfill urgent pharmaceutical or chemical supply contracts.' },
  { icon: 'lightning', title: 'Full Plant Scalability', description: 'Scale your production line from single tanks to complete robotic mixing systems. Volume interest rates for established manufacturers.' },
];

const steps = [
  { stepNumber: 1, icon: 'contact', title: 'Grade Assessment', description: 'Define your material requirements (SS304/SS316L) and production capacity.' },
  { stepNumber: 2, icon: 'document', title: 'SME Verification', description: 'Simple documentation review for manufacturing enterprises and pharmaceutical labs.' },
  { stepNumber: 3, icon: 'check', title: 'Asset Validation', description: 'Technical appraisal of the processing equipment and regulatory certifications.' },
  { stepNumber: 4, icon: 'clipboard', title: 'Capital Deployment', description: 'Fast disbursement of funds directly to the equipment manufacturer or supplier.' },
  { stepNumber: 5, icon: 'truck', title: 'Production Start', description: 'Commence high-precision manufacturing with your new specialized assets.' },
];

const faqs = [
  { 
    question: 'Do you finance custom-made stainless steel vessels?', 
    answer: 'Yes. We provide capital for both standard industrial tanks and custom-engineered chemical reactors or mixing vessels tailored to your specific processing needs.' 
  },
  { 
    question: 'Can I finance used chemical processing equipment?', 
    answer: 'Absolutely. Stainless steel assets hold value exceptionally well. We fund high-quality used tanks and processing lines of any age, provided they are functional and clean.' 
  }
];

const productSchema = generateProductSchema({
  name: 'Industrial Chemical Tank Financing Malaysia',
  description: 'Specialized financing for stainless steel chemical tanks and pharmaceutical processing vessels. Mobilize high-precision manufacturing assets with strategic capital.',
  imageUrl: `${SITE_CONFIG.url}/images/equipment/chemical-tank.jpg`,
  category: 'Manufacturing Financing',
  offers: {
    price: '280000',
    currency: 'MYR',
    availability: 'https://schema.org/InStock',
  },
});

const faqSchema = generateFAQSchema(faqs);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
  keywords={keywords}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={encodeJSONLD(productSchema)} />
    <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />
  </Fragment>

  <!-- Hero Section -->
  <Hero
    title="Chemical Tank Financing"
    subtitle="Strategic capital for SS316L pharmaceutical tanks and chemical processing vessels. 0% deposit available—GMP compliance ready, any age accepted."
    ctaText="Scale Your Manufacturing"
    ctaLink="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20get%20a%20quote%20for%20chemical%20tank%20financing."
    ctaSecondaryText="Call Decision Maker"
    ctaSecondaryLink="tel:+60175700889"
    lang={lang}
    variant="luxe"
    equipmentImage="/images/equipment/Industrial Stainless Steel Chemical Tank.JPG"
    trustSignals={['40 Years Expertise', 'Industrial Specialists', '0% Deposit Option', 'SS316L Approved']}
  />

  <!-- Breadcrumbs -->
  <div class="container-custom py-4 font-display text-white">
    <Breadcrumbs items={breadcrumbs} lang={lang} />
  </div>

  <!-- Economics Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto">
        <div class="mb-16 md:mb-20 text-center">
            <h2 class="text-4xl md:text-7xl font-display uppercase  mb-8 tracking-tight leading-[1.1]">
                Production <br/><span class="text-[#D4A574]">Calculating</span>
            </h2>
            <p class="text-lg md:text-xl text-[#0A0A0A]/60 font-light max-w-2xl mx-auto leading-relaxed">
                Precision manufacturing requires specialized capital. We provide the financing you need to eliminate production bottlenecks and meet global regulatory standards.
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 md:gap-16 mb-16 md:mb-20 items-center">
            <div class="bg-[#F9F9F9] p-8 md:p-12 rounded-[30px] md:rounded-[40px] border border-[#eee]">
                <p class="text-xl md:text-2xl font-display uppercase tracking-widest text-[#0A0A0A] mb-8">Asset Returns</p>
                <div class="space-y-6">
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Output Increase (Projected)</span>
                        <span class="font-display tracking-widest text-sm md:text-base">40% - 60%</span>
                    </div>
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Material Grade Compliance</span>
                        <span class="font-display tracking-widest text-sm md:text-base text-green-600">CERTIFIED</span>
                    </div>
                    <div class="pt-4 border-t-2 border-green-500/20">
                        <div class="flex justify-between items-center">
                            <span class="font-bold text-[#0A0A0A] text-sm uppercase">Operational Stability</span>
                            <span class="font-display text-2xl text-[#D4A574]">HIGH GAIN</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-[#0A0A0A] p-8 md:p-16 rounded-[40px] md:rounded-[60px] text-white shadow-2xl">
                <h3 class="text-2xl md:text-4xl font-display uppercase text-[#D4A574] mb-8">Plant <br/>Planner</h3>
                <div class="space-y-6 mb-12">
                   <div class="flex justify-between border-b border-white/10 pb-4">
                       <span class="font-light text-white/40 text-sm">Monthly Asset Commitment</span>
                       <span class="font-display tracking-widest text-white/50 italic text-sm">SCALABLE</span>
                   </div>
                   <div class="flex justify-between pb-4">
                       <span class="font-light text-green-500/80 text-sm italic">Projected ROI Status</span>
                       <span class="font-display tracking-widest text-green-500 ">POSITIVE</span>
                   </div>
                </div>
                <Calculator lang={lang} equipmentType="Chemical Tank" defaultPrice={280000} variant="luxe" />
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section bg-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16">
        <h2 class="text-4xl md:text-5xl font-display uppercase  text-white mb-4 tracking-tight leading-[1.1]">
          Dominant <span class="text-[#D4A574]">Efficiency.</span>
        </h2>
        <p class="text-lg text-white/50 font-light max-w-xl">
          Scale your manufacturing line with pharmaceutical-grade assets that pay for themselves through increased throughput and regulatory compliance.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        {benefits.map((benefit) => (
          <BenefitCard
            icon={benefit.icon}
            title={benefit.title}
            description={benefit.description}
            variant="luxe"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Step Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16">
        <h2 class="text-4xl md:text-5xl font-display uppercase  mb-4 text-[#0A0A0A] tracking-tight leading-[1.1]">
          Strategic <span class="text-[#D4A574]">Onboarding.</span>
        </h2>
        <p class="text-lg text-[#0A0A0A]/60 font-light max-w-xl">
          A specialized process designed for professional manufacturers—from technical appraisal to capital deployment.
        </p>
      </div>

      <div class="grid md:grid-cols-5 gap-4">
        {steps.map((step) => (
          <StepCard
            stepNumber={step.stepNumber}
            icon={step.icon}
            title={step.title}
            description={step.description}
            variant="luxe"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section bg-white text-[#0A0A0A] border-t border-black/5">
    <div class="container-custom">
      <div class="mb-16 md:mb-20 text-center">
        <h2 class="text-4xl md:text-6xl font-display uppercase  mb-4  text-[#0A0A0A] tracking-tight leading-[1.1]">
          Industrial <br/> <span class="text-[#D4A574]">Intelligence</span>
        </h2>
        <p class="text-lg md:text-xl text-[#0A0A0A]/40 font-light mx-auto max-w-xl">
          Everything you need to know about scaling your chemical and pharmaceutical processing assets.
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="space-y-4">
          {faqs.map((faq) => (
            <FAQItem question={faq.question} answer={faq.answer} variant="luxe" />
          ))}
        </div>
      </div>
    </div>
  </section>

  <RelatedEquipment lang={lang} currentEquipment="cnc-machine" variant="luxe" />

  <section class="section bg-[#D4A574] relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('/images/texture.png')] mix-blend-overlay pointer-events-none"></div>
    <div class="container-custom text-center relative z-10">
      <h2 class="text-5xl md:text-8xl font-display uppercase  text-[#0A0A0A] mb-8 tracking-tight leading-[1.1]">
        COMMAND YOUR <br/><span class="opacity-40">FINISHING FIELD</span>
      </h2>
      <p class="text-[#0A0A0A]/70 text-xl font-light mb-12 max-w-2xl mx-auto leading-relaxed">
        Stop losing contracts to limited capacity. Build your own manufacturing empire. Secure your chemical tank financing today.
      </p>
 
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center mb-20">
        <a
          href="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20apply%20for%20chemical%20tank%20financing."
          class="bg-[#0A0A0A] text-white px-12 py-6 font-display uppercase tracking-widest hover:bg-white hover:text-[#0A0A0A] transition-all shadow-2xl"
        >
          Secure Your Unit
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section class="section bg-[#0A0A0A]">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto bg-white/5 border border-white/10 rounded-3xl overflow-hidden flex flex-col lg:flex-row shadow-2xl">
        <div class="lg:w-1/3 p-12 bg-[#D4A574] text-[#0A0A0A]">
            <h2 class="text-4xl font-display uppercase  mb-8 tracking-tight leading-[1.1]">Establish<br/>Capacity<br/>Today.</h2>
            <p class="font-light opacity-80 mb-8">
                Request a strategic consultation for industrial equipment financing. 
            </p>
            <div class="space-y-4 text-sm font-display uppercase tracking-widest">
                <p>Monday - Friday: 9am - 5pm</p>
                <p>Saturday: 9am - 1pm</p>
            </div>
        </div>
        <div class="lg:w-2/3 p-12 bg-white/5">
            <ContactForm lang={lang} />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>