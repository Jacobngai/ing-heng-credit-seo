    link: '/en/equipment/food-stall'
  },
  {
    name: 'Sand Mixer',
    description: 'Continuous sand mixing and foundry automation for metal casting operations.',
    image: '/images/equipment/Pivotal Continuous Sand Mixer.JPG',
    features: ['Foundry automation', '0% deposit option', 'Output scaling', 'Industrial grade'],
    link: '/en/equipment/sand-mixer'
  },
  {
    name: 'Helicopter',
    description: 'Private and corporate aviation assets including Robinson R66 and offshore helicopters.',
    image: '/images/equipment/Robinson R66 Turbine Marine Helicopter.jpg',
    features: ['Aviation expertise', '0% deposit option', 'Discrete financing', 'CAAM aligned'],
    link: '/en/equipment/helicopter',
    badge: 'Elite'
  },
  {
    name: 'Quilting Machine',
    description: 'Automated quilting and bedding production lines for textile manufacturers.',
