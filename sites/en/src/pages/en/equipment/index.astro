---
/**
 * Equipment Index Page - English
 * Catalog page showcasing all equipment types available for financing
 * SEO: Equipment financing Malaysia, heavy equipment financing
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import ProductCard from '../../../components/ProductCard.astro';
import Calculator from '../../../components/Calculator.astro';

import { encodeJSONLD } from '../../../utils/schema';

const lang = 'en';

// SEO Data
const pageTitle = 'Heavy Equipment Catalog | 4,000+ Units Funded | Ing Heng Credit';
const pageDescription = 'Browse Malaysia\'s most flexible equipment financing catalog. Banks say no to old machine; we say yes. 0% deposit for excavators, prime movers, and industrial machinery.';
const keywords = ['equipment financing Malaysia', 'heavy equipment financing', 'construction equipment loan', 'machinery financing', 'equipment leasing Malaysia'];

// Featured Equipment Listings - FULL CATALOG
