];

// ItemList Schema for Equipment Categories
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Equipment Financing Catalog',
  description: 'Comprehensive equipment financing options for construction, logistics, and industrial equipment in Malaysia',
  itemListElement: featuredEquipment.map((equipment, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    item: {
      '@type': 'Product',
      name: equipment.name,
      description: equipment.description,
      offers: {
        '@type': 'Offer',
        priceCurrency: 'MYR',
        availability: 'https://schema.org/InStock',
        seller: {
          '@type': 'Organization',
          name: 'Ing Heng Credit & Leasing'
        }
      }
    }
  }))
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
  keywords={keywords}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={encodeJSONLD(itemListSchema)} />
  </Fragment>

  <!-- Hero Section -->
  <Hero
    title="Any Machine. Any Age. We Say Yes."
    subtitle="Banks reject equipment over 5 years old. We don't. Finance excavators, prime movers, and industrial machinery up to 50 years old with 0% deposit."
    ctaText="Browse Major Fleet"
    ctaLink="#catalog"
    ctaSecondaryText="Call Decision Maker"
    ctaSecondaryLink="tel:+60175700889"
    lang={lang}
    variant="luxe"
    trustSignals={['40 Years Expertise', 'Direct Capital', '0% Deposit Option', 'Bad Credit Approved']}
  />

  <!-- Equipment Catalog -->
  <section class="section bg-white text-[#0A0A0A]" id="catalog">
    <div class="container-custom">
      <div class="mb-16 md:mb-24 text-center">
        <h2 class="text-4xl md:text-7xl font-display uppercase mb-8 tracking-tight leading-[1.1]">
          The Fleet <br/><span class="text-[#D4A574]">Intelligence</span>
        </h2>
        <p class="text-lg md:text-xl text-[#0A0A0A]/60 font-light max-w-2xl mx-auto leading-relaxed">
          The banking system is built for brand new machines. Our system is built for entrepreneurs who know that older equipment builds real wealth.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 mb-20">
        {featuredEquipment.map((equipment) => (
          <ProductCard
            name={equipment.name}
            description={equipment.description}
            features={equipment.features}
            link={equipment.link}
            lang={lang}
            image={equipment.image}
            badge={equipment.badge}
            variant="luxe"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Financial Section -->
  <section class="section bg-[#0A0A0A] relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('/images/texture.png')] mix-blend-overlay pointer-events-none"></div>
    <div class="container-custom relative z-10">
      <div class="grid lg:grid-cols-2 gap-12 md:gap-20 items-center">
        <div>
            <h2 class="text-white text-4xl md:text-6xl font-display uppercase  mb-8 tracking-tight leading-[1.1]">
                Your Strategic <br/><span class="text-[#D4A574]">Calculus</span>
            </h2>
            <p class="text-white/50 text-lg font-light leading-relaxed mb-12 max-w-xl">
                Planning your equipment mobilization requires precise capital management. Identify your monthly commitment instantly via our luxe calculator.
            </p>
            <div class="space-y-6">
                {[
                    { step: '01', text: 'Select your equipment category.' },
                    { step: '02', text: 'Define your investment value.' },
                    { step: '03', text: 'Optimize your down payment structure.' }
                ].map(item => (
                    <div class="flex items-center space-x-6 group">
                        <div class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center font-display text-[#D4A574] group-hover:bg-[#D4A574] group-hover:text-[#0A0A0A] transition-all">
                            {item.step}
                        </div>
                        <span class="text-white/60 font-light">{item.text}</span>
                    </div>
                ))}
            </div>
        </div>
        
        <div class="bg-white/5 backdrop-blur-xl p-8 md:p-12 rounded-[40px] border border-white/10">
            <Calculator lang={lang} equipmentType="General Equipment" defaultPrice={150000} variant="luxe" />
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section bg-[#D4A574] relative overflow-hidden">
    <div class="container-custom text-center relative z-10">
      <h2 class="text-5xl md:text-8xl font-display uppercase text-[#0A0A0A] mb-8 tracking-tight leading-[1.1]">
        EVOLVE YOUR <br/><span class="opacity-40 text-black/40">INFRASTRUCTURE</span>
      </h2>
      <p class="text-[#0A0A0A]/70 text-xl font-light mb-12 max-w-2xl mx-auto leading-relaxed">
        Stop losing contracts to equipment rental companies. Own your tools. Build your empire. Secure your financing today.
      </p>
 
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
        <a
          href="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20discuss%20equipment%20financing."
          class="bg-[#0A0A0A] text-white px-12 py-6 font-display uppercase tracking-widest hover:bg-white hover:text-[#0A0A0A] transition-all shadow-2xl"
        >
          Talk to Decision Maker
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
