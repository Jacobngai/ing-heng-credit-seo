---
/**
 * Forklift Financing Landing Page - English
 * Target: Warehouse managers and logistics owners
 * Keywords: forklift financing Malaysia, Toyota forklift loan, warehouse equipment financing
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import StepCard from '../../../components/StepCard.astro';
import FAQItem from '../../../components/FAQItem.astro';
import Calculator from '../../../components/Calculator.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import RelatedEquipment from '../../../components/RelatedEquipment.astro';

import { generateProductSchema, generateFAQSchema, encodeJSONLD } from '../../../utils/schema';
import { SITE_CONFIG } from '../../../utils/constants';

const lang = 'en';

// SEO Data
const pageTitle = 'Forklift Financing Malaysia | Better Than Renting | Ing Heng';
const pageDescription = 'Stop paying RM 3.5k monthly forklift rental. Own your fleet for less. 0% deposit available for warehouses. Toyota, Mitsubishi, Linde brands accepted.';
const keywords = ['forklift financing Malaysia', 'warehouse equipment loan', 'forklift hire purchase', 'electric forklift loan'];

// Breadcrumbs
const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Equipment', url: '/en/equipment' },
  { label: 'Forklift', url: '/en/equipment/forklift' },
];

const benefits = [
  { icon: 'clock', title: 'Own for Less Than Rent', description: 'Average rental: RM 3,500. Average HP payment: RM 2,650. Stop losing RM 10k per year per unit.' },
  { icon: 'percentage', title: '0% Deposit for Warehouses', description: 'Finance up to 100% of equipment value for established warehouse operations. Preserve your working capital.' },
  { icon: 'shield', title: 'Electric & Diesel Accepted', description: 'From 15-year old Toyota reach trucks to new Lithium-Ion units. We value the asset\'s utility, not just age.' },
  { icon: 'lightning', title: '24-Hour Credit Decision', description: 'Fast processing for fleet expansion. Don\'t let e-commerce surges outpace your material handling capacity.' },
];

const steps = [
  { stepNumber: 1, icon: 'contact', title: 'Fleet Review', description: 'We evaluate your current rental costs and operation intensity to build your ownership plan.' },
  { stepNumber: 2, icon: 'document', title: 'Fast Application', description: 'Submit SSM and 6 months bank statements. No complex business plans or bank bureaucracy required.' },
  { stepNumber: 3, icon: 'check', title: 'Strategic Approval', description: 'We focus on your operational cash flow. Approval based on how your forklifts generate revenue.' },
  { stepNumber: 4, icon: 'truck', title: 'Secure Your Fleet', description: 'Take delivery and start building equity today. Every payment brings you closer to asset ownership.' },
];

const faqs = [
  { 
    question: 'Why should I own instead of renting for my warehouse?', 
    answer: 'Rental payments are 100% expense with zero equity. Over 4 years, you pay for the forklift twice but own nothing. Financing allows you to build a tangible asset balance sheet while paying less monthly than rental.' 
  },
  { 
    question: 'Do you finance high-lift reach trucks or VNA equipment?', 
    answer: 'Yes. Specialized material handling equipment including reach trucks, order pickers, and VNA units (Toyota, Linde, BT) are all accepted.' 
  },
  {
    question: 'Can I finance Lithium-Ion battery upgrades?',
    answer: 'We can package battery upgrades and charging infrastructure into your forklift financing, helping you transition to more efficient electric operations.'
  }
];

const productSchema = generateProductSchema({
  name: 'Forklift Financing Malaysia',
  description: 'Specialized financing for material handling equipment. Stop rental leakage and build warehouse equity. All major brands accepted.',
  imageUrl: `${SITE_CONFIG.url}/images/equipment/forklift.jpg`,
  category: 'Material Handling Financing',
  offers: {
    price: '85000',
    currency: 'MYR',
    availability: 'https://schema.org/InStock',
  },
});

const faqSchema = generateFAQSchema(faqs);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
  keywords={keywords}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={encodeJSONLD(productSchema)} />
    <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />
  </Fragment>

  <!-- Hero Section -->
  <Hero
    title="Forklift Financing"
    subtitle="Own your warehouse fleet for less than the cost of rental. 0% deposit available. Toyota, Mitsubishi, Linde units—any age accepted."
    ctaText="Stop Rental Leakage"
    ctaLink="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20get%20a%20quote%20for%20forklift%20financing."
    ctaSecondaryText="Call Decision Maker"
    ctaSecondaryLink="tel:+60175700889"
    lang={lang}
    variant="luxe"
    equipmentImage="/images/equipment/Mitsubishi FD250 Forklift.JPG"
    trustSignals={['40 Years Expertise', 'Warehouse Specialist', '0% Deposit Option', 'New & Used Accepted']}
  />

  <!-- Breadcrumbs -->
  <div class="container-custom py-4 font-display text-white">
    <Breadcrumbs items={breadcrumbs} lang={lang} />
  </div>

  <!-- Economics Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto">
        <div class="mb-16 md:mb-20 text-center">
            <h2 class="text-4xl md:text-7xl font-display uppercase  mb-8 tracking-tight leading-[1.1]">
                Warehouse <br/><span class="text-[#D4A574]">ROI</span>
            </h2>
            <p class="text-lg md:text-xl text-[#0A0A0A]/60 font-light max-w-2xl mx-auto leading-relaxed">
                Material handling is an operational cost. Every Ringgit spent on rental is gone forever. Every Ringgit spent on financing is a deposit on your future asset.
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 md:gap-16 mb-16 md:mb-20 items-center">
            <div class="bg-[#F9F9F9] p-8 md:p-12 rounded-[30px] md:rounded-[40px] border border-[#eee]">
                <p class="text-xl md:text-2xl font-display uppercase tracking-widest text-[#0A0A0A] mb-8">The Rental Trap</p>
                <div class="space-y-6">
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Monthly Forklift Rental</span>
                        <span class="font-display tracking-widest">RM 3,500</span>
                    </div>
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Duration</span>
                        <span class="font-display tracking-widest text-[#0A0A0A]">48 Months</span>
                    </div>
                    <div class="pt-4 border-t-2 border-red-500/20">
                        <div class="flex justify-between items-center">
                            <span class="font-bold text-[#0A0A0A] text-sm uppercase">Total Spent (Zero Equity)</span>
                            <span class="font-display text-2xl text-red-600">RM 168,000</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-[#0A0A0A] p-8 md:p-16 rounded-[40px] md:rounded-[60px] text-white shadow-2xl">
                <h3 class="text-2xl md:text-4xl font-display uppercase text-[#D4A574] mb-8">Ownership <br/>Pathway</h3>
                <div class="space-y-6 mb-12">
                   <div class="flex justify-between border-b border-white/10 pb-4">
                       <span class="font-light text-white/40 text-sm">Financed Installment</span>
                       <span class="font-display tracking-widest">RM 2,650</span>
                   </div>
                   <div class="flex justify-between pb-4">
                       <span class="font-light text-green-500/80 text-sm italic">Monthly Operational Saving</span>
                       <span class="font-display tracking-widest text-green-500">RM 850</span>
                   </div>
                </div>
                <Calculator lang={lang} equipmentType="Forklift" defaultPrice={100000} variant="luxe" />
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section bg-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16">
        <h2 class="text-4xl md:text-5xl font-display uppercase  text-white mb-4 tracking-tight leading-[1.1]">
          Built for <span class="text-[#D4A574]">Efficiency.</span>
        </h2>
        <p class="text-lg text-white/50 font-light max-w-xl">
          We understand warehouse lifecycle. From peak demand scaling to simple cost consolidation.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        {benefits.map((benefit) => (
          <BenefitCard
            icon={benefit.icon}
            title={benefit.title}
            description={benefit.description}
            variant="luxe"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16 md:mb-20 text-center">
        <h2 class="text-4xl md:text-6xl font-display uppercase  mb-4  text-[#0A0A0A] tracking-tight leading-[1.1]">
          Warehouse <br/> <span class="text-[#D4A574]">Intelligence</span>
        </h2>
        <p class="text-lg md:text-xl text-[#0A0A0A]/40 font-light mx-auto max-w-xl">
          Everything you need to know about scaling your material handling fleet.
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="space-y-4">
          {faqs.map((faq) => (
            <FAQItem question={faq.question} answer={faq.answer} variant="luxe" />
          ))}
        </div>
      </div>
    </div>
  </section>

  <RelatedEquipment lang={lang} currentEquipment="forklift" variant="luxe" />

  <section class="section bg-[#D4A574] relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('/images/texture.png')] mix-blend-overlay pointer-events-none"></div>
    <div class="container-custom text-center relative z-10">
      <h2 class="text-5xl md:text-8xl font-display uppercase  text-[#0A0A0A] mb-8 tracking-tight leading-[1.1]">
        COMMAND YOUR <br/><span class="opacity-40">WAREHOUSE</span>
      </h2>
      <p class="text-[#0A0A0A]/70 text-xl font-light mb-12 max-w-2xl mx-auto leading-relaxed">
        Stop the rental cycle. Build asset value for your business balance sheet today. Apply for forklift financing in 24 hours.
      </p>
 
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center mb-20">
        <a
          href="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20apply%20for%20forklift%20financing."
          class="bg-[#0A0A0A] text-white px-12 py-6 font-display uppercase tracking-widest hover:bg-white hover:text-[#0A0A0A] transition-all shadow-2xl"
        >
          Secure Your Fleet
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
