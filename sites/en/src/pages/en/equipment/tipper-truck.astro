---
/**
 * Tipper Truck (Dump Truck) Financing Landing Page - English
 * Target: Sand/gravel contractors, earthwork operators, construction material transport
 * Keywords: tipper truck financing Malaysia, dump truck loan, sand truck financing
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import StepCard from '../../../components/StepCard.astro';
import FAQItem from '../../../components/FAQItem.astro';
import Calculator from '../../../components/Calculator.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import RelatedEquipment from '../../../components/RelatedEquipment.astro';

import { generateProductSchema, generateFAQSchema, encodeJSONLD } from '../../../utils/schema';
import { SITE_CONFIG } from '../../../utils/constants';

const lang = 'en';

// SEO Data
const pageTitle = 'Used Tipper Truck Financing Malaysia | Direct Capital | Ing Heng';
const pageDescription = 'Stop losing RM 15k-20k per project to trucking contractors. Finance used tippers 15+ years old. 0% deposit option. Complete full projects yourself.';
const keywords = ['tipper truck financing Malaysia', 'dump truck loan', 'sand truck financing', 'used tipper loan'];

// Breadcrumbs
const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Equipment', url: '/en/equipment' },
  { label: 'Tipper Truck', url: '/en/equipment/tipper-truck' },
];

const benefits = [
  { icon: 'percentage', title: '0% Deposit Option', description: '100% financing for qualified contractors. Keep your working capital for diesel and maintenance.' },
  { icon: 'shield', title: 'Any Age Accepted', description: 'Nissan, Hino, Isuzu - we finance tippers 15+ years old. We value performance over age.' },
  { icon: 'users', title: 'Self-Haul Profit', description: 'Stop paying RM 400/load to truckers. Keep the full project revenue in your business.' },
  { icon: 'clock', title: 'Streamlined Processing', description: 'Decision from complete application. Don\'t miss your next soil removal contract.' },
];

const steps = [
  { stepNumber: 1, icon: 'contact', title: 'Project Briefing', description: 'Discuss your upcoming projects and trucking requirements with our specialists.' },
  { stepNumber: 2, icon: 'document', title: 'Fast Registration', description: 'Submit IC/SSM and bank statements for a same-day preliminary assessment.' },
  { stepNumber: 3, icon: 'check', title: 'Direct Approval', description: 'Decision made by us, for you. Project-based approval even with thin credit.' },
  { stepNumber: 4, icon: 'truck', title: 'Haul & Earn', description: 'Release funds, collect your tipper, and start keeping 100% of your trucking fees.' },
];

const faqs = [
  { 
    question: 'Can I finance a 15-year-old Nissan tipper?', 
    answer: 'YES. We understand that tippers are mechanically simple and durable. We finance units 15+ years old as long as the hydraulic system and engine are in working order.' 
  },
  { 
    question: 'How much can I save by owning my own tipper?', 
    answer: 'A typical project requiring 50 loads costs RM 20,000 in external trucking fees. By financing your own unit for ~RM 2,500/month, you recover the investment in just one project.' 
  },
  {
    question: 'Do you finance tippers from independent sellers?',
    answer: 'Yes. We finance tippers from authorized dealers, private sellers, or even units you already own that you want to refinance.'
  },
  {
    question: 'What documents are required for 0% down payment?',
    answer: 'Existing contractors with active excavation projects or stable bank statements are eligible for our zero-deposit program.'
  }
];

const productSchema = generateProductSchema({
  name: 'Used Tipper Truck Financing',
  description: 'Specialized financing for tipper trucks in Malaysia. New and used units, 0% deposit options, any age accepted.',
  imageUrl: `${SITE_CONFIG.url}/images/equipment/tipper.jpg`,
  category: 'Commercial Vehicle Financing',
  offers: {
    price: '35000',
    currency: 'MYR',
    availability: 'https://schema.org/InStock',
  },
});

const faqSchema = generateFAQSchema(faqs);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
  keywords={keywords}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={encodeJSONLD(productSchema)} />
    <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />
  </Fragment>

  <!-- Hero Section -->
  <Hero
    title="Tipper Truck Financing"
    subtitle="Stop paying RM 400 per load to external truckers. Finance your own tipper. Any age accepted. 0% deposit for contractors."
    ctaText="Build Your Fleet"
    ctaLink="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20get%20a%20quote%20for%20tipper%20truck%20financing."
    ctaSecondaryText="Call Now"
    ctaSecondaryLink="tel:+60175700889"
    lang={lang}
    variant="luxe"
    equipmentImage="/images/equipment/Nissan Tipper Truck.jpg"
    trustSignals={['15+ Year Age Accepted', '0% Deposit Available', 'Direct Capital', 'Project-Based Approval']}
  />

  <!-- Breadcrumbs -->
  <div class="container-custom py-4 font-display text-white">
    <Breadcrumbs items={breadcrumbs} lang={lang} />
  </div>

  <!-- ROI Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto">
        <div class="mb-16 md:mb-20 text-center">
            <h2 class="text-4xl md:text-7xl font-display uppercase  mb-8 tracking-tight leading-[1.1]">
                Double Your <br/><span class="text-[#D4A574]">Project Margin</span>
            </h2>
            <p class="text-lg md:text-xl text-[#0A0A0A]/60 font-light max-w-2xl mx-auto leading-relaxed">
                Trucking is the biggest leakage in an excavation project. For the cost of 10 external loads, you could pay a full month's installment on your own tipper.
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 md:gap-16 mb-16 md:mb-20 items-center border-t border-black/5 pt-16">
            <div class="bg-[#F9F9F9] p-8 md:p-12 rounded-[30px] md:rounded-[40px] border border-[#eee]">
                <p class="text-xl md:text-2xl font-display uppercase tracking-widest text-[#0A0A0A] mb-8">The Leakage calculation</p>
                <div class="space-y-6">
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">External Trucking Fee</span>
                        <span class="font-display tracking-widest">RM 400 / load</span>
                    </div>
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Loads per Project (Avg)</span>
                        <span class="font-display tracking-widest">50 Loads</span>
                    </div>
                    <div class="flex justify-between pb-4">
                        <span class="font-light text-red-600/80 text-sm italic">Project Profit Leakage</span>
                        <span class="font-display tracking-widest text-red-600">RM 20,000</span>
                    </div>
                </div>
            </div>

            <div class="bg-[#0A0A0A] p-8 md:p-16 rounded-[40px] md:rounded-[60px] text-white shadow-2xl">
                <h3 class="text-2xl md:text-4xl font-display uppercase text-[#D4A574] mb-8">The Ownership <br/>Advantage</h3>
                <div class="space-y-6 mb-12">
                   <div class="flex justify-between border-b border-white/10 pb-4">
                       <span class="font-light text-white/40 text-sm">Monthly Installment (Est)</span>
                       <span class="font-display tracking-widest">RM 2,800</span>
                   </div>
                   <div class="flex justify-between border-b border-white/10 pb-4">
                       <span class="font-light text-white/40 text-sm">Net Savings per Project</span>
                       <span class="font-display tracking-widest text-green-500">RM 17,200+</span>
                   </div>
                </div>
                <Calculator lang={lang} equipmentType="Tipper Truck" defaultPrice={85000} variant="luxe" />
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section bg-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16">
        <h2 class="text-4xl md:text-5xl font-display uppercase  text-white mb-4 tracking-tight leading-[1.1]">
          Strategic <span class="text-[#D4A574]">Advantage.</span>
        </h2>
        <p class="text-lg text-white/50 font-light max-w-xl">
          Controlling your own trucking means you control your project schedule. No more waiting for external truckers while your excavator sits idle.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        {benefits.map((benefit) => (
          <BenefitCard
            icon={benefit.icon}
            title={benefit.title}
            description={benefit.description}
            variant="luxe"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section bg-white">
    <div class="container-custom">
      <div class="text-center mb-16 md:mb-20">
        <h2 class="text-4xl md:text-6xl font-display uppercase  mb-4 tracking-tight leading-[1.1]">
          Fulfillment <br/> <span class="text-[#D4A574]">Protocol</span>
        </h2>
        <p class="text-lg md:text-xl text-[#0A0A0A]/40 font-light mx-auto max-w-xl">
          Direct approval for Malaysian contractors. We focus on your revenue potential, not just your credit score.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8 mb-12 md:mb-16">
        {steps.map((step) => (
          <StepCard
            stepNumber={step.stepNumber}
            icon={step.icon}
            title={step.title}
            description={step.description}
            variant="luxe"
          />
        ))}
      </div>

      <div class="text-center px-4">
          <a href="https://wa.me/60175700889" class="inline-block w-full sm:w-auto bg-[#0A0A0A] text-white px-12 md:px-16 py-6 font-display uppercase tracking-widest text-sm hover:bg-[#D4A574] transition-all shadow-2xl">
              Stop The Leakage
          </a>
      </div>
    </div>
  </section>

  <!-- Brand Matrix -->
  <section class="section bg-[#F9F9F9] text-[#0A0A0A]">
    <div class="container-custom">
        <div class="bg-[#0A0A0A] p-8 md:p-20 rounded-[40px] md:rounded-[60px] text-center">
            <h3 class="text-2xl md:text-4xl font-display uppercase text-[#D4A574] mb-4">Authorized Brand Matrix</h3>
            <p class="text-white/40 font-light mb-12 max-w-lg mx-auto">We finance all major Japanese and European tipper brands, new or used.</p>
            <div class="flex flex-wrap justify-center gap-3 md:gap-4 max-w-4xl mx-auto">
              {['Nissan Diesel', 'Hino', 'Isuzu', 'UD Trucks', 'Mitsubishi Fuso', 'Mercedes-Benz', 'Volvo', 'MAN', 'Sinotruk', 'Dongfeng'].map((brand) => (
                <span class="px-5 md:px-6 py-2 md:py-3 bg-white/5 border border-white/10 rounded-full text-white/60 font-display uppercase tracking-widest text-[10px] md:text-xs">
                  {brand}
                </span>
              ))}
            </div>
        </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16 md:mb-20 text-center">
        <h2 class="text-4xl md:text-6xl font-display uppercase  mb-4  text-[#0A0A0A] tracking-tight leading-[1.1]">
          Technical <br/> <span class="text-[#D4A574]">Briefing</span>
        </h2>
        <p class="text-lg md:text-xl text-[#0A0A0A]/40 font-light mx-auto max-w-xl">
          Everything you need to know about tipper truck financing.
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="space-y-4">
          {faqs.map((faq) => (
            <FAQItem question={faq.question} answer={faq.answer} variant="luxe" />
          ))}
        </div>
      </div>
    </div>
  </section>

  <RelatedEquipment lang={lang} currentEquipment="tipper-truck" variant="luxe" />

  <section class="section bg-[#D4A574] relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('/images/texture.png')] mix-blend-overlay pointer-events-none"></div>
    <div class="container-custom text-center relative z-10">
      <h2 class="text-5xl md:text-8xl font-display uppercase  text-[#0A0A0A] mb-8 tracking-tight leading-[1.1]">
        CAPTURE THE <br/><span class="opacity-40">FULL MARGIN</span>
      </h2>
      <p class="text-[#0A0A0A]/70 text-xl font-light mb-12 max-w-2xl mx-auto leading-relaxed">
        Join excavation contractors who have secured their own fleet. Stop paying truckers and start building your own equipment legacy.
      </p>
 
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center mb-20">
        <a
          href="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20apply%20for%20tipper%20truck%20financing."
          class="bg-[#0A0A0A] text-white px-12 py-6 font-display uppercase tracking-widest hover:bg-white hover:text-[#0A0A0A] transition-all shadow-2xl"
        >
          Secure Your Tipper
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
