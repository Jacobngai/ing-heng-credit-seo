---
/**
 * Refrigerated Truck Financing Landing Page - English
 * Target: Cold chain logistics operators and food distributors
 * Keywords: refrigerated truck financing Malaysia, cold chain loan, reefer truck financing
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import FAQItem from '../../../components/FAQItem.astro';
import Calculator from '../../../components/Calculator.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import RelatedEquipment from '../../../components/RelatedEquipment.astro';

import { generateProductSchema, generateFAQSchema, encodeJSONLD } from '../../../utils/schema';
import { SITE_CONFIG } from '../../../utils/constants';

const lang = 'en';

// SEO Data
const pageTitle = 'Refrigerated Truck Financing Malaysia | Cold Chain Support | Ing Heng';
const pageDescription = 'Finance your Isuzu or Hino refrigerated truck today. 0% deposit available for cold chain logistics. We fund units with Carrier and Thermo King units. Own your reefer fleet.';
const keywords = ['refrigerated truck financing Malaysia', 'cold chain vehicle loan', 'reefer truck financing', 'Carrier refrigeration loan'];

// Breadcrumbs
const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Equipment', url: '/en/equipment' },
  { label: 'Refrigerated Truck', url: '/en/equipment/refrigerated-truck' },
];

const benefits = [
  { icon: 'clock', title: 'Perishable Asset Power', description: 'Fresh produce and pharmaceutical logistics never stop. Secure 24/7 temperature-controlled earning capacity.' },
  { icon: 'percentage', title: '0% Deposit for Logistics', description: 'Finance up to 100% of your reefer unit. Preserve liquidity for warehouse operations and stock procurement.' },
  { icon: 'shield', title: 'Carrier & Thermo King Ready', description: 'We finance the complete unit—chassis plus premium refrigeration systems. 10+ year old units accepted.' },
  { icon: 'lightning', title: 'Peak Season Readiness', description: 'Fast credit decisions within 24-48 hours. Mobilize your fleet before the CNY and festive demand peaks.' },
];

const faqs = [
  { 
    question: 'Do you finance both the truck chassis and the refrigeration unit?', 
    answer: 'Yes. We provide comprehensive financing for the entire vehicle, including the chassis (Isuzu, Hino, Fuso) and the refrigeration plant (Carrier, Thermo King, Zanotti).' 
  },
  { 
    question: 'Can I finance a used refrigerated truck?', 
    answer: 'Absolutely. We specialize in financing used cold chain assets. As long as the thermal box is insulated and the cooling unit is functional, we fund it regardless of its age.' 
  },
  {
    question: 'Is HACCP or GDP certification required for approval?',
    answer: 'While not mandatory for the loan, having these certifications demonstrates your business quality and helps us approve larger fleet facilities faster.'
  }
];

const productSchema = generateProductSchema({
  name: 'Refrigerated Truck Financing Malaysia',
  description: 'Specialized financing for temperature-controlled logistics. Secure Isuzu and Hino reefer trucks with strategic capital solutions.',
  imageUrl: `${SITE_CONFIG.url}/images/equipment/refrigerated-truck.jpg`,
  category: 'Cold Chain Financing',
  offers: {
    price: '165000',
    currency: 'MYR',
    availability: 'https://schema.org/InStock',
  },
});

const faqSchema = generateFAQSchema(faqs);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
  keywords={keywords}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={encodeJSONLD(productSchema)} />
    <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />
  </Fragment>

  <!-- Hero Section -->
  <Hero
    title="Refrigerated Truck Financing"
    subtitle="Finance your 1-ton to 5-ton refrigerated trucks with 0% deposit. We fund Isuzu, Hino, and Fuso units with premium cooling systems—any age accepted."
    ctaText="Secure Cold Chain Capital"
    ctaLink="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20get%20a%20quote%20for%20refrigerated%20truck%20financing."
    ctaSecondaryText="Call Decision Maker"
    ctaSecondaryLink="tel:+60175700889"
    lang={lang}
    variant="luxe"
    equipmentImage="/images/equipment/refrigerated-truck.jpg"
    trustSignals={['40 Years Expertise', 'Logistics Specialist', '0% Deposit Option', 'Bad Credit Approved']}
  />

  <!-- Breadcrumbs -->
  <div class="container-custom py-4 font-display text-white">
    <Breadcrumbs items={breadcrumbs} lang={lang} />
  </div>

  <!-- Economics Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto">
        <div class="mb-16 md:mb-20 text-center">
            <h2 class="text-4xl md:text-7xl font-display uppercase  mb-8 tracking-tight leading-[1.1]">
                Thermal <br/><span class="text-[#D4A574]">Profitability</span>
            </h2>
            <p class="text-lg md:text-xl text-[#0A0A0A]/60 font-light max-w-2xl mx-auto leading-relaxed">
                Cold chain logistics is a premium-rate industry. We provide the specialized equipment you need to secure high-value pharmaceutical and fresh food distribution contracts.
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 md:gap-16 mb-16 md:mb-20 items-center">
            <div class="bg-[#F9F9F9] p-8 md:p-12 rounded-[30px] md:rounded-[40px] border border-[#eee]">
                <p class="text-xl md:text-2xl font-display uppercase tracking-widest text-[#0A0A0A] mb-8">Asset Returns</p>
                <div class="space-y-6">
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Premium Distribution Rate (Daily)</span>
                        <span class="font-display tracking-widest">RM 600-1,200</span>
                    </div>
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Typical 1-Year Revenue</span>
                        <span class="font-display tracking-widest">RM 180,000+</span>
                    </div>
                    <div class="pt-4 border-t-2 border-green-500/20">
                        <div class="flex justify-between items-center">
                            <span class="font-bold text-[#0A0A0A] text-sm uppercase">Estimated Payback Period</span>
                            <span class="font-display text-2xl text-[#D4A574]">18-24 MONTHS</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-[#0A0A0A] p-8 md:p-16 rounded-[40px] md:rounded-[60px] text-white shadow-2xl">
                <h3 class="text-2xl md:text-4xl font-display uppercase text-[#D4A574] mb-8">Reefer <br/>Planner</h3>
                <div class="space-y-6 mb-12">
                   <div class="flex justify-between border-b border-white/10 pb-4">
                       <span class="font-light text-white/40 text-sm">Financed Installment</span>
                       <span class="font-display tracking-widest text-white/50 italic">Monthly Structure</span>
                   </div>
                   <div class="flex justify-between pb-4">
                       <span class="font-light text-green-500/80 text-sm italic">Operational Cash Flow</span>
                       <span class="font-display tracking-widest text-green-500 ">POSITIVE</span>
                   </div>
                </div>
                <Calculator lang={lang} equipmentType="Refrigerated Truck" defaultPrice={180000} variant="luxe" />
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section bg-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16">
        <h2 class="text-4xl md:text-5xl font-display uppercase  text-white mb-4 tracking-tight leading-[1.1]">
          Integrated <span class="text-[#D4A574]">Cooling.</span>
        </h2>
        <p class="text-lg text-white/50 font-light max-w-xl">
          Scale your temperature-controlled fleet with heavy-duty reefer trucks that secure your position in the growing Malaysian cold chain market.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        {benefits.map((benefit) => (
          <BenefitCard
            icon={benefit.icon}
            title={benefit.title}
            description={benefit.description}
            variant="luxe"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16 md:mb-20 text-center">
        <h2 class="text-4xl md:text-6xl font-display uppercase  mb-4  text-[#0A0A0A] tracking-tight leading-[1.1]">
          Chain <br/> <span class="text-[#D4A574]">Intelligence</span>
        </h2>
        <p class="text-lg md:text-xl text-[#0A0A0A]/40 font-light mx-auto max-w-xl">
          Everything you need to know about scaling your temperature-controlled logistics assets.
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="space-y-4">
          {faqs.map((faq) => (
            <FAQItem question={faq.question} answer={faq.answer} variant="luxe" />
          ))}
        </div>
      </div>
    </div>
  </section>

  <RelatedEquipment lang={lang} currentEquipment="refrigerated-truck" variant="luxe" />

  <section class="section bg-[#D4A574] relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('/images/texture.png')] mix-blend-overlay pointer-events-none"></div>
    <div class="container-custom text-center relative z-10">
      <h2 class="text-5xl md:text-8xl font-display uppercase  text-[#0A0A0A] mb-8 tracking-tight leading-[1.1]">
        COMMAND YOUR <br/><span class="opacity-40">COLD CHAIN</span>
      </h2>
      <p class="text-[#0A0A0A]/70 text-xl font-light mb-12 max-w-2xl mx-auto leading-relaxed">
        Stop losing contracts to capital constraints. Build your own reefer empire. Secure your refrigerated truck financing today.
      </p>
 
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center mb-20">
        <a
          href="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20apply%20for%20refrigerated%20truck%20financing."
          class="bg-[#0A0A0A] text-white px-12 py-6 font-display uppercase tracking-widest hover:bg-white hover:text-[#0A0A0A] transition-all shadow-2xl"
        >
          Secure Your Fleet
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
