      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 mb-20">
        {steps.map((step) => (
          <StepCard
            stepNumber={step.stepNumber}
            icon={step.icon}
            title={step.title}
            description={step.description}
            variant="luxe"
          />
        ))}
      </div>

      <div class="text-center">
          <a href="https://wa.me/60175700889" class="inline-block bg-[#0A0A0A] text-white px-16 py-6 font-display uppercase tracking-widest text-sm hover:bg-[#D4A574] transition-all shadow-2xl">
              Start Your Acquisition
