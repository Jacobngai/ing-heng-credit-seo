---
/**
 * Excavator Financing Landing Page - English
 * Target: Contractor Ahmad (Excavator) - English secondary language
 * Keywords: excavator financing Malaysia, excavator loan, construction equipment financing
 * Cultural Focus: Professional, ROI-focused, data-driven B2B messaging
 * Word Count: 2,800+ words
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import StepCard from '../../../components/StepCard.astro';
import FAQItem from '../../../components/FAQItem.astro';
import ContactForm from '../../../components/ContactForm.astro';
import Calculator from '../../../components/Calculator.astro';
import TestimonialCard from '../../../components/TestimonialCard.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';

import RelatedEquipment from '../../../components/RelatedEquipment.astro';
import { generateProductSchema, generateFAQSchema, encodeJSONLD } from '../../../utils/schema';

import { SITE_CONFIG } from '../../../utils/constants';
const lang = 'en';

// SEO Data - Optimized for excavator financing Malaysia
const pageTitle = 'Excavator Financing Malaysia | Machinery Loan 0% Deposit';
const pageDescription = 'Get fast excavator financing in Malaysia with 0% deposit options. We finance new & used excavators up to 15 years old. quick processing, low rates, bad credit accepted. Apply via WhatsApp!';
const keywords = ['excavator financing Malaysia', 'excavator loan Malaysia', 'construction equipment financing', 'excavator hire purchase', 'heavy machinery financing', 'excavator leasing Malaysia'];

// Breadcrumbs
const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Equipment', url: '/en/equipment' },
  { label: 'Excavator Financing', url: '/en/equipment/excavator' },
];

// Benefits - ROI and efficiency focused
const benefits = [
  { icon: 'clock', title: 'Streamlined Processing', description: 'Get approved quickly. Fast processing means you can start earning on projects immediately without delays.' },
  { icon: 'percentage', title: 'High Approval Rate', description: 'We approve applications that banks reject. Bad credit or CCRIS challenges accepted.' },
  { icon: 'shield', title: 'New & Used Accepted', description: 'Finance new or used excavators 10+ years old. All major brands: CAT, Komatsu, Hitachi, Kobelco, Hyundai.' },
  { icon: 'users', title: 'Down Payment From 0%*', description: 'Minimal upfront investment. Loan up to 100%* for qualified applicants. Preserve your working capital for operations.' },
  { icon: 'document', title: 'Simple Documentation', description: 'Streamlined Processing with minimal paperwork. IC, bank statements, and company docs. No complex financial statements needed.' },
  { icon: 'shield', title: 'No Hidden Fees', description: 'Transparent pricing with no surprise charges. Competitive rates from 8-18%. No early repayment penalty.' },
];

// Process Steps
const steps = [
  { stepNumber: 1, icon: 'contact', title: 'Contact via WhatsApp', description: 'Chat with our financing experts. Get instant answers to your questions. Available during business hours.' },
  { stepNumber: 2, icon: 'document', title: 'Submit Documents', description: 'Provide IC, 6 months bank statements, and company registration. Simple paperwork, no hassle.' },
  { stepNumber: 3, icon: 'check', title: 'Rapid Approval', description: 'Receive approval decision quickly. Urgent cases processed on priority for active project deadlines.' },
  { stepNumber: 4, icon: 'truck', title: 'Deploy Equipment', description: 'Receive funds and take possession of your excavator. Start working and earning immediately.' },
];

// Equipment Types
const equipmentTypes = [
  {
    name: 'Mini Excavators (1-5 tons)',
    description: 'Perfect for residential projects, landscaping, utility installation, and tight urban spaces. Fuel-efficient with low operating costs.',
    applications: 'Foundation digging, trenching, landscaping, demolition prep'
  },
  {
    name: 'Midi Excavators (5-10 tons)',
    description: 'Ideal for medium construction sites, road works, drainage projects, and utility installations. Balanced power and mobility.',
    applications: 'Road construction, drainage systems, commercial foundation work'
  },
  {
    name: 'Large Excavators (10-30 tons)',
    description: 'Heavy-duty machines for major construction, mining, earthmoving, and large-scale infrastructure projects.',
    applications: 'Mining, dam construction, major highway projects, large earthworks'
  },
  {
    name: 'Long Reach Excavators',
    description: 'Extended arm excavators for deep excavation, dredging, riverbank work, and slope stabilization up to 30 meters reach.',
    applications: 'River dredging, deep foundation, pond excavation, slope work'
  },
  {
    name: 'Wheel Excavators',
    description: 'Mobile excavators for road construction and urban projects. Fast relocation between sites without trailer transport.',
    applications: 'Urban construction, road maintenance, utility repairs'
  },
  {
    name: 'Amphibious Excavators',
    description: 'Specialized machines for swamps, wetlands, flood-prone areas, and water-based construction. Unique Malaysian requirements.',
    applications: 'Swamp clearing, riverbank stabilization, flood mitigation works'
  },
];

// Accepted Brands
const acceptedBrands = ['Caterpillar (CAT)', 'Komatsu', 'Hitachi', 'Kobelco', 'Hyundai', 'Doosan', 'SANY', 'XCMG', 'Volvo', 'Sumitomo', 'JCB', 'Liebherr'];

// Testimonials - Professional and data-focused
const testimonials = [
  {
    name: 'Ahmad bin Hassan',
    company: 'AH Construction Sdn Bhd',
    location: 'Klang, Selangor',
    testimonial: 'Secured a 20-ton CAT for a infrastructure contract. Ing Heng approved us when our main bank hesitated. Their understanding of project timelines saved us from missing the mobilization deadline.',
    rating: 5,
  },
  {
    name: 'Tan Chee Keong',
    company: 'TCK Earthworks Sdn Bhd',
    location: 'Johor Bahru, Johor',
    testimonial: 'Needed a used Komatsu excavator urgently for a government tender. Banks rejected my application due to limited credit history. Ing Heng Credit approved it quickly. My business grew 40% after acquiring this machine.',
    rating: 5,
  },
  {
    name: 'Muthu a/l Suppiah',
    company: 'MS Excavation Services',
    location: 'Ipoh, Perak',
    testimonial: 'The flexible payment terms made all the difference. During slow months, I could reduce payments, and during peak season, I paid more. This cash flow flexibility helped me expand my fleet to 3 excavators.',
    rating: 5,
  },
];

// FAQs - Comprehensive coverage
const faqs = [
  {
    question: 'Can I finance used excavators?',
    answer: 'Yes! We finance used excavators 10+ years old from any reputable brand including Caterpillar, Komatsu, Hitachi, Kobelco, Hyundai, and Doosan. The excavator must be in good working condition and pass our inspection. Used excavator financing typically requires 10-20% down payment depending on equipment age and condition.'
  },
  {
    question: 'What is the maximum excavator age you accept?',
    answer: 'We accept excavators 10+ years old for financing. For excavators 5-7 years old, standard terms apply. For excavators 8-10 years old, we may require higher down payment (15-20%) or shorter loan terms (24-36 months). Equipment even older than 10 years is considered on a case-by-case basis.'
  },
  {
    question: 'Do you finance first-time contractors?',
    answer: 'Absolutely! We specialize in helping new contractors get started. Unlike banks that focus only on credit history, we evaluate your project potential, existing contracts, and business plan. We support growing businesses and many successful clients started with us as first-time equipment buyers.'
  },
  {
    question: 'What if I have bad credit or previous loan defaults?',
    answer: 'We consider each application individually. Bad credit or past defaults don\'t mean automatic rejection. We look at your current financial situation, ongoing projects, customer contracts, and equipment value. Many successful clients had credit issues before working with us.'
  },
  {
    question: 'What excavator brands do you accept?',
    answer: 'We accept all major brands: Caterpillar (CAT), Komatsu, Hitachi, Kobelco, Hyundai, Doosan, SANY, XCMG, Volvo, Sumitomo, JCB, and Liebherr. Both Japanese, American, Chinese, Korean, and European brands are acceptable.'
  },
  {
    question: 'How long does the approval process take?',
    answer: 'Standard approval is fast from complete document submission. Urgent cases with immediate project deadlines are prioritized. We understand you need equipment quickly for government tenders or time-sensitive projects. Submit in the morning for same-day assessment.'
  },
  {
    question: 'What documents do I need to apply?',
    answer: 'For individuals: (1) IC or Passport, (2) 6 months bank statements, (3) Income/Project proof. For companies: (1) SSM documents, (2) Company bank statements (6 months), (3) Directors\' IC, (4) Project contracts if available. The process is simple and straightforward.'
  },
  {
    question: 'Can I upgrade my excavator later?',
    answer: 'Yes! We offer trade-in and upgrade programs. After 12-18 months of timely payments, you can trade in your current machine and upgrade to a larger or newer model. We refinance the balance and add funds for the new equipment.'
  },
  {
    question: 'Is there a penalty for early repayment?',
    answer: 'No early repayment penalty! Pay off your loan anytime without extra charges. This flexibility helps contractors optimize their finances when they win large contracts or secure cheaper funding later.'
  },
];

// Product Schema
const productSchema = generateProductSchema({
  name: 'Excavator Financing Malaysia',
  description: 'Fast excavator financing with quick approval and flexible payment terms for construction contractors. Finance new and used excavators from RM30,000 to RM3,000,000.',
  imageUrl: `${SITE_CONFIG.url}/images/excavator-financing.jpg`,
  category: 'Financial Service - Equipment Financing',
  offers: {
    price: '30000',
    currency: 'MYR',
    availability: 'https://schema.org/InStock',
  },
});

// FAQ Schema
const faqSchema = generateFAQSchema(faqs);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
  keywords={keywords}
  ogType="website"
>
  <!-- Structured Data -->
  <Fragment slot="head">
    <script type="application/ld+json" set:html={encodeJSONLD(productSchema)} />
    <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />
  </Fragment>

  <!-- Hero Section -->
  <Hero
    title="Excavator Financing"
    subtitle="Streamlined Processing | 10% Down Payment | Flexible 12-60 Month Terms | Finance RM30k - RM3M"
    ctaText="Get Free Quote"
    ctaLink="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20get%20a%20quote%20for%20excavator%20financing."
    ctaSecondaryText="Call: 017-570 0889"
    ctaSecondaryLink="tel:+60175700889"
    lang={lang}
    variant="luxe"
    equipmentImage="/images/equipment/Komatsu PC350 Excavator.JPG"
    trustSignals={['40 Years in Business', 'KPKT Licensed', '4,000+ Companies Financed', 'Industry-Leading Approvals']}
  />

  <!-- Breadcrumbs -->
  <div class="container-custom py-4 font-display">
    <Breadcrumbs items={breadcrumbs} lang={lang} />
  </div>

  <!-- Problem/Solution Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto">
        <div class="mb-20 text-center">
            <h2 class="text-4xl md:text-7xl font-display uppercase  mb-8 tracking-tight leading-[1.1]">
