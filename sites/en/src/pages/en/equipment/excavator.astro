                <div class="mt-12">
                    <a href="#contact" class="inline-block bg-[#D4A574] text-[#0A0A0A] px-10 md:px-12 py-5 font-display uppercase tracking-widest text-xs hover:bg-white transition-all">
                        Submit Your Case
