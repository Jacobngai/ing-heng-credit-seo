            <p class="text-xl text-[#0A0A0A]/60 font-light max-w-2xl mx-auto leading-relaxed">
                You have projects lined up and contracts ready. But traditional banks are failing your growth.
            </p>
        </div>

        <div class="grid lg:grid-cols-2 gap-16 items-center mb-20">
            <div class="space-y-12">
                <div class="bg-[#F9F9F9] p-10 rounded-[40px] border border-[#eee]">
                    <p class="text-2xl font-display uppercase tracking-widest text-red-600 mb-6">Market Obstacles</p>
                    <ul class="space-y-4">
                        {[
                            'Banks reject applications due to limited credit history',
                            'High down payment requirements (30-50%) drain capital',
                            'Seasonal cash flow issues during monsoon months',
                            'Missing tender opportunities without ready equipment'
                        ].map(item => (
                            <li class="flex items-center space-x-3 text-[#0A0A0A]/60 font-light text-sm italic">
                                <span class="w-1.5 h-1.5 bg-red-600 rounded-full"></span>
                                <span>{item}</span>
                            </li>
                        ))}
                    </ul>
                </div>

                <div class="bg-[#F9F9F9] p-10 rounded-[40px] border border-[#eee]">
                    <p class="text-2xl font-display uppercase tracking-widest text-green-600 mb-6">Strategic Solutions</p>
                    <ul class="space-y-4">
                        {[
                            'Only 10% down payment required for qualified SME',
                            'Approval decision based on contract potential',
                            'Flexible payment structures for monsoon seasons',
                            'Equipment deployment within 3-5 business days'
                        ].map(item => (
                            <li class="flex items-center space-x-3 text-[#0A0A0A]/60 font-light text-sm">
                                <span class="w-1.5 h-1.5 bg-green-600 rounded-full"></span>
                                <span>{item}</span>
                            </li>
                        ))}
                    </ul>
                </div>
            </div>

        <div class="bg-[#0A0A0A] p-8 md:p-20 rounded-[40px] md:rounded-[60px] text-white relative overflow-hidden">
            <div class="absolute top-0 right-0 p-12 opacity-5 pointer-events-none">
                <svg class="w-48 h-48 text-[#D4A574]" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-2h2v2zm0-4H7v-2h2v2zm0-4H7V7h2v2zm4 8h-2v-2h2v2zm0-4h-2v-2h2v2zm0-4h-2V7h2v2zm4 8h-2v-2h2v2zm0-4h-2v-2h2v2zm0-4h-2V7h2v2z"/>
                </svg>
