        </h2>
        <p class="text-xl text-[#0A0A0A]/40 font-light mx-auto max-w-xl">
          Comprehensive financing for all excavator tonnage classes and specialized applications.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20">
        {equipmentTypes.map((equipment) => (
          <div class="bg-white p-12 rounded-[40px] border border-[#eee] hover:border-[#D4A574]/20 transition-all group">
            <h3 class="text-2xl font-display uppercase tracking-widest mb-6 group-hover:text-[#D4A574] transition-colors">{equipment.name}</h3>
            <p class="text-[#0A0A0A]/60 font-light text-sm mb-8 leading-relaxed h-20">{equipment.description}</p>
            <div class="pt-4 border-t border-black/5">
                <p class="text-xs font-display uppercase tracking-widest opacity-40">Applications: {equipment.applications.split(',')[0]}...</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Accepted Brands -->
      <div class="bg-[#0A0A0A] p-12 md:p-20 rounded-[60px] text-center">
