---
/**
 * Used Wheel Loader Financing Landing Page - English
 * Target: Quarry operators tired of renting, contractors wanting to own equipment
 * Keywords: wheel loader financing Malaysia, stop renting equipment, own vs rent wheel loader
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import FAQItem from '../../../components/FAQItem.astro';
import Calculator from '../../../components/Calculator.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import RelatedEquipment from '../../../components/RelatedEquipment.astro';

import { generateProductSchema, generateFAQSchema, encodeJSONLD } from '../../../utils/schema';
import { SITE_CONFIG } from '../../../utils/constants';

const lang = 'en';

// SEO Data
const pageTitle = 'Stop Renting Wheel Loaders | Own Your Equipment | Ing Heng';
const pageDescription = 'Tired of RM 16,000/month rental? Finance your own wheel loader with 0% deposit. We finance CAT, Komatsu, Volvo units any age. Build equity, stop rental leakage.';
const keywords = ['wheel loader financing Malaysia', 'stop renting wheel loader', 'CAT 966 financing', 'used wheel loader loan'];

// Breadcrumbs
const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Equipment', url: '/en/equipment' },
  { label: 'Wheel Loader', url: '/en/equipment/wheel-loader' },
];

const benefits = [
  { icon: 'clock', title: 'Convert Rent to Equity', description: 'Average rental: RM 16,000. Average HP payment: RM 12,800. Stop losing RM 38,000 per year per machine.' },
  { icon: 'percentage', title: '0% Deposit Available', description: 'Finance up to 100% of equipment value for established quarry and construction operators. Preserve liquidity.' },
  { icon: 'shield', title: 'Age-Agnostic Approval', description: 'CAT 966C, 950G—we value mechanical condition over production year. We approve loaders that banks reject.' },
  { icon: 'lightning', title: 'Streamlined Deployment', description: 'Fast credit decisions within 24 hours. Mobilize your fleet for new tenders without capital delays.' },
];

const faqs = [
  { 
    question: 'Why should I buy instead of continuing to rent?', 
    answer: 'Rent is a 100% loss. Over 3 years, you pay for a loader twice but own nothing. Financing builds a tangible asset on your balance sheet while often reducing your monthly operational expense.' 
  },
  { 
    question: 'Do you finance older CAT or Komatsu loaders?', 
    answer: 'YES. We specialize in financing used heavy assets. If the hydraulics are strong and the machine is productive, we provide the capital regardless of it being 15+ years old.' 
  },
  {
    question: 'Can I refinance my existing loader for cash flow?',
    answer: 'Absolutely. We can provide capital against your current owned fleet, allowing you to unlock equity for project mobilization or operational expansion.'
  }
];

const productSchema = generateProductSchema({
  name: 'Wheel Loader Financing Malaysia',
  description: 'Specialized financing for used wheel loaders. Stop rental leakage and build quarry equity. CAT, Komatsu, Volvo brands accepted.',
  imageUrl: `${SITE_CONFIG.url}/images/equipment/wheel-loader.jpg`,
  category: 'Heavy Equipment Financing',
  offers: {
    price: '185000',
    currency: 'MYR',
    availability: 'https://schema.org/InStock',
  },
});

const faqSchema = generateFAQSchema(faqs);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
  keywords={keywords}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={encodeJSONLD(productSchema)} />
    <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />
  </Fragment>

  <!-- Hero Section -->
  <Hero
    title="Wheel Loader Financing"
    subtitle="Escaping the RM 16,000/month rental trap. 0% deposit available. We finance CAT, Komatsu, Volvo units—any age, any condition."
    ctaText="Stop Rental Leakage"
    ctaLink="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20get%20a%20quote%20for%20wheel%20loader%20financing."
    ctaSecondaryText="Call Decision Maker"
    ctaSecondaryLink="tel:+60175700889"
    lang={lang}
    variant="luxe"
    equipmentImage="/images/equipment/Caterpillar 966C.JPG"
    trustSignals={['40 Years Expertise', 'Quarry Specialist', '0% Deposit Option', 'Bad Credit Approved']}
  />

  <!-- Breadcrumbs -->
  <div class="container-custom py-4 font-display text-white">
    <Breadcrumbs items={breadcrumbs} lang={lang} />
  </div>

  <!-- Economics Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto">
        <div class="mb-16 md:mb-20 text-center">
            <h2 class="text-4xl md:text-7xl font-display uppercase  mb-8 tracking-tight leading-[1.1]">
                Ownership <br/><span class="text-[#D4A574]">Economics</span>
            </h2>
            <p class="text-lg md:text-xl text-[#0A0A0A]/60 font-light max-w-2xl mx-auto leading-relaxed">
                Profitability is a game of asset control. Renting is a tax on your growth; ownership is a deposit on your project success.
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 md:gap-16 mb-16 md:mb-20 items-center">
            <div class="bg-[#F9F9F9] p-8 md:p-12 rounded-[30px] md:rounded-[40px] border border-[#eee]">
                <p class="text-xl md:text-2xl font-display uppercase tracking-widest text-[#0A0A0A] mb-8">The Rental Burn</p>
                <div class="space-y-6">
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Monthly Rental Payment</span>
                        <span class="font-display tracking-widest">RM 16,000</span>
                    </div>
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Typical 4-Year Spend</span>
                        <span class="font-display tracking-widest">RM 768,000</span>
                    </div>
                    <div class="pt-4 border-t-2 border-red-500/20">
                        <div class="flex justify-between items-center">
                            <span class="font-bold text-[#0A0A0A] text-sm uppercase">Balance Sheet Value</span>
                            <span class="font-display text-2xl text-red-600">RM 0.00</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-[#0A0A0A] p-8 md:p-16 rounded-[40px] md:rounded-[60px] text-white shadow-2xl">
                <h3 class="text-2xl md:text-4xl font-display uppercase text-[#D4A574] mb-8">Asset <br/>Strategy</h3>
                <div class="space-y-6 mb-12">
                   <div class="flex justify-between border-b border-white/10 pb-4">
                       <span class="font-light text-white/40 text-sm">Financed Installment</span>
                       <span class="font-display tracking-widest">RM 12,800</span>
                   </div>
                   <div class="flex justify-between pb-4">
                       <span class="font-light text-green-500/80 text-sm italic">Monthly Operational Surplus</span>
                       <span class="font-display tracking-widest text-green-500">RM 3,200</span>
                   </div>
                </div>
                <Calculator lang={lang} equipmentType="Wheel Loader" defaultPrice={250000} variant="luxe" />
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section bg-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16">
        <h2 class="text-4xl md:text-5xl font-display uppercase  text-white mb-4 tracking-tight leading-[1.1]">
          Uncompromised <span class="text-[#D4A574]">Utility.</span>
        </h2>
        <p class="text-lg text-white/50 font-light max-w-xl">
          Secure the heavy assets your quarry depends on with the flexibility the banking sector refuses to offer.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        {benefits.map((benefit) => (
          <BenefitCard
            icon={benefit.icon}
            title={benefit.title}
            description={benefit.description}
            variant="luxe"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16 md:mb-20 text-center">
        <h2 class="text-4xl md:text-6xl font-display uppercase  mb-4  text-[#0A0A0A] tracking-tight leading-[1.1]">
          Quarry <br/> <span class="text-[#D4A574]">Intelligence</span>
        </h2>
        <p class="text-lg md:text-xl text-[#0A0A0A]/40 font-light mx-auto max-w-xl">
          Everything you need to know about scaling your heavy equipment assets.
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="space-y-4">
          {faqs.map((faq) => (
            <FAQItem question={faq.question} answer={faq.answer} variant="luxe" />
          ))}
        </div>
      </div>
    </div>
  </section>

  <RelatedEquipment lang={lang} currentEquipment="wheel-loader" variant="luxe" />

  <section class="section bg-[#D4A574] relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('/images/texture.png')] mix-blend-overlay pointer-events-none"></div>
    <div class="container-custom text-center relative z-10">
      <h2 class="text-5xl md:text-8xl font-display uppercase  text-[#0A0A0A] mb-8 tracking-tight leading-[1.1]">
        EVOLVE TO <br/><span class="opacity-40">FULL OWNERSHIP</span>
      </h2>
      <p class="text-[#0A0A0A]/70 text-xl font-light mb-12 max-w-2xl mx-auto leading-relaxed">
        Stop enriching rental fleets. Build your own infrastructure empire. Secure your wheel loader financing today.
      </p>
 
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center mb-20">
        <a
          href="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20apply%20for%20wheel%20loader%20financing."
          class="bg-[#0A0A0A] text-white px-12 py-6 font-display uppercase tracking-widest hover:bg-white hover:text-[#0A0A0A] transition-all shadow-2xl"
        >
          Secure Your Fleet
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
