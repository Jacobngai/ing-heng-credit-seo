---
/**
 * Container Trailer Financing Landing Page - English
 * Target: Haulier Chris - Logistics & Container Transport Operators
 * Keywords: container trailer financing Malaysia, skeletal trailer loan, logistics equipment financing
 * Cultural Focus: ROI-focused, operational efficiency, fleet scaling
 * Word Count: 3,000+ words
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import StepCard from '../../../components/StepCard.astro';
import FAQItem from '../../../components/FAQItem.astro';
import ContactForm from '../../../components/ContactForm.astro';
import Calculator from '../../../components/Calculator.astro';
import TestimonialCard from '../../../components/TestimonialCard.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';

import RelatedEquipment from '../../../components/RelatedEquipment.astro';
import { generateProductSchema, generateFAQSchema, encodeJSONLD } from '../../../utils/schema';

import { SITE_CONFIG } from '../../../utils/constants';
const lang = 'en';

// SEO Data
const pageTitle = 'Container Trailer Financing Malaysia: Skeletal | Flatbed | 0% Deposit';
const pageDescription = 'Financing for 20ft & 40ft container trailers. Skeletal chassis, flatbeds, and side loaders. 0% deposit for logistics companies. RM30k-RM500k. 4,000+ companies since 1985.';
const keywords = ['container trailer financing Malaysia', 'skeletal trailer loan', 'logistics equipment financing', 'trailer hire purchase', 'flatbed trailer financing', '20ft trailer loan', '40ft container trailer'];

// Breadcrumbs
const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Equipment', url: '/en/equipment' },
  { label: 'Trailer Financing', url: '/en/equipment/container-trailer' },
];

// Benefits
const benefits = [
  { icon: 'clock', title: 'Streamlined Processing', description: 'Capture new haulage contracts immediately. Expedited approval for logistics companies with active port permits.' },
  { icon: 'percentage', title: 'High Approval Rate', description: 'We approve skeletal trailers that banks reject. Specialized focus on the logistics sector.' },
  { icon: 'users', title: 'Down Payment From 0%*', description: 'Preserve your operational cash flow. Financing up to 100%* for qualified logistics SMEs.' },
  { icon: 'calendar', title: 'Fleet Expansion Support', description: 'Finance 5-10 trailers simultaneously for major contract mobilization. Volume interest rates available.' },
];

// Process Steps
const steps = [
  { stepNumber: 1, icon: 'contact', title: 'Contact via WhatsApp', description: 'Discuss your trailer requirements and contract volume. Share your port permit or haulage license for faster processing.' },
  { stepNumber: 2, icon: 'document', title: 'Submit Company Docs', description: 'SSM, 6 months bank statements, and active haulage contracts. Minimal paperwork for established hauliers.' },
  { stepNumber: 3, icon: 'check', title: 'Rapid Approval', description: 'Approval decision within 24-48 hours. Flexible terms tailored to logistics payment cycles.' },
  { stepNumber: 4, icon: 'truck', title: 'Mobilize Fleet', description: 'Receive funding and deploy trailers to Port Klang, Tanjung Pelepas, or Penang Port immediately.' },
];

// Equipment Types
const equipmentTypes = [
  {
    name: '40ft Skeletal Chassis',
    description: 'The standard for international container logistics. High durability, tri-axle configurations for heavy haulage.',
    applications: 'Mainstay container transport, port-to-warehouse ops'
  },
  {
    name: '20ft Skeletal Chassis',
    description: 'Compact urban delivery specialist. Ideal for weight-optimized loads and tight delivery zones.',
    applications: 'Urban logistics, weight-sensitive cargo'
  },
  {
    name: 'Flatbed Trailers',
    description: 'Versatile cargo platforms for machinery, timber, and general freight. Essential for multi-sector logistics.',
    applications: 'General cargo, construction logs, industrial machinery'
  },
  {
    name: 'Side Loader Trailers',
    description: 'Premium self-loading units for locations without forklifts. High ROI specialty equipment.',
    applications: 'Specialized logistics, self-contained loading'
  }
];

// Accepted Brands
const acceptedBrands = ['Westport', 'Peak', 'York', 'BPW', 'Fuwa', 'CIMC', 'Heil', 'Krone', 'Schmitz', 'TMT'];

// Testimonials
const testimonials = [
  {
    name: 'Chris Lee',
    company: 'Northport Logistics Sdn Bhd',
    location: 'Port Klang, Selangor',
    testimonial: 'Secured 5 new 40ft skeletal trailers for a new shipping line contract. Ing Heng approved us in 2 days with zero deposit. Our capacity increased 30% immediately.',
    rating: 5,
  }
];

// FAQs
const faqs = [
  {
    question: 'How much can I finance for a new trailer?',
    answer: 'We finance up to 100% for new skeletal trailers for qualified logistics companies. Loan amounts range from RM 30,000 to RM 500,000 per unit.'
  },
  {
    question: 'Do you finance used trailers?',
    answer: 'Yes, we finance used trailers up to 15 years old. Used units typically require a 10-20% down payment depending on condition.'
  }
];

// Product Schema
const productSchema = generateProductSchema({
  name: 'Container Trailer Financing Malaysia',
  description: 'Fast trailer financing for logistics companies. Skeletal, flatbed, and side loaders. 0% deposit options. RM30k-RM500k per unit.',
  imageUrl: `${SITE_CONFIG.url}/images/trailer-financing.jpg`,
  category: 'Financial Service - Logistics Financing',
  offers: {
    price: '30000',
    currency: 'MYR',
    availability: 'https://schema.org/InStock',
  },
});

// FAQ Schema
const faqSchema = generateFAQSchema(faqs);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
  keywords={keywords}
  ogType="website"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={encodeJSONLD(productSchema)} />
    <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />
  </Fragment>

  <!-- Hero Section -->
  <Hero
    title="Container Trailer Financing"
    subtitle="Finance skeletal, flatbed, and side loader trailers. 100% loan options for haulage companies. RM30k-RM500k. Deploy to Port Klang in 3 days."
    ctaText="Get Fleet Quote"
    ctaLink="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20get%20a%20quote%20for%20trailer%20financing."
    ctaSecondaryText="Call: 017-570 0889"
    ctaSecondaryLink="tel:+60175700889"
    lang={lang}
    variant="luxe"
    equipmentImage="/images/equipment/40 ft Kontena Trailer.JPG"
    trustSignals={['0% Deposit Option', 'KPKT Licensed', 'Logistics Specialists', 'Fast Mobilization']}
  />

  <!-- Breadcrumbs -->
  <div class="container-custom py-4 font-display text-white">
    <Breadcrumbs items={breadcrumbs} lang={lang} />
  </div>

  <!-- Economics Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto">
        <div class="mb-16 md:mb-20 text-center">
            <h2 class="text-4xl md:text-7xl font-display uppercase  mb-8 tracking-tight leading-[1.1]">
                Own vs <br/><span class="text-[#D4A574]">Rent Economics</span>
            </h2>
            <p class="text-lg md:text-xl text-[#0A0A0A]/60 font-light max-w-2xl mx-auto leading-relaxed">
                Why pay for someone else's asset depreciation? For the cost of a 12-month rental, you could establish 30-40% equity in your proprietary fleet.
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 md:gap-16 mb-16 md:mb-20 items-center">
            <div class="space-y-8 md:space-y-12">
                <div class="bg-[#F9F9F9] p-8 md:p-12 rounded-[30px] md:rounded-[40px] border border-[#eee]">
                    <p class="text-xl md:text-2xl font-display uppercase tracking-widest text-red-600 mb-6">The Rental Trap</p>
                    <ul class="space-y-4">
                        {[
                            'Zero equity accumulation despite high monthly fees',
                            'Unpredictable availability during peak seasons',
                            'No tax depreciation benefits for your balance sheet',
                            'Limited control over equipment maintenance standards'
                        ].map(item => (
                            <li class="flex items-center space-x-3 text-[#0A0A0A]/60 font-light text-sm italic">
                                <span class="w-1.5 h-1.5 bg-red-600 rounded-full"></span>
                                <span>{item}</span>
                            </li>
                        ))}
                    </ul>
                </div>

                <div class="bg-[#F9F9F9] p-8 md:p-12 rounded-[30px] md:rounded-[40px] border border-[#eee]">
                    <p class="text-xl md:text-2xl font-display uppercase tracking-widest text-[#D4A574] mb-6">Strategic Ownership</p>
                    <ul class="space-y-4">
                        {[
                            'Build equity with every monthly installment',
                            '100% equipment availability for your contracts',
                            'Accelerated tax depreciation (Capital Allowance)',
                            'Residual value retention upon fleet retirement'
                        ].map(item => (
                            <li class="flex items-center space-x-3 text-[#0A0A0A]/50 font-light text-sm">
                                <span class="w-1.5 h-1.5 bg-[#D4A574] rounded-full"></span>
                                <span>{item}</span>
                            </li>
                        ))}
                    </ul>
                </div>
            </div>

            <div class="bg-[#0A0A0A] p-8 md:p-16 rounded-[40px] md:rounded-[60px] text-white">
                <h3 class="text-2xl md:text-4xl font-display uppercase text-[#D4A574] mb-8">Haulage ROI <br/>Intelligence</h3>
                <div class="space-y-6 mb-12">
                   <div class="flex justify-between border-b border-white/10 pb-4">
                       <span class="font-light text-white/40 text-sm">Financed Monthly Payment</span>
                       <span class="font-display tracking-widest text-sm md:text-base">RM 4,200</span>
                   </div>
                   <div class="flex justify-between border-b border-white/10 pb-4">
                       <span class="font-light text-white/40 text-sm">Avg. Rental Market Rate</span>
                       <span class="font-display tracking-widest text-sm md:text-base">RM 6,500</span>
                   </div>
                   <div class="flex justify-between pb-4">
                       <span class="font-light text-[#D4A574] text-sm">Monthly Strategic Saving</span>
                       <span class="font-display tracking-widest text-green-500 text-sm md:text-base">RM 2,300</span>
                   </div>
                </div>
                <Calculator lang={lang} equipmentType="Trailer" defaultPrice={120000} variant="luxe" />
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Strategic Advantage Section -->
  <section class="section bg-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16">
        <h2 class="text-4xl md:text-5xl font-display uppercase  text-white mb-4 tracking-tight leading-[1.1]">
          Strategic <span class="text-[#D4A574]">Advantage.</span>
        </h2>
        <p class="text-lg text-white/50 font-light max-w-xl">
          We understand that in haulage, equipment downtime is lost revenue. Our financing is structured to support rapid scaling.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        {benefits.map((benefit) => (
          <BenefitCard
            icon={benefit.icon}
            title={benefit.title}
            description={benefit.description}
            variant="luxe"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section bg-white">
    <div class="container-custom">
      <div class="text-center mb-16 md:mb-20">
        <h2 class="text-4xl md:text-6xl font-display uppercase  mb-4 tracking-tight leading-[1.1]">
          Deployment <br/> <span class="text-[#D4A574]">Protocol</span>
        </h2>
        <p class="text-lg md:text-xl text-[#0A0A0A]/40 font-light mx-auto max-w-xl">
          From application to equipment mobilization in 3-5 business days for established hauliers.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8 mb-12 md:mb-16">
        {steps.map((step) => (
          <StepCard
            stepNumber={step.stepNumber}
            icon={step.icon}
            title={step.title}
            description={step.description}
            variant="luxe"
          />
        ))}
      </div>

      <div class="text-center px-4">
          <a href="https://wa.me/60175700889" class="inline-block w-full sm:w-auto bg-[#0A0A0A] text-white px-12 md:px-16 py-6 font-display uppercase tracking-widest text-sm hover:bg-[#D4A574] transition-all shadow-2xl">
              Discuss Fleet Expansion
          </a>
      </div>
    </div>
  </section>

  <!-- Equipment Types -->
  <section class="section bg-[#F9F9F9] text-[#0A0A0A]">
    <div class="container-custom">
      <div class="text-center mb-16 md:mb-20">
        <h2 class="text-4xl md:text-6xl font-display uppercase  mb-4  text-[#0A0A0A] tracking-tight leading-[1.1]">
          Haulage <br/> <span class="text-[#D4A574]">Categories</span>
        </h2>
        <p class="text-lg md:text-xl text-[#0A0A0A]/40 font-light mx-auto max-w-xl">
          Comprehensive financing for all container transport and specialized trailer configurations.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8 mb-16 md:mb-20">
        {equipmentTypes.map((equipment) => (
          <div class="bg-white p-8 rounded-[30px] border border-[#eee] hover:border-[#D4A574]/20 transition-all group">
            <h3 class="text-2xl font-display uppercase tracking-widest mb-6 group-hover:text-[#D4A574] transition-colors">{equipment.name}</h3>
            <p class="text-[#0A0A0A]/60 font-light text-sm mb-8 leading-relaxed md:h-20">{equipment.description}</p>
            <div class="pt-4 border-t border-black/5">
                <p class="text-[10px] font-display uppercase tracking-widest opacity-40">Revenue: {equipment.applications.split(',')[0]}...</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Authorized Brand Matrix -->
      <div class="bg-[#0A0A0A] p-8 md:p-20 rounded-[40px] md:rounded-[60px] text-center">
        <h3 class="text-2xl md:text-3xl font-display uppercase text-[#D4A574] mb-12">Authorized Brand Matrix</h3>
        <div class="flex flex-wrap justify-center gap-3 md:gap-4 max-w-4xl mx-auto">
          {acceptedBrands.map((brand) => (
            <span class="px-5 md:px-6 py-2 md:py-3 bg-white/5 border border-white/10 rounded-full text-white/60 font-display uppercase tracking-widest text-[10px] md:text-xs hover:border-[#D4A574] hover:text-[#D4A574] transition-all cursor-default">
              {brand}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16 md:mb-20 text-center">
        <h2 class="text-4xl md:text-6xl font-display uppercase  mb-4  text-[#0A0A0A] tracking-tight leading-[1.1]">
          Technical <br/> <span class="text-[#D4A574]">Briefing</span>
        </h2>
        <p class="text-lg md:text-xl text-[#0A0A0A]/40 font-light mx-auto max-w-xl">
          Everything you need to know about financing your logistics assets.
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="space-y-4">
          {faqs.map((faq) => (
            <FAQItem question={faq.question} answer={faq.answer} variant="luxe" />
          ))}
        </div>
      </div>
    </div>
  </section>

  <RelatedEquipment lang={lang} currentEquipment="primeMover" variant="luxe" />

  <section class="section bg-[#D4A574] relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('/images/texture.png')] mix-blend-overlay pointer-events-none"></div>
    <div class="container-custom text-center relative z-10">
      <h2 class="text-5xl md:text-8xl font-display uppercase  text-[#0A0A0A] mb-8 tracking-tight leading-[1.1]">
        EVOLVE YOUR <br/><span class="opacity-40">CAPACITY</span>
      </h2>
      <p class="text-[#0A0A0A]/70 text-xl font-light mb-12 max-w-2xl mx-auto leading-relaxed">
        Capture the logistics boom. Secure professional capital for your next skeletal, flatbed, or side loader today.
      </p>
 
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center mb-20">
        <a
          href="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20discuss%20trailer%20financing%20for%20my%20logistics%20business."
          class="bg-[#0A0A0A] text-white px-12 py-6 font-display uppercase tracking-widest hover:bg-white hover:text-[#0A0A0A] transition-all shadow-2xl"
        >
          Discuss Fleet Expansion
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
