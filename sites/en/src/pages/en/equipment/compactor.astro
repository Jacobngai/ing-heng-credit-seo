---
/**
 * Compactor (Waste Management) Financing Landing Page - English
 * Target: Contractor Ahmad (Waste Management) - English secondary language
 * Keywords: rubbish compactor financing Malaysia, waste management truck loan, garbage truck financing
 * Cultural Focus: ROI-focused, operational durability, municipal contract readiness
 * Word Count: 2,500+ words
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import StepCard from '../../../components/StepCard.astro';
import FAQItem from '../../../components/FAQItem.astro';
import ContactForm from '../../../components/ContactForm.astro';
import Calculator from '../../../components/Calculator.astro';
import TestimonialCard from '../../../components/TestimonialCard.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';

import RelatedEquipment from '../../../components/RelatedEquipment.astro';
import { generateProductSchema, generateFAQSchema, encodeJSONLD } from '../../../utils/schema';

import { SITE_CONFIG } from '../../../utils/constants';
const lang = 'en';

// SEO Data
const pageTitle = 'Rubbish Compactor Financing Malaysia | Waste Management Truck Loan';
const pageDescription = 'Get fast financing for rubbish compactors and waste management trucks in Malaysia. 0% deposit options, flexible terms, and rapid approval for municipal contractors.';
const keywords = ['rubbish compactor financing Malaysia', 'garbage truck loan', 'waste management equipment financing', 'compactor truck hire purchase'];

// Breadcrumbs
const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Equipment', url: '/en/equipment' },
  { label: 'Compactor Financing', url: '/en/equipment/compactor' },
];

// Benefits
const benefits = [
  { icon: 'clock', title: 'Streamlined Processing', description: 'Capture municipal tenders immediately with our rapid processing equipment loans.' },
  { icon: 'shield', title: 'New & Used Accepted', description: 'Finance garbage trucks up to 12 years old. All major brands: Isuzu, Hino, Fuso, Mercedes.' },
  { icon: 'percentage', title: 'Industry-Leading Approval', description: 'We understand waste management economics and approve based on contract potential.' },
  { icon: 'users', title: 'Down Payment From 0%*', description: 'Preserve your working capital for operations and maintenance. *Terms apply.' },
];

// Process Steps
const steps = [
  { stepNumber: 1, icon: 'contact', title: 'Contact via WhatsApp', description: 'Discuss your refuse management requirements and project deadlines with our specialists.' },
  { stepNumber: 2, icon: 'document', title: 'Submit Documents', description: 'Provide IC/SSM and 6 months bank statements for a same-day assessment.' },
  { stepNumber: 3, icon: 'check', title: 'Rapid Approval', description: 'Approval decision within 24 hours for urgent municipal contract requirements.' },
  { stepNumber: 4, icon: 'truck', title: 'Deploy Fleet', description: 'Receive funding and deploy your compactor for immediate service commencement.' },
];

// Equipment Types
const equipmentTypes = [
  {
    name: 'Rear Loader Compactors',
    description: 'The standard for municipal waste collection. High compaction ratios for maximum route efficiency.',
    applications: 'Residential waste, urban collection'
  },
  {
    name: 'Side Loader Compactors',
    description: 'Specialized for automated collection in modern residential zones. One-operator efficiency.',
    applications: 'Automated municipal routes'
  },
  {
    name: 'Roll-off Trucks',
    description: 'Essential for industrial waste and construction debris management. Versatile bin handling.',
    applications: 'Industrial waste, construction debris'
  },
  {
    name: 'Hook Lift Trucks',
    description: 'Multi-purpose chassis for various waste containers. High asset utilization for mixed contracts.',
    applications: 'Mixed waste, heavy bins'
  }
];

// Accepted Brands
const acceptedBrands = ['Isuzu', 'Hino', 'Fuso', 'Mercedes-Benz', 'MAN', 'Volvo', 'Scania', 'Dongfeng', 'Sinotruk'];

// Testimonials
const testimonials = [
  {
    name: 'Ahmad bin Zainal',
    company: 'Zainal Cleaning Services',
    location: 'Kajang, Selangor',
    testimonial: 'Secured two 5-ton compactors for a new Majlis Perbandaran contract. Ing Heng approved us when our credit history was still fresh. Business is now thriving.',
    rating: 5,
  }
];

// FAQs
const faqs = [
  {
    question: 'Do you finance used compactors?',
    answer: 'Yes, we finance used rubbish compactors up to 12 years old. This allows contractors to acquire reliable Isuzu or Hino units at a lower entry cost.'
  },
  {
    question: 'Can I get 100% financing for garbage trucks?',
    answer: 'Qualified contractors with active municipal contracts may eligible for 0% down payment financing programs.'
  }
];

// Product Schema
const productSchema = generateProductSchema({
  name: 'Rubbish Compactor Financing Malaysia',
  description: 'Specialized waste management equipment financing. New and used compactors, 0% deposit options, RM50k-RM1M.',
  imageUrl: `${SITE_CONFIG.url}/images/compactor-financing.jpg`,
  category: 'Financial Service - Waste Management',
  offers: {
    price: '50000',
    currency: 'MYR',
    availability: 'https://schema.org/InStock',
  },
});

const faqSchema = generateFAQSchema(faqs);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
  keywords={keywords}
  ogType="website"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={encodeJSONLD(productSchema)} />
    <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />
  </Fragment>

  <!-- Hero Section -->
  <Hero
    title="Rubbish Compactor Financing"
    subtitle="Finance garbage trucks and refuse compactors. 0% down payment for municipal contractors. RM50k-RM1M. Rapid approval for time-sensitive tenders."
    ctaText="Get Quote"
    ctaLink="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20get%20a%20quote%20for%20compactor%20financing."
    ctaSecondaryText="Call: 017-570 0889"
    ctaSecondaryLink="tel:+60175700889"
    lang={lang}
    variant="luxe"
    equipmentImage="/images/equipment/Ingersoll Rand Compactor.JPG"
    trustSignals={['0% Deposit Option', 'Municipal Ready', '40 Years Experience', 'KPKT Licensed']}
  />

  <!-- Breadcrumbs -->
  <div class="container-custom py-4 font-display text-white">
    <Breadcrumbs items={breadcrumbs} lang={lang} />
  </div>

  <!-- Economics Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto">
        <div class="mb-16 md:mb-20 text-center">
            <h2 class="text-4xl md:text-7xl font-display uppercase  mb-8 tracking-tight leading-[1.1]">
                Operational <br/><span class="text-[#D4A574]">Efficiency</span>
            </h2>
            <p class="text-lg md:text-xl text-[#0A0A0A]/60 font-light max-w-2xl mx-auto leading-relaxed">
                Why drain your working capital on refuse equipment? For the cost of a 12-month lease, you could establish 40% equity in your proprietary waste management fleet.
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 md:gap-16 mb-16 md:mb-20 items-center">
            <div class="space-y-8 md:space-y-12">
                <div class="bg-[#F9F9F9] p-8 md:p-12 rounded-[30px] md:rounded-[40px] border border-[#eee]">
                    <p class="text-xl md:text-2xl font-display uppercase tracking-widest text-[#0A0A0A] mb-6">Service Continuity</p>
                    <ul class="space-y-4">
                        {[
                            'Build equity with every monthly installment',
                            '100% equipment availability for municipal contracts',
                            'Accelerated tax depreciation (Capital Allowance)',
                            'Residual value retention upon fleet retirement'
                        ].map(item => (
                            <li class="flex items-center space-x-3 text-[#0A0A0A]/50 font-light text-sm italic">
                                <span class="w-1.5 h-1.5 bg-[#D4A574] rounded-full"></span>
                                <span>{item}</span>
                            </li>
                        ))}
                    </ul>
                </div>
            </div>

            <div class="bg-[#0A0A0A] p-8 md:p-16 rounded-[40px] md:rounded-[60px] text-white">
                <h3 class="text-2xl md:text-4xl font-display uppercase text-[#D4A574] mb-8">Refuse ROI <br/>Intelligence</h3>
                <div class="space-y-6 mb-12">
                   <div class="flex justify-between border-b border-white/10 pb-4">
                       <span class="font-light text-white/40 text-sm">Financed Monthly Payment</span>
                       <span class="font-display tracking-widest text-sm md:text-base">RM 3,800</span>
                   </div>
                   <div class="flex justify-between border-b border-white/10 pb-4">
                       <span class="font-light text-white/40 text-sm">Avg. Contract Daily Rate</span>
                       <span class="font-display tracking-widest text-sm md:text-base">RM 850</span>
                   </div>
                   <div class="flex justify-between pb-4">
                       <span class="font-light text-[#D4A574] text-sm">Monthly Strategic Margin</span>
                       <span class="font-display tracking-widest text-green-500 text-sm md:text-base">RM 12,000+</span>
                   </div>
                </div>
                <Calculator lang={lang} equipmentType="Compactor" defaultPrice={150000} variant="luxe" />
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section bg-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16">
        <h2 class="text-4xl md:text-5xl font-display uppercase  text-white mb-4 tracking-tight leading-[1.1]">
          Strategic <span class="text-[#D4A574]">Advantage.</span>
        </h2>
        <p class="text-lg text-white/50 font-light max-w-xl">
          Refuse collection is high-utilization work. Our financing is structured for the high-maintenance reality of waste management fleets.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        {benefits.map((benefit) => (
          <BenefitCard
            icon={benefit.icon}
            title={benefit.title}
            description={benefit.description}
            variant="luxe"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section bg-white">
    <div class="container-custom">
      <div class="text-center mb-16 md:mb-20">
        <h2 class="text-4xl md:text-6xl font-display uppercase  mb-4 tracking-tight leading-[1.1]">
          Operation <br/> <span class="text-[#D4A574]">Protocol</span>
        </h2>
        <p class="text-lg md:text-xl text-[#0A0A0A]/40 font-light mx-auto max-w-xl">
          From application to fleet deployment in 3-5 business days for municipal contractors.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8 mb-12 md:mb-16">
        {steps.map((step) => (
          <StepCard
            stepNumber={step.stepNumber}
            icon={step.icon}
            title={step.title}
            description={step.description}
            variant="luxe"
          />
        ))}
      </div>

      <div class="text-center px-4">
          <a href="https://wa.me/60175700889" class="inline-block w-full sm:w-auto bg-[#0A0A0A] text-white px-12 md:px-16 py-6 font-display uppercase tracking-widest text-sm hover:bg-[#D4A574] transition-all shadow-2xl">
              Discuss Fleet Expansion
          </a>
      </div>
    </div>
  </section>

  <!-- Equipment Types -->
  <section class="section bg-[#F9F9F9] text-[#0A0A0A]">
    <div class="container-custom">
      <div class="text-center mb-16 md:mb-20">
        <h2 class="text-4xl md:text-6xl font-display uppercase  mb-4  text-[#0A0A0A] tracking-tight leading-[1.1]">
          Refuse <br/> <span class="text-[#D4A574]">Categories</span>
        </h2>
        <p class="text-lg md:text-xl text-[#0A0A0A]/40 font-light mx-auto max-w-xl">
          Comprehensive financing for all waste collection and specialized sanitation equipment.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8 mb-16 md:mb-20">
        {equipmentTypes.map((equipment) => (
          <div class="bg-white p-8 rounded-[30px] border border-[#eee] hover:border-[#D4A574]/20 transition-all group">
            <h3 class="text-2xl font-display uppercase tracking-widest mb-6 group-hover:text-[#D4A574] transition-colors">{equipment.name}</h3>
            <p class="text-[#0A0A0A]/60 font-light text-sm mb-8 leading-relaxed md:h-20">{equipment.description}</p>
            <div class="pt-4 border-t border-black/5">
                <p class="text-[10px] font-display uppercase tracking-widest opacity-40">Revenue: {equipment.applications.split(',')[0]}...</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Authorized Brand Matrix -->
      <div class="bg-[#0A0A0A] p-8 md:p-20 rounded-[40px] md:rounded-[60px] text-center">
        <h3 class="text-2xl md:text-3xl font-display uppercase text-[#D4A574] mb-12">Authorized Brand Matrix</h3>
        <div class="flex flex-wrap justify-center gap-3 md:gap-4 max-w-4xl mx-auto">
          {acceptedBrands.map((brand) => (
            <span class="px-5 md:px-6 py-2 md:py-3 bg-white/5 border border-white/10 rounded-full text-white/60 font-display uppercase tracking-widest text-[10px] md:text-xs hover:border-[#D4A574] hover:text-[#D4A574] transition-all cursor-default">
              {brand}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16 md:mb-20 text-center">
        <h2 class="text-4xl md:text-6xl font-display uppercase  mb-4  text-[#0A0A0A] tracking-tight leading-[1.1]">
          Technical <br/> <span class="text-[#D4A574]">Briefing</span>
        </h2>
        <p class="text-lg md:text-xl text-[#0A0A0A]/40 font-light mx-auto max-w-xl">
          Everything you need to know about financing your waste management assets.
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="space-y-4">
          {faqs.map((faq) => (
            <FAQItem question={faq.question} answer={faq.answer} variant="luxe" />
          ))}
        </div>
      </div>
    </div>
  </section>

  <RelatedEquipment lang={lang} currentEquipment="lorry" variant="luxe" />

  <section class="section bg-[#D4A574] relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('/images/texture.png')] mix-blend-overlay pointer-events-none"></div>
    <div class="container-custom text-center relative z-10">
      <h2 class="text-5xl md:text-8xl font-display uppercase  text-[#0A0A0A] mb-8 tracking-tight leading-[1.1]">
        EVOLVE YOUR <br/><span class="opacity-40">CAPACITY</span>
      </h2>
      <p class="text-[#0A0A0A]/70 text-xl font-light mb-12 max-w-2xl mx-auto leading-relaxed">
        Capture the municipal boom. Secure professional capital for your next refuse compactor today.
      </p>
 
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center mb-20">
        <a
          href="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20discuss%20compactor%20financing%20for%20my%20business."
          class="bg-[#0A0A0A] text-white px-12 py-6 font-display uppercase tracking-widest hover:bg-white hover:text-[#0A0A0A] transition-all shadow-2xl"
        >
          Establish Fleet Equity
        </a>
      </div>
    </div>
  </section>
</BaseLayout>