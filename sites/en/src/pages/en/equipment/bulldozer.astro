---
/**
 * Bulldozer Financing Landing Page - English
 * Target: Major contractors and government tender specialists
 * Keywords: bulldozer financing Malaysia, CIDB G7 equipment loan, heavy earthmoving financing
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import FAQItem from '../../../components/FAQItem.astro';
import Calculator from '../../../components/Calculator.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import RelatedEquipment from '../../../components/RelatedEquipment.astro';

import { generateProductSchema, generateFAQSchema, encodeJSONLD } from '../../../utils/schema';
import { SITE_CONFIG } from '../../../utils/constants';

const lang = 'en';

// SEO Data
const pageTitle = 'Bulldozer Financing Malaysia | CIDB G7 Fleet Support | Ing Heng';
const pageDescription = 'Up to RM 15M bulldozer fleet financing for government tenders. MRT3, ECRL, Pan Borneo Highway approved. 0% deposit for CIDB G7 contractors. 24-hr credit decision.';
const keywords = ['bulldozer financing Malaysia', 'CIDB G7 equipment financing', 'heavy infrastructure loan', 'GPS bulldozer financing'];

// Breadcrumbs
const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Equipment', url: '/en/equipment' },
  { label: 'Bulldozer', url: '/en/equipment/bulldozer' },
];

const benefits = [
  { icon: 'clock', title: 'RM 15M Fleet Capacity', description: 'Scale for mega projects immediately. We finance 5-10 heavy bulldozers simultaneously for CIDB G7 contractors.' },
  { icon: 'percentage', title: '0% Deposit Strategy', description: 'Finance up to 100% of fleet value for qualified government tender projects. Preserve capital for performance bonds.' },
  { icon: 'shield', title: 'GPS Technology Inclusive', description: 'We finance 3D machine control and GPS-guided units (CAT AccuGrade, Komatsu iMC) to maximize tender scoring.' },
  { icon: 'lightning', title: 'Retention-Aligned Payments', description: 'Repayment structures that match government project cash flows and the 5-10% retention release schedules.' },
];

const faqs = [
  { 
    question: 'How does equipment ownership affect my government tender score?', 
    answer: 'Ownership typically accounts for 20-30 points in technical evaluation. "Owned equipment" scores significantly higher than rental or "intent to purchase," often being the deciding factor for RM 500M+ contracts.' 
  },
  { 
    question: 'Do you finance specialized swamp or LGP bulldozers for projects in Sarawak/Sabah?', 
    answer: 'Yes. We provide capital for LGP (Low Ground Pressure) and swamp-configured dozers essential for Pan Borneo Highway alignment and wetland reclamation.' 
  },
  {
    question: 'Can you help with CIDB G6 to G7 equipment upgrades?',
    answer: 'Absolutely. We specialize in structuring the equipment ownership block required for G7 unlimited tender registration, financing the full 80% of your new earthmoving fleet.'
  }
];

const productSchema = generateProductSchema({
  name: 'Bulldozer Financing Malaysia',
  description: 'Major fleet financing for CIDB G7 infrastructure projects. Secure D6-D11 bulldozers with strategic capital. GPS-ready units accepted.',
  imageUrl: `${SITE_CONFIG.url}/images/equipment/bulldozer.jpg`,
  category: 'Infrastructure Financing',
  offers: {
    price: '1850000',
    currency: 'MYR',
    availability: 'https://schema.org/InStock',
  },
});

const faqSchema = generateFAQSchema(faqs);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
  keywords={keywords}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={encodeJSONLD(productSchema)} />
    <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />
  </Fragment>

  <!-- Hero Section -->
  <Hero
    title="Bulldozer Financing"
    subtitle="RM 5M-15M bulldozer fleet financing for CIDB G7 contractors. 0% deposit available for ECRL, MRT3, and Pan Borneo Highway projects."
    ctaText="Get Fleet Strategy"
    ctaLink="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20discuss%20bulldozer%20fleet%20financing%20for%20a%20government%20tender."
    ctaSecondaryText="Call Decision Maker"
    ctaSecondaryLink="tel:+60175700889"
    lang={lang}
    variant="luxe"
    equipmentImage="/images/equipment/bulldozer.jpg"
    trustSignals={['40 Years Expertise', 'CIDB G7 Partner', 'RM 15M Capacity', 'Mega Project Approved']}
  />

  <!-- Breadcrumbs -->
  <div class="container-custom py-4 font-display text-white">
    <Breadcrumbs items={breadcrumbs} lang={lang} />
  </div>

  <!-- Economics Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto">
        <div class="mb-16 md:mb-20 text-center">
            <h2 class="text-4xl md:text-7xl font-display uppercase  mb-8 tracking-tight leading-[1.1]">
                Infrastructure <br/><span class="text-[#D4A574]">Capital</span>
            </h2>
            <p class="text-lg md:text-xl text-[#0A0A0A]/60 font-light max-w-2xl mx-auto leading-relaxed">
                MRT3, Pan Borneo, and national flood mitigation require heavy assets. We provide the liquidity you need to demonstrate equipment ownership and win high-value contracts.
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 md:gap-16 mb-16 md:mb-20 items-center">
            <div class="bg-[#F9F9F9] p-8 md:p-12 rounded-[30px] md:rounded-[40px] border border-[#eee]">
                <p class="text-xl md:text-2xl font-display uppercase tracking-widest text-[#0A0A0A] mb-8">The Tender Challenge</p>
                <div class="space-y-6">
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Fleet Investment Required</span>
                        <span class="font-display tracking-widest">RM 8,500,000</span>
                    </div>
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Typical Bank Down Payment (40%)</span>
                        <span class="font-display tracking-widest">RM 3,400,000</span>
                    </div>
                    <div class="pt-4 border-t-2 border-red-500/20">
                        <div class="flex justify-between items-center">
                            <span class="font-bold text-[#0A0A0A] text-sm uppercase">Our Down Payment (From 0%*)</span>
                            <span class="font-display text-2xl text-[#D4A574]">CAPITAL PRESERVED</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-[#0A0A0A] p-8 md:p-16 rounded-[40px] md:rounded-[60px] text-white shadow-2xl">
                <h3 class="text-2xl md:text-4xl font-display uppercase text-[#D4A574] mb-8">Fleet <br/>Planner</h3>
                <div class="space-y-6 mb-12">
                   <div class="flex justify-between border-b border-white/10 pb-4">
                       <span class="font-light text-white/40 text-sm">Typical Monthly Retainer</span>
                       <span class="font-display tracking-widest text-white/50 italic">Per Project Basis</span>
                   </div>
                   <div class="flex justify-between pb-4">
                       <span class="font-light text-green-500/80 text-sm italic">Project Equity Built</span>
                       <span class="font-display tracking-widest text-green-500 ">YES</span>
                   </div>
                </div>
                <Calculator lang={lang} equipmentType="Bulldozer Fleet" defaultPrice={1800000} variant="luxe" />
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section bg-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16">
        <h2 class="text-4xl md:text-5xl font-display uppercase  text-white mb-4 tracking-tight leading-[1.1]">
          Unrivaled <span class="text-[#D4A574]">Capability.</span>
        </h2>
        <p class="text-lg text-white/50 font-light max-w-xl">
          Strategic equipment packages designed to pass the most rigorous technical evaluations in Malaysian mega projects.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        {benefits.map((benefit) => (
          <BenefitCard
            icon={benefit.icon}
            title={benefit.title}
            description={benefit.description}
            variant="luxe"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16 md:mb-20 text-center">
        <h2 class="text-4xl md:text-6xl font-display uppercase  mb-4  text-[#0A0A0A] tracking-tight leading-[1.1]">
          Tender <br/> <span class="text-[#D4A574]">Intelligence</span>
        </h2>
        <p class="text-lg md:text-xl text-[#0A0A0A]/40 font-light mx-auto max-w-xl">
          Everything major contractors need to know about scaling heavy earthmoving capacity.
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="space-y-4">
          {faqs.map((faq) => (
            <FAQItem question={faq.question} answer={faq.answer} variant="luxe" />
          ))}
        </div>
      </div>
    </div>
  </section>

  <RelatedEquipment lang={lang} currentEquipment="bulldozer" variant="luxe" />

  <section class="section bg-[#D4A574] relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('/images/texture.png')] mix-blend-overlay pointer-events-none"></div>
    <div class="container-custom text-center relative z-10">
      <h2 class="text-5xl md:text-8xl font-display uppercase  text-[#0A0A0A] mb-8 tracking-tight leading-[1.1]">
        COMMAND YOUR <br/><span class="opacity-40">MEGA PROJECT</span>
      </h2>
      <p class="text-[#0A0A0A]/70 text-xl font-light mb-12 max-w-2xl mx-auto leading-relaxed">
        Don't let capital constraints cost you the tender. Secure your heavy bulldozer fleet with a strategic financing partner today.
      </p>
 
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center mb-20">
        <a
          href="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20apply%20for%20bulldozer%20fleet%20financing."
          class="bg-[#0A0A0A] text-white px-12 py-6 font-display uppercase tracking-widest hover:bg-white hover:text-[#0A0A0A] transition-all shadow-2xl"
        >
          Secure Your Fleet
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
