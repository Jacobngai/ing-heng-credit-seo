---
/**
 * Self-Loader Truck Financing Landing Page - English
 * Target: Towing entrepreneurs and vehicle transport specialists
 * Keywords: self loader truck financing Malaysia, Nissan carrier loan, towing business financing
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import FAQItem from '../../../components/FAQItem.astro';
import Calculator from '../../../components/Calculator.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import RelatedEquipment from '../../../components/RelatedEquipment.astro';

import { generateProductSchema, generateFAQSchema, encodeJSONLD } from '../../../utils/schema';
import { SITE_CONFIG } from '../../../utils/constants';

const lang = 'en';

// SEO Data
const pageTitle = 'Self-Loader Truck Financing Malaysia | Towing Business Support | Ing Heng';
const pageDescription = 'Finance your Nissan or Hino self-loader truck today. Enter the RM 2.5B towing industry with 0% deposit. Fast credit for towing entrepreneurs. Own your unit.';
const keywords = ['self loader truck financing Malaysia', 'towing business loan', 'Nissan self loader financing', 'vehicle recovery loan'];

// Breadcrumbs
const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Equipment', url: '/en/equipment' },
  { label: 'Self-Loader', url: '/en/equipment/self-loader' },
];

const benefits = [
  { icon: 'clock', title: 'Recession-Proof Revenue', description: 'Breakdowns never stop. Emergency towing: RM 200-800 per job. Secure your unit for 24/7 earning capacity.' },
  { icon: 'percentage', title: '0% Deposit for Operators', description: 'Finance up to 100% of your self-loader. Preserve your cash for licensing, insurance, and depot leases.' },
  { icon: 'shield', title: 'Condition Over Age', description: 'Nissan, Hino, Isuzu—from 15-year old recovery units to new carriers. If the hydraulics are strong, we fund it.' },
  { icon: 'lightning', title: 'Rapid Fleet Entry', description: 'Fast credit decisions within 24-48 hours. Don\'t let automotive service opportunities pass you by.' },
];

const faqs = [
  { 
    question: 'Can I start a towing business with financed equipment?', 
    answer: 'Yes. Most successful towing fleets start with financed units. Financing allows you to preserve capital while the truck generates the revenue required to pay itself off.' 
  },
  { 
    question: 'What types of self-loader trucks do you finance?', 
    answer: 'We finance Nissan, Hino, and Isuzu self-loaders, including car carriers and vehicle recovery trucks. We look at the income potential of the unit, not just the brand.' 
  },
  {
    question: 'Can I include repair or refurbishment costs in the financing?',
    answer: 'In many cases, we can package initial maintenance or hydraulic refurbishment costs into your financing facility to ensure your unit is road-ready.'
  }
];

const productSchema = generateProductSchema({
  name: 'Self-Loader Truck Financing Malaysia',
  description: 'Specialized financing for vehicle recovery and towing trucks. Enter the high-profit automotive services sector with strategic capital.',
  imageUrl: `${SITE_CONFIG.url}/images/equipment/self-loader.jpg`,
  category: 'Towing & Recovery Financing',
  offers: {
    price: '95000',
    currency: 'MYR',
    availability: 'https://schema.org/InStock',
  },
});

const faqSchema = generateFAQSchema(faqs);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
  keywords={keywords}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={encodeJSONLD(productSchema)} />
    <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />
  </Fragment>

  <!-- Hero Section -->
  <Hero
    title="Self-Loader Truck Financing"
    subtitle="Enter the RM 2.5 Billion automotive services market. 0% deposit available for Nissan, Hino, and Isuzu recovery trucks—any age accepted."
    ctaText="Start Your Towing Empire"
    ctaLink="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20get%20a%20quote%20for%20self-loader%20truck%20financing."
    ctaSecondaryText="Call Decision Maker"
    ctaSecondaryLink="tel:+60175700889"
    lang={lang}
    variant="luxe"
    equipmentImage="/images/equipment/Nissan Self Loader.JPG"
    trustSignals={['40 Years Expertise', 'Automotive Specialist', '0% Deposit Option', 'Bad Credit Approved']}
  />

  <!-- Breadcrumbs -->
  <div class="container-custom py-4 font-display text-white">
    <Breadcrumbs items={breadcrumbs} lang={lang} />
  </div>

  <!-- Economics Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto">
        <div class="mb-16 md:mb-20 text-center">
            <h2 class="text-4xl md:text-7xl font-display uppercase  mb-8 tracking-tight leading-[1.1]">
                Towing <br/><span class="text-[#D4A574]">Revenue</span>
            </h2>
            <p class="text-lg md:text-xl text-[#0A0A0A]/60 font-light max-w-2xl mx-auto leading-relaxed">
                Emergency recovery is a high-margin, recession-proof business. We provide the capital equipment you need to secure insurance contracts and roadside assistance revenue.
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 md:gap-16 mb-16 md:mb-20 items-center">
            <div class="bg-[#F9F9F9] p-8 md:p-12 rounded-[30px] md:rounded-[40px] border border-[#eee]">
                <p class="text-xl md:text-2xl font-display uppercase tracking-widest text-[#0A0A0A] mb-8">Service Potential</p>
                <div class="space-y-6">
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Emergency Towing (Per Job)</span>
                        <span class="font-display tracking-widest">RM 200-800</span>
                    </div>
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Target Monthly Jobs</span>
                        <span class="font-display tracking-widest">60-120</span>
                    </div>
                    <div class="pt-4 border-t-2 border-green-500/20">
                        <div class="flex justify-between items-center">
                            <span class="font-bold text-[#0A0A0A] text-sm uppercase">Estimated Monthly Revenue</span>
                            <span class="font-display text-2xl text-[#D4A574]">RM 15k-40k</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-[#0A0A0A] p-8 md:p-16 rounded-[40px] md:rounded-[60px] text-white shadow-2xl">
                <h3 class="text-2xl md:text-4xl font-display uppercase text-[#D4A574] mb-8">Business <br/>Planner</h3>
                <div class="space-y-6 mb-12">
                   <div class="flex justify-between border-b border-white/10 pb-4">
                       <span class="font-light text-white/40 text-sm">Financed Installment</span>
                       <span class="font-display tracking-widest">RM 2,450</span>
                   </div>
                   <div class="flex justify-between pb-4">
                       <span class="font-light text-green-500/80 text-sm italic">Estimated Surplus Potential</span>
                       <span class="font-display tracking-widest text-green-500 ">HIGH</span>
                   </div>
                </div>
                <Calculator lang={lang} equipmentType="Self Loader" defaultPrice={120000} variant="luxe" />
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section bg-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16">
        <h2 class="text-4xl md:text-5xl font-display uppercase  text-white mb-4 tracking-tight leading-[1.1]">
          Uninterrupted <span class="text-[#D4A574]">Services.</span>
        </h2>
        <p class="text-lg text-white/50 font-light max-w-xl">
          Enter the automotive services sector with heavy-duty self-loaders that pay for themselves through 24/7 recovery operations.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        {benefits.map((benefit) => (
          <BenefitCard
            icon={benefit.icon}
            title={benefit.title}
            description={benefit.description}
            variant="luxe"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16 md:mb-20 text-center">
        <h2 class="text-4xl md:text-6xl font-display uppercase  mb-4  text-[#0A0A0A] tracking-tight leading-[1.1]">
          Automotive <br/> <span class="text-[#D4A574]">Logistics</span>
        </h2>
        <p class="text-lg md:text-xl text-[#0A0A0A]/40 font-light mx-auto max-w-xl">
          Everything you need to know about starting your own vehicle transport and recovery business.
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="space-y-4">
          {faqs.map((faq) => (
            <FAQItem question={faq.question} answer={faq.answer} variant="luxe" />
          ))}
        </div>
      </div>
    </div>
  </section>

  <RelatedEquipment lang={lang} currentEquipment="self-loader" variant="luxe" />

  <section class="section bg-[#D4A574] relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('/images/texture.png')] mix-blend-overlay pointer-events-none"></div>
    <div class="container-custom text-center relative z-10">
      <h2 class="text-5xl md:text-8xl font-display uppercase  text-[#0A0A0A] mb-8 tracking-tight leading-[1.1]">
        DOMINATE THE <br/><span class="opacity-40">RECOVERY MARKET</span>
      </h2>
      <p class="text-[#0A0A0A]/70 text-xl font-light mb-12 max-w-2xl mx-auto leading-relaxed">
        Stop waiting for opportunities. Create them with your own self-loader fleet. Secure your towing business financing today.
      </p>
 
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center mb-20">
        <a
          href="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20apply%20for%20self-loader%20truck%20financing."
          class="bg-[#0A0A0A] text-white px-12 py-6 font-display uppercase tracking-widest hover:bg-white hover:text-[#0A0A0A] transition-all shadow-2xl"
        >
          Secure Your Unit
        </a>
      </div>
    </div>
  </section>
</BaseLayout>