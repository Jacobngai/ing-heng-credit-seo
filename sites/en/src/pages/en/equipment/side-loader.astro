---
/**
 * Container Side Loader Financing Landing Page - English
 * Target: Container depot owners and logistics specialized hauliers
 * Keywords: container side loader financing Malaysia, side loader loan, hammerlift financing
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import FAQItem from '../../../components/FAQItem.astro';
import Calculator from '../../../components/Calculator.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import RelatedEquipment from '../../../components/RelatedEquipment.astro';

import { generateProductSchema, generateFAQSchema, encodeJSONLD } from '../../../utils/schema';
import { SITE_CONFIG } from '../../../utils/constants';

const lang = 'en';

// SEO Data
const pageTitle = 'Container Side Loader Financing Malaysia | Depot Scaling | Ing Heng';
const pageDescription = 'Finance your 20ft & 40ft side loaders with 0% deposit. Strategic capital for container depots. We fund Steelbro, Hammar, and Boxloader units of any age.';
const keywords = ['container side loader financing Malaysia', 'side loader loan', 'Steelbro financing', 'Hammar side loader loan'];

// Breadcrumbs
const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Equipment', url: '/en/equipment' },
  { label: 'Side Loader', url: '/en/equipment/side-loader' },
];

const benefits = [
  { icon: 'clock', title: 'Depot-Speed Approval', description: 'Eliminate crane-dependency. We provide rapid credit decisions for side loaders that allow your depot to load/unload containers independently 24/7.' },
  { icon: 'percentage', title: '0% Deposit for Logistics', description: 'Finance up to 100% of your side loader unit. Preserve your cash for yard maintenance, fuel, and driver wages.' },
  { icon: 'shield', title: 'Hydraulic Agnostic Approval', description: 'Steelbro, Hammar, Boxloader—any brand, any age. If the hydraulic lifting arms are roadworthy and operational, we fund it.' },
  { icon: 'lightning', title: 'Multi-Unit Fleet Scaling', description: 'Scale from 1 to 5 units simultaneously. Specialized volume interest rates for established Port Klang haulage contractors.' },
];

const faqs = [
  { 
    question: 'Do you finance used container side loaders?', 
    answer: 'Yes. We specialize in financing used logistics assets. While banks reject units over 7 years old, we provide capital for reliable side loaders up to 15-20 years old.' 
  },
  { 
    question: 'Can I include trailer maintenance in the financing?', 
    answer: 'In many cases, we can package initial hydraulic servicing and system overhauls into your financing facility to ensure your side loader is operational from day one.' 
  }
];

const productSchema = generateProductSchema({
  name: 'Container Side Loader Financing Malaysia',
  description: 'Specialized financing for 20ft and 40ft container side loaders. Mobilize high-efficiency logistics assets with strategic capital.',
  imageUrl: `${SITE_CONFIG.url}/images/equipment/side-loader.jpg`,
  category: 'Logistics Financing',
  offers: {
    price: '450000',
    currency: 'MYR',
    availability: 'https://schema.org/InStock',
  },
});

const faqSchema = generateFAQSchema(faqs);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
  keywords={keywords}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={encodeJSONLD(productSchema)} />
    <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />
  </Fragment>

  <!-- Hero Section -->
  <Hero
    title="Side Loader Financing"
    subtitle="Escaping the bottleneck of third-party crane rentals. 0% deposit available for Steelbro, Hammar, and Boxloader side loaders—any age accepted."
    ctaText="Scale Your Depot"
    ctaLink="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20get%20a%20quote%20for%20side%20loader%20financing."
    ctaSecondaryText="Call Decision Maker"
    ctaSecondaryLink="tel:+60175700889"
    lang={lang}
    variant="luxe"
    equipmentImage="/images/equipment/Kontena Side Loader.JPG"
    trustSignals={['40 Years Expertise', 'Port Klang Specialist', '0% Deposit Option', 'Bad Credit Approved']}
  />

  <!-- Breadcrumbs -->
  <div class="container-custom py-4 font-display text-white">
    <Breadcrumbs items={breadcrumbs} lang={lang} />
  </div>

  <!-- Economics Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto">
        <div class="mb-16 md:mb-20 text-center">
            <h2 class="text-4xl md:text-7xl font-display uppercase  mb-8 tracking-tight leading-[1.1]">
                Logistics <br/><span class="text-[#D4A574]">Calculating</span>
            </h2>
            <p class="text-lg md:text-xl text-[#0A0A0A]/60 font-light max-w-2xl mx-auto leading-relaxed">
                Independent loading is a massive competitive advantage. We provide the capital you need to remove operational bottlenecks and build a self-sufficient haulage empire.
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 md:gap-16 mb-16 md:mb-20 items-center">
            <div class="bg-[#F9F9F9] p-8 md:p-12 rounded-[30px] md:rounded-[40px] border border-[#eee]">
                <p class="text-xl md:text-2xl font-display uppercase tracking-widest text-[#0A0A0A] mb-8">Asset Returns</p>
                <div class="space-y-6">
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Crane Rental Savings (Per Job)</span>
                        <span class="font-display tracking-widest text-sm md:text-base">RM 450+</span>
                    </div>
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Independent Load Capacity</span>
                        <span class="font-display tracking-widest text-sm md:text-base">20ft / 40ft Units</span>
                    </div>
                    <div class="pt-4 border-t-2 border-green-500/20">
                        <div class="flex justify-between items-center">
                            <span class="font-bold text-[#0A0A0A] text-sm uppercase">Operational Margin</span>
                            <span class="font-display text-2xl text-[#D4A574]">HIGH GAIN</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-[#0A0A0A] p-8 md:p-16 rounded-[40px] md:rounded-[60px] text-white shadow-2xl">
                <h3 class="text-2xl md:text-4xl font-display uppercase text-[#D4A574] mb-8">Fleet <br/>Planner</h3>
                <div class="space-y-6 mb-12">
                   <div class="flex justify-between border-b border-white/10 pb-4">
                       <span class="font-light text-white/40 text-sm">Multi-Unit Capacity</span>
                       <span class="font-display tracking-widest text-white/50 italic">UP TO 5 UNITS</span>
                   </div>
                   <div class="flex justify-between pb-4">
                       <span class="font-light text-green-500/80 text-sm italic">Projected ROI Status</span>
                       <span class="font-display tracking-widest text-green-500 ">POSITIVE</span>
                   </div>
                </div>
                <Calculator lang={lang} equipmentType="Side Loader" defaultPrice={450000} variant="luxe" />
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section bg-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16">
        <h2 class="text-4xl md:text-5xl font-display uppercase  text-white mb-4 tracking-tight leading-[1.1]">
          Dominant <span class="text-[#D4A574]">Autonomy.</span>
        </h2>
        <p class="text-lg text-white/50 font-light max-w-xl">
          Scale your logistics fleet with self-loading trailers that pay for themselves through eliminated crane fees and increased turnaround speed.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        {benefits.map((benefit) => (
          <BenefitCard
            icon={benefit.icon}
            title={benefit.title}
            description={benefit.description}
            variant="luxe"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16 md:mb-20 text-center">
        <h2 class="text-4xl md:text-6xl font-display uppercase  mb-4  text-[#0A0A0A] tracking-tight leading-[1.1]">
          Logistics <br/> <span class="text-[#D4A574]">Intelligence</span>
        </h2>
        <p class="text-lg md:text-xl text-[#0A0A0A]/40 font-light mx-auto max-w-xl">
          Everything you need to know about scaling your container side loader and haulage assets.
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="space-y-4">
          {faqs.map((faq) => (
            <FAQItem question={faq.question} answer={faq.answer} variant="luxe" />
          ))}
        </div>
      </div>
    </div>
  </section>

  <RelatedEquipment lang={lang} currentEquipment="prime-mover" variant="luxe" />

  <section class="section bg-[#D4A574] relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('/images/texture.png')] mix-blend-overlay pointer-events-none"></div>
    <div class="container-custom text-center relative z-10">
      <h2 class="text-5xl md:text-8xl font-display uppercase  text-[#0A0A0A] mb-8 tracking-tight leading-[1.1]">
        COMMAND YOUR <br/><span class="opacity-40">FINISHING FIELD</span>
      </h2>
      <p class="text-[#0A0A0A]/70 text-xl font-light mb-12 max-w-2xl mx-auto leading-relaxed">
        Stop losing margin to third-party crane rentals. Build your own logistics empire. Secure your container side loader financing today.
      </p>
 
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center mb-20">
        <a
          href="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20apply%20for%20side%20loader%20financing."
          class="bg-[#0A0A0A] text-white px-12 py-6 font-display uppercase tracking-widest hover:bg-white hover:text-[#0A0A0A] transition-all shadow-2xl"
        >
          Secure Your Unit
        </a>
      </div>
    </div>
  </section>
</BaseLayout>