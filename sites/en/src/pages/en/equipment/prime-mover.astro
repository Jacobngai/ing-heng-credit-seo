---
/**
 * Used Prime Mover Financing Landing Page - English
 * Target: Container trailer owners hiring drivers with trucks or renting trucks
 * Keywords: used prime mover financing Malaysia, Volvo prime mover loan, container transport financing
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import StepCard from '../../../components/StepCard.astro';
import FAQItem from '../../../components/FAQItem.astro';
import Calculator from '../../../components/Calculator.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import RelatedEquipment from '../../../components/RelatedEquipment.astro';

import { generateProductSchema, generateFAQSchema, encodeJSONLD } from '../../../utils/schema';
import { SITE_CONFIG } from '../../../utils/constants';

const lang = 'en';

// SEO Data
const pageTitle = 'Prime Mover Financing Malaysia | Stop Revenue Leakage | Ing Heng';
const pageDescription = 'Own your prime movers instead of hiring owner-drivers. Stop losing 40% revenue splits. Finance used Volvo, Scania 15+ years old. 0% deposit available.';
const keywords = ['prime mover financing Malaysia', 'used prime mover loan', 'container transport financing', 'Volvo prime mover loan'];

// Breadcrumbs
const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Equipment', url: '/en/equipment' },
  { label: 'Prime Mover', url: '/en/equipment/prime-mover' },
];

const benefits = [
  { icon: 'percentage', title: '0% Deposit Option', description: 'Finance up to 100% of equipment value for established logistics operators. Build equity for your fleet.' },
  { icon: 'shield', title: 'Any Age Accepted', description: 'Volvo FL10, Scania R420 - we finance units 15+ years old. High-mileage European trucks welcome.' },
  { icon: 'chart', title: 'Full Revenue Control', description: 'Hire salaried drivers and keep 100% of your freight revenue. Stop splitting your profits 60/40.' },
  { icon: 'lightning', title: 'Streamlined Processing', description: 'Quick decisions for urgent capacity expansion. Keep your trailers on the road and earning.' },
];

const steps = [
  { stepNumber: 1, icon: 'contact', title: 'Fleet Assessment', description: 'Discuss your current trailer capacity and revenue leakage with our logistics specialists.' },
  { stepNumber: 2, icon: 'document', title: 'Fast Application', description: 'Submit SSM and 6 months bank statements for a same-day preliminary approval.' },
  { stepNumber: 3, icon: 'check', title: 'Direct Funding', description: 'Approval based on your operational strength, not just credit score. Funds released directly to sellers.' },
  { stepNumber: 4, icon: 'truck', title: 'Command Your Fleet', description: 'Take delivery of your truck, hire your driver, and secure 100% of your next trip revenue.' },
];

const faqs = [
  { 
    question: 'Why should I own trucks instead of hiring owner-drivers?', 
    answer: 'Standard 60/40 splits mean you lose 40% of every trip just because the driver owns the truck. Over 2 years, you pay for the entire truck in splits but own nothing. Owning means you keep 100% revenue and build asset equity.' 
  },
  { 
    question: 'Do you finance high-mileage Volvo or Scania trucks?', 
    answer: 'YES. European trucks are built for 1.5 million km. Banks reject high mileage, but we value the remaining productive life of quality European engineering.' 
  },
  {
    question: 'Can I start with just one truck?',
    answer: 'Absolutely. Most of our clients grew their multi-unit fleets by starting with a single used prime mover to replace their most expensive hired truck.'
  },
  {
    question: 'What if I have CCRIS/CTOS records?',
    answer: 'We evaluate your current trailer business strength. If you have trailers and contracts, your business is viable collateral. We approve based on your ability to earn.'
  }
];

const productSchema = generateProductSchema({
  name: 'Prime Mover Financing Malaysia',
  description: 'Specialized financing for used prime movers. Stop revenue splits and build your own logistics fleet. Volvo, Scania, Mercedes brands accepted.',
  imageUrl: `${SITE_CONFIG.url}/images/equipment/prime-mover.jpg`,
  category: 'Logistics Asset Financing',
  offers: {
    price: '120000',
    currency: 'MYR',
    availability: 'https://schema.org/InStock',
  },
});

const faqSchema = generateFAQSchema(faqs);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
  keywords={keywords}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={encodeJSONLD(productSchema)} />
    <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />
  </Fragment>

  <!-- Hero Section -->
  <Hero
    title="Prime Mover Financing"
    subtitle="Own your prime movers. Hire salaried drivers. Keep 100% of your freight revenue. Finance used Volvo, Scania 15+ years old. 0% deposit option."
    ctaText="Stop Revenue Leakage"
    ctaLink="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20get%20a%20quote%20for%20prime%20mover%20financing."
    ctaSecondaryText="Call Decision Maker"
    ctaSecondaryLink="tel:+60175700889"
    lang={lang}
    variant="luxe"
    equipmentImage="/images/equipment/Volvo Prime Mover.JPG"
    trustSignals={['40 Years Expertise', 'European Truck Specialist', '0% Deposit Option', 'Bad Credit Approved']}
  />

  <!-- Breadcrumbs -->
  <div class="container-custom py-4 font-display text-white">
    <Breadcrumbs items={breadcrumbs} lang={lang} />
  </div>

  <!-- Economics Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto">
        <div class="mb-16 md:mb-20 text-center">
            <h2 class="text-4xl md:text-7xl font-display uppercase  mb-8 tracking-tight leading-[1.1]">
                Ownership <br/><span class="text-[#D4A574]">Economics</span>
            </h2>
            <p class="text-lg md:text-xl text-[#0A0A0A]/60 font-light max-w-2xl mx-auto leading-relaxed">
                Logistics is a margin game. When you hire owner-drivers, they take the cream of your profit. When you own the asset, the profit belongs to your business.
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 md:gap-16 mb-16 md:mb-20 items-center">
            <div class="bg-[#F9F9F9] p-8 md:p-12 rounded-[30px] md:rounded-[40px] border border-[#eee]">
                <p class="text-xl md:text-2xl font-display uppercase tracking-widest text-[#0A0A0A] mb-8">The Split Trap</p>
                <div class="space-y-6">
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Typical Trip Revenue</span>
                        <span class="font-display tracking-widest">RM 1,200</span>
                    </div>
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Owner-Driver Cut (40%)</span>
                        <span class="font-display tracking-widest text-red-600">RM 480</span>
                    </div>
                    <div class="flex justify-between pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm italic">Trips per Month</span>
                        <span class="font-display tracking-widest">20 Trips</span>
                    </div>
                    <div class="pt-4 border-t-2 border-[#D4A574]">
                        <div class="flex justify-between">
                            <span class="font-bold text-[#0A0A0A] text-sm uppercase">Monthly Revenue Leakage</span>
                            <span class="font-display text-2xl text-red-600">RM 9,600</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-[#0A0A0A] p-8 md:p-16 rounded-[40px] md:rounded-[60px] text-white shadow-2xl">
                <h3 class="text-2xl md:text-4xl font-display uppercase text-[#D4A574] mb-8">The Logistics <br/>ROI ROI</h3>
                <div class="space-y-6 mb-12">
                   <div class="flex justify-between border-b border-white/10 pb-4">
                       <span class="font-light text-white/40 text-sm">Financed Installment</span>
                       <span class="font-display tracking-widest">RM 5,500</span>
                   </div>
                   <div class="flex justify-between border-b border-white/10 pb-4">
                       <span class="font-light text-white/40 text-sm">Monthly Driver Salary</span>
                       <span class="font-display tracking-widest">RM 4,500</span>
                   </div>
                   <div class="flex justify-between pb-4">
                       <span class="font-light text-green-500/80 text-sm italic">Strategic Gain after Loan</span>
                       <span class="font-display tracking-widest text-green-500">RM 10,000+</span>
                   </div>
                </div>
                <Calculator lang={lang} equipmentType="Prime Mover" defaultPrice={180000} variant="luxe" />
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section bg-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16">
        <h2 class="text-4xl md:text-5xl font-display uppercase  text-white mb-4 tracking-tight leading-[1.1]">
          Unmatched <span class="text-[#D4A574]">Control.</span>
        </h2>
        <p class="text-lg text-white/50 font-light max-w-xl">
          Own your trucks, command your schedule, and capture every Ringgit of your logistics operations.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        {benefits.map((benefit) => (
          <BenefitCard
            icon={benefit.icon}
            title={benefit.title}
            description={benefit.description}
            variant="luxe"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section bg-white">
    <div class="container-custom">
      <div class="text-center mb-16 md:mb-20">
        <h2 class="text-4xl md:text-6xl font-display uppercase  mb-4 tracking-tight leading-[1.1]">
          Operational <br/> <span class="text-[#D4A574]">Pathway</span>
        </h2>
        <p class="text-lg md:text-xl text-[#0A0A0A]/40 font-light mx-auto max-w-xl">
          Transition from outsourcing to fleet ownership in 3-5 business days. 
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8 mb-12 md:mb-16">
        {steps.map((step) => (
          <StepCard
            stepNumber={step.stepNumber}
            icon={step.icon}
            title={step.title}
            description={step.description}
            variant="luxe"
          />
        ))}
      </div>

      <div class="text-center px-4">
          <a href="https://wa.me/60175700889" class="inline-block w-full sm:w-auto bg-[#0A0A0A] text-white px-12 md:px-16 py-6 font-display uppercase tracking-widest text-sm hover:bg-[#D4A574] transition-all shadow-2xl">
              Consolidate Your Revenue
          </a>
      </div>
    </div>
  </section>

  <!-- Brand Matrix -->
  <section class="section bg-[#F9F9F9] text-[#0A0A0A]">
    <div class="container-custom">
        <div class="bg-[#0A0A0A] p-8 md:p-20 rounded-[40px] md:rounded-[60px] text-center">
            <h3 class="text-2xl md:text-4xl font-display uppercase text-[#D4A574] mb-4">Master Brand Matrix</h3>
            <p class="text-white/40 font-light mb-12 max-w-lg mx-auto">Specialized financing for European reliability and Japanese efficiency.</p>
            <div class="flex flex-wrap justify-center gap-3 md:gap-4 max-w-4xl mx-auto">
              {['Volvo', 'Scania', 'Mercedes-Benz', 'MAN', 'Hino 700', 'UD Trucks', 'Isuzu Giga', 'Sinotruk', 'Dongfeng', 'Shacman'].map((brand) => (
                <span class="px-5 md:px-6 py-2 md:py-3 bg-white/5 border border-white/10 rounded-full text-white/60 font-display uppercase tracking-widest text-[10px] md:text-xs">
                  {brand}
                </span>
              ))}
            </div>
        </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16 md:mb-20 text-center">
        <h2 class="text-4xl md:text-6xl font-display uppercase  mb-4  text-[#0A0A0A] tracking-tight leading-[1.1]">
          Strategic <br/> <span class="text-[#D4A574]">Review</span>
        </h2>
        <p class="text-lg md:text-xl text-[#0A0A0A]/40 font-light mx-auto max-w-xl">
          Everything you need to know about scaling your logistics fleet.
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="space-y-4">
          {faqs.map((faq) => (
            <FAQItem question={faq.question} answer={faq.answer} variant="luxe" />
          ))}
        </div>
      </div>
    </div>
  </section>

  <RelatedEquipment lang={lang} currentEquipment="prime-mover" variant="luxe" />

  <section class="section bg-[#D4A574] relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('/images/texture.png')] mix-blend-overlay pointer-events-none"></div>
    <div class="container-custom text-center relative z-10">
      <h2 class="text-5xl md:text-8xl font-display uppercase  text-[#0A0A0A] mb-8 tracking-tight leading-[1.1]">
        EVOLVE TO <br/><span class="opacity-40">FULL CAPACITY</span>
      </h2>
      <p class="text-[#0A0A0A]/70 text-xl font-light mb-12 max-w-2xl mx-auto leading-relaxed">
        Join the logistics leaders who have reclaimed their trip revenue. Contact our specialists today to fund your next prime mover.
      </p>
 
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center mb-20">
        <a
          href="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20apply%20for%20used%20prime%20mover%20financing."
          class="bg-[#0A0A0A] text-white px-12 py-6 font-display uppercase tracking-widest hover:bg-white hover:text-[#0A0A0A] transition-all shadow-2xl"
        >
          Secure Your Fleet
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
