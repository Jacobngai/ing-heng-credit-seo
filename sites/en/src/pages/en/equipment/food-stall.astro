---
/**
 * Food Stall Equipment Financing Landing Page - English
 * Target: Hawker entrepreneurs, food court vendors, F&B startups
 * Keywords: food stall financing Malaysia, stainless steel stall loan, hawker equipment financing
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import StepCard from '../../../components/StepCard.astro';
import FAQItem from '../../../components/FAQItem.astro';
import ContactForm from '../../../components/ContactForm.astro';
import Calculator from '../../../components/Calculator.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import RelatedEquipment from '../../../components/RelatedEquipment.astro';

import { generateProductSchema, generateFAQSchema, encodeJSONLD } from '../../../utils/schema';
import { SITE_CONFIG } from '../../../utils/constants';

const lang = 'en';

// SEO Data
const pageTitle = 'Food Stall Equipment Financing Malaysia | Hawker Growth | Ing Heng';
const pageDescription = 'Finance your stainless steel food stalls and commercial kitchen equipment with 0% deposit. Strategic capital for F&B entrepreneurs. Monthly payments from RM 300.';
const keywords = ['food stall financing Malaysia', 'hawker stall loan', 'stainless steel stall financing', 'kitchen equipment loan'];

// Breadcrumbs
const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Equipment', url: '/en/equipment' },
  { label: 'Food Stall', url: '/en/equipment/food-stall' },
];

const benefits = [
  { icon: 'clock', title: 'Startup-Speed Approval', description: 'Begin your culinary journey immediately. We provide rapid credit decisions for first-time hawkers and food court vendors with minimal paperwork.' },
  { icon: 'percentage', title: '0% Deposit for Entrepreneurs', description: 'Finance 100% of your food stall setup. Preserve your startup capital for ingredients, rental deposits, and marketing.' },
  { icon: 'shield', title: 'All Equipment Accepted', description: 'Stainless steel stalls, deep fryers, refrigeration, or POS systems. If it’s essential for your food business, we fund it.' },
  { icon: 'lightning', title: 'Franchise-Scale Potential', description: 'Scale from one stall to a nationwide chain. Multi-unit financing packages for ambitious food entrepreneurs looking to dominate food courts.' },
];

const steps = [
  { stepNumber: 1, icon: 'contact', title: 'Concept Assessment', description: 'Define your stall design, equipment list, and intended food court location.' },
  { stepNumber: 2, icon: 'document', title: 'Vendor Verification', description: 'Simple review for small business owners and F&B entrepreneurs.' },
  { stepNumber: 3, icon: 'check', title: 'Unit Validation', description: 'Technical appraisal of the stainless steel stall and cooking equipment.' },
  { stepNumber: 4, icon: 'clipboard', title: 'Capital Deployment', description: 'Fast disbursement of funds directly to your equipment supplier or fabricator.' },
  { stepNumber: 5, icon: 'truck', title: 'Grand Opening', description: 'Commence your F&B operations with elite, professional-grade assets.' },
];

const faqs = [
  { 
    question: 'Can I finance a food stall for a new startup?', 
    answer: 'Yes. We specialize in helping F&B entrepreneurs launch their careers. While banks require years of financial history, we focus on your business potential and equipment value.' 
  },
  { 
    question: 'What is the minimum financing amount for a food stall?', 
    answer: 'Our financing starts from as low as RM 5,000, making it perfect for basic stainless steel hawker setups or specialized kitchen equipment.' 
  }
];

const productSchema = generateProductSchema({
  name: 'Food Stall Equipment Financing Malaysia',
  description: 'Specialized financing for stainless steel food stalls and commercial kitchen equipment. Empowering Malaysian F&B entrepreneurs with strategic capital.',
  imageUrl: `${SITE_CONFIG.url}/images/equipment/food-stall.jpg`,
  category: 'F&B Financing',
  offers: {
    price: '15000',
    currency: 'MYR',
    availability: 'https://schema.org/InStock',
  },
});

const faqSchema = generateFAQSchema(faqs);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
  keywords={keywords}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={encodeJSONLD(productSchema)} />
    <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />
  </Fragment>

  <!-- Hero Section -->
  <Hero
    title="Food Stall Financing"
    subtitle="Professional stainless steel food stalls and kitchen equipment for F&B entrepreneurs. 0% deposit available—monthly installments from RM 300."
    ctaText="Start Your Business"
    ctaLink="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20get%20a%20quote%20for%20food%20stall%20financing."
    ctaSecondaryText="Call Decision Maker"
    ctaSecondaryLink="tel:+60175700889"
    lang={lang}
    variant="luxe"
    equipmentImage="/images/equipment/Stainless Steel Stall.JPG"
    trustSignals={['40 Years Expertise', 'Small Business Support', '0% Deposit Option', 'Bad Credit Approved']}
  />

  <!-- Breadcrumbs -->
  <div class="container-custom py-4 font-display text-white">
    <Breadcrumbs items={breadcrumbs} lang={lang} />
  </div>

  <!-- Economics Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto">
        <div class="mb-16 md:mb-20 text-center">
            <h2 class="text-4xl md:text-7xl font-display uppercase  mb-8 tracking-tight leading-[1.1]">
                Business <br/><span class="text-[#D4A574]">Calculating</span>
            </h2>
            <p class="text-lg md:text-xl text-[#0A0A0A]/60 font-light max-w-2xl mx-auto leading-relaxed">
                Elite presentation drives customer trust and revenue. We provide the capital for professional equipment that transforms a street vendor into a food court authority.
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 md:gap-16 mb-16 md:mb-20 items-center">
            <div class="bg-[#F9F9F9] p-8 md:p-12 rounded-[30px] md:rounded-[40px] border border-[#eee]">
                <p class="text-xl md:text-2xl font-display uppercase tracking-widest text-[#0A0A0A] mb-8">Asset Returns</p>
                <div class="space-y-6">
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Monthly Installment Starting</span>
                        <span class="font-display tracking-widest text-sm md:text-base">RM 300+</span>
                    </div>
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Professional Look Impact</span>
                        <span class="font-display tracking-widest text-sm md:text-base text-green-600">HIGH TRUST</span>
                    </div>
                    <div class="pt-4 border-t-2 border-green-500/20">
                        <div class="flex justify-between items-center">
                            <span class="font-bold text-[#0A0A0A] text-sm uppercase">Barrier To Entry</span>
                            <span class="font-display text-2xl text-[#D4A574]">REMOVED</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-[#0A0A0A] p-8 md:p-16 rounded-[40px] md:rounded-[60px] text-white shadow-2xl">
                <h3 class="text-2xl md:text-4xl font-display uppercase text-[#D4A574] mb-8">Stall <br/>Planner</h3>
                <div class="space-y-6 mb-12">
                   <div class="flex justify-between border-b border-white/10 pb-4">
                       <span class="font-light text-white/40 text-sm">Financing Availability</span>
                       <span class="font-display tracking-widest text-white/50 italic text-sm">UP TO RM 100K</span>
                   </div>
                   <div class="flex justify-between pb-4">
                       <span class="font-light text-green-500/80 text-sm italic">Projected ROI Status</span>
                       <span class="font-display tracking-widest text-green-500 ">POSITIVE</span>
                   </div>
                </div>
                <Calculator lang={lang} equipmentType="Food Stall" defaultPrice={15000} variant="luxe" />
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section bg-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16">
        <h2 class="text-4xl md:text-5xl font-display uppercase  text-white mb-4 tracking-tight leading-[1.1]">
          Dominant <span class="text-[#D4A574]">Enterprise.</span>
        </h2>
        <p class="text-lg text-white/50 font-light max-w-xl">
          Empower your culinary vision with professional assets that attract customers and eliminate operational reliability issues.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        {benefits.map((benefit) => (
          <BenefitCard
            icon={benefit.icon}
            title={benefit.title}
            description={benefit.description}
            variant="luxe"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Step Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16">
        <h2 class="text-4xl md:text-5xl font-display uppercase  mb-4 text-[#0A0A0A] tracking-tight leading-[1.1]">
          Strategic <span class="text-[#D4A574]">Onboarding.</span>
        </h2>
        <p class="text-lg text-[#0A0A0A]/60 font-light max-w-xl">
          From concept appraisal to grand opening. A streamlined process designed for Malaysian F&B entrepreneurs.
        </p>
      </div>

      <div class="grid md:grid-cols-5 gap-4">
        {steps.map((step) => (
          <StepCard
            stepNumber={step.stepNumber}
            icon={step.icon}
            title={step.title}
            description={step.description}
            variant="luxe"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section bg-white text-[#0A0A0A] border-t border-black/5">
    <div class="container-custom">
      <div class="mb-16 md:mb-20 text-center">
        <h2 class="text-4xl md:text-6xl font-display uppercase  mb-4  text-[#0A0A0A] tracking-tight leading-[1.1]">
          F&B <br/> <span class="text-[#D4A574]">Intelligence</span>
        </h2>
        <p class="text-lg md:text-xl text-[#0A0A0A]/40 font-light mx-auto max-w-xl">
          Everything you need to know about scaling your food stall and commercial kitchen assets.
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="space-y-4">
          {faqs.map((faq) => (
            <FAQItem question={faq.question} answer={faq.answer} variant="luxe" />
          ))}
        </div>
      </div>
    </div>
  </section>

  <RelatedEquipment lang={lang} currentEquipment="forklift" variant="luxe" />

  <section class="section bg-[#D4A574] relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('/images/texture.png')] mix-blend-overlay pointer-events-none"></div>
    <div class="container-custom text-center relative z-10">
      <h2 class="text-5xl md:text-8xl font-display uppercase  text-[#0A0A0A] mb-8 tracking-tight leading-[1.1]">
        COMMAND YOUR <br/><span class="opacity-40">KITCHEN FIELD</span>
      </h2>
      <p class="text-[#0A0A0A]/70 text-xl font-light mb-12 max-w-2xl mx-auto leading-relaxed">
        Stop waiting for enough savings to start. Build your own food empire now. Secure your food stall financing today.
      </p>
 
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center mb-20">
        <a
          href="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20apply%20for%20food%20stall%20financing."
          class="bg-[#0A0A0A] text-white px-12 py-6 font-display uppercase tracking-widest hover:bg-white hover:text-[#0A0A0A] transition-all shadow-2xl"
        >
          Secure Your Unit
        </a>
      </div>
    </div>
  </section>

  <!-- Contact Form Section -->
  <section class="section bg-[#0A0A0A]">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto bg-white/5 border border-white/10 rounded-3xl overflow-hidden flex flex-col lg:flex-row shadow-2xl">
        <div class="lg:w-1/3 p-12 bg-[#D4A574] text-[#0A0A0A]">
            <h2 class="text-4xl font-display uppercase  mb-8 tracking-tight leading-[1.1]">Establish<br/>Capacity<br/>Today.</h2>
            <p class="font-light opacity-80 mb-8">
                Request a strategic consultation for F&B equipment financing. 
            </p>
            <div class="space-y-4 text-sm font-display uppercase tracking-widest">
                <p>Monday - Friday: 9am - 5pm</p>
                <p>Saturday: 9am - 1pm</p>
            </div>
        </div>
        <div class="lg:w-2/3 p-12 bg-white/5">
            <ContactForm lang={lang} />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>