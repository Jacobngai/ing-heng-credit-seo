---
/**
 * Soil Compactor / Road Roller Financing Landing Page - English
 * Target: Civil engineering contractors and road builders
 * Keywords: soil compactor financing Malaysia, road roller loan, BOMAG financing
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import FAQItem from '../../../components/FAQItem.astro';
import Calculator from '../../../components/Calculator.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import RelatedEquipment from '../../../components/RelatedEquipment.astro';

import { generateProductSchema, generateFAQSchema, encodeJSONLD } from '../../../utils/schema';
import { SITE_CONFIG } from '../../../utils/constants';

const lang = 'en';

// SEO Data
const pageTitle = 'Soil Compactor Financing Malaysia | Road Roller Loan | Ing Heng';
const pageDescription = 'Finance your BOMAG, Dynapac, or Ingersoll Rand soil compactor today. 0% deposit available for road construction projects. Secure heavy machinery capital.';
const keywords = ['soil compactor financing Malaysia', 'road roller loan', 'BOMAG financing Malaysia', 'Dynapac compactor loan'];

// Breadcrumbs
const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Equipment', url: '/en/equipment' },
  { label: 'Soil Compactor', url: '/en/equipment/soil-compactor' },
];

const benefits = [
  { icon: 'clock', title: 'Infrastructure Ready', description: 'Capture immediate road construction contracts. We provide rapid credit decisions for time-sensitive infrastructure projects.' },
  { icon: 'percentage', title: '0% Deposit for Contractors', description: 'Finance up to 100% of your compaction unit. Preserve your cash for site mobilization and material procurement.' },
  { icon: 'shield', title: 'Premium Brand Support', description: 'BOMAG, Dynapac, CAT, Ingersoll Rand—any brand, any age. If the vibration system is strong, we fund it.' },
  { icon: 'lightning', title: 'Project-Based Speed', description: 'Fast credit decisions within 24-48 hours. Don\'t let public works opportunities pass you by due to capital delay.' },
];

const faqs = [
  { 
    question: 'Do you finance used soil compactors?', 
    answer: 'Yes. We specialize in financing used heavy machinery. As long as the unit is operational and has a strong service history, we fund it regardless of age.' 
  },
  { 
    question: 'Can I include transport costs in the financing?', 
    answer: 'In many cases, we can package initial transportation and site mobilization costs into your financing facility to ensure you are project-ready.' 
  }
];

const productSchema = generateProductSchema({
  name: 'Soil Compactor Financing Malaysia',
  description: 'Specialized financing for road rollers and soil compactors. Secure high-performance construction assets with strategic capital.',
  imageUrl: `${SITE_CONFIG.url}/images/equipment/soil-compactor.jpg`,
  category: 'Construction Financing',
  offers: {
    price: '145000',
    currency: 'MYR',
    availability: 'https://schema.org/InStock',
  },
});

const faqSchema = generateFAQSchema(faqs);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
  keywords={keywords}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={encodeJSONLD(productSchema)} />
    <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />
  </Fragment>

  <!-- Hero Section -->
  <Hero
    title="Soil Compactor Financing"
    subtitle="Secure high-performance soil compactors with 0% deposit. We fund BOMAG, Dynapac, and Ingersoll Rand—any age accepted for road builders."
    ctaText="Secure Civil Capital"
    ctaLink="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20get%20a%20quote%20for%20soil%20compactor%20financing."
    ctaSecondaryText="Call Decision Maker"
    ctaSecondaryLink="tel:+60175700889"
    lang={lang}
    variant="luxe"
    equipmentImage="/images/equipment/Ingersoll Rand Compactor.JPG"
    trustSignals={['40 Years Expertise', 'Infrastructure Specialist', '0% Deposit Option', 'Bad Credit Approved']}
  />

  <!-- Breadcrumbs -->
  <div class="container-custom py-4 font-display text-white">
    <Breadcrumbs items={breadcrumbs} lang={lang} />
  </div>

  <!-- Economics Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto">
        <div class="mb-16 md:mb-20 text-center">
            <h2 class="text-4xl md:text-7xl font-display uppercase  mb-8 tracking-tight leading-[1.1]">
                Infrastructure <br/><span class="text-[#D4A574]">Calculating</span>
            </h2>
            <p class="text-lg md:text-xl text-[#0A0A0A]/60 font-light max-w-2xl mx-auto leading-relaxed">
                Road construction margin is built on equipment reliability. We provide the capital you need to secure more public works and build a tangible construction empire.
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 md:gap-16 mb-16 md:mb-20 items-center">
            <div class="bg-[#F9F9F9] p-8 md:p-12 rounded-[30px] md:rounded-[40px] border border-[#eee]">
                <p class="text-xl md:text-2xl font-display uppercase tracking-widest text-[#0A0A0A] mb-8">Asset Returns</p>
                <div class="space-y-6">
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Typical Project Revenue (Monthly)</span>
                        <span class="font-display tracking-widest text-sm md:text-base">RM 25,000+</span>
                    </div>
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Financed Monthly Payment</span>
                        <span class="font-display tracking-widest text-sm md:text-base">RM 3,200</span>
                    </div>
                    <div class="pt-4 border-t-2 border-green-500/20">
                        <div class="flex justify-between items-center">
                            <span class="font-bold text-[#0A0A0A] text-sm uppercase">Operational Margin</span>
                            <span class="font-display text-2xl text-[#D4A574]">HIGH GAIN</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-[#0A0A0A] p-8 md:p-16 rounded-[40px] md:rounded-[60px] text-white shadow-2xl">
                <h3 class="text-2xl md:text-4xl font-display uppercase text-[#D4A574] mb-8">Asset <br/>Planner</h3>
                <div class="space-y-6 mb-12">
                   <div class="flex justify-between border-b border-white/10 pb-4">
                       <span class="font-light text-white/40 text-sm">Fleet Expansion Potential</span>
                       <span class="font-display tracking-widest text-white/50 italic">RM 2M+ CAPACITY</span>
                   </div>
                   <div class="flex justify-between pb-4">
                       <span class="font-light text-green-500/80 text-sm italic">Projected ROI Status</span>
                       <span class="font-display tracking-widest text-green-500 ">POSITIVE</span>
                   </div>
                </div>
                <Calculator lang={lang} equipmentType="Soil Compactor" defaultPrice={160000} variant="luxe" />
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section bg-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16">
        <h2 class="text-4xl md:text-5xl font-display uppercase  text-white mb-4 tracking-tight leading-[1.1]">
          Dominant <span class="text-[#D4A574]">Compaction.</span>
        </h2>
        <p class="text-lg text-white/50 font-light max-w-xl">
          Scale your road construction fleet with heavy-duty rollers that pay for themselves through consistent infrastructure sub-contracts.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        {benefits.map((benefit) => (
          <BenefitCard
            icon={benefit.icon}
            title={benefit.title}
            description={benefit.description}
            variant="luxe"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16 md:mb-20 text-center">
        <h2 class="text-4xl md:text-6xl font-display uppercase  mb-4  text-[#0A0A0A] tracking-tight leading-[1.1]">
          Civil <br/> <span class="text-[#D4A574]">Intelligence</span>
        </h2>
        <p class="text-lg md:text-xl text-[#0A0A0A]/40 font-light mx-auto max-w-xl">
          Everything you need to know about scaling your road construction and compaction assets.
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="space-y-4">
          {faqs.map((faq) => (
            <FAQItem question={faq.question} answer={faq.answer} variant="luxe" />
          ))}
        </div>
      </div>
    </div>
  </section>

  <RelatedEquipment lang={lang} currentEquipment="excavator" variant="luxe" />

  <section class="section bg-[#D4A574] relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('/images/texture.png')] mix-blend-overlay pointer-events-none"></div>
    <div class="container-custom text-center relative z-10">
      <h2 class="text-5xl md:text-8xl font-display uppercase  text-[#0A0A0A] mb-8 tracking-tight leading-[1.1]">
        COMMAND YOUR <br/><span class="opacity-40">INFRASTRUCTURE</span>
      </h2>
      <p class="text-[#0A0A0A]/70 text-xl font-light mb-12 max-w-2xl mx-auto leading-relaxed">
        Stop losing tenders to equipment unavailability. Build your own civil engineering empire. Secure your soil compactor financing today.
      </p>
 
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center mb-20">
        <a
          href="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20apply%20for%20soil%20compactor%20financing."
          class="bg-[#0A0A0A] text-white px-12 py-6 font-display uppercase tracking-widest hover:bg-white hover:text-[#0A0A0A] transition-all shadow-2xl"
        >
          Secure Your Unit
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
