---
/**
 * Lorry (Commercial Truck) Financing Landing Page - English
 * Target: Logistics operators and fleet managers
 * Keywords: lorry financing Malaysia, commercial truck loan, Port Klang logistics
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import BenefitCard from '../../../components/BenefitCard.astro';
import FAQItem from '../../../components/FAQItem.astro';
import Calculator from '../../../components/Calculator.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import RelatedEquipment from '../../../components/RelatedEquipment.astro';

import { generateProductSchema, generateFAQSchema, encodeJSONLD } from '../../../utils/schema';
import { SITE_CONFIG } from '../../../utils/constants';

const lang = 'en';

// SEO Data
const pageTitle = 'Commercial Lorry Financing Malaysia | Fleet Expansion | Ing Heng';
const pageDescription = 'Finance your 1-ton to 40-ton lorries with 0% deposit. Port Klang specialists. We fund Isuzu, Hino, and UD Trucks of any age. Fast 24-hr credit approval.';
const keywords = ['lorry financing Malaysia', 'commercial truck loan', 'Port Klang logistics financing', 'SME lorry loan'];

// Breadcrumbs
const breadcrumbs = [
  { label: 'Home', url: '/en' },
  { label: 'Equipment', url: '/en/equipment' },
  { label: 'Lorry', url: '/en/equipment/lorry' },
];

const benefits = [
  { icon: 'clock', title: '24-Hour Fleet Entry', description: 'Capture immediate logistics contracts. We provide lightning-fast credit decisions for time-sensitive haulage opportunities.' },
  { icon: 'percentage', title: '0% Deposit for Fleets', description: 'Finance up to 100% of your commercial units. Preserve working capital for fuel, driver wages, and maintenance.' },
  { icon: 'shield', title: 'Age-Agnostic Approval', description: 'Isuzu, Hino, UD Trucks—any tonnage, any age. If the unit is roadworthy and generates revenue, we fund it.' },
  { icon: 'lightning', title: 'Multi-Unit Capacity', description: 'Scale from 1 to 10 units simultaneously. Specialized volume interest rates for established logistics SMEs.' },
];

const faqs = [
  { 
    question: 'Do you finance used commercial lorries?', 
    answer: 'Yes. We specialize in financing used commercial assets. While banks reject units over 5-7 years old, we provide capital for reliable lorries up to 15-20 years old.' 
  },
  { 
    question: 'Can I refinance my existing lorry loan?', 
    answer: 'Absolutely. If you are paying high interest elsewhere, we can settle your existing facility and provide a more competitive rate to improve your monthly cash flow.' 
  },
  {
    question: 'What is the maximum loan amount for a prime mover?',
    answer: 'We can finance up to RM 800,000 for high-value prime movers and container trailers, depending on your business track record and contract volume.'
  }
];

const productSchema = generateProductSchema({
  name: 'Commercial Lorry Financing Malaysia',
  description: 'Specialized financing for 1-ton to 40-ton commercial trucks. Fleet solutions for Port Klang and Klang Valley logistics operators.',
  imageUrl: `${SITE_CONFIG.url}/images/equipment/lorry.jpg`,
  category: 'Logistics Financing',
  offers: {
    price: '85000',
    currency: 'MYR',
    availability: 'https://schema.org/InStock',
  },
});

const faqSchema = generateFAQSchema(faqs);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
  keywords={keywords}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={encodeJSONLD(productSchema)} />
    <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} />
  </Fragment>

  <!-- Hero Section -->
  <Hero
    title="Lorry Financing"
    subtitle="Escaping the high-barrier entry of logistics. 0% deposit available for Isuzu, Hino, and UD Trucks—any age, any tonnage."
    ctaText="Scale Your Fleet"
    ctaLink="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20get%20a%20quote%20for%20lorry%20financing."
    ctaSecondaryText="Call Decision Maker"
    ctaSecondaryLink="tel:+60175700889"
    lang={lang}
    variant="luxe"
    equipmentImage="/images/equipment/lorry.jpg"
    trustSignals={['40 Years Expertise', 'Port Klang Specialist', '0% Deposit Option', 'Bad Credit Approved']}
  />

  <!-- Breadcrumbs -->
  <div class="container-custom py-4 font-display text-white">
    <Breadcrumbs items={breadcrumbs} lang={lang} />
  </div>

  <!-- Economics Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="max-w-6xl mx-auto">
        <div class="mb-16 md:mb-20 text-center">
            <h2 class="text-4xl md:text-7xl font-display uppercase  mb-8 tracking-tight leading-[1.1]">
                Logistics <br/><span class="text-[#D4A574]">Calculating</span>
            </h2>
            <p class="text-lg md:text-xl text-[#0A0A0A]/60 font-light max-w-2xl mx-auto leading-relaxed">
                Profitability in logistics is a game of asset volume. We provide the capital you need to secure more routes and build a tangible haulage empire.
            </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 md:gap-16 mb-16 md:mb-20 items-center">
            <div class="bg-[#F9F9F9] p-8 md:p-12 rounded-[30px] md:rounded-[40px] border border-[#eee]">
                <p class="text-xl md:text-2xl font-display uppercase tracking-widest text-[#0A0A0A] mb-8">The Scaling Problem</p>
                <div class="space-y-6 text-[#0A0A0A]">
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Target Monthly Revenue (Per Unit)</span>
                        <span class="font-display tracking-widest text-sm md:text-base">RM 15,000+</span>
                    </div>
                    <div class="flex justify-between border-b border-black/5 pb-4">
                        <span class="font-light text-[#0A0A0A]/40 text-sm">Typical Finance Payment</span>
                        <span class="font-display tracking-widest text-sm md:text-base">RM 2,800</span>
                    </div>
                    <div class="pt-4 border-t-2 border-green-500/20">
                        <div class="flex justify-between items-center">
                            <span class="font-bold text-[#0A0A0A] text-sm uppercase">Monthly Net Gain</span>
                            <span class="font-display text-2xl text-[#D4A574]">HIGH MARGIN</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-[#0A0A0A] p-8 md:p-16 rounded-[40px] md:rounded-[60px] text-white shadow-2xl">
                <h3 class="text-2xl md:text-4xl font-display uppercase text-[#D4A574] mb-8">Fleet <br/>Planner</h3>
                <div class="space-y-6 mb-12">
                   <div class="flex justify-between border-b border-white/10 pb-4">
                       <span class="font-light text-white/40 text-sm">Multi-Unit Capacity</span>
                       <span class="font-display tracking-widest text-white/50 italic">UP TO 10 UNITS</span>
                   </div>
                   <div class="flex justify-between pb-4">
                       <span class="font-light text-green-500/80 text-sm italic">Projected ROI Status</span>
                       <span class="font-display tracking-widest text-green-500 ">POSITIVE</span>
                   </div>
                </div>
                <Calculator lang={lang} equipmentType="Lorry" defaultPrice={120000} variant="luxe" />
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section bg-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16">
        <h2 class="text-4xl md:text-5xl font-display uppercase  text-white mb-4 tracking-tight leading-[1.1]">
          Dominant <span class="text-[#D4A574]">Utility.</span>
        </h2>
        <p class="text-lg text-white/50 font-light max-w-xl">
          Secure the commercial assets your logistics route depends on with the flexibility the banking sector refuses to offer.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        {benefits.map((benefit) => (
          <BenefitCard
            icon={benefit.icon}
            title={benefit.title}
            description={benefit.description}
            variant="luxe"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Case Study Section -->
  <section class="section bg-white text-[#0A0A0A]">
      <div class="container-custom">
          <div class="max-w-5xl mx-auto bg-[#0A0A0A] rounded-[40px] md:rounded-[80px] p-8 md:p-24 text-white relative overflow-hidden">
              <div class="absolute top-0 right-0 p-12 opacity-5 text-9xl font-display uppercase rotate-12 select-none">Route</div>
              <div class="relative z-10 grid md:grid-cols-2 gap-12 items-center">
                  <div>
                      <h3 class="text-3xl md:text-5xl font-display uppercase mb-8 leading-[1.1]">Scalability <br/><span class="text-[#D4A574]">Verified.</span></h3>
                      <p class="text-white/40 font-light text-lg mb-8 leading-relaxed">
                          Lee from Port Klang needed 3 box lorries for a major e-commerce contract worth RM 45,000/month. Banks rejected him due to "short company history."
                      </p>
                      <div class="bg-white/5 border border-white/10 p-6">
                          <p class="font-display text-[#D4A574] text-xl mb-2">THE OUTCOME</p>
                          <p class="text-sm font-light leading-relaxed">We approved RM 420,000 in 20 hours. Lee earned RM 540k in 12 months and now operates an 8-lorry fleet.</p>
                      </div>
                  </div>
                  <div class="aspect-square bg-white/5 border border-white/10 rounded-full flex items-center justify-center p-12 text-center group">
                      <p class="font-display text-4xl md:text-6xl uppercase  leading-[1.1] group-hover:scale-110 transition-transform duration-700">8 UNIT <br/><span class="text-[#D4A574]">FLEET</span></p>
                  </div>
              </div>
          </div>
      </div>
  </section>

  <!-- FAQ Section -->
  <section class="section bg-white text-[#0A0A0A]">
    <div class="container-custom">
      <div class="mb-16 md:mb-20 text-center">
        <h2 class="text-4xl md:text-6xl font-display uppercase  mb-4  text-[#0A0A0A] tracking-tight leading-[1.1]">
          Logistics <br/> <span class="text-[#D4A574]">Intelligence</span>
        </h2>
        <p class="text-lg md:text-xl text-[#0A0A0A]/40 font-light mx-auto max-w-xl">
          Everything you need to know about scaling your commercial haulage assets.
        </p>
      </div>

      <div class="max-w-4xl mx-auto">
        <div class="space-y-4">
          {faqs.map((faq) => (
            <FAQItem question={faq.question} answer={faq.answer} variant="luxe" />
          ))}
        </div>
      </div>
    </div>
  </section>

  <RelatedEquipment lang={lang} currentEquipment="lorry" variant="luxe" />

  <section class="section bg-[#D4A574] relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('/images/texture.png')] mix-blend-overlay pointer-events-none"></div>
    <div class="container-custom text-center relative z-10">
      <h2 class="text-5xl md:text-8xl font-display uppercase  text-[#0A0A0A] mb-8 tracking-tight leading-[1.1]">
        EVOLVE TO <br/><span class="opacity-40">FULL CAPACITY</span>
      </h2>
      <p class="text-[#0A0A0A]/70 text-xl font-light mb-12 max-w-2xl mx-auto leading-relaxed">
        Stop losing contracts to vehicle unavailability. Build your own logistics empire. Secure your commercial lorry financing today.
      </p>
 
      <div class="flex flex-col sm:flex-row gap-6 justify-center items-center mb-20">
        <a
          href="https://wa.me/60175700889?text=Hi!%20I%27d%20like%20to%20apply%20for%20lorry%20financing."
          class="bg-[#0A0A0A] text-white px-12 py-6 font-display uppercase tracking-widest hover:bg-white hover:text-[#0A0A0A] transition-all shadow-2xl"
        >
          Secure Your Fleet
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
