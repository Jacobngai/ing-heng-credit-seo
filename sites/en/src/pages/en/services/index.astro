---
/**
 * Services Overview Page - English
 * Complete financing solutions for all your equipment needs
 */

import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';

import ContactForm from '../../../components/ContactForm.astro';
import CTAButton from '../../../components/CTAButton.astro';
import StructuredData from '../../../components/StructuredData.astro';
import { generateOrganizationSchema } from '../../../utils/schema';
import { COMPANY_INFO } from '../../../utils/constants';

const lang = 'en';

// SEO Configuration
const title = 'Our Services - Equipment Financing Solutions | Ing Heng Credit';
const description = 'Complete financing solutions for all your equipment needs. Hire purchase, business loans, warehouse equipment financing, and insurance services. Streamlined Processing and flexible terms. Get your free quote today!';
const keywords = [
  'equipment financing services',
  'hire purchase Malaysia',
  'business loan services',
  'equipment insurance',
  'financing solutions Malaysia',
  'Ing Heng Credit services',
  'construction equipment financing',
  'logistics equipment loan',
  'warehouse equipment financing',
  'material handling equipment finance',
  'forklift financing services'
];

// Breadcrumbs
const breadcrumbItems = [
  { label: 'Home', href: '/en' },
  { label: 'Services', href: '/en/services' }
];

const organizationSchema = generateOrganizationSchema();
---

<BaseLayout
  title={title}
  description={description}
  lang={lang}
  keywords={keywords}
>
  <StructuredData schema={organizationSchema} />

  <!-- HERO: THE DIRECT CAPITAL (Midnight Theme) -->
  <section class="relative min-h-[70vh] flex items-center bg-[#0A0A0A] pt-20 overflow-hidden">
    <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-[#8B6F47]/15 blur-[120px] rounded-full"></div>
    
    <div class="container-custom relative z-10">
      <div class="max-w-4xl">
        <span class="inline-block text-[#D4A574] font-display tracking-[0.4em] uppercase text-sm mb-6 font-bold">Total Financing Solutions</span>
        <h1 class="text-white  mb-8 tracking-tight leading-[1.1]">
          LOANS MADE DIRECT. <br />
          <span class="text-[#D4A574]">GROW YOUR BUSINESS.</span>
        </h1>
        <p class="text-white/70 text-xl font-light max-w-2xl mb-12 leading-relaxed">
          We help you buy any machine for your business. From excavators to forklifts, we have the money ready for you. Direct loans. No agents. 
        </p>
      </div>
    </div>
  </section>

  <!-- THE SERVICES: PROFIT TOOLS (Daylight Theme) -->
  <section class="bg-white py-24 md:py-32 rounded-t-[40px] -mt-10 relative z-20">
    <div class="container-custom">
      <div class="text-center mb-16">
        <span class="text-[#8B6F47] font-display tracking-[0.3em] uppercase text-sm mb-4 block font-bold">What We Do</span>
        <h2 class="text-[#0A0A0A] mb-4 text-5xl md:text-6xl tracking-tight leading-[1.1]">Ways to <span class="text-[#D4A574]">Build Your Business.</span></h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-20">
        <!-- Service 1: Hire Purchase -->
        <div class="bg-[#F5F5F5] p-10 border-t-4 border-[#8B6F47] hover:bg-white hover:shadow-2xl transition-all duration-500">
          <div class="text-5xl mb-6">🚜</div>
          <h3 class="font-display text-2xl uppercase text-[#0A0A0A] mb-4">Hire Purchase</h3>
          <p class="text-[#1A140D]/60 mb-8">Buy the machine you need and pay slowly. Perfect for excavators and lorries.</p>
          <a href="/en/services/hire-purchase" class="text-[#8B6F47] font-bold uppercase tracking-widest text-sm hover:text-[#0A0A0A]">Read More →</a>
        </div>

        <!-- Service 2: Loan Financing -->
        <div class="bg-[#F5F5F5] p-10 border-t-4 border-[#D4A574] hover:bg-white hover:shadow-2xl transition-all duration-500">
          <div class="text-5xl mb-6">💰</div>
          <h3 class="font-display text-2xl uppercase text-[#0A0A0A] mb-4">Direct Loans</h3>
          <p class="text-[#1A140D]/60 mb-8">Get cash directly for your business. Over 4,000 SMEs trust us since 1985.</p>
          <a href="/en/services/loan-financing" class="text-[#8B6F47] font-bold uppercase tracking-widest text-sm hover:text-[#0A0A0A]">Read More →</a>
        </div>

        <!-- Service 3: Insurance -->
        <div class="bg-[#F5F5F5] p-10 border-t-4 border-[#8B6F47] hover:bg-white hover:shadow-2xl transition-all duration-500">
          <div class="text-5xl mb-6">🛡️</div>
          <h3 class="font-display text-2xl uppercase text-[#0A0A0A] mb-4">Insurance</h3>
          <p class="text-[#1A140D]/60 mb-8">Protect your machines and your drivers. Easy payment and fast claims.</p>
          <a href="/en/services/insurance" class="text-[#8B6F47] font-bold uppercase tracking-widest text-sm hover:text-[#0A0A0A]">Read More →</a>
        </div>

        <!-- Service 4: Warehouse -->
        <div class="bg-[#F5F5F5] p-10 border-t-4 border-[#D4A574] hover:bg-white hover:shadow-2xl transition-all duration-500">
          <div class="text-5xl mb-6">🏗️</div>
          <h3 class="font-display text-2xl uppercase text-[#0A0A0A] mb-4">Warehouse</h3>
          <p class="text-[#1A140D]/60 mb-8">Finance for forklifts and racking. Stop paying rent and own your equipment.</p>
          <a href="/en/services/warehouse-equipment-financing" class="text-[#8B6F47] font-bold uppercase tracking-widest text-sm hover:text-[#0A0A0A]">Read More →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- THE CHOICE: DIRECT CAPITAL (Alloy Theme) -->
  <section class="bg-[#F5F5F5] py-24">
    <div class="container-custom">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
            <span class="text-[#8B6F47] font-display tracking-[0.3em] uppercase text-sm mb-4 block font-bold">Direct Partnership</span>
            <h2 class="text-[#0A0A0A] mb-8 tracking-tight leading-[1.1]">Talk directly to <br /><span class="text-[#D4A574]">the Decision Maker.</span></h2>
            <div class="space-y-8">
                <div class="bg-white p-8 border-l-4 border-[#8B6F47] shadow-sm">
                    <h3 class="font-display text-2xl mb-2 text-[#0A0A0A]">We use our own money.</h3>
                    <p class="text-[#1A140D]/60">We are not agents. We don't blast your data to banks. We make the decision ourselves.</p>
                </div>
                <div class="bg-white p-8 border-l-4 border-[#D4A574] shadow-sm">
                    <h3 class="font-display text-2xl mb-2 text-[#0A0A0A]">Easy Steps. No Agents.</h3>
                    <p class="text-[#1A140D]/60">Simple documentation. Personal service. We know your business and your workshop.</p>
                </div>
            </div>
        </div>
        <div class="bg-white p-10 md:p-16 border border-[#8B6F47]/20 shadow-xl">
            <h3 class="font-display text-4xl mb-8 uppercase text-[#0A0A0A]">Get a Free Quote Now</h3>
            <ContactForm lang={lang} />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[#0A0A0A] py-24 relative overflow-hidden">
    <div class="absolute inset-0 bg-[#8B6F47]/5"></div>
    <div class="container-custom relative z-10 text-center">
        <h2 class="text-white text-5xl mb-8 uppercase font-display tracking-tight leading-[1.1]">Ready to Start?</h2>
        <p class="text-white/60 mb-12 text-xl max-w-2xl mx-auto">Join 4,000+ businesses who trust Ing Heng Credit. Talk to us directly today.</p>
        <a href={COMPANY_INFO.whatsapp.link} class="bg-[#8B6F47] text-white font-display text-2xl tracking-[0.1em] px-12 py-6 hover:bg-white hover:text-[#0A0A0A] transition-all duration-500 inline-block uppercase">
            WhatsApp Us Now
        </a>
    </div>
  </section>
</BaseLayout>
<style>
  .hero-section {
    font-family: 'Bebas Neue', sans-serif;
  }

  .from-accent {
    --tw-gradient-from: #0F172A;
  }

  .to-primary-dark {
    --tw-gradient-to: #1E3A8A;
  }

  .bg-gradient-to-br {
    background-image: linear-gradient(to bottom right, var(--tw-gradient-from), var(--tw-gradient-to));
  }

  .text-secondary {
    color: #8B6F47;
  }

  .text-navy-900 {
    color: #2D1810;
  }
</style>
