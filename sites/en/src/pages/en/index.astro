---
/**
 * English Homepage - Updated with Live Site Hero
 * Equipment Financing Malaysia - Ing Heng Credit & Leasing
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTAButton from '../../components/CTAButton.astro';
import { COMPANY_INFO } from '../../utils/constants';

const lang = 'en';
---

<BaseLayout
  title="Buy 5 Used Machines. Make 5X More Money. | Ing Heng Credit"
  description="Banks say no to old machines. We say yes. Get 0% deposit loans for used excavators, lorries & forklifts. Talk to us directly—no agents, no middlemen."
  lang={lang}
  keywords={[
    'used equipment financing Malaysia',
    'old machine loan',
    'direct equipment financing',
    'excavator loan Malaysia',
    'lorry financing 0 deposit',
    'Ing Heng Credit financing',
    'SME machinery loan'
  ]}
>
  <!-- HERO: THE POWER OF YES (Midnight Theme) -->
  <section class="relative min-h-[90vh] flex items-center bg-[#0A0A0A] pt-20 overflow-hidden">
    <!-- Ambient Glow -->
    <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-[#8B6F47]/20 blur-[120px] rounded-full"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[30%] h-[30%] bg-[#D4A574]/10 blur-[100px] rounded-full"></div>

    <div class="container-custom relative z-10 pb-12 md:pb-20">
      <div class="max-w-4xl">
        <div class="flex flex-wrap gap-4 mb-8">
            <span class="inline-block border border-[#D4A574] text-[#D4A574] px-4 py-1 font-display tracking-widest text-xs uppercase font-bold">KPKT Licensed</span>
            <span class="inline-block border border-white/20 text-white/60 px-4 py-1 font-display tracking-widest text-xs uppercase font-bold">Direct Capital</span>
        </div>
        
        <h1 class="text-white leading-[0.9] mb-8">
          WE SAY <span class="text-[#D4A574]">YES</span><br />
          WHEN BANKS SAY NO.
        </h1>
        <p class="text-white/70 text-xl font-light max-w-2xl mb-12 leading-relaxed">
          Banks do not like old machines. We believe in you. Whether it is a 50-year-old excavator or a second-hand lorry, we give you the loan to grow your business. <strong>Talk to us directly.</strong>
        </p>

        <div class="flex flex-col sm:flex-row gap-6 mb-16">
          <a href={`/${lang}/contact`} class="bg-[#8B6F47] text-white font-display text-2xl tracking-[0.1em] px-12 py-6 hover:bg-white hover:text-[#0A0A0A] transition-all duration-500 text-center uppercase">
            Get a Loan Today
          </a>
          <a href={COMPANY_INFO.whatsapp.link} class="border-2 border-white/20 text-white font-display text-2xl tracking-[0.1em] px-12 py-6 hover:border-[#D4A574] hover:text-[#D4A574] transition-all duration-500 text-center uppercase">
            WhatsApp Decision Maker
          </a>
        </div>

        <!-- Obvious Badges -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl">
            <div class="bg-white/5 border border-white/10 p-6 backdrop-blur-sm">
                <div class="text-[#D4A574] font-display text-4xl mb-1">40+</div>
                <div class="text-white/40 text-[10px] uppercase tracking-widest font-bold">Years Heritage</div>
            </div>
            <div class="bg-white/5 border border-white/10 p-6 backdrop-blur-sm">
                <div class="text-[#D4A574] font-display text-4xl mb-1">0%</div>
                <div class="text-white/40 text-[10px] uppercase tracking-widest font-bold">Deposit Load</div>
            </div>
            <div class="bg-white/5 border border-white/10 p-6 backdrop-blur-sm">
                <div class="text-[#D4A574] font-display text-4xl mb-1">4K+</div>
                <div class="text-white/40 text-[10px] uppercase tracking-widest font-bold">SMEs Funded</div>
            </div>
            <div class="bg-white/5 border border-white/10 p-6 backdrop-blur-sm">
                <div class="text-[#D4A574] font-display text-4xl mb-1">KPKT</div>
                <div class="text-white/40 text-[10px] uppercase tracking-widest font-bold">Certified</div>
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- THE ROI LOGIC (Daylight Theme) -->
  <section class="bg-white py-24 md:py-32 rounded-t-[40px] md:-mt-10 relative z-20">
    <div class="container-custom">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <span class="text-[#8B6F47] font-display tracking-[0.3em] uppercase text-sm mb-4 block font-bold">The Business Soul</span>
          <h2 class="text-[#0A0A0A] mb-8">Buy 5 Used Machines. <br /><span class="text-[#D4A574]">Make 5X More Money.</span></h2>
          <p class="text-[#1A140D]/70 text-lg mb-8 leading-relaxed">
            Why buy 1 expensive new machine? You can buy 5 used machines for the same price. More machines mean more profit. We use our own capital to make sure you get the equipment today.
          </p>
          <div class="space-y-4">
            <div class="flex items-center gap-4">
                <div class="w-8 h-8 rounded-full bg-[#8B6F47]/10 flex items-center justify-center text-[#8B6F47]">✓</div>
                <span class="font-bold text-[#0A0A0A]">No Agents. No Middlemen.</span>
            </div>
            <div class="flex items-center gap-4">
                <div class="w-8 h-8 rounded-full bg-[#8B6F47]/10 flex items-center justify-center text-[#8B6F47]">✓</div>
                <span class="font-bold text-[#0A0A0A]">Loans for Machines up to 50 Years Old.</span>
            </div>
            <div class="flex items-center gap-4">
                <div class="w-8 h-8 rounded-full bg-[#8B6F47]/10 flex items-center justify-center text-[#8B6F47]">✓</div>
                <span class="font-bold text-[#0A0A0A]">0% Deposit Options Available.</span>
            </div>
          </div>
        </div>

        <div class="relative group">
            <div class="absolute -inset-4 bg-[#8B6F47]/5 rounded-[2rem] group-hover:bg-[#8B6F47]/10 transition-all duration-700"></div>
            <div class="relative bg-[#F5F5F5] p-2 rounded-[2rem] overflow-hidden border border-black/5">
                <img src="/images/equipment/bulldozer.jpg" alt="High Quality Used Bull Dozer" class="w-full h-full object-cover rounded-[1.8rem]" />
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- THE PARTNERSHIP (Alloy Theme) -->
  <section class="bg-[#F5F5F5] py-24">
    <div class="container-custom">
        <div class="max-w-4xl mx-auto text-center">
            <h2 class="text-4xl md:text-5xl mb-8">We trust your <span class="text-[#8B6F47]">expertise.</span></h2>
            <div class="bg-white p-10 md:p-16 border border-[#8B6F47]/20 shadow-xl relative">
                <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 w-16 h-1 w-20 bg-[#8B6F47]"></div>
                <p class="text-xl md:text-2xl font-light italic text-[#0A0A0A]">
                    "We know you are good at your work. You know how to fix your machines. You know how to make them run. We trust that you will use the equipment to succeed."
                </p>
                <div class="mt-8 pt-8 border-t border-black/5">
                    <span class="font-display tracking-widest uppercase text-[#8B6F47]">Direct Capital Partnership Since 1985</span>
                </div>
            </div>
        </div>
    </div>
  </section>
</BaseLayout>
