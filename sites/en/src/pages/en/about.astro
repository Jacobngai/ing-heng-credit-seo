---
/**
 * About Page - English - Updated with Live Site Hero
 * Company information and history
 */

import BaseLayout from '../../layouts/BaseLayout.astro';

import CTAButton from '../../components/CTAButton.astro';
import { COMPANY_INFO } from '../../utils/constants';

const lang = 'en';
const pageTitle = 'About Us - 40+ Years Equipment Financing Experience | Ing Heng Credit';
const pageDescription = 'Leading equipment financing company in Malaysia since 1985. 0% deposit, 100% financing for construction, logistics and industrial equipment.';
const keywords = ['equipment financing Malaysia', 'Ing Heng Credit history', 'construction equipment loans', 'about Ing Heng', 'equipment leasing company'];
---

<BaseLayout title={pageTitle} description={pageDescription} lang={lang} keywords={keywords}>
  <!-- HERO: THE HERITAGE (Midnight Theme) -->
  <section class="relative min-h-[70vh] flex items-center bg-[#0A0A0A] pt-20 overflow-hidden">
    <div class="absolute top-[-10%] right-[-10%] w-[40%] h-[40%] bg-[#8B6F47]/15 blur-[120px] rounded-full"></div>
    
    <div class="container-custom relative z-10">
      <div class="max-w-4xl">
        <span class="inline-block text-[#D4A574] font-display tracking-[0.4em] uppercase text-sm mb-6 font-bold">Reliable Since 1985</span>
        <h1 class="text-white leading-[0.9] mb-8">
          WE HELP SMES GROW <br />
          <span class="text-[#D4A574]">WITH PRIVATE CAPITAL.</span>
        </h1>
        <p class="text-white/70 text-xl font-light max-w-2xl mb-12 leading-relaxed">
          Ing Heng Credit is not an agent. We use our own money to help you buy the machines you need. We have supported Malaysian businesses for over 40 years.
        </p>
      </div>
    </div>
  </section>

  <!-- THE STORY: GETTING OUR HANDS DIRTY (Daylight Theme) -->
  <section class="bg-white py-24 md:py-32 rounded-t-[40px] -mt-10 relative z-20">
    <div class="container-custom">
      <div class="grid lg:grid-cols-2 gap-20 items-start">
        <div>
          <span class="text-[#8B6F47] font-display tracking-[0.3em] uppercase text-sm mb-4 block font-bold">Our Story</span>
          <h2 class="text-[#0A0A0A] mb-8">We trust the <br /><span class="text-[#D4A574]">Person, not the Bank.</span></h2>
          <div class="space-y-6 text-[#1A140D]/70 text-lg leading-relaxed">
            <p>
                Banks only look at paper. We look at your business. Since 1985, we have helped thousands of businesses buy excavators, lorries, and manufacturing tools.
            </p>
            <p>
                We know you take risks to grow. We take risks too. We like old machines because they cost less but still make a lot of money for you. If you have a workshop and you know how to fix your tools, we will help you buy them.
            </p>
          </div>
        </div>

        <div class="space-y-12">
            <div class="bg-[#F5F5F5] p-10 border-l-4 border-[#8B6F47]">
                <h3 class="font-display text-3xl mb-4 text-[#0A0A0A]">Direct Decision</h3>
                <p class="text-[#1A140D]/60 italic font-light">"When you talk to us, you talk to the person who holds the money. No middlemen. No waiting for bank officers to call you back."</p>
            </div>
            <div class="bg-[#F5F5F5] p-10 border-l-4 border-[#D4A574]">
                <h3 class="font-display text-3xl mb-4 text-[#0A0A0A]">Heritage Success</h3>
                <p class="text-[#1A140D]/60 italic font-light">"We have seen the ups and downs of the Malaysian economy. We are still here because our clients trust us to be their backbone."</p>
            </div>
        </div>
      </div>
    </div>
  </section>

  <!-- THE NUMBERS (Alloy Theme) -->
  <section class="bg-[#F5F5F5] py-24">
    <div class="container-custom text-center">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div>
            <div class="text-6xl font-display text-[#8B6F47] mb-4">1985</div>
            <p class="text-[#0A0A0A] uppercase tracking-widest font-bold">Helping SMEs</p>
        </div>
        <div>
            <div class="text-6xl font-display text-[#8B6F47] mb-4">4000+</div>
            <p class="text-[#0A0A0A] uppercase tracking-widest font-bold">Successful Loans</p>
        </div>
        <div>
            <div class="text-6xl font-display text-[#8B6F47] mb-4">RM500M+</div>
            <p class="text-[#0A0A0A] uppercase tracking-widest font-bold">Capital Invested</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-white py-24 border-t border-black/5">
    <div class="container-custom text-center">
        <h2 class="text-4xl md:text-5xl mb-8">Need Money for Your Machine?</h2>
        <a href={COMPANY_INFO.whatsapp.link} class="bg-[#8B6F47] text-white font-display text-2xl tracking-[0.1em] px-12 py-6 hover:bg-[#0A0A0A] transition-all duration-500 inline-block uppercase">
            Talk to Us Directly
        </a>
    </div>
  </section>
</BaseLayout>
