---
/**
 * English Contact Page
 * Direct Line to Capital - No Middlemen
 */

import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/ContactForm.astro';
import { COMPANY_INFO, SITE_CONFIG } from '../../utils/constants';

const lang = 'en';

// SEO Data
const pageTitle = 'Talk Direct. Talk Capital. | Contact Ing Heng Credit';
const pageDescription = 'No agents. No middlemen. Talk directly to the decision makers. Get fast equipment financing in Malaysia. Since 1985.';

// LocalBusiness Schema
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Ing Heng Credit & Leasing Sdn Bhd',
  url: `${SITE_CONFIG.url}/en/contact`,
  telephone: COMPANY_INFO.phone.international,
  address: {
    '@type': 'PostalAddress',
    streetAddress: COMPANY_INFO.address.street,
    addressLocality: COMPANY_INFO.address.city,
    addressRegion: COMPANY_INFO.address.state,
    postalCode: COMPANY_INFO.address.postcode,
    addressCountry: 'MY',
  }
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  lang={lang}
>
  <!-- HERO: TALK DIRECT (Midnight Theme) -->
  <section class="relative min-h-[60vh] flex items-center bg-[#0A0A0A] pt-20 overflow-hidden">
    <div class="absolute top-[-10%] right-[-10%] w-[40%] h-[40%] bg-[#8B6F47]/10 blur-[120px] rounded-full"></div>
    
    <div class="container-custom relative z-10">
      <div class="max-w-4xl">
        <span class="inline-block text-[#D4A574] font-display tracking-[0.4em] uppercase text-sm mb-6 font-bold">No Agents. No Middlemen.</span>
        <h1 class="text-white leading-[0.9] mb-8">
          TALK DIRECT. <br />
          <span class="text-[#D4A574]">TALK CAPITAL.</span>
        </h1>
        <p class="text-white/60 text-xl font-light max-w-2xl mb-12 leading-relaxed">
          Stop talking to data-blasters and agents who take a cut. We are the direct funder. You talk to us, we give you the answer. Simple, fast, and professional.
        </p>

        <div class="flex flex-wrap gap-4">
            <a href="https://wa.me/60175700889" class="bg-[#8B6F47] text-white font-display text-xl tracking-widest px-10 py-5 hover:bg-white hover:text-[#0A0A0A] transition-all uppercase">Instant WhatsApp Chat →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACT GRID: (Daylight Theme) -->
  <section class="bg-white py-24 md:py-32">
    <div class="container-custom">
        <div class="grid lg:grid-cols-3 gap-8">
            <!-- Office -->
            <div class="p-10 border border-black/5 bg-[#F5F5F5] group hover:bg-white hover:shadow-2xl transition-all duration-700">
                <span class="text-3xl mb-8 block">📍</span>
                <h3 class="font-display text-2xl uppercase mb-4 text-[#0A0A0A]">Visit Our HQ</h3>
                <p class="text-[#1A140D]/60 font-light text-sm leading-relaxed mb-6">
                    {COMPANY_INFO.address.full}
                </p>
                <a href={COMPANY_INFO.address.googleMapsUrl} target="_blank" class="text-[#8B6F47] font-display uppercase tracking-widest text-xs border-b border-[#8B6F47] pb-1">Get Directions</a>
            </div>

            <!-- Call -->
            <div class="p-10 border border-black/5 bg-[#F5F5F5] group hover:bg-white hover:shadow-2xl transition-all duration-700">
                <span class="text-3xl mb-8 block">📞</span>
                <h3 class="font-display text-2xl uppercase mb-4 text-[#0A0A0A]">Call Direct</h3>
                <p class="text-[#1A140D]/60 font-light text-sm leading-relaxed mb-6">
                    M-F: 9AM - 5PM<br />
                    Sat: 9AM - 1PM
                </p>
                <a href={`tel:${COMPANY_INFO.phone.international}`} class="text-[#0A0A0A] font-display text-xl tracking-tight">{COMPANY_INFO.phone.display}</a>
            </div>

            <!-- Support -->
            <div class="p-10 border border-black/5 bg-[#F5F5F5] group hover:bg-white hover:shadow-2xl transition-all duration-700">
                <span class="text-3xl mb-8 block">✉️</span>
                <h3 class="font-display text-2xl uppercase mb-4 text-[#0A0A0A]">Expert Advice</h3>
                <p class="text-[#1A140D]/60 font-light text-sm leading-relaxed mb-6">
                    Send us your documents or query and our asset specialists will reply promptly.
                </p>
                <a href={`mailto:${COMPANY_INFO.email}`} class="text-[#0A0A0A] font-display text-lg tracking-tight border-b border-black/10">{COMPANY_INFO.email}</a>
            </div>
        </div>
    </div>
  </section>

  <!-- FORM: (Alloy Theme) -->
  <section class="bg-[#F5F5F5] py-24 md:py-32">
    <div class="container-custom">
        <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-20 items-start">
            <div>
                <span class="text-[#8B6F47] font-display tracking-[0.3em] uppercase text-sm mb-4 block font-bold">Inquiry Form</span>
                <h2 class="text-[#0A0A0A] mb-8 text-5xl md:text-6xl uppercase leading-none">Tell Us What <br /><span class="text-[#D4A574]">You Need.</span></h2>
                <p class="text-[#1A140D]/60 text-lg mb-12 font-light leading-relaxed">
                    Fill in the form and we will call you back within 2 working hours. As an action-taker, we know your time is money.
                </p>
                
                <div class="space-y-6">
                    <div class="bg-white p-6 border border-black/5 flex items-center gap-6">
                        <div class="w-12 h-12 bg-[#0A0A0A] text-[#D4A574] flex items-center justify-center font-display text-xl">✓</div>
                        <span class="text-[#0A0A0A]/60 font-medium">Direct Funder (No Agents)</span>
                    </div>
                    <div class="bg-white p-6 border border-black/5 flex items-center gap-6">
                        <div class="w-12 h-12 bg-[#0A0A0A] text-[#D4A574] flex items-center justify-center font-display text-xl">✓</div>
                        <span class="text-[#0A0A0A]/60 font-medium">40+ Years of Stability</span>
                    </div>
                    <div class="bg-white p-6 border border-black/5 flex items-center gap-6">
                        <div class="w-12 h-12 bg-[#0A0A0A] text-[#D4A574] flex items-center justify-center font-display text-xl">✓</div>
                        <span class="text-[#0A0A0A]/60 font-medium">KPKT Licensed & Trusted</span>
                    </div>
                </div>
            </div>

            <div class="bg-white p-12 shadow-2xl border border-black/5">
                <ContactForm lang={lang} />
            </div>
        </div>
    </div>
  </section>

  <!-- MAP: (Midnight Theme) -->
  <section class="bg-[#0A0A0A] h-[500px] grayscale hover:grayscale-0 transition-all duration-1000">
    <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3984.3448!2d101.4424!3d3.0449!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zM8KwMDInNDEuNiJOIDEwMcKwMjYnMzMuOCJF!5e0!3m2!1sen!2smy!4v1234567890"
        width="100%"
        height="100%"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
    ></iframe>
  </section>

</BaseLayout>

<style>
  h1, h2, h3 {
    font-family: 'Bebas Neue', var(--font-display);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
