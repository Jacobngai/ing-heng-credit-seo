---
/**
 * BlogLayout - Layout for Blog Posts (English only)
 * Extends BaseLayout with blog-specific features:
 * - Article schema markup
 * - Breadcrumbs
 * - Reading time and publish date
 * - Share buttons
 * - Table of contents
 * - Related posts
 * - Newsletter signup
 */

import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ShareButtons from '../components/ShareButtons.astro';
import TableOfContents from '../components/TableOfContents.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import CTAButton from '../components/CTAButton.astro';
import { generateArticleSchema, generateFAQSchema, encodeJSONLD } from '../utils/schema';
import type { Locale } from '../utils/i18n';
import type { CollectionEntry } from 'astro:content';

interface Props {
  frontmatter: CollectionEntry<'blogs'>['data'];
  headings: { depth: number; slug: string; text: string }[];
  slug: string;
}

const { frontmatter: fmProps, headings = [], slug = "" } = Astro.props;
// Use frontmatter prop if it exists, otherwise use all props
const frontmatter = fmProps || Astro.props;

// Hardcode to English
const locale: Locale = 'en';

// Format date
const publishDate = new Date(frontmatter.publishDate);
const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

// Calculate reading time if not provided
const readingTime = frontmatter.readingTime || 8;

// Breadcrumb items
const breadcrumbs = [
  { label: 'Home', href: `/${locale}` },
  { label: 'Blog', href: `/${locale}/blog` },
  { label: frontmatter.title, href: `/${locale}/blog/${slug}` }
];

// Generate Article Schema
const articleSchema = generateArticleSchema({
  headline: frontmatter.title,
  description: frontmatter.description,
  image: frontmatter.ogImage || '/images/default-blog.jpg',
  datePublished: frontmatter.publishDate.toString(),
  dateModified: frontmatter.updatedDate?.toString() || frontmatter.publishDate.toString(),
  author: frontmatter.author,
  keywords: frontmatter.keywords
});

// Generate FAQ Schema if FAQ data exists
let faqSchema;
if (frontmatter.faqSchema && frontmatter.faqSchema.length > 0) {
  faqSchema = generateFAQSchema(frontmatter.faqSchema);
}

// English translations
const t = {
  publishedOn: 'Published on',
  updatedOn: 'Updated on',
  readingTime: 'min read',
  writtenBy: 'Written by',
  category: 'Category',
  tags: 'Tags',
  share: 'Share this article'
};
---

<BaseLayout
  title={frontmatter.metaTitle || `${frontmatter.title} | Ing Heng Credit Blog`}
  description={frontmatter.metaDescription || frontmatter.description}
  lang={locale}
  image={frontmatter.ogImage}
  ogType="article"
  publishedTime={frontmatter.publishDate.toString()}
  modifiedTime={frontmatter.updatedDate?.toString()}
  keywords={frontmatter.keywords}
>
  <!-- Article Schema -->
  <script type="application/ld+json" set:html={encodeJSONLD(articleSchema)} slot="head" />

  <!-- FAQ Schema (if exists) -->
  {faqSchema && (
    <script type="application/ld+json" set:html={encodeJSONLD(faqSchema)} slot="head" />
  )}

  <!-- Reading Progress Bar -->
  <div class="reading-progress-bar fixed top-0 left-0 h-1 bg-[#D4A574] z-[100] transition-all duration-300 shadow-[0_0_10px_#D4A574]" style="width: 0%"></div>

  <!-- Breadcrumbs -->
  <div class="bg-[#0A0A0A] border-b border-white/5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <Breadcrumbs items={breadcrumbs} locale={locale} />
    </div>
  </div>

  <!-- Article Header -->
  <header class="bg-[#0A0A0A] py-16 lg:py-24 relative overflow-hidden">
    <!-- Ambient Glow -->
    <div class="absolute top-[-20%] right-[-10%] w-[50%] h-[50%] bg-[#D4A574]/5 blur-[120px] rounded-full"></div>
    
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <!-- Category Badge -->
      {frontmatter.category && (
        <a
          href={`/${locale}/blog/category/${frontmatter.category.toLowerCase().replace(/\s+/g, '-')}`}
          class="inline-block px-4 py-1.5 border border-[#D4A574]/30 text-[#D4A574] text-xs font-display tracking-[0.2em] uppercase rounded-full hover:bg-[#D4A574] hover:text-[#0A0A0A] transition-all mb-8 shadow-[0_0_15px_rgba(212,165,116,0.1)]"
        >
          {frontmatter.category}
        </a>
      )}

      <!-- Title -->
      <h1 class="text-4xl sm:text-5xl lg:text-7xl font-display uppercase tracking-[-0.02em] leading-[0.95] text-white mb-8">
        {frontmatter.title.split('|')[0].trim()} <br/>
        <span class="text-[#D4A574]">{frontmatter.title.split('|').slice(1).join(' | ')}</span>
      </h1>

      <!-- Description -->
      <p class="text-xl text-white/50 font-light mb-10 leading-relaxed max-w-3xl">
        {frontmatter.description}
      </p>

      <!-- Meta Info -->
      <div class="flex flex-wrap items-center gap-6 text-xs font-display tracking-widest uppercase text-white/30 pb-10 border-b border-white/5">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[#D4A574]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <time datetime={frontmatter.publishDate.toString()}>
            {formattedDate}
          </time>
        </div>

        <div class="flex items-center gap-2 border-l border-white/10 pl-6">
          <svg class="w-4 h-4 text-[#D4A574]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <span>{readingTime} MIN READ</span>
        </div>

        <div class="flex items-center gap-2 border-l border-white/10 pl-6">
          <svg class="w-4 h-4 text-[#D4A574]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          <span>BY {frontmatter.author}</span>
        </div>
      </div>

      <!-- Share Buttons (Top) -->
      <div class="mt-8">
        <ShareButtons title={frontmatter.title} locale={locale} />
      </div>
    </div>
  </header>

  <!-- Article Content -->
  <div class="bg-[#0A0A0A] pb-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
        <!-- Main Content -->
        <article class="lg:col-span-8 luxe-prose max-w-none">
          <!-- Hero Image -->
          {frontmatter.ogImage && (
            <div class="mb-12 rounded-2xl overflow-hidden border border-white/10 shadow-[0_20px_50px_rgba(0,0,0,0.5)]">
               <img src={frontmatter.ogImage} alt={frontmatter.title} class="w-full aspect-[21/9] object-cover" />
            </div>
          )}
          <slot />
        </article>

        <!-- Sidebar (TOC) -->
        <aside class="lg:col-span-4 mt-8 lg:mt-0">
          <div class="lg:sticky lg:top-24 space-y-12">
            <!-- Table of Contents -->
            <div class="bg-white/5 border border-white/10 p-8 rounded-2xl backdrop-blur-xl">
                <TableOfContents headings={headings} locale={locale} />
            </div>
          </div>
        </aside>
      </div>
    </div>
  </div>

  <!-- Tags Section -->
  {frontmatter.tags && frontmatter.tags.length > 0 && (
    <section class="bg-[#0A0A0A] py-12 border-t border-white/5">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h3 class="text-xs font-display tracking-widest text-[#D4A574] uppercase mb-4">{t.tags}:</h3>
        <div class="flex flex-wrap gap-3">
          {frontmatter.tags.map((tag: string) => (
            <span class="inline-block px-4 py-1.5 bg-white/5 text-white/60 text-xs font-display tracking-widest uppercase rounded-full border border-white/10 hover:border-[#D4A574] hover:text-[#D4A574] transition-all cursor-default">
              #{tag}
            </span>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Section -->
  <section class="bg-[#D4A574] py-20 relative overflow-hidden">
     <!-- Texture Overlay -->
     <div class="absolute inset-0 opacity-10 bg-[url('/images/texture.png')] mix-blend-overlay"></div>
     
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
      <h3 class="text-4xl lg:text-5xl font-display uppercase tracking-tight text-[#0A0A0A] mb-6">
        Ready to take action?
      </h3>
      <p class="text-[#0A0A0A]/70 text-lg font-light mb-10 max-w-2xl mx-auto">
        Finance your equipment with the agency that understands industrial growth. No metaphors. Just ROI.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        <a
          href={`https://wa.me/60175700889?text=${encodeURIComponent('I read your blog about ' + frontmatter.title)}`}
          class="bg-[#0A0A0A] text-white px-10 py-5 font-display uppercase tracking-widest hover:bg-white hover:text-[#0A0A0A] transition-all shadow-2xl"
        >
          WhatsApp Us Now
        </a>
        <a
          href={`/${locale}/contact`}
          class="border border-[#0A0A0A]/20 text-[#0A0A0A] px-10 py-5 font-display uppercase tracking-widest hover:bg-[#0A0A0A] hover:text-white transition-all"
        >
          View Rates
        </a>
      </div>
    </div>
  </section>

  <!-- Related Posts -->
  <RelatedPosts
    currentSlug={slug}
    locale={locale}
    category={frontmatter.category}
    tags={frontmatter.tags}
    limit={3}
  />

  <!-- Schema and Reading Progress Scripts -->
  <script>
    // Reading progress bar
    window.addEventListener('scroll', () => {
      const article = document.querySelector('article');
      const progressBar = document.querySelector('.reading-progress-bar') as HTMLElement;

      if (!article || !progressBar) return;

      const articleTop = article.offsetTop;
      const articleHeight = article.offsetHeight;
      const windowHeight = window.innerHeight;
      const scrollTop = window.pageYOffset || document.documentElement.scrollTop;

      const progress = ((scrollTop - articleTop + windowHeight) / articleHeight) * 100;
      const clampedProgress = Math.min(Math.max(progress, 0), 100);

      progressBar.style.width = `${clampedProgress}%`;
    });
  </script>
</BaseLayout>

<style is:global>
  /* Blog Post Luxe Prose Styles */
  .luxe-prose {
    @apply text-white/80 font-light;
  }

  .luxe-prose h2 {
    font-family: 'Bebas Neue', sans-serif;
    @apply text-4xl lg:text-5xl text-[#D4A574] mt-20 mb-8 scroll-mt-32 uppercase tracking-tight leading-tight;
  }

  .luxe-prose h3 {
    font-family: 'Bebas Neue', sans-serif;
    @apply text-2xl lg:text-3xl text-white mt-12 mb-6 scroll-mt-32 uppercase tracking-wide;
  }

  .luxe-prose h4 {
    font-family: 'Bebas Neue', sans-serif;
    @apply text-xl text-white/70 mt-8 mb-4 scroll-mt-32 uppercase tracking-widest;
  }

  .luxe-prose p {
    @apply mb-8 leading-[1.8] text-lg;
  }

  .luxe-prose a {
    @apply text-[#D4A574] border-b border-[#D4A574]/30 hover:border-[#D4A574] transition-all no-underline;
  }

  .luxe-prose ul, .luxe-prose ol {
    @apply mb-10 pl-8 space-y-4;
  }

  .luxe-prose li {
    @apply relative pl-2;
  }

  .luxe-prose ul li::before {
    content: '→';
    @apply absolute -left-6 text-[#D4A574] font-bold;
  }

  .luxe-prose strong {
    @apply font-bold text-white;
  }

  .luxe-prose blockquote {
    @apply border-l-2 border-[#D4A574] pl-10 py-4 italic text-white/60 my-12 bg-white/[0.02] rounded-r-2xl;
  }

  .luxe-prose code {
    @apply bg-white/10 px-2 py-1 rounded text-sm font-mono text-[#D4A574];
  }

  .luxe-prose pre {
    @apply bg-black/40 border border-white/5 text-white/90 p-8 rounded-2xl overflow-x-auto my-12 backdrop-blur-md;
  }

  .luxe-prose pre code {
    @apply bg-transparent p-0 text-inherit;
  }

  .luxe-prose table {
    @apply w-full border-collapse my-12 bg-white/[0.02] rounded-2xl overflow-hidden border border-white/5;
  }

  .luxe-prose th {
    @apply bg-white/[0.05] border-b border-white/10 px-6 py-4 text-left font-display uppercase tracking-widest text-xs text-[#D4A574];
  }

  .luxe-prose td {
    @apply border-b border-white/[0.03] px-6 py-4 text-sm text-white/50 font-light;
  }

  .luxe-prose tr:last-child td {
    @apply border-none;
  }

  .luxe-prose img {
    @apply rounded-2xl my-16 border border-white/10 shadow-2xl;
  }

  .luxe-prose hr {
    @apply my-20 border-white/5;
  }
</style>
