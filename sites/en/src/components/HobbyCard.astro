---
/**
 * Hobby Card Component
 * Card for displaying hobby categories with large image, title, and description
 * Design matches ProductCard from equipment page
 */

import type { Locale } from '../utils/i18n';
import { t } from '../utils/i18n';

interface Props {
  lang: Locale;
  title?: string;
  titleKey?: string;
  description?: string;
  descriptionKey?: string;
  icon?: string;
  image?: string;
  href?: string;
  items?: string[];
  badge?: string;
  comingSoon?: boolean;
}

const { lang, title, titleKey, description, descriptionKey, icon, image, href, items, badge, comingSoon } = Astro.props;

const cardTitle = title || (titleKey ? t(titleKey, lang) : '');
const cardDescription = description || (descriptionKey ? t(descriptionKey, lang) : '');
const cardIcon = icon || '📋';
const cardImage = image || null;
const cardHref = href || '#';
const cardBadge = badge || '';
const isComingSoon = comingSoon || false;
const hasItems = items && items.length > 0;
---

<div class={`group relative bg-[#F5F5F5] overflow-hidden border border-black/5 hover:bg-white hover:shadow-2xl transition-all duration-700 h-full flex flex-col ${isComingSoon ? 'opacity-60 grayscale' : ''}`}>
  {/* Image Section */}
  {cardImage && (
    <div class="relative aspect-[4/3] overflow-hidden bg-[#0A0A0A]">
      <img
        src={cardImage}
        alt={cardTitle}
        class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000"
        loading="lazy"
      />
      {cardBadge && (
        <span class="absolute top-4 right-4 bg-[#8B6F47] text-white px-3 py-1 font-display tracking-widest text-[10px] uppercase font-bold">
          {cardBadge}
        </span>
      )}
      {isComingSoon && (
        <span class="absolute top-4 right-4 bg-[#0A0A0A]/40 text-white px-3 py-1 font-display tracking-widest text-[10px] uppercase font-bold backdrop-blur-sm">
          Coming Soon
        </span>
      )}
      <div class="absolute inset-0 bg-[#0A0A0A]/20 opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
    </div>
  )}

  {/* Content Section */}
  <div class="p-8 flex flex-col flex-grow">
    <h3 class="font-display text-2xl uppercase text-[#0A0A0A] mb-3 group-hover:text-[#8B6F47] transition-colors">
      {cardTitle}
    </h3>

    {cardDescription && (
      <p class="text-[#1A140D]/60 text-sm leading-relaxed mb-6 font-light">
        {cardDescription}
      </p>
    )}

    {hasItems && (
      <div class="flex flex-wrap gap-2 mb-8">
        {items.map((item) => (
          <span class="text-[10px] uppercase tracking-wider bg-white border border-black/5 px-2 py-1 text-[#0A0A0A]/60 font-medium">
            {item}
          </span>
        ))}
      </div>
    )}

    {/* CTA Logic */}
    {!isComingSoon && (
      <div class="mt-auto pt-4 border-t border-black/5 flex justify-between items-center">
        {cardHref.includes('wa.me') ? (
          <a href={cardHref} target="_blank" rel="noopener noreferrer" class="text-[#8B6F47] font-display uppercase tracking-widest text-sm hover:text-[#0A0A0A] transition-all">
            Contact Specialist →
          </a>
        ) : (
          <a href={cardHref} class="text-[#0A0A0A] font-display uppercase tracking-widest text-sm hover:text-[#8B6F47] transition-all">
            See Collection →
          </a>
        )}
      </div>
    )}

    {isComingSoon && (
      <div class="mt-auto pt-4 border-t border-black/5">
        <span class="text-black/20 font-display uppercase tracking-widest text-sm cursor-not-allowed">Coming Soon</span>
      </div>
    )}
  </div>
</div>

<style>
  .hobby-card {
    /* Legacy base styles removed in favor of modern tailwind structure */
  }
</style>
