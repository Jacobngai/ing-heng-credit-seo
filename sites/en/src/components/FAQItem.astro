---
/**
 * FAQItem Component
 * Collapsible accordion-style FAQ item with Industrial Trust brutal design
 * Follows MASTER-BRAND-DESIGN-RULES.md specifications
 */

interface Props {
  question: string;
  answer: string;
  id?: string;
  isOpen?: boolean;
  variant?: 'standard' | 'luxe';
}

const {
  question,
  answer,
  id = `faq-${Math.random().toString(36).substr(2, 9)}`,
  isOpen = false,
  variant = 'standard',
} = Astro.props;
---

<div class={`overflow-hidden transition-all duration-300 ${variant === 'luxe' ? 'bg-[#F9F9F9] border border-black/5 rounded-2xl mb-4 hover:border-[#D4A574]/30' : 'bg-white border-3 border-[#2D1810] rounded-lg shadow-[4px_4px_0_#2D1810] hover:shadow-[6px_6px_0_#2D1810] hover:translate-x-[-2px] hover:translate-y-[-2px] mb-6'}`} data-faq-item>
  <!-- Question Button -->
  <button
    type="button"
    class={`w-full px-6 py-6 text-left focus:outline-none transition-all ${variant === 'luxe' ? 'bg-transparent hover:bg-black/[0.02]' : 'bg-white hover:bg-[#F5F1EC]'}`}
    style="min-height: 64px;"
    aria-expanded={isOpen}
    aria-controls={id}
    data-faq-button
  >
    <div class="flex items-center justify-between gap-6">
      <h3 class={`text-lg md:text-xl font-display uppercase tracking-wide flex-1 transition-colors ${variant === 'luxe' ? 'text-[#0A0A0A] group-hover:text-[#D4A574]' : 'text-[#8B6F47] font-black'}`}>
        {question}
      </h3>
      <div class={`flex-shrink-0 w-10 h-10 flex items-center justify-center transition-all ${variant === 'luxe' ? 'text-[#D4A574]' : 'bg-[#D4A574] border-2 border-[#2D1810] rounded text-[#2D1810]'}`}>
        <svg
          class="w-6 h-6 transition-transform duration-500"
          data-faq-icon
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          stroke-width="2.5"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </div>
    </div>
  </button>

  <!-- Answer Content -->
  <div
    id={id}
    class="overflow-hidden transition-all duration-500 ease-in-out"
    style={isOpen ? 'max-height: 2000px;' : 'max-height: 0;'}
    data-faq-content
    role="region"
    aria-labelledby={`${id}-button`}
  >
    <div class={`px-6 md:px-8 pb-8 pt-2 ${variant === 'luxe' ? 'bg-transparent text-[#0A0A0A]/60 font-light' : 'border-t-2 border-[#D4A574] bg-[#F5F5DC] text-[#4F3E29] font-medium'}`}>
      <div class="prose max-w-none">
        <p class="text-base md:text-lg leading-relaxed" set:html={answer} />
      </div>
    </div>
  </div>
</div>

<script>
  // FAQ accordion functionality with proper max-height calculation
  document.addEventListener('DOMContentLoaded', () => {
    const faqItems = document.querySelectorAll('[data-faq-item]');

    faqItems.forEach((item) => {
      const button = item.querySelector('[data-faq-button]') as HTMLButtonElement;
      const content = item.querySelector('[data-faq-content]') as HTMLDivElement;
      const icon = item.querySelector('[data-faq-icon]') as SVGElement;

      if (!button || !content || !icon) return;

      button.addEventListener('click', () => {
        const isExpanded = button.getAttribute('aria-expanded') === 'true';

        // Toggle current item
        button.setAttribute('aria-expanded', (!isExpanded).toString());

        if (!isExpanded) {
          // Expand - use scrollHeight for proper full content display
          content.style.maxHeight = content.scrollHeight + 100 + 'px'; // Add buffer for safety
          icon.style.transform = 'rotate(180deg)';
        } else {
          // Collapse
          content.style.maxHeight = '0';
          icon.style.transform = 'rotate(0deg)';
        }
      });
    });
  });
</script>
