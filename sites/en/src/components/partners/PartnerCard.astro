---
import type { PartnerSummary } from '../../utils/partners';

interface Props {
  partner: PartnerSummary;
}

const { partner } = Astro.props;
---

<article class="card flex h-full flex-col bg-white">
  <a href={`/en/our-partners/${partner.slug}`} class="block">
    <div class="aspect-[4/3] overflow-hidden border-b-3 border-[#2D1810] bg-[#F5F1EB]">
      {partner.coverImageUrl ? (
        <img
          src={partner.coverImageUrl}
          alt={partner.name}
          class="h-full w-full object-cover transition-transform duration-300 hover:scale-105"
          loading="lazy"
        />
      ) : partner.logoImageUrl ? (
        <div class="flex h-full items-center justify-center bg-gradient-to-br from-[#F5F1EB] to-[#E8DFD4] p-8">
          <img
            src={partner.logoImageUrl}
            alt={partner.name}
            class="h-28 w-28 object-contain"
            loading="lazy"
          />
        </div>
      ) : (
        <div class="flex h-full items-center justify-center bg-gradient-to-br from-[#F5F1EB] to-[#E8DFD4] px-6 text-center">
          <span class="font-display text-3xl uppercase tracking-wide text-[#8B6F47]">{partner.name}</span>
        </div>
      )}
    </div>
  </a>

  <div class="card-body flex flex-1 flex-col gap-5">
    <div class="space-y-3">
      {partner.featured && <span class="badge badge-secondary">Featured Partner</span>}
      {partner.logoImageUrl && (
        <div class="flex h-16 w-16 items-center justify-center overflow-hidden border-3 border-[#2D1810] bg-white shadow-brutal-sm">
          <img src={partner.logoImageUrl} alt={partner.name} class="h-full w-full object-contain p-2" loading="lazy" />
        </div>
      )}
      {partner.companyName && <p class="text-sm font-bold uppercase tracking-[0.12em] text-[#8B6F47]">{partner.companyName}</p>}
      <h2 class="text-4xl leading-none text-[#2D1810]">
        <a href={`/en/our-partners/${partner.slug}`} class="text-inherit no-underline hover:text-[#8B6F47]">
          {partner.name}
        </a>
      </h2>
      {partner.location && <p class="text-sm font-bold uppercase tracking-[0.1em] text-[#6B5437]">{partner.location}</p>}
      <p class="text-base leading-relaxed text-[#4F3E29]">{partner.shortDescription}</p>
    </div>

    <div class="mt-auto flex flex-wrap gap-3">
      <a href={`/en/our-partners/${partner.slug}`} class="btn btn-primary px-5 py-3 text-base">View Profile</a>
      {partner.website && (
        <a
          href={partner.website}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-outline px-5 py-3 text-base"
        >
          Visit Website
        </a>
      )}
    </div>
  </div>
</article>
