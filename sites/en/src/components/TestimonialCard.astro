---
/**
 * TestimonialCard Component
 * Display customer testimonial with rating and photo
 */

interface Props {
  name: string;
  company?: string;
  location?: string;
  testimonial: string;
  rating?: number;
  image?: string;
  variant?: 'default' | 'luxe';
}

const {
  name,
  company,
  location,
  testimonial,
  rating = 5,
  image,
  variant = 'default',
} = Astro.props;
---

{
  variant === 'luxe' ? (
    <div class="bg-white/5 backdrop-blur-xl rounded-3xl border border-white/10 p-10 shadow-2xl relative group overflow-hidden transition-all duration-500 hover:border-[#D4A574]/30">
      <div class="absolute top-0 right-0 p-8 opacity-10 group-hover:opacity-20 transition-opacity">
        <svg class="w-16 h-16 text-white" fill="currentColor" viewBox="0 0 24 24">
          <path d="M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C19.5693 16 20.017 15.5523 20.017 15V9C20.017 8.44772 19.5693 8 19.017 8H16.017C15.4647 8 15.017 8.44772 15.017 9V12C15.017 12.5523 14.5693 13 14.017 13H11.017C10.4647 13 10.017 12.5523 10.017 12V9C10.017 7.89543 10.9124 7 12.017 7H19.017C20.1216 7 21.017 7.89543 21.017 9V15C21.017 17.2091 19.2261 19 17.017 19H14.017V21ZM5.01697 21L5.01697 18C5.01697 16.8954 5.9124 16 7.01697 16H10.017C10.5693 16 11.017 15.5523 11.017 15V9C11.017 8.44772 10.5693 8 10.017 8H7.01697C6.46468 8 6.01697 8.44772 6.01697 9V12C6.01697 12.5523 5.56926 13 5.01697 13H2.01697C1.46468 13 1.01697 12.5523 1.01697 12V9C1.01697 7.89543 1.9124 7 3.01697 7H10.017C11.1215 7 12.017 7.89543 12.017 9V15C12.017 17.2091 10.2261 19 8.01697 19H5.01697V21Z" />
        </svg>
      </div>

      <div class="relative z-10">
        <div class="flex items-center space-x-1 mb-8">
          {Array.from({ length: 5 }).map((_, i) => (
            <svg
              class={`w-4 h-4 ${i < rating ? 'text-[#D4A574]' : 'text-white/10'}`}
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>

        <blockquote class="text-white/80 text-lg font-light leading-relaxed mb-10 italic">
          "{testimonial}"
        </blockquote>

        <div class="flex items-center space-x-4 pt-8 border-t border-white/5">
          {image ? (
            <img src={image} alt={name} class="w-14 h-14 rounded-full border border-white/10 p-1" />
          ) : (
            <div class="w-14 h-14 rounded-full bg-gradient-to-br from-[#D4A574] to-[#8B6F47] flex items-center justify-center text-[#0A0A0A] font-display text-xl uppercase">
              {name.charAt(0)}
            </div>
          )}
          <div>
            <div class="text-white font-display uppercase tracking-widest text-sm">{name}</div>
            <div class="text-[#D4A574] text-xs font-light mt-1">{company} • {location}</div>
          </div>
        </div>
      </div>
    </div>
  ) : (
    <div class="bg-white rounded-lg shadow-[6px_6px_0_#2D1810] p-6 hover:shadow-[12px_12px_0_#2D1810] transition-shadow duration-300">
      <div class="flex items-center space-x-1 mb-4">
        {Array.from({ length: 5 }).map((_, i) => (
          <svg
            class={`w-5 h-5 ${i < rating ? 'text-[#D4A574]' : 'text-gray-300'}`}
            fill="currentColor"
            viewBox="0 0 20 20"
          >
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
      </div>

      <blockquote class="text-gray-700 italic mb-6 leading-relaxed">
        "{testimonial}"
      </blockquote>

      <div class="flex items-center space-x-4 pt-4 border-t border-gray-100">
        {image ? (
          <img
            src={image}
            alt={name}
            class="w-12 h-12 rounded-full object-cover"
            loading="lazy"
          />
        ) : (
          <div class="w-12 h-12 rounded-full bg-gradient-to-br from-primary to-secondary flex items-center justify-center text-white font-bold text-lg">
            {name.charAt(0)}
          </div>
        )}

        <div>
          <div class="font-semibold text-primary">{name}</div>
          {company && (
            <div class="text-sm text-gray-600">{company}</div>
          )}
          {location && (
            <div class="text-xs text-gray-500">{location}</div>
          )}
        </div>
      </div>
    </div>
  )
}
